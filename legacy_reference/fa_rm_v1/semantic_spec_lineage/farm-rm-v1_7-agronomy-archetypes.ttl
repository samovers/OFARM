farm17:nextOperationUri a owl:DatatypeProperty ; rdfs:range xsd:string .
farm17:cleanoutAttachmentRoleCode a owl:DatatypeProperty ; rdfs:range xsd:string .
farm17:hasProductUse a owl:ObjectProperty ; rdfs:range farm17:EquipmentCleanoutProductUse .
farm17:productName a owl:DatatypeProperty ; rdfs:range xsd:string .
farm17:activeSubstance a owl:DatatypeProperty ; rdfs:range xsd:string .
farm17:materialLotUri a owl:DatatypeProperty ; rdfs:range xsd:string .

### External code-system alignment
farm17:ExternalCodeSystem a owl:Class ;
  rdfs:label "External code system" ;
  rdfs:comment "Controlled vocabulary or identifier system maintained outside Farm-RM." .

farm17:recommendedCodeSystem a owl:ObjectProperty ;
  rdfs:label "recommended code system" ;
  rdfs:comment "Links a Farm-RM code-valued property to the preferred external code system for interoperability." .

farm17:AGROVOC a farm17:ExternalCodeSystem ;
  rdfs:label "FAO AGROVOC" ;
  rdfs:seeAlso <http://aims.fao.org/aos/agrovoc/> .

farm17:BBCH a farm17:ExternalCodeSystem ;
  rdfs:label "BBCH growth stages" ;
  rdfs:seeAlso <https://www.bbch-scale.net/> .

farm17:EPPO a farm17:ExternalCodeSystem ;
  rdfs:label "EPPO Global Database" ;
  rdfs:seeAlso <https://gd.eppo.int/> .

farm17:pestCode farm17:recommendedCodeSystem farm17:EPPO .
farm17:coverCropSpeciesCode farm17:recommendedCodeSystem farm17:AGROVOC .
farm17:coverCropSpeciesCode farm17:recommendedCodeSystem farm17:EPPO .
farm17:mixSpeciesCode farm17:recommendedCodeSystem farm17:AGROVOC .
farm17:mixSpeciesCode farm17:recommendedCodeSystem farm17:EPPO .
farm17:bbchCode farm17:recommendedCodeSystem farm17:BBCH .
farm17:terminationStageCode farm17:recommendedCodeSystem farm17:BBCH .
