@prefix farm: <https://w3id.org/farm-rm/v1#> .
@prefix farm11: <https://w3id.org/farm-rm/v1.1#> .
@prefix farm17: <https://w3id.org/farm-rm/v1.7#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/farm-rm/v1.7> a owl:Ontology ;
  rdfs:label "Farm-RM v1.7 Agronomy Archetypes Extension" ;
  rdfs:comment "Additive extension for crop-stage, pest-trap, remote-sensing, soil-profile, field-pedoclimatic-profile, climate-hazard, crop-adaptation, variety-trial, agrometeorological and leaf-wetness observations, diagnostic and disease decision artifacts, IPM planning, phytosanitary case files, irrigation/harvest, nutrient and plant-protection application records, delivery-ticket, storage-condition/storage-aeration/storage-quality, warehouse-quality-panel traceability, storage-lot lineage, cover-crop/tillage, equipment plus seed/variety-field suitability evaluations, variety risk profiling, and equipment integrity archetypes." .

