@prefix farm: <https://w3id.org/farm-rm/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/farm-rm/v1> a owl:Ontology ;
  rdfs:label "Farm-RM v1" ;
  rdfs:comment "OpenEHR-inspired semantic reference model for farm operations and compliance." .

### Classes

farm:Farm a owl:Class .
farm:Field a owl:Class .
farm:ParcelBlock a owl:Class .
farm:GERK a owl:Class .
farm:CropInstance a owl:Class .
farm:Resource a owl:Class .
farm:Machine a owl:Class ; rdfs:subClassOf farm:Resource .
farm:Worker a owl:Class ; rdfs:subClassOf farm:Resource .
farm:InputMaterial a owl:Class ; rdfs:subClassOf farm:Resource .
farm:MaterialLot a owl:Class .
farm:StorageLot a owl:Class .
farm:OperationTemplate a owl:Class .
farm:PlannedOperation a owl:Class .
farm:ExecutedOperation a owl:Class .
farm:TimeWindow a owl:Class .
farm:Constraint a owl:Class .
farm:Observation a owl:Class .
farm:SensorObservation a owl:Class ; rdfs:subClassOf farm:Observation .
farm:DerivedObservation a owl:Class ; rdfs:subClassOf farm:Observation .
farm:EvidenceRecord a owl:Class .
farm:ComplianceSubmission a owl:Class .
farm:InspectionCase a owl:Class .
farm:CertificationScope a owl:Class .
farm:ControlBody a owl:Class .
farm:NonConformity a owl:Class .
farm:CorrectiveAction a owl:Class .
farm:RuleSet a owl:Class .
farm:RuleExecutionTrace a owl:Class .
farm:EventRecord a owl:Class .
farm:Party a owl:Class .
farm:RoleAssignment a owl:Class .

### Core object properties

farm:hasField a owl:ObjectProperty ; rdfs:domain farm:Farm ; rdfs:range farm:Field .
farm:hasParcelBlock a owl:ObjectProperty ; rdfs:domain farm:Field ; rdfs:range farm:ParcelBlock .
farm:hasGERK a owl:ObjectProperty ; rdfs:domain farm:ParcelBlock ; rdfs:range farm:GERK .
farm:hasCropInstance a owl:ObjectProperty ; rdfs:domain farm:Field ; rdfs:range farm:CropInstance .
farm:instantiatesTemplate a owl:ObjectProperty ; rdfs:domain farm:PlannedOperation ; rdfs:range farm:OperationTemplate .
farm:targetsCropInstance a owl:ObjectProperty ; rdfs:domain farm:PlannedOperation ; rdfs:range farm:CropInstance .
farm:targetsField a owl:ObjectProperty ; rdfs:domain farm:PlannedOperation ; rdfs:range farm:Field .
farm:hasTimeWindow a owl:ObjectProperty ; rdfs:domain farm:PlannedOperation ; rdfs:range farm:TimeWindow .
farm:hasConstraint a owl:ObjectProperty ; rdfs:domain farm:PlannedOperation ; rdfs:range farm:Constraint .
farm:appliesToTemplate a owl:ObjectProperty ; rdfs:domain farm:Constraint ; rdfs:range farm:OperationTemplate .
farm:appliesToPlannedOperation a owl:ObjectProperty ; rdfs:domain farm:Constraint ; rdfs:range farm:PlannedOperation .
farm:realizesPlannedOperation a owl:ObjectProperty ; rdfs:domain farm:ExecutedOperation ; rdfs:range farm:PlannedOperation .
farm:usedResource a owl:ObjectProperty ; rdfs:domain farm:ExecutedOperation ; rdfs:range farm:Resource .
farm:usedMaterialLot a owl:ObjectProperty ; rdfs:domain farm:ExecutedOperation ; rdfs:range farm:MaterialLot .
farm:producedObservation a owl:ObjectProperty ; rdfs:domain farm:ExecutedOperation ; rdfs:range farm:Observation .
farm:relatesToField a owl:ObjectProperty ; rdfs:domain farm:Observation ; rdfs:range farm:Field .
farm:relatesToCropInstance a owl:ObjectProperty ; rdfs:domain farm:Observation ; rdfs:range farm:CropInstance .
farm:hasEvidenceRecord a owl:ObjectProperty ; rdfs:domain farm:ExecutedOperation ; rdfs:range farm:EvidenceRecord .
farm:hasRuleSet a owl:ObjectProperty ; rdfs:domain farm:Constraint ; rdfs:range farm:RuleSet .
farm:hasExecutionTrace a owl:ObjectProperty ; rdfs:domain farm:Constraint ; rdfs:range farm:RuleExecutionTrace .
farm:belongsToInspectionCase a owl:ObjectProperty ; rdfs:domain farm:EvidenceRecord ; rdfs:range farm:InspectionCase .
farm:belongsToSubmission a owl:ObjectProperty ; rdfs:domain farm:EvidenceRecord ; rdfs:range farm:ComplianceSubmission .
farm:hasCertificationScope a owl:ObjectProperty ; rdfs:domain farm:Farm ; rdfs:range farm:CertificationScope .
farm:certifiedBy a owl:ObjectProperty ; rdfs:domain farm:CertificationScope ; rdfs:range farm:ControlBody .
farm:hasRoleAssignment a owl:ObjectProperty ; rdfs:domain farm:Party ; rdfs:range farm:RoleAssignment .
farm:assignedToFarm a owl:ObjectProperty ; rdfs:domain farm:RoleAssignment ; rdfs:range farm:Farm .
farm:assignedToOperation a owl:ObjectProperty ; rdfs:domain farm:RoleAssignment ; rdfs:range farm:PlannedOperation .
farm:sourceStorageLot a owl:ObjectProperty ; rdfs:range farm:StorageLot .
farm:targetStorageLot a owl:ObjectProperty ; rdfs:range farm:StorageLot .
farm:derivedFromStorageLot a owl:ObjectProperty ; rdfs:domain farm:StorageLot ; rdfs:range farm:StorageLot .
farm:producedStorageLot a owl:ObjectProperty ; rdfs:domain farm:ExecutedOperation ; rdfs:range farm:StorageLot .
farm:supersedes a owl:ObjectProperty .
farm:recordsEventFor a owl:ObjectProperty ; rdfs:domain farm:EventRecord .

### Datatype properties

farm:uri a owl:DatatypeProperty ; rdfs:range xsd:anyURI .
farm:localId a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:jurisdiction a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:label a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:season a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:productionStatus a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:operationType a owl:DatatypeProperty ; rdfs:range xsd:anyURI .
farm:status a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:priority a owl:DatatypeProperty ; rdfs:range xsd:integer .
farm:plannedQuantity a owl:DatatypeProperty ; rdfs:range xsd:decimal .
farm:actualQuantity a owl:DatatypeProperty ; rdfs:range xsd:decimal .
farm:unit a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:startTime a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
farm:endTime a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
farm:earliestStart a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
farm:latestEnd a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
farm:observationType a owl:DatatypeProperty ; rdfs:range xsd:anyURI .
farm:value a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:observedAt a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
farm:constraintType a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:expressionLanguage a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:expression a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:severity a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:effectiveFrom a owl:DatatypeProperty ; rdfs:range xsd:date .
farm:effectiveTo a owl:DatatypeProperty ; rdfs:range xsd:date .
farm:legalReference a owl:DatatypeProperty ; rdfs:range xsd:anyURI .
farm:evidenceType a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:evidenceRef a owl:DatatypeProperty ; rdfs:range xsd:anyURI .
farm:createdAt a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
farm:createdBy a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:eventType a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:eventAt a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
farm:eventPayloadHash a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:commercialReference a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:deliveryReference a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:invoiceReference a owl:DatatypeProperty ; rdfs:range xsd:string .
farm:paymentReference a owl:DatatypeProperty ; rdfs:range xsd:string .

### Controlled values

farm:ProductionStatusScheme a skos:ConceptScheme ;
  skos:prefLabel "Production status scheme" .

farm:organic_certified a skos:Concept ;
  skos:inScheme farm:ProductionStatusScheme ;
  skos:prefLabel "Organic certified" .

farm:in_conversion a skos:Concept ;
  skos:inScheme farm:ProductionStatusScheme ;
  skos:prefLabel "In conversion" .

farm:conventional a skos:Concept ;
  skos:inScheme farm:ProductionStatusScheme ;
  skos:prefLabel "Conventional" .
