{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/bridgecandidate/v0.1",
  "title": "OFARM BridgeCandidate v0.1",
  "$comment": "Candidate machine contract for scenario-originated proposals to enter a governed next-step path.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bridgeCandidateId",
    "sourceScenarioResultSetId",
    "proposedNextStepClass",
    "targetScopes",
    "requiresHumanApproval",
    "rationale"
  ],
  "properties": {
    "schemaVersion": { "const": "ofarm.bridgecandidate.v0.1" },
    "bridgeCandidateId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "sourceScenarioResultSetId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "proposedNextStepClass": {
      "enum": [
        "REQUEST_REVIEW",
        "REQUEST_EVIDENCE",
        "PREPARE_REPORT_ASSEMBLY",
        "PREPARE_DOSSIER_ASSEMBLY",
        "PREPARE_SUBMISSION_ASSEMBLY",
        "PREPARE_OPERATION_PLAN",
        "PREPARE_ASSERTION_DRAFT"
      ]
    },
    "targetScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scopeType", "scopeRef"],
        "properties": {
          "scopeType": { "enum": ["FARM", "SITE", "FIELD", "CROP_CYCLE", "LOT", "FACILITY", "OPERATION"] },
          "scopeRef": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
        }
      }
    },
    "requiresHumanApproval": { "type": "boolean" },
    "rationale": { "type": "string" },
    "prerequisiteRefs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
    }
  }
}
