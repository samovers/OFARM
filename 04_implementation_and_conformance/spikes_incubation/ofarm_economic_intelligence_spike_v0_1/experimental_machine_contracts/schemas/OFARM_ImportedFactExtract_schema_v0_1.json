{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/importedfactextract/v0.1",
  "title": "OFARM ImportedFactExtract v0.1",
  "$comment": "Candidate machine contract for non-ledger accounting/economic fact extracts used as scenario inputs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "extractId",
    "sourceSystemRef",
    "extractType",
    "sourcePostingStatus",
    "extractedAt",
    "scopeBindings",
    "lineItems"
  ],
  "properties": {
    "schemaVersion": { "const": "ofarm.importedfactextract.v0.1" },
    "extractId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "sourceSystemRef": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "extractType": {
      "enum": [
        "SETTLEMENT_SUMMARY",
        "INVOICE_LINE_SUMMARY",
        "PAYROLL_SUMMARY_BY_CLASS",
        "ENERGY_COST_SUMMARY",
        "CONTRACTOR_RATE_EXTRACT",
        "FINANCING_TERM_SUMMARY",
        "OTHER"
      ]
    },
    "sourcePostingStatus": {
      "enum": ["POSTED", "PRELIMINARY", "ESTIMATED", "UNKNOWN"]
    },
    "extractedAt": { "type": "string", "format": "date-time" },
    "sourceDocumentRefs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
    },
    "scopeBindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scopeType", "scopeRef"],
        "properties": {
          "scopeType": { "enum": ["FARM", "SITE", "FIELD", "CROP_CYCLE", "LOT", "FACILITY", "PARTY", "SEASON"] },
          "scopeRef": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
        }
      }
    },
    "lineItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lineId", "label", "amount", "currency"],
        "properties": {
          "lineId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
          "label": { "type": "string" },
          "categoryCode": { "type": "string" },
          "amount": { "type": "number" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "quantity": { "type": "number" },
          "unit": { "type": "string" },
          "timeIntervalLabel": { "type": "string" },
          "evidenceRef": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
