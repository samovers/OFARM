{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/advisoryscenarioresultset/v0.1",
  "title": "OFARM AdvisoryScenarioResultSet v0.1",
  "$comment": "Candidate machine contract for generated scenario outputs with explicit freshness and trace posture.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scenarioResultSetId",
    "sourceScenarioId",
    "generatedAt",
    "freshnessState",
    "resultClass",
    "results",
    "basisTraceRefs"
  ],
  "properties": {
    "schemaVersion": { "const": "ofarm.advisoryscenarioresultset.v0.1" },
    "scenarioResultSetId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "sourceScenarioId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "freshnessState": { "enum": ["FRESH", "STALE", "INVALID"] },
    "resultClass": {
      "enum": ["RANKED_ALTERNATIVES", "THRESHOLD_SCREEN", "CAPACITY_SCREEN", "SENSITIVITY_SET", "DOSSIER_PREP", "GENERAL_SUMMARY"]
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resultId", "label", "valueExpression"],
        "properties": {
          "resultId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
          "label": { "type": "string" },
          "valueExpression": { "type": "string" },
          "rank": { "type": "integer", "minimum": 1 },
          "uncertaintyExpression": { "type": "string" },
          "evidenceClassesUsed": {
            "type": "array",
            "items": { "enum": ["ACTUAL_POSTED", "ACTUAL_PRELIMINARY", "ESTIMATE", "BENCHMARK", "PROXY", "MODEL_OUTPUT"] }
          }
        }
      }
    },
    "basisTraceRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
    },
    "notes": { "type": "string" }
  }
}
