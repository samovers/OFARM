{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/advisoryscenariospec/v0.1",
  "title": "OFARM AdvisoryScenarioSpec v0.1",
  "$comment": "Candidate machine contract for Advisory-only scenario definitions built over the active OFARM substrate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scenarioId",
    "targetTwin",
    "anchorScopes",
    "evaluationTimePolicy",
    "scenarioClass",
    "basisRefs",
    "assumptions",
    "methodRef",
    "requestedOutputClass"
  ],
  "properties": {
    "schemaVersion": { "const": "ofarm.advisoryscenariospec.v0.1" },
    "scenarioId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "targetTwin": { "const": "ADVISORY" },
    "anchorScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scopeType", "scopeRef"],
        "properties": {
          "scopeType": {
            "enum": ["FARM", "SITE", "FIELD", "ZONE", "CROP_CYCLE", "LOT", "FACILITY", "OPERATION"]
          },
          "scopeRef": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
        }
      }
    },
    "evaluationTimePolicy": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["policyType"], "properties": { "policyType": { "const": "NOW" } } },
        { "type": "object", "additionalProperties": false, "required": ["policyType", "asOfTime"], "properties": { "policyType": { "const": "AS_OF" }, "asOfTime": { "type": "string", "format": "date-time" } } },
        { "type": "object", "additionalProperties": false, "required": ["policyType", "windowStart", "windowEnd"], "properties": { "policyType": { "const": "WINDOW" }, "windowStart": { "type": "string", "format": "date-time" }, "windowEnd": { "type": "string", "format": "date-time" } } }
      ]
    },
    "scenarioClass": {
      "enum": [
        "CROP_SYSTEM_RANKING",
        "INCREMENTAL_CHANGE",
        "CONSTRAINT_CAPACITY",
        "POSTHARVEST_ROUTING",
        "CAPEX_PRE_GATE",
        "CASHFLOW_SCREEN",
        "GENERAL_ADVISORY"
      ]
    },
    "basisRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationalRefs"],
      "properties": {
        "operationalRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
        },
        "currentStateMaterializationRefs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
        },
        "importedFactExtractRefs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
        },
        "contextSnapshotRefs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assumptionId", "label", "valueExpression", "evidenceClass"],
        "properties": {
          "assumptionId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
          "label": { "type": "string" },
          "valueExpression": { "type": "string" },
          "evidenceClass": {
            "enum": ["ACTUAL_POSTED", "ACTUAL_PRELIMINARY", "ESTIMATE", "BENCHMARK", "PROXY", "MODEL_OUTPUT"]
          },
          "sourceRef": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
        }
      }
    },
    "methodRef": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
    "requestedOutputClass": {
      "enum": ["VIEW", "REPORT_ASSEMBLY", "DOSSIER_ASSEMBLY", "SUBMISSION_ASSEMBLY"]
    },
    "notes": { "type": "string" }
  }
}
