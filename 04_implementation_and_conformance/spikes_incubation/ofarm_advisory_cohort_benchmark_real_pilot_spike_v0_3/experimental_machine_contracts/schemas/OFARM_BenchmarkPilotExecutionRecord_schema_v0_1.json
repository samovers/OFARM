{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM BenchmarkPilotExecutionRecord v0.1",
  "type": "object",
  "required": [
    "schemaVersion",
    "pilotExecutionId",
    "datasetRef",
    "datasetKind",
    "actualTenantData",
    "executionMode",
    "requestScenarioRef",
    "requestedBenchmarkKind",
    "effectiveBenchmarkKind",
    "basisRef",
    "decision",
    "materializationFreshnessState",
    "contributorCountInternal",
    "contributorCountDisplay",
    "dominanceShareMax",
    "exactContributorCountHidden",
    "rawPeerRowsHidden",
    "rawEvidenceHidden",
    "allowedMetricNames",
    "handoffReadiness",
    "promotionReadiness",
    "claimBoundary",
    "outputAssemblyType",
    "blockingReasonCodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.benchmarkpilotexecutionrecord.v0.1"
    },
    "pilotExecutionId": {
      "type": "string",
      "minLength": 1
    },
    "datasetRef": {
      "type": "string",
      "minLength": 1
    },
    "datasetKind": {
      "type": "string",
      "enum": [
        "REAL_REDACTED_TEMPLATE",
        "REDACTED_REHEARSAL_NON_REAL",
        "REAL_REDACTED_PILOT"
      ]
    },
    "actualTenantData": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "executionMode": {
      "type": "string",
      "enum": [
        "TEMPLATE_CHECK",
        "REHEARSAL",
        "REAL_PILOT"
      ]
    },
    "requestScenarioRef": {
      "type": "string",
      "minLength": 1
    },
    "requestedBenchmarkKind": {
      "type": "string",
      "enum": [
        "PRODUCT_CLASS",
        "EXACT_PRODUCT"
      ]
    },
    "effectiveBenchmarkKind": {
      "type": "string",
      "enum": [
        "PRODUCT_CLASS",
        "EXACT_PRODUCT",
        "NONE"
      ]
    },
    "basisRef": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "BROADEN",
        "REFUSE"
      ]
    },
    "materializationFreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE",
        "INVALID"
      ]
    },
    "contributorCountInternal": {
      "type": "integer",
      "minimum": 0
    },
    "contributorCountDisplay": {
      "type": "string",
      "enum": [
        "HIDDEN",
        "3-4",
        "5-9",
        "10-19",
        "20_PLUS"
      ]
    },
    "dominanceShareMax": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "exactContributorCountHidden": {
      "type": "boolean"
    },
    "rawPeerRowsHidden": {
      "type": "boolean"
    },
    "rawEvidenceHidden": {
      "type": "boolean"
    },
    "allowedMetricNames": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "AVG_UNIT_PRICE",
          "QUANTITY_BAND",
          "POSITION_BAND"
        ]
      },
      "uniqueItems": true
    },
    "userVisibleMetrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "metricName"
        ],
        "properties": {
          "metricName": {
            "type": "string",
            "enum": [
              "AVG_UNIT_PRICE",
              "QUANTITY_BAND",
              "POSITION_BAND"
            ]
          },
          "numericValue": {
            "type": "number"
          },
          "labelValue": {
            "type": "string"
          },
          "unitCode": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "handoffReadiness": {
      "type": "string",
      "enum": [
        "READY_FOR_REAL_PILOT_HANDOFF",
        "BLOCKED"
      ]
    },
    "promotionReadiness": {
      "const": "NOT_FOR_PROMOTION"
    },
    "claimBoundary": {
      "type": "string",
      "minLength": 1
    },
    "outputAssemblyType": {
      "type": "string",
      "enum": [
        "VIEW_MODULE",
        "SUMMARY_ROWS"
      ]
    },
    "blockingReasonCodes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
