{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM BenchmarkViewSurfaceAudit v0.1",
  "type": "object",
  "required": [
    "schemaVersion",
    "auditId",
    "requestScenarioRef",
    "surfaceType",
    "showsRawPeerRows",
    "showsRawEvidenceRefs",
    "showsExactContributorCount",
    "showsPeerTotalSpend",
    "showsPerHectareMetric",
    "showsBasisExplanation",
    "showsFreshnessExplanation",
    "showsDisclosureReason",
    "outcome",
    "failureReasonCodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.benchmarkviewsurfaceaudit.v0.1"
    },
    "auditId": {
      "type": "string",
      "minLength": 1
    },
    "requestScenarioRef": {
      "type": "string",
      "minLength": 1
    },
    "surfaceType": {
      "type": "string",
      "enum": [
        "VIEW_MODULE",
        "SUMMARY_ROWS"
      ]
    },
    "showsRawPeerRows": {
      "type": "boolean"
    },
    "showsRawEvidenceRefs": {
      "type": "boolean"
    },
    "showsExactContributorCount": {
      "type": "boolean"
    },
    "showsPeerTotalSpend": {
      "type": "boolean"
    },
    "showsPerHectareMetric": {
      "type": "boolean"
    },
    "showsBasisExplanation": {
      "type": "boolean"
    },
    "showsFreshnessExplanation": {
      "type": "boolean"
    },
    "showsDisclosureReason": {
      "type": "boolean"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "failureReasonCodes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
