{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/benchmarkmaterializationstate/v0.1",
  "title": "OFARM BenchmarkMaterializationState v0.1",
  "$comment": "Candidate machine contract for freshness and recompute state of an advisory cohort benchmark materialization.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "materializationStateId",
    "targetTwin",
    "materializationRef",
    "generatedAt",
    "evaluatedAt",
    "declaredUseClass",
    "benchmarkWindowStart",
    "benchmarkWindowEnd",
    "sourceContributionRefs",
    "freshnessState",
    "invalidationTriggers",
    "recomputeRequired",
    "staleAllowedForDeclaredUse",
    "visibleFreshnessLabel",
    "reasonCodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.benchmarkmaterializationstate.v0.1"
    },
    "materializationStateId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetTwin": {
      "const": "ADVISORY"
    },
    "materializationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "declaredUseClass": {
      "enum": [
        "ADVISORY_BENCHMARK_VIEW"
      ]
    },
    "benchmarkWindowStart": {
      "type": "string",
      "format": "date-time"
    },
    "benchmarkWindowEnd": {
      "type": "string",
      "format": "date-time"
    },
    "sourceContributionRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "freshnessState": {
      "enum": [
        "FRESH",
        "STALE",
        "INVALID"
      ]
    },
    "invalidationTriggers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "triggerType",
          "triggeredAt"
        ],
        "properties": {
          "triggerType": {
            "enum": [
              "CONTRIBUTION_REVOKED",
              "RULE_VERSION_CHANGE",
              "AGE_WINDOW_EXCEEDED",
              "DISCLOSURE_POLICY_CHANGE",
              "REQUEST_HISTORY_POLICY_CHANGE"
            ]
          },
          "triggerRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "triggeredAt": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "recomputeRequired": {
      "type": "boolean"
    },
    "staleAllowedForDeclaredUse": {
      "type": "boolean"
    },
    "visibleFreshnessLabel": {
      "enum": [
        "FRESH",
        "STALE_EXPLORATORY",
        "UNAVAILABLE_RECOMPUTE_REQUIRED"
      ]
    },
    "successorMaterializationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
