{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/productnormalizationtrace/v0.1",
  "title": "OFARM ProductNormalizationTrace v0.1",
  "$comment": "Candidate machine contract for reviewed normalization of receipt-backed invoice-line extracts into exact product, product class, or refusal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "normalizationTraceId",
    "targetTwin",
    "sourceExtractRef",
    "sourceLineId",
    "createdAt",
    "reviewedByPartyRef",
    "sourceLabel",
    "sourceAmount",
    "sourceCurrency",
    "normalizationOutcome",
    "comparabilityStatus",
    "normalizedCurrency"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.productnormalizationtrace.v0.1"
    },
    "normalizationTraceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetTwin": {
      "const": "ADVISORY"
    },
    "sourceExtractRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceLineId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "reviewedByPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceLabel": {
      "type": "string"
    },
    "sourceCategoryCode": {
      "type": "string"
    },
    "sourceEvidenceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceDocumentRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceQuantity": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "sourceUnit": {
      "type": "string"
    },
    "sourceAmount": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "sourceCurrency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "normalizedQuantity": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "normalizedUnitCode": {
      "type": "string"
    },
    "normalizedCurrency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "normalizationOutcome": {
      "enum": [
        "EXACT_PRODUCT",
        "PRODUCT_CLASS",
        "REFUSED"
      ]
    },
    "normalizedProductRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "normalizedProductClassRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "normalizationMethod": {
      "enum": [
        "CODE_MATCH",
        "REVIEWED_LOOKUP",
        "MANUAL_CLASSIFICATION",
        "MIXED"
      ]
    },
    "ambiguityReasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "comparabilityStatus": {
      "enum": [
        "COMPARABLE",
        "NON_COMPARABLE",
        "REVIEW_REQUIRED"
      ]
    },
    "comparabilityNotes": {
      "type": "string"
    },
    "packagingNormalizationApplied": {
      "type": "boolean"
    },
    "unitNormalizationApplied": {
      "type": "boolean"
    },
    "currencyNormalizationApplied": {
      "type": "boolean"
    },
    "fxPolicyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "normalizationOutcome": {
            "const": "EXACT_PRODUCT"
          }
        },
        "required": [
          "normalizationOutcome"
        ]
      },
      "then": {
        "required": [
          "normalizedProductRef",
          "normalizedProductClassRef",
          "normalizedQuantity",
          "normalizedUnitCode"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "normalizationOutcome": {
            "const": "PRODUCT_CLASS"
          }
        },
        "required": [
          "normalizationOutcome"
        ]
      },
      "then": {
        "required": [
          "normalizedProductClassRef",
          "normalizedQuantity",
          "normalizedUnitCode"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "normalizationOutcome": {
            "const": "REFUSED"
          }
        },
        "required": [
          "normalizationOutcome"
        ]
      },
      "then": {
        "required": [
          "ambiguityReasonCodes"
        ]
      }
    }
  ]
}
