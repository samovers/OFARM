{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/benchmarkrequesthistoryassessment/v0.1",
  "title": "OFARM BenchmarkRequestHistoryAssessment v0.1",
  "$comment": "Candidate machine contract for viewer-specific request-history assessment before cohort benchmark disclosure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "assessmentId",
    "targetTwin",
    "assessedAt",
    "requestedByPartyRef",
    "requestedBenchmarkKind",
    "benchmarkWindowStart",
    "benchmarkWindowEnd",
    "requestSignature",
    "safeFilterFingerprint",
    "priorRequestRefs",
    "priorRequestRelations",
    "nearMatchRequestCount",
    "distinctWindowCount",
    "differencingRiskClass",
    "differencingGuardStatus",
    "actionRecommendation",
    "reasonCodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.benchmarkrequesthistoryassessment.v0.1"
    },
    "assessmentId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetTwin": {
      "const": "ADVISORY"
    },
    "assessedAt": {
      "type": "string",
      "format": "date-time"
    },
    "requestedByPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestedBenchmarkKind": {
      "enum": [
        "PRODUCT_CLASS",
        "EXACT_PRODUCT"
      ]
    },
    "requestedProductRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestedProductClassRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "benchmarkWindowStart": {
      "type": "string",
      "format": "date-time"
    },
    "benchmarkWindowEnd": {
      "type": "string",
      "format": "date-time"
    },
    "requestSignature": {
      "type": "string"
    },
    "safeFilterFingerprint": {
      "type": "string"
    },
    "priorRequestRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "priorRequestRelations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priorRequestRef",
          "relationType"
        ],
        "properties": {
          "priorRequestRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "relationType": {
            "enum": [
              "EQUIVALENT",
              "BROADER_THAN_PRIOR",
              "STRICTER_THAN_PRIOR",
              "OVERLAPPING",
              "DISJOINT"
            ]
          }
        }
      }
    },
    "nearMatchRequestCount": {
      "type": "integer",
      "minimum": 0
    },
    "distinctWindowCount": {
      "type": "integer",
      "minimum": 1
    },
    "differencingRiskClass": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "differencingGuardStatus": {
      "enum": [
        "CLEAR",
        "BROADEN",
        "BLOCKED",
        "REVIEW_REQUIRED"
      ]
    },
    "actionRecommendation": {
      "enum": [
        "PROCEED",
        "PROCEED_WITH_BROADENING",
        "REFUSE",
        "REVIEW"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
