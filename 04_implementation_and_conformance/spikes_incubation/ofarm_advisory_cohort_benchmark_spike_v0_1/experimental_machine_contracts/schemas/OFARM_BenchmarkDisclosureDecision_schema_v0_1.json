{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/benchmarkdisclosuredecision/v0.1",
  "title": "OFARM BenchmarkDisclosureDecision v0.1",
  "$comment": "Candidate machine contract for deterministic disclosure decisions on cohort benchmark requests.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "decisionId",
    "targetTwin",
    "requestedAt",
    "requestedByPartyRef",
    "decision",
    "requestedBenchmarkKind",
    "effectiveBenchmarkKind",
    "benchmarkWindowStart",
    "benchmarkWindowEnd",
    "contributorCountInternal",
    "contributorCountDisplay",
    "minContributorsRequired",
    "dominanceShareMax",
    "dominanceThreshold",
    "differencingGuardStatus",
    "safeFilterFingerprint",
    "allowedUserMetricFamily",
    "fallbackApplied",
    "reasonCodes",
    "userVisibleMetrics",
    "sourceContributionRefs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.benchmarkdisclosuredecision.v0.1"
    },
    "decisionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetTwin": {
      "const": "ADVISORY"
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "requestedByPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "decision": {
      "enum": [
        "ALLOW",
        "BROADEN",
        "SUPPRESS",
        "REFUSE"
      ]
    },
    "requestedBenchmarkKind": {
      "enum": [
        "PRODUCT_CLASS",
        "EXACT_PRODUCT"
      ]
    },
    "effectiveBenchmarkKind": {
      "enum": [
        "PRODUCT_CLASS",
        "EXACT_PRODUCT",
        "NONE"
      ]
    },
    "requestedProductRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestedProductClassRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "effectiveProductRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "effectiveProductClassRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "benchmarkWindowStart": {
      "type": "string",
      "format": "date-time"
    },
    "benchmarkWindowEnd": {
      "type": "string",
      "format": "date-time"
    },
    "contributorCountInternal": {
      "type": "integer",
      "minimum": 0
    },
    "contributorCountDisplay": {
      "enum": [
        "HIDDEN",
        "3-4",
        "5-9",
        "10-19",
        "20_PLUS"
      ]
    },
    "minContributorsRequired": {
      "type": "integer",
      "minimum": 2
    },
    "dominanceShareMax": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "dominanceThreshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "differencingGuardStatus": {
      "enum": [
        "CLEAR",
        "BLOCKED",
        "REVIEW_REQUIRED"
      ]
    },
    "safeFilterFingerprint": {
      "type": "string"
    },
    "allowedUserMetricFamily": {
      "enum": [
        "AVG_UNIT_PRICE",
        "QUANTITY_BAND",
        "POSITION_BAND"
      ]
    },
    "fallbackApplied": {
      "enum": [
        "NONE",
        "TO_PRODUCT_CLASS",
        "TO_REFUSAL"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "sourceContributionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "userVisibleMetrics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metricName"
        ],
        "properties": {
          "metricName": {
            "enum": [
              "AVG_UNIT_PRICE",
              "QUANTITY_BAND",
              "POSITION_BAND"
            ]
          },
          "numericValue": {
            "type": "number"
          },
          "bandLabel": {
            "type": "string"
          },
          "textValue": {
            "type": "string"
          },
          "currency": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3
          },
          "unitCode": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "ALLOW"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "effectiveBenchmarkKind": {
            "enum": [
              "PRODUCT_CLASS",
              "EXACT_PRODUCT"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "BROADEN"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "requestedBenchmarkKind": {
            "const": "EXACT_PRODUCT"
          },
          "effectiveBenchmarkKind": {
            "const": "PRODUCT_CLASS"
          },
          "fallbackApplied": {
            "const": "TO_PRODUCT_CLASS"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "enum": [
              "SUPPRESS",
              "REFUSE"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "effectiveBenchmarkKind": {
            "enum": [
              "PRODUCT_CLASS",
              "EXACT_PRODUCT",
              "NONE"
            ]
          }
        }
      }
    }
  ]
}
