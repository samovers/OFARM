{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/benchmarkcontribution/v0.1",
  "title": "OFARM BenchmarkContribution v0.1",
  "$comment": "Candidate machine contract for one-row-per-contributor-per-benchmark-window derived benchmark input objects.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contributionId",
    "targetTwin",
    "contributorPartitionRef",
    "sourceNormalizationTraceRef",
    "sourceExtractRef",
    "anchorScopes",
    "benchmarkWindowStart",
    "benchmarkWindowEnd",
    "benchmarkKind",
    "normalizedProductClassRef",
    "normalizedQuantity",
    "normalizedUnitCode",
    "metricFamily",
    "metricValue",
    "totalAmount",
    "currency",
    "evidenceClass",
    "directness",
    "shareGrantRef",
    "revocationState",
    "currentUseState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.benchmarkcontribution.v0.1"
    },
    "contributionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetTwin": {
      "const": "ADVISORY"
    },
    "contributorPartitionRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceNormalizationTraceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceExtractRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "anchorScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "CROP_CYCLE",
              "FACILITY",
              "SEASON"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "benchmarkWindowStart": {
      "type": "string",
      "format": "date-time"
    },
    "benchmarkWindowEnd": {
      "type": "string",
      "format": "date-time"
    },
    "benchmarkKind": {
      "enum": [
        "PRODUCT_CLASS",
        "EXACT_PRODUCT"
      ]
    },
    "normalizedProductRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "normalizedProductClassRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "normalizedQuantity": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "normalizedUnitCode": {
      "type": "string"
    },
    "metricFamily": {
      "enum": [
        "UNIT_PRICE"
      ]
    },
    "metricValue": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "totalAmount": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "evidenceClass": {
      "enum": [
        "REVIEWED_EXTRACT_DIRECT",
        "REVIEWED_EXTRACT_WITH_NORMALIZATION"
      ]
    },
    "directness": {
      "enum": [
        "DIRECT",
        "DERIVED_NON_ALLOCATED"
      ]
    },
    "shareGrantRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "revocationState": {
      "enum": [
        "ACTIVE",
        "REVOKED_FOR_FUTURE_USE"
      ]
    },
    "currentUseState": {
      "enum": [
        "ELIGIBLE",
        "INELIGIBLE"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "benchmarkKind": {
            "const": "EXACT_PRODUCT"
          }
        },
        "required": [
          "benchmarkKind"
        ]
      },
      "then": {
        "required": [
          "normalizedProductRef"
        ]
      }
    }
  ]
}
