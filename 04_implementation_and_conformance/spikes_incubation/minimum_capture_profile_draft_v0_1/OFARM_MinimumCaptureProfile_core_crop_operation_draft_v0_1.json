{
  "schemaVersion": "ofarm.minimumcaptureprofile.v0.1",
  "profileId": "minimum_capture.core_crop_operation.draft.v0.1",
  "status": "DRAFT_NON_DEFAULT",
  "profileScope": "CORE_CROP_OPERATION",
  "allowedUse": [
    "LOW_CONSEQUENCE_CAPTURE",
    "ADVISORY_PREVIEW",
    "IMPORT_CANDIDATE",
    "COMPLIANCE_PRECHECK_ONLY",
    "PILOT_ONLY"
  ],
  "requiredAtCapture": [
    {
      "fieldRef": "operationDateOrApproximation",
      "requirementClass": "REQUIRED",
      "notes": "Capture must have a temporal anchor."
    },
    {
      "fieldRef": "fieldOrApproximateLocation",
      "requirementClass": "REQUIRED",
      "notes": "Location anchor needed for review."
    },
    {
      "fieldRef": "actorOrRecorder",
      "requirementClass": "REQUIRED_IF_KNOWN",
      "notes": "Unknown actor must remain unresolved, not guessed."
    },
    {
      "fieldRef": "productTextOrRef",
      "requirementClass": "REQUIRED_IF_KNOWN",
      "notes": "Product identity may be late-bound but blocks high-consequence use."
    }
  ],
  "mayBeLateBound": [
    "actorRef",
    "productIdentityRef",
    "unitRef",
    "exactAreaRef",
    "evidenceRefs"
  ],
  "blocksHighConsequenceIfMissing": [
    "actorRef",
    "productIdentityRef",
    "unitRef",
    "exactAreaRef",
    "evidenceRefs",
    "authorityGrantRef"
  ],
  "prohibitedDefaults": [
    "default_unknown_actor_to_farm_owner",
    "default_text_product_to_registered_product",
    "default_fmis_area_to_current_geometry",
    "default_stale_materialization_to_current_truth"
  ],
  "activationPrerequisites": [
    "pilot evidence",
    "owner review",
    "conformance tests for blocked high-consequence use"
  ],
  "notes": "Draft only. Supports ordinary capture without weakening truth or evidence gates."
}
