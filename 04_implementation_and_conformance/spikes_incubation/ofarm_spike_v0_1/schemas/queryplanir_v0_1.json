{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/queryplanir/v0.1",
  "title": "OFARM QueryPlanIR v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceQuerySpecificationId",
    "normalizedTarget",
    "resolvedPathAliases",
    "executionSteps",
    "materializationPolicy",
    "outputAssembly"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.queryplanir.v0.1"
    },
    "planId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceQuerySpecificationId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "normalizedTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "twin",
        "anchorScopes",
        "evaluationTimePolicy",
        "contextSnapshotRef"
      ],
      "properties": {
        "twin": {
          "enum": [
            "COMPLIANCE",
            "ADVISORY"
          ]
        },
        "anchorScopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "scopeType",
              "scopeRef"
            ],
            "properties": {
              "scopeType": {
                "enum": [
                  "FARM",
                  "SITE",
                  "FIELD",
                  "ZONE",
                  "CROP_CYCLE",
                  "LOT",
                  "FACILITY",
                  "OPERATION"
                ]
              },
              "scopeRef": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._:-]+$"
              }
            }
          }
        },
        "evaluationTimePolicy": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "policyType"
              ],
              "properties": {
                "policyType": {
                  "const": "NOW"
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "policyType",
                "asOfTime"
              ],
              "properties": {
                "policyType": {
                  "const": "AS_OF"
                },
                "asOfTime": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "policyType",
                "windowStart",
                "windowEnd"
              ],
              "properties": {
                "policyType": {
                  "const": "WINDOW"
                },
                "windowStart": {
                  "type": "string",
                  "format": "date-time"
                },
                "windowEnd": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          ]
        },
        "contextSnapshotRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "authorityContextHash": {
          "type": "string"
        }
      }
    },
    "resolvedPathAliases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "alias",
          "rootVar",
          "pathRef",
          "resolvedToType",
          "resolvedRef",
          "resolutionVersionRef"
        ],
        "properties": {
          "alias": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
          },
          "rootVar": {
            "type": "string",
            "pattern": "^[a-z][A-Za-z0-9_]*$"
          },
          "pathRef": {
            "type": "string",
            "pattern": "^/"
          },
          "resolvedToType": {
            "enum": [
              "SEMANTIC_ANCHOR",
              "GOVERNED_CONTENT_NODE"
            ]
          },
          "resolvedRef": {
            "type": "string"
          },
          "resolutionVersionRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "executionSteps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stepId",
          "executorType",
          "operationType",
          "inputBindings",
          "outputBindingSetId"
        ],
        "properties": {
          "stepId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "executorType": {
            "enum": [
              "SEMANTIC_GRAPH",
              "CURRENT_STATE_MATERIALIZATION",
              "READ_MODEL",
              "SEARCH_INDEX",
              "RESOURCE_FILTER_ENDPOINT"
            ]
          },
          "operationType": {
            "enum": [
              "MATCH",
              "FILTER",
              "JOIN",
              "PROJECT",
              "AGGREGATE",
              "ORDER",
              "PAGINATE",
              "RESHAPE"
            ]
          },
          "inputBindings": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
            }
          },
          "outputBindingSetId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "targetRef": {
            "type": "string"
          },
          "freshnessRequirement": {
            "enum": [
              "REQUIRE_FRESH",
              "ALLOW_STALE_EXPLORATORY",
              "NO_CURRENT_STATE_DEPENDENCY"
            ]
          }
        }
      }
    },
    "materializationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredFreshness",
        "highConsequenceUse"
      ],
      "properties": {
        "requiredFreshness": {
          "enum": [
            "REQUIRE_FRESH",
            "ALLOW_STALE_EXPLORATORY",
            "NO_CURRENT_STATE_DEPENDENCY"
          ]
        },
        "highConsequenceUse": {
          "type": "boolean"
        }
      }
    },
    "equivalenceRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semanticEquivalenceRequired",
        "projectionTraceBackRequired"
      ],
      "properties": {
        "semanticEquivalenceRequired": {
          "type": "boolean",
          "const": true
        },
        "projectionTraceBackRequired": {
          "type": "boolean"
        }
      }
    },
    "outputAssembly": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "enum": [
            "RAW_BINDINGS",
            "VIEW_MODULE",
            "PASSPORT_VIEW",
            "DOCUMENT_ASSEMBLY_INPUT"
          ]
        },
        "viewModuleRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "compiledOutputSubtype": {
          "enum": [
            "REPORT",
            "DOSSIER",
            "SUBMISSION"
          ]
        }
      }
    }
  }
}