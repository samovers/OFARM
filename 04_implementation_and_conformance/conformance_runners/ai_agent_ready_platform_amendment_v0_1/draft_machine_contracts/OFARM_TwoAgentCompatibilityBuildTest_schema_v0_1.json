{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/twoagentcompatibilitybuildtest/v0.1",
  "title": "OFARM TwoAgentCompatibilityBuildTest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "testId",
    "phase",
    "status",
    "agentCount",
    "targetApplication",
    "materialsProvided",
    "requiredWorkflows",
    "comparisonDimensions",
    "failureCriteria",
    "requiredDeliverables"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.twoagentcompatibilitybuildtest.v0.1"
    },
    "testId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "phase": {
      "const": 8
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE_CANDIDATE",
        "DEPRECATED"
      ]
    },
    "agentCount": {
      "type": "integer",
      "minimum": 2
    },
    "targetApplication": {
      "type": "string"
    },
    "materialsProvided": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "requiredWorkflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "comparisonDimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "failureCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "requiredDeliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "scoringRubric": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dimension",
          "passCondition"
        ],
        "properties": {
          "dimension": {
            "type": "string"
          },
          "passCondition": {
            "type": "string"
          },
          "blocker": {
            "type": "boolean"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
