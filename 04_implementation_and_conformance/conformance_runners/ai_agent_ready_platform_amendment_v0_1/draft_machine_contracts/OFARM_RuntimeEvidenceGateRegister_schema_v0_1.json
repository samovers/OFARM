{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_RuntimeEvidenceGateRegister_schema_v0_1.json",
  "title": "OFARM Runtime Evidence Gate Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "registerId",
    "date",
    "status",
    "gates"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.runtimeevidencegate.register.v0.1"
    },
    "registerId": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gateId",
          "name",
          "currentStatus",
          "evidenceRequired",
          "evidenceAvailable",
          "blocksClaims"
        ],
        "properties": {
          "gateId": {
            "type": "string",
            "pattern": "^REG-[0-9]{3}$"
          },
          "name": {
            "type": "string"
          },
          "currentStatus": {
            "type": "string",
            "enum": [
              "contract_defined_not_executed",
              "partially_satisfied_contract_only",
              "unresolved_no_runtime",
              "not_applicable_to_phase9",
              "satisfied_by_static_validation"
            ]
          },
          "evidenceRequired": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidenceAvailable": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocksClaims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
