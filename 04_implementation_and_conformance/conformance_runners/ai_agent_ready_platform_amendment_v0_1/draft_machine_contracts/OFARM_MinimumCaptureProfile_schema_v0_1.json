{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/minimumcaptureprofile/v0.1",
  "title": "OFARM MinimumCaptureProfile v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "profileId",
    "status",
    "profileScope",
    "allowedUse",
    "requiredAtCapture",
    "mayBeLateBound",
    "blocksHighConsequenceIfMissing",
    "prohibitedDefaults"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.minimumcaptureprofile.v0.1"
    },
    "profileId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT_NON_DEFAULT",
        "PILOT_ONLY",
        "ACTIVE_PROFILE_CANDIDATE"
      ]
    },
    "profileScope": {
      "enum": [
        "CORE_CROP_OPERATION",
        "OBSERVATION_ONLY",
        "INVENTORY_NOTE",
        "ADVISORY_ONLY",
        "OTHER"
      ]
    },
    "allowedUse": {
      "type": "array",
      "items": {
        "enum": [
          "LOW_CONSEQUENCE_CAPTURE",
          "ADVISORY_PREVIEW",
          "IMPORT_CANDIDATE",
          "COMPLIANCE_PRECHECK_ONLY",
          "PILOT_ONLY"
        ]
      }
    },
    "requiredAtCapture": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fieldRef",
          "requirementClass"
        ],
        "properties": {
          "fieldRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "requirementClass": {
            "enum": [
              "REQUIRED",
              "REQUIRED_IF_KNOWN",
              "OPTIONAL",
              "NOT_ALLOWED"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "mayBeLateBound": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "blocksHighConsequenceIfMissing": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "prohibitedDefaults": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "activationPrerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "description": "Draft non-default profile for ordinary farm capture. It does not weaken evidence, authority, or high-consequence output gates."
}
