{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/preflightrequest/v0.1",
  "title": "OFARM PreflightRequest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "requestedOperationId",
    "actorRef",
    "requestedAt",
    "intendedConsequence",
    "dryRun"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.preflightrequest.v0.1"
    },
    "requestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestedOperationId": {
      "type": "string"
    },
    "actorRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "tenantRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "authorityContextRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "intendedConsequence": {
      "enum": [
        "READ_ONLY",
        "DRAFT_ONLY",
        "STATE_AFFECTING",
        "HIGH_CONSEQUENCE",
        "PUBLICATION_AFFECTING"
      ]
    },
    "dryRun": {
      "type": "boolean"
    },
    "subjectRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "candidatePayload": {
      "type": "object"
    },
    "idempotencyKey": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
