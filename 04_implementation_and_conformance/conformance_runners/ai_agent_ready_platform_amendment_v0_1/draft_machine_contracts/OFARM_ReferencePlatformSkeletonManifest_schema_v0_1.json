{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/referenceplatformskeletonmanifest/v0.1",
  "title": "OFARM ReferencePlatformSkeletonManifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "skeletonId",
    "status",
    "moduleRoot",
    "modules",
    "apps",
    "forbiddenShortcuts",
    "importBoundaryMatrixRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.referenceplatformskeletonmanifest.v0.1"
    },
    "skeletonId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "CANDIDATE",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "moduleRoot": {
      "type": "string"
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "moduleId",
          "path",
          "responsibility",
          "publicSurfacePosture",
          "mustEmitTrace"
        ],
        "properties": {
          "moduleId": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9.-]*$"
          },
          "path": {
            "type": "string"
          },
          "responsibility": {
            "type": "string"
          },
          "publicSurfacePosture": {
            "enum": [
              "PUBLIC_WRAPPER_ONLY",
              "INTERNAL_SERVICE",
              "GENERATED_CONTRACTS_ONLY",
              "CONFORMANCE_ONLY",
              "APP_SAMPLE_ONLY"
            ]
          },
          "mustEmitTrace": {
            "type": "boolean"
          },
          "allowedImportsRef": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "apps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "appId",
          "path",
          "purpose",
          "mustUseSdkOnly"
        ],
        "properties": {
          "appId": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9.-]*$"
          },
          "path": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "mustUseSdkOnly": {
            "type": "boolean"
          }
        }
      }
    },
    "forbiddenShortcuts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "importBoundaryMatrixRef": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
