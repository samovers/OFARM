{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentreadinessconformancesuite/v0.1",
  "title": "OFARM AgentReadinessConformanceSuite v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "suiteId",
    "phase",
    "status",
    "suiteName",
    "objective",
    "caseCount",
    "cases",
    "acceptanceCriteria"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentreadinessconformancesuite.v0.1"
    },
    "suiteId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "phase": {
      "const": 8
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE_CANDIDATE",
        "DEPRECATED"
      ]
    },
    "suiteName": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "researchBasisRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "caseCount": {
      "type": "integer",
      "minimum": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://ofarm.dev/schema/agentreadinessconformancecase/v0.1"
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
