{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentreadinessconformancecase/v0.1",
  "title": "OFARM AgentReadinessConformanceCase v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "caseId",
    "phase",
    "suiteId",
    "status",
    "category",
    "severity",
    "title",
    "failureMode",
    "given",
    "when",
    "then",
    "assertions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentreadinessconformancecase.v0.1"
    },
    "caseId": {
      "type": "string",
      "pattern": "^[A-Z0-9_.:-]+$"
    },
    "phase": {
      "const": 8
    },
    "suiteId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE_CANDIDATE",
        "DEPRECATED"
      ]
    },
    "category": {
      "enum": [
        "SEMANTIC_LAW",
        "CONTRACT_DISCIPLINE",
        "SYNC_IMPORT",
        "NUMERIC_DISPLAY",
        "EXPLAINABILITY",
        "SDK_BOUNDARY",
        "TWO_AGENT_BUILD",
        "HARD_PATH",
        "OTHER"
      ]
    },
    "severity": {
      "enum": [
        "BLOCKER",
        "MAJOR",
        "MINOR"
      ]
    },
    "title": {
      "type": "string"
    },
    "failureMode": {
      "type": "string"
    },
    "affectedArtifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publicSurfaceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtimeProblemReasonCodeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "traceTypes": {
      "type": "array",
      "items": {
        "enum": [
          "AUTHORIZATION",
          "PROMOTION",
          "QUERY",
          "MATERIALIZATION",
          "PUBLICATION",
          "PACK_ACTIVATION",
          "IMPORT",
          "CALCULATION",
          "PREFLIGHT",
          "COMMIT",
          "EVIDENCE",
          "IDENTITY",
          "CORRECTION_DISPUTE",
          "SYNC",
          "OUTPUT_ASSEMBLY",
          "CONFORMANCE"
        ]
      }
    },
    "given": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "when": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "then": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "mustFailIf": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assertionId",
          "statement",
          "expectedBehavior"
        ],
        "properties": {
          "assertionId": {
            "type": "string",
            "pattern": "^[A-Z0-9_.:-]+$"
          },
          "statement": {
            "type": "string"
          },
          "expectedBehavior": {
            "enum": [
              "PASS",
              "FAIL",
              "BLOCK",
              "REFUSE",
              "REQUIRE_REVIEW",
              "PRESERVE_STATE",
              "EMIT_TRACE"
            ]
          },
          "evidenceRequired": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "negativeExample": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
