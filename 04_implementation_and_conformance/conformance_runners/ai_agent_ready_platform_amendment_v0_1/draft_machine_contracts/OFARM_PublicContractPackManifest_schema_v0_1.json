{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/publiccontractpackmanifest/v0.1",
  "title": "OFARM PublicContractPackManifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packId",
    "status",
    "contractDocuments",
    "publicInternalBoundary",
    "generationRules",
    "validationGates"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.publiccontractpackmanifest.v0.1"
    },
    "packId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "CANDIDATE_PUBLIC_CONTRACT_PACK",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "contractDocuments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "documentId",
          "path",
          "documentType",
          "exposure"
        ],
        "properties": {
          "documentId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "path": {
            "type": "string"
          },
          "documentType": {
            "enum": [
              "OPENAPI",
              "ASYNCAPI",
              "JSON_SCHEMA",
              "SCHEMA_CATALOG",
              "TOOL_MANIFEST",
              "CODEGEN_MANIFEST",
              "OVERLAY",
              "OTHER"
            ]
          },
          "exposure": {
            "enum": [
              "PUBLIC",
              "INTERNAL",
              "DRAFT_PUBLIC",
              "EXAMPLE_ONLY"
            ]
          },
          "sourceOfTruth": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "publicInternalBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publicEntryDocs",
        "internalEntryDocs",
        "forbiddenLeakageTests"
      ],
      "properties": {
        "publicEntryDocs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "internalEntryDocs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenLeakageTests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "generationRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "validationGates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
