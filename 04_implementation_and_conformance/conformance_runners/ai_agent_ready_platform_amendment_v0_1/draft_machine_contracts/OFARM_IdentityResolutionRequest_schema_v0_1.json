{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/identityresolutionrequest/v0.1",
  "title": "OFARM IdentityResolutionRequest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "requestedUse",
    "subjectType",
    "externalIdentifiers",
    "candidateContext"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.identityresolutionrequest.v0.1"
    },
    "requestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestedUse": {
      "enum": [
        "IMPORT_CANDIDATE",
        "COMMIT_PRECHECK",
        "DISPLAY_LABEL",
        "ADAPTER_MAPPING",
        "DUPLICATE_CHECK"
      ]
    },
    "subjectType": {
      "enum": [
        "FIELD",
        "GEOMETRY",
        "ZONE",
        "PRODUCT",
        "ACTOR",
        "WORKER",
        "CONTRACTOR",
        "MACHINE",
        "INVENTORY_LOT",
        "STORAGE_LOCATION",
        "CROP_CYCLE",
        "OTHER"
      ]
    },
    "externalIdentifiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "idSystem",
          "idValue"
        ],
        "properties": {
          "idSystem": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "idValue": {
            "type": "string"
          },
          "sourceSystemRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "confidence": {
            "type": "number"
          }
        }
      }
    },
    "candidateContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tenantRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "fieldRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "timeRange": {
          "type": "string"
        },
        "sourceFidelityEnvelopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "duplicateCheck": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fingerprint": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "idempotencyKey": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "sourceRecordRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "highConsequenceUse": {
          "type": "boolean"
        },
        "allowProvisionalDisplay": {
          "type": "boolean"
        },
        "blockIfAmbiguous": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
