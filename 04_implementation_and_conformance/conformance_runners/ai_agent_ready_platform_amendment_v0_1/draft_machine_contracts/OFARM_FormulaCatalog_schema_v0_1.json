{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/formulacatalog/v0.1",
  "title": "OFARM FormulaCatalog v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "catalogId",
    "status",
    "formulas"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.formulacatalog.v0.1"
    },
    "catalogId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE_CANDIDATE",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "formulas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "formulaId",
          "formulaVersion",
          "formulaClass",
          "inputRoles",
          "outputRole",
          "governanceStatus"
        ],
        "properties": {
          "formulaId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "formulaVersion": {
            "type": "string"
          },
          "formulaClass": {
            "enum": [
              "RATE_AREA_PRODUCT_QUANTITY",
              "ACTIVE_INGREDIENT",
              "CARRIER_VOLUME",
              "INVENTORY_DRAWDOWN",
              "UNIT_CONVERSION",
              "OTHER"
            ]
          },
          "inputRoles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:/#-]+$"
            }
          },
          "outputRole": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "canonicalUnitRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "roundingPolicyRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "governanceStatus": {
            "enum": [
              "DRAFT",
              "PROFILE_GOVERNED",
              "BASELINE_GOVERNED",
              "RESEARCH_ONLY"
            ]
          },
          "testVectorRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:/#-]+$"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "description": "Draft formula catalogue carrier. It does not make a formula active law unless separately governed."
}
