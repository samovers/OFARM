{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/publicoperationdescriptor/v0.1",
  "title": "OFARM PublicOperationDescriptor v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "operationId",
    "status",
    "surfaceCategory",
    "transport",
    "callableBy",
    "consequenceClass",
    "humanApproval",
    "preflightRequired",
    "traceRequired",
    "idempotencyRequired"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.publicoperationdescriptor.v0.1"
    },
    "operationId": {
      "type": "string",
      "pattern": "^[a-z][A-Za-z0-9.:-]*$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "CANDIDATE_PUBLIC",
        "ACTIVE_PUBLIC",
        "DEPRECATED"
      ]
    },
    "surfaceCategory": {
      "enum": [
        "DISCOVERY",
        "AUTHORITY",
        "COMMIT",
        "EVIDENCE",
        "QUERY",
        "MATERIALIZATION",
        "PUBLICATION",
        "CORRECTION_DISPUTE",
        "IDENTITY",
        "IMPORT",
        "PACK",
        "TRACE",
        "CALCULATION",
        "OTHER"
      ]
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolFamily",
        "method",
        "path"
      ],
      "properties": {
        "protocolFamily": {
          "enum": [
            "HTTP",
            "MESSAGE_BUS",
            "FILE_EXCHANGE",
            "SDK",
            "OTHER"
          ]
        },
        "method": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "callableBy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "APPLICATION",
          "SDK",
          "AI_AGENT",
          "PLATFORM_MODULE",
          "INTEGRATION_ADAPTER",
          "HUMAN_OPERATOR"
        ]
      }
    },
    "consequenceClass": {
      "enum": [
        "READ_ONLY",
        "DRAFT_ONLY",
        "STATE_AFFECTING",
        "HIGH_CONSEQUENCE",
        "PUBLICATION_AFFECTING"
      ]
    },
    "humanApproval": {
      "enum": [
        "NEVER",
        "WHEN_POLICY_REQUIRES",
        "ALWAYS"
      ]
    },
    "preflightRequired": {
      "type": "boolean"
    },
    "traceRequired": {
      "type": "boolean"
    },
    "idempotencyRequired": {
      "type": "boolean"
    },
    "authorityActionClassRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "requestSchemaRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "resultSchemaRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "runtimeProblemReasonCodeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "cachePolicy": {
      "enum": [
        "NOT_CACHEABLE",
        "CACHEABLE_WITH_FRESHNESS_POSTURE",
        "CACHEABLE_READ_ONLY",
        "IMPLEMENTATION_DEFINED"
      ]
    },
    "forbiddenShortcuts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
