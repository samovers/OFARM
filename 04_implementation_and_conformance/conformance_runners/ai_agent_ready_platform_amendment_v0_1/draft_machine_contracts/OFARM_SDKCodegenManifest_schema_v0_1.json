{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/sdkcodegenmanifest/v0.1",
  "title": "OFARM SDKCodegenManifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestId",
    "status",
    "sourceContractRefs",
    "generatedTargets",
    "forbiddenGeneratedAffordances",
    "boundaryAssertions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.sdkcodegenmanifest.v0.1"
    },
    "manifestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "CANDIDATE",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "sourceContractRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contractType",
          "path",
          "use"
        ],
        "properties": {
          "contractType": {
            "enum": [
              "OPENAPI",
              "ASYNCAPI",
              "JSON_SCHEMA_CATALOG",
              "AGENT_TOOL_MANIFEST",
              "REASON_CODE_REGISTRY",
              "PUBLIC_SURFACE_MANIFEST",
              "OTHER"
            ]
          },
          "path": {
            "type": "string"
          },
          "use": {
            "type": "string"
          }
        }
      }
    },
    "generatedTargets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "language",
          "packageName",
          "status",
          "generatedFrom",
          "clientShape",
          "validatorBehavior"
        ],
        "properties": {
          "language": {
            "enum": [
              "typescript",
              "python",
              "java",
              "csharp",
              "other"
            ]
          },
          "packageName": {
            "type": "string"
          },
          "status": {
            "enum": [
              "DRAFT",
              "CANDIDATE",
              "ACTIVE",
              "DEPRECATED"
            ]
          },
          "generatedFrom": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "clientShape": {
            "enum": [
              "OPERATION_CENTRIC_THIN_CLIENT",
              "RESOURCE_CRUD_CLIENT",
              "OTHER"
            ]
          },
          "validatorBehavior": {
            "enum": [
              "STRICT_PUBLIC_SCHEMA_VALIDATION",
              "IMPLEMENTATION_DEFINED"
            ]
          },
          "includesAsyncListeners": {
            "type": "boolean"
          },
          "includesProblemEnums": {
            "type": "boolean"
          },
          "includesTraceTypes": {
            "type": "boolean"
          },
          "bootstrapSequence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "forbiddenGeneratedAffordances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "boundaryAssertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assertionId",
          "severity",
          "assertion"
        ],
        "properties": {
          "assertionId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "severity": {
            "enum": [
              "BLOCKER",
              "WARNING",
              "INFO"
            ]
          },
          "assertion": {
            "type": "string"
          },
          "testHint": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
