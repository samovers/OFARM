{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/app-demo-scenario/v0.1",
  "title": "OFARM AppDemoScenario v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scenarioId",
    "title",
    "scenarioClass",
    "authorityPosture",
    "purpose",
    "sourceRecipeRefs",
    "steps",
    "expectedOutcomes",
    "blockedShortcuts",
    "conformanceChecks"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.appdemoscenario.v0.1"
    },
    "scenarioId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "title": {
      "type": "string"
    },
    "scenarioClass": {
      "enum": [
        "GOLDEN_PATH",
        "HARD_PATH",
        "NEGATIVE_PATH"
      ]
    },
    "authorityPosture": {
      "enum": [
        "IMPLEMENTATION_SUPPORT_ONLY",
        "CANDIDATE_APP_DEMO",
        "ACCEPTED_APP_DEMO"
      ]
    },
    "purpose": {
      "type": "string"
    },
    "sourceRecipeRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/demoStep"
      }
    },
    "expectedOutcomes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockedShortcuts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conformanceChecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "demoStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stepOrder",
        "stepId",
        "actor",
        "appAction",
        "publicOperationRef",
        "canonicalStateBefore",
        "canonicalStateAfter",
        "safeLabel",
        "traceRefs",
        "mustNotInfer"
      ],
      "properties": {
        "stepOrder": {
          "type": "integer",
          "minimum": 1
        },
        "stepId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "actor": {
          "type": "string"
        },
        "appAction": {
          "type": "string"
        },
        "publicOperationRef": {
          "type": "string"
        },
        "canonicalStateBefore": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalStateAfter": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "safeLabel": {
          "type": "string"
        },
        "traceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mustNotInfer": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runtimeProblemRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
