{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/calculationspec/v0.1",
  "title": "OFARM CalculationSpec v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "calculationSpecId",
    "calculationClass",
    "requestedUse",
    "inputQuantities",
    "governance"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.calculationspec.v0.1"
    },
    "calculationSpecId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "calculationClass": {
      "enum": [
        "UNIT_CONVERSION",
        "RATE_AREA_PRODUCT_QUANTITY",
        "ACTIVE_INGREDIENT",
        "CARRIER_VOLUME",
        "INVENTORY_DRAWDOWN",
        "YIELD_QUANTITY",
        "DENSITY_CONVERSION",
        "OTHER"
      ]
    },
    "requestedUse": {
      "enum": [
        "ADVISORY_PREVIEW",
        "COMPLIANCE_PREVIEW",
        "COMMIT_PRECHECK",
        "IMPORT_NORMALIZATION",
        "DISPLAY_PREVIEW"
      ]
    },
    "profileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "formulaRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "roundingPolicyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "inputQuantities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "quantityKindRef",
          "unitRef",
          "valueStatus"
        ],
        "properties": {
          "role": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "quantityKindRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "unitRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "value": {
            "type": "number"
          },
          "valueStatus": {
            "enum": [
              "PROVIDED",
              "DERIVED",
              "UNRESOLVED",
              "NOT_APPLICABLE"
            ]
          },
          "sourceRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "uncertainty": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "identityRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truthEffect",
        "blocksIfUnresolved",
        "requiresTrace"
      ],
      "properties": {
        "truthEffect": {
          "enum": [
            "NO_TRUTH_EFFECT",
            "ADVISORY_ONLY",
            "COMMIT_PRECHECK",
            "PUBLICATION_BASIS_PRECHECK"
          ]
        },
        "blocksIfUnresolved": {
          "type": "array",
          "items": {
            "enum": [
              "UNIT",
              "PRODUCT_IDENTITY",
              "AREA_EXTENT",
              "FORMULA",
              "ROUNDING_POLICY",
              "INVENTORY_IDENTITY"
            ]
          }
        },
        "requiresTrace": {
          "type": "boolean"
        },
        "highConsequenceUse": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "description": "Draft app/platform-facing calculation request. It carries inputs and desired governance posture; it does not authorize local UI formula decisions."
}
