{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/calculationresult/v0.1",
  "title": "OFARM CalculationResult v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "calculationResultId",
    "calculationSpecRef",
    "resultStatus",
    "outputQuantities",
    "reasonCodes",
    "traceRefs",
    "blockedUses"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.calculationresult.v0.1"
    },
    "calculationResultId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "calculationSpecRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "resultStatus": {
      "enum": [
        "SUCCESS",
        "REFUSED",
        "REVIEW_REQUIRED",
        "PARTIAL",
        "ADVISORY_ONLY"
      ]
    },
    "outputQuantities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "quantityKindRef",
          "unitRef",
          "valueStatus"
        ],
        "properties": {
          "role": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "quantityKindRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "unitRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "value": {
            "type": "number"
          },
          "valueStatus": {
            "enum": [
              "PROVIDED",
              "DERIVED",
              "UNRESOLVED",
              "NOT_APPLICABLE"
            ]
          },
          "sourceRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "uncertainty": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "unitConversionTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "formulaVersionRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "roundingApplied": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "roundingPolicyRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "roundingStage": {
          "type": "string"
        },
        "displayOnly": {
          "type": "boolean"
        }
      }
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "traceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "blockedUses": {
      "type": "array",
      "items": {
        "enum": [
          "COMPLIANCE_OUTPUT",
          "COMMIT_PROMOTION",
          "INVENTORY_MUTATION",
          "PUBLICATION_ASSEMBLY",
          "NONE"
        ]
      }
    },
    "qualificationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "notes": {
      "type": "string"
    }
  },
  "description": "Draft calculation result envelope. A successful preview still does not create canonical truth unless later submitted through governed commit/promotion surfaces."
}
