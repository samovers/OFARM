{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentreadinessconformanceexecutionreport/v0.1",
  "title": "OFARM AgentReadinessConformanceExecutionReport v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportId",
    "phase",
    "status",
    "generatedAt",
    "checks"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentreadinessconformanceexecutionreport.v0.1"
    },
    "reportId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "phase": {
      "const": 8
    },
    "status": {
      "enum": [
        "PASS",
        "FAIL",
        "MIXED",
        "NOT_RUN"
      ]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "checkId",
          "status",
          "note"
        ],
        "properties": {
          "checkId": {
            "type": "string"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "NOT_RUN",
              "WARNING"
            ]
          },
          "note": {
            "type": "string"
          },
          "caseRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
