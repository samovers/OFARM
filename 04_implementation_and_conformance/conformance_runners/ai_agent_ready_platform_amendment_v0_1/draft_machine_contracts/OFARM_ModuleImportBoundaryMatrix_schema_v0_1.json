{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/moduleimportboundarymatrix/v0.1",
  "title": "OFARM ModuleImportBoundaryMatrix v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "matrixId",
    "status",
    "allowedImports",
    "forbiddenImports",
    "rules"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.moduleimportboundarymatrix.v0.1"
    },
    "matrixId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "allowedImports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fromModule",
          "toModule",
          "reason"
        ],
        "properties": {
          "fromModule": {
            "type": "string"
          },
          "toModule": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "forbiddenImports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fromModule",
          "toModule",
          "reason"
        ],
        "properties": {
          "fromModule": {
            "type": "string"
          },
          "toModule": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
