{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/internalschemacatalog/v0.1",
  "title": "OFARM InternalSchemaCatalog v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "catalogId",
    "status",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.internalschemacatalog.v0.1"
    },
    "catalogId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaRef",
          "schemaName",
          "internalReason",
          "applicationUsePolicy",
          "sourcePath"
        ],
        "properties": {
          "schemaRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "schemaName": {
            "type": "string"
          },
          "internalReason": {
            "enum": [
              "CANONICAL_STORE",
              "MATERIALIZATION_STORE",
              "TRACE_ASSEMBLY_INTERNAL",
              "GATE_INTERNAL",
              "PLATFORM_MODULE_INTERNAL",
              "OTHER"
            ]
          },
          "applicationUsePolicy": {
            "enum": [
              "FORBIDDEN_DIRECT_USE",
              "READ_THROUGH_PUBLIC_API_ONLY",
              "EXAMPLE_DO_NOT_COPY"
            ]
          },
          "sourcePath": {
            "type": "string"
          },
          "publicAlternativeOperationRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
