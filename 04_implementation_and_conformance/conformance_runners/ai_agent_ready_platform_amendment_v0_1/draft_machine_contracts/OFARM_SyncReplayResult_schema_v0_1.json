{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/syncreplayresult/v0.1",
  "title": "OFARM SyncReplayResult v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "syncReplayResultId",
    "offlineCaptureEnvelopeRef",
    "replayStatus",
    "idempotencyOutcome",
    "authorityRecheck",
    "acceptedConsequences",
    "reviewItems",
    "reasonCodes",
    "traceRefs",
    "resultQualification"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.syncreplayresult.v0.1"
    },
    "syncReplayResultId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "offlineCaptureEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "replayStatus": {
      "enum": [
        "ACCEPTED",
        "REVIEW_REQUIRED",
        "REJECTED",
        "DUPLICATE_REPLAY",
        "CONFLICT",
        "REFUSED"
      ]
    },
    "idempotencyOutcome": {
      "enum": [
        "NEW_REPLAY",
        "REUSED_EXISTING_RESULT",
        "CONFLICTING_REPLAY_BLOCKED"
      ]
    },
    "authorityRecheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "decisionRef",
        "checkedAt"
      ],
      "properties": {
        "status": {
          "enum": [
            "PASSED",
            "DENIED",
            "REVIEW_REQUIRED",
            "STALE_SNAPSHOT"
          ]
        },
        "decisionRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "acceptedConsequences": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "reviewItems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reviewItemId",
          "reasonCode"
        ],
        "properties": {
          "reviewItemId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "reasonCode": {
            "type": "string",
            "pattern": "^[A-Z0-9_:-]+$"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "traceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "resultQualification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truthPosture",
        "displayState"
      ],
      "properties": {
        "truthPosture": {
          "enum": [
            "ACCEPTED_TRUTH",
            "REVIEW_REQUIRED_NOT_TRUTH",
            "REJECTED_NOT_TRUTH",
            "DUPLICATE_NO_NEW_TRUTH",
            "CONFLICT_BLOCKED"
          ]
        },
        "displayState": {
          "type": "string"
        },
        "blocksHighConsequenceOutput": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
