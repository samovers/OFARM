{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_DoNotPromoteRegister_schema_v0_1.json",
  "title": "OFARM Do Not Promote Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "registerId",
    "date",
    "status",
    "items"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.donotpromote.register.v0.1"
    },
    "registerId": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "item",
          "reason",
          "riskIfPromoted",
          "allowedUse"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^DNP-[0-9]{3}$"
          },
          "item": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "riskIfPromoted": {
            "type": "string"
          },
          "allowedUse": {
            "type": "string"
          }
        }
      }
    }
  }
}
