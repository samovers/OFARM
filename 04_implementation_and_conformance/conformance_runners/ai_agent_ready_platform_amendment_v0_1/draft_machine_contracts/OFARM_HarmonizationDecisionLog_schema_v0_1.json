{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_HarmonizationDecisionLog_schema_v0_1.json",
  "title": "OFARM Harmonization Decision Log",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "logId",
    "date",
    "status",
    "decisions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.harmonizationdecisionlog.v0.1"
    },
    "logId": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decisionId",
          "proposalId",
          "decision",
          "decider",
          "date",
          "rationale",
          "followUp"
        ],
        "properties": {
          "decisionId": {
            "type": "string"
          },
          "proposalId": {
            "type": "string"
          },
          "decision": {
            "type": "string",
            "enum": [
              "accepted",
              "rejected",
              "deferred",
              "requires_revision"
            ]
          },
          "decider": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "followUp": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
