{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/publicschemacatalog/v0.1",
  "title": "OFARM PublicSchemaCatalog v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "catalogId",
    "status",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.publicschemacatalog.v0.1"
    },
    "catalogId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaRef",
          "schemaName",
          "schemaStatus",
          "exposure",
          "sourcePath"
        ],
        "properties": {
          "schemaRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "schemaName": {
            "type": "string"
          },
          "schemaStatus": {
            "enum": [
              "DRAFT",
              "ACTIVE",
              "DEPRECATED"
            ]
          },
          "exposure": {
            "enum": [
              "PUBLIC_REQUEST",
              "PUBLIC_RESULT",
              "PUBLIC_SHARED",
              "PUBLIC_READ_ONLY",
              "EXAMPLE_ONLY",
              "DEPRECATED"
            ]
          },
          "sourcePath": {
            "type": "string"
          },
          "operationRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "lastUpdated": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    }
  }
}
