{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_BaselineHarmonizationRegister_schema_v0_1.json",
  "title": "OFARM Baseline Harmonization Proposal Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "registerId",
    "date",
    "status",
    "activeBaselineEdited",
    "proposals"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.baselineharmonization.register.v0.1"
    },
    "registerId": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "PROPOSAL_ONLY_NO_BASELINE_EDITS",
        "ACCEPTED_PENDING_PATCH",
        "ACCEPTED_APPLIED"
      ]
    },
    "activeBaselineEdited": {
      "type": "boolean"
    },
    "scope": {
      "type": "string"
    },
    "proposals": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://ofarm.example/schemas/OFARM_BaselineHarmonizationProposal_schema_v0_1.json",
        "title": "OFARM Baseline Harmonization Proposal",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "proposalId",
          "targetFile",
          "changeClass",
          "authorityEffect",
          "proposedInsertionLocation",
          "proposedText",
          "rationale",
          "affectedArtifacts",
          "sourceArtifacts",
          "requiresRuntimeEvidence",
          "status"
        ],
        "properties": {
          "proposalId": {
            "type": "string",
            "pattern": "^BHP-[0-9]{3}$"
          },
          "title": {
            "type": "string"
          },
          "targetFile": {
            "type": "string"
          },
          "changeClass": {
            "type": "string",
            "enum": [
              "baseline_clarification",
              "baseline_reference",
              "readiness_memo_update",
              "hostile_review_gate",
              "alignment_note"
            ]
          },
          "authorityEffect": {
            "type": "string",
            "enum": [
              "proposal_only_no_active_edit",
              "would_update_active_baseline_if_accepted"
            ]
          },
          "proposedInsertionLocation": {
            "type": "string"
          },
          "proposedText": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "affectedArtifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sourceArtifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requiresRuntimeEvidence": {
            "type": "boolean"
          },
          "runtimeEvidenceGateRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptanceCriteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "ready_for_review",
              "hold_until_runtime_evidence",
              "do_not_promote",
              "proposal_only"
            ]
          }
        }
      }
    }
  }
}
