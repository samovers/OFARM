{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/importcandidate/v0.1",
  "title": "OFARM ImportCandidate v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "importCandidateId",
    "sourceFidelityEnvelopeRef",
    "adapterRef",
    "candidateClass",
    "candidateStatus",
    "sourceRecordRefs",
    "proposedOfarmObjects",
    "unresolvedItems",
    "promotionPosture"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.importcandidate.v0.1"
    },
    "importCandidateId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sourceFidelityEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "adapterRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "candidateClass": {
      "enum": [
        "FMIS_SHADOW_IMPORT",
        "MACHINERY_TELEMETRY_IMPORT",
        "SENSOR_IMPORT",
        "WEATHER_IMPORT",
        "INVENTORY_IMPORT",
        "FINANCE_IMPORT",
        "MANUAL_IMPORT"
      ]
    },
    "candidateStatus": {
      "enum": [
        "CANDIDATE_ONLY",
        "DRAFT_READY",
        "REVIEW_REQUIRED",
        "REJECTED",
        "DUPLICATE_CANDIDATE",
        "PROMOTION_ELIGIBLE_AFTER_REVIEW"
      ]
    },
    "sourceRecordRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "proposedOfarmObjects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "proposedObjectRef",
          "proposedObjectClass",
          "truthPosture"
        ],
        "properties": {
          "proposedObjectRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "proposedObjectClass": {
            "type": "string"
          },
          "truthPosture": {
            "enum": [
              "CANDIDATE_ONLY",
              "CLAIM_ONLY",
              "EVIDENCE_REFERENCE_ONLY",
              "DRAFT_ASSERTION_ONLY"
            ]
          },
          "basisRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:/#-]+$"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "unresolvedItems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "itemClass",
          "reasonCode"
        ],
        "properties": {
          "itemClass": {
            "enum": [
              "IDENTITY",
              "UNIT",
              "TIME",
              "GEOMETRY",
              "PRODUCT",
              "ACTOR",
              "EVIDENCE",
              "QUANTITY",
              "OTHER"
            ]
          },
          "reasonCode": {
            "type": "string",
            "pattern": "^[A-Z0-9_:-]+$"
          },
          "sourcePath": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "promotionPosture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultCommitClass",
        "requiresReviewBeforeAcceptedTruth"
      ],
      "properties": {
        "defaultCommitClass": {
          "enum": [
            "DRAFT_ASSERTION",
            "OPERATION_CLAIM",
            "OBSERVATION_ASSERTION",
            "EVIDENCE_RECORD",
            "NONE"
          ]
        },
        "requiresReviewBeforeAcceptedTruth": {
          "type": "boolean"
        },
        "blockedUses": {
          "type": "array",
          "items": {
            "enum": [
              "COMPLIANCE_OUTPUT",
              "CURRENT_STATE_MATERIALIZATION",
              "INVENTORY_MUTATION",
              "PASSPORT_FREEZE",
              "NONE"
            ]
          }
        }
      }
    },
    "traceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
