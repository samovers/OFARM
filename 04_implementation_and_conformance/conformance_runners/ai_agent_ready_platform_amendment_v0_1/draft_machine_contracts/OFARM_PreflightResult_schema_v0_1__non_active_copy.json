{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/preflightresult/v0.1",
  "title": "OFARM PreflightResult v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "preflightId",
    "requestId",
    "decision",
    "executedAuthoritativeChange",
    "authorityPosture",
    "freshnessPosture",
    "evidencePosture",
    "identityPosture",
    "packPosture",
    "problems",
    "nextActions",
    "traceRefs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.preflightresult.v0.1"
    },
    "preflightId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "decision": {
      "enum": [
        "ALLOWED",
        "ALLOWED_WITH_WARNINGS",
        "HUMAN_APPROVAL_REQUIRED",
        "REVIEW_REQUIRED",
        "CANDIDATE_ONLY",
        "BLOCKED"
      ]
    },
    "executedAuthoritativeChange": {
      "const": false
    },
    "authorityPosture": {
      "enum": [
        "NOT_CHECKED",
        "ALLOWED",
        "DENIED",
        "HUMAN_APPROVAL_REQUIRED",
        "SCOPE_LIMITED"
      ]
    },
    "freshnessPosture": {
      "enum": [
        "NOT_APPLICABLE",
        "CURRENT",
        "STALE_INFORMATIONAL",
        "STALE_BLOCKING",
        "INVALIDATED"
      ]
    },
    "evidencePosture": {
      "enum": [
        "NOT_APPLICABLE",
        "SUFFICIENT",
        "INSUFFICIENT",
        "MISSING",
        "REDACTED",
        "REVIEW_REQUIRED"
      ]
    },
    "identityPosture": {
      "enum": [
        "NOT_APPLICABLE",
        "RESOLVED",
        "UNRESOLVED",
        "AMBIGUOUS",
        "REVIEW_REQUIRED"
      ]
    },
    "packPosture": {
      "enum": [
        "NOT_APPLICABLE",
        "RESOLVED",
        "CONFLICT",
        "GOVERNANCE_REQUIRED"
      ]
    },
    "calculationPosture": {
      "enum": [
        "NOT_APPLICABLE",
        "READY",
        "INCOMPLETE_BASIS",
        "UNIT_UNRESOLVED",
        "FORMULA_UNAVAILABLE"
      ]
    },
    "publicationPosture": {
      "enum": [
        "NOT_APPLICABLE",
        "DRAFT_READY",
        "FROZEN_READY",
        "BLOCKED",
        "ANNEX_REQUIRED"
      ]
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reasonCode",
          "severity",
          "title"
        ],
        "properties": {
          "reasonCode": {
            "type": "string",
            "pattern": "^[A-Z0-9_:-]+$"
          },
          "severity": {
            "enum": [
              "INFO",
              "WARNING",
              "ERROR"
            ]
          },
          "title": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "suggestedRemediation": {
            "type": "string"
          },
          "relatedTraceTypes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "actionId",
          "label",
          "actorClass"
        ],
        "properties": {
          "actionId": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "actorClass": {
            "enum": [
              "USER",
              "HUMAN_REVIEWER",
              "SYSTEM",
              "AI_AGENT",
              "PLATFORM_OPERATOR"
            ]
          },
          "operationRef": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "traceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
