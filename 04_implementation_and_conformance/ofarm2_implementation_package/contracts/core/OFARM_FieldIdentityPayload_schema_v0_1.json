{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/fieldidentitypayload/v0.1",
  "title": "OFARM FieldIdentityPayload v0.1 (candidate)",
  "$comment": "NEW_CANDIDATE structure-assertion payload for the Field durable identity (Constitution RC2.1 sections 7.19, 7.24). Parcel identifiers such as GERK are profile-governed scheme bindings with reference-snapshot support, never universal core law.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "fieldidentitypayloadId",
    "identityRecordRef",
    "recordedAt",
    "displayName",
    "parentFarmIdentityRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.fieldidentitypayload.v0.1"
    },
    "fieldidentitypayloadId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "identityRecordRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "parentFarmIdentityRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "parcelIdentifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scheme",
          "value"
        ],
        "properties": {
          "scheme": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "referenceSnapshotRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "declaredArea": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unitCode"
      ],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0
        },
        "unitCode": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "geometryEvidenceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    }
  }
}
