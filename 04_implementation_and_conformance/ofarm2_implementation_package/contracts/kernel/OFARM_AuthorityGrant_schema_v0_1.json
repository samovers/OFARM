{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/authoritygrant/v0.1",
  "title": "OFARM AuthorityGrant v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a77.13, authority companion policy \u00a74, and Authority Source Record Closure RFC v0.1 \u00a74.2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "authorityGrantId",
    "grantedByPartyRef",
    "grantTarget",
    "targetScope",
    "authorityActionClasses",
    "validFrom",
    "inheritanceMode",
    "grantState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.authoritygrant.v0.1"
    },
    "authorityGrantId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "grantedByPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "grantTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetKind",
        "targetRef"
      ],
      "properties": {
        "targetKind": {
          "enum": [
            "PARTY",
            "ROLE_ASSIGNMENT"
          ]
        },
        "targetRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "authorityFamilies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authorityActionClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "purpose": {
      "type": "string"
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "inheritanceMode": {
      "enum": [
        "EXACT_ONLY",
        "DESCENDANT_SCOPES",
        "DERIVED_LINEAGE_SCOPES",
        "NO_INHERIT"
      ]
    },
    "grantState": {
      "enum": [
        "ACTIVE",
        "REVOKED",
        "EXPIRED",
        "DRAFT"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
