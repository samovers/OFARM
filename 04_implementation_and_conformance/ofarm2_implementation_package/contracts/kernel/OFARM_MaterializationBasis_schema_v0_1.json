{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/materializationbasis/v0.1",
  "title": "OFARM MaterializationBasis v0.1",
  "$comment": "Minimal machine contract derived from Current State Materialization RFC v0.1 \u00a74, Platform RC2.1 \u00a74.3, and Source Truth Record Closure RFC v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "basisId",
    "twin",
    "anchorScopes",
    "contextSnapshotRefs",
    "evaluationTimePolicy",
    "contributingAssertionRefs",
    "contributingAcceptedConsequenceRefs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.materializationbasis.v0.1"
    },
    "basisId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "anchorScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "contextSnapshotRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "evaluationTimePolicy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyType"
          ],
          "properties": {
            "policyType": {
              "const": "NOW"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyType",
            "asOfTime"
          ],
          "properties": {
            "policyType": {
              "const": "AS_OF"
            },
            "asOfTime": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyType",
            "windowStart",
            "windowEnd"
          ],
          "properties": {
            "policyType": {
              "const": "WINDOW"
            },
            "windowStart": {
              "type": "string",
              "format": "date-time"
            },
            "windowEnd": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      ]
    },
    "contributingAssertionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "contributingAcceptedConsequenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "contributingReviewDecisionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "identityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    }
  }
}
