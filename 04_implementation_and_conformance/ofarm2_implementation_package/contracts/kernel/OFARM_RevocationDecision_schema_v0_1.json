{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/revocationdecision/v0.1",
  "title": "OFARM RevocationDecision v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a77.17, authority companion policy \u00a78, and Authority Source Record Closure RFC v0.1 \u00a74.5.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "revocationDecisionId",
    "revokesArtifactFamily",
    "revokesArtifactRef",
    "decidedByPartyRef",
    "decidedAt",
    "effectiveFrom",
    "revocationMode",
    "targetScope"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.revocationdecision.v0.1"
    },
    "revocationDecisionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "revokesArtifactFamily": {
      "enum": [
        "AUTHORITY_GRANT",
        "DELEGATION_GRANT",
        "SHARING_GRANT"
      ]
    },
    "revokesArtifactRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "decidedByPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "decidedAt": {
      "type": "string",
      "format": "date-time"
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date-time"
    },
    "revocationMode": {
      "enum": [
        "TERMINATE",
        "NARROW_SCOPE",
        "NARROW_ACTIONS",
        "NARROW_TIME"
      ]
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "affectedActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "replacementGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
