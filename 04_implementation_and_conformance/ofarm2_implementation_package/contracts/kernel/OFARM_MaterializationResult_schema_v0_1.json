{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/materializationresult/v0.1",
  "title": "OFARM MaterializationResult v0.1",
  "$comment": "Minimal boundary result envelope for current-state use evaluation derived from Platform RC2.1 \u00a7\u00a74.5-4.7.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "resultId",
    "requestId",
    "evaluatedAt",
    "decisionOutcome",
    "targetTwin",
    "anchorScopes",
    "requiredFreshness",
    "highConsequenceUse",
    "freshnessState",
    "satisfiedFreshnessRequirement",
    "materializationBasisRef",
    "materializationSnapshotRef",
    "contextSnapshotRef",
    "invalidationTriggerFamilies",
    "problems",
    "reasonSummary"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.materializationresult.v0.1"
    },
    "resultId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "decisionOutcome": {
      "enum": [
        "ALLOW_REUSE",
        "RECOMPUTE_REQUIRED",
        "REQUIRE_REVIEW",
        "REFUSE_USE"
      ]
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "anchorScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "requiredFreshness": {
      "enum": [
        "REQUIRE_FRESH",
        "ALLOW_STALE_EXPLORATORY",
        "NO_CURRENT_STATE_DEPENDENCY"
      ]
    },
    "highConsequenceUse": {
      "type": "boolean"
    },
    "freshnessState": {
      "enum": [
        "FRESH",
        "STALE",
        "INVALID"
      ]
    },
    "satisfiedFreshnessRequirement": {
      "type": "boolean"
    },
    "materializationBasisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "materializationSnapshotRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "contextSnapshotRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "invalidationTriggerFamilies": {
      "type": "array",
      "items": {
        "enum": [
          "TRUTH_BASIS",
          "IDENTITY_LIFECYCLE",
          "CONTEXT",
          "TIME_POLICY",
          "TWIN_SPECIFIC"
        ]
      }
    },
    "reasonSummary": {
      "type": "string"
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "problemId",
          "severity",
          "reasonCode",
          "title",
          "detail"
        ],
        "properties": {
          "schemaVersion": {
            "const": "ofarm.runtimeproblem.v0.1"
          },
          "problemId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "severity": {
            "enum": [
              "INFO",
              "WARNING",
              "ERROR"
            ]
          },
          "reasonCode": {
            "type": "string",
            "pattern": "^[A-Z0-9_:-]+$"
          },
          "title": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "pointerRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relatedRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "suggestedRemediation": {
            "type": "string"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decisionOutcome": {
            "const": "ALLOW_REUSE"
          }
        }
      },
      "then": {
        "properties": {
          "satisfiedFreshnessRequirement": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "freshnessState": {
            "const": "INVALID"
          }
        }
      },
      "then": {
        "properties": {
          "decisionOutcome": {
            "enum": [
              "RECOMPUTE_REQUIRED",
              "REQUIRE_REVIEW",
              "REFUSE_USE"
            ]
          },
          "satisfiedFreshnessRequirement": {
            "const": false
          }
        }
      }
    }
  ]
}
