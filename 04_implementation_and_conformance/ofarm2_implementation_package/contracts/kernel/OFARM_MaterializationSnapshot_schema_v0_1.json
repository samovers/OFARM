{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/materializationsnapshot/v0.1",
  "title": "OFARM MaterializationSnapshot v0.1",
  "$comment": "Minimal machine contract derived from Current State Materialization RFC v0.1 \u00a75 and Platform RC2.1 \u00a74.4 / \u00a710.5.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "snapshotId",
    "generatedAt",
    "twin",
    "anchorScopes",
    "materializationBasisRef",
    "freshnessState",
    "retentionReason",
    "materializedStateRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.materializationsnapshot.v0.1"
    },
    "snapshotId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "anchorScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "materializationBasisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "freshnessState": {
      "enum": [
        "FRESH",
        "STALE",
        "INVALID"
      ]
    },
    "declaredUseClass": {
      "enum": [
        "EXPLORATORY",
        "HIGH_CONSEQUENCE",
        "ATTESTED_OUTPUT",
        "AUDIT_EXPLANATION"
      ]
    },
    "retentionReason": {
      "type": "string"
    },
    "materializedStateRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    }
  }
}
