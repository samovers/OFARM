{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/packactivationset/v0.1",
  "title": "OFARM PackActivationSet v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a76.3-6.15 and Platform RC2.1 \u00a713.6-13.11. This contract realizes the already-governed PackActivationSet concept without reopening pack law.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packActivationSetId",
    "evaluatedAt",
    "targetScope",
    "timeContext",
    "requestedPackRefs",
    "activePackRefs",
    "activeProfileRefs",
    "relevantPrecedenceClasses"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.packactivationset.v0.1"
    },
    "packActivationSetId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "timeContext": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyType"
          ],
          "properties": {
            "policyType": {
              "const": "NOW"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyType",
            "asOfTime"
          ],
          "properties": {
            "policyType": {
              "const": "AS_OF"
            },
            "asOfTime": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyType",
            "windowStart",
            "windowEnd"
          ],
          "properties": {
            "policyType": {
              "const": "WINDOW"
            },
            "windowStart": {
              "type": "string",
              "format": "date-time"
            },
            "windowEnd": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      ]
    },
    "requestedPackRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "requestedProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "activePackRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "activeProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "activeScopedExtensionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "relevantPrecedenceClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "JURISDICTION_LAW_SAFETY",
          "CERTIFICATION_CLAIM_CONTRACT",
          "CROP_SYSTEM_BIOPHYSICAL",
          "TOOLING_METHOD",
          "LOCAL_COMMUNITY_PREFERENCE"
        ]
      }
    },
    "declaredCompatibilityRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "declaredMergePolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
