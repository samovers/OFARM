{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/capabilitymanifest/v0.1",
  "title": "OFARM Capability Manifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestId",
    "ofarmVersion",
    "platformVersion",
    "publishedAt",
    "deploymentScope",
    "capabilitySections",
    "registryRelation",
    "conformance"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.capabilitymanifest.v0.1"
    },
    "manifestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED",
        "RETIRED"
      ]
    },
    "ofarmVersion": {
      "type": "string"
    },
    "platformVersion": {
      "type": "string"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "supersedesManifestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "deploymentScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "capabilitySections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactSupport",
        "packSupport",
        "querySupport",
        "eventSupport",
        "authoritySupport",
        "importExportSupport",
        "enforcementSupport"
      ],
      "properties": {
        "artifactSupport": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "supportedArtifactTypes"
          ],
          "properties": {
            "supportedArtifactTypes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          }
        },
        "packSupport": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "supportsPackActivation",
            "supportedPrecedenceClasses",
            "supportedSurfaceFamilies"
          ],
          "properties": {
            "supportsPackActivation": {
              "type": "boolean"
            },
            "activePackRefs": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._:-]+$"
              }
            },
            "activeProfileRefs": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._:-]+$"
              }
            },
            "supportedPrecedenceClasses": {
              "type": "array",
              "items": {
                "enum": [
                  "JURISDICTION_LAW_SAFETY",
                  "CERTIFICATION_CLAIM_CONTRACT",
                  "CROP_SYSTEM_BIOPHYSICAL",
                  "TOOLING_METHOD",
                  "LOCAL_COMMUNITY_PREFERENCE"
                ]
              }
            },
            "supportedSurfaceFamilies": {
              "type": "array",
              "items": {
                "enum": [
                  "VOCABULARY_BINDINGS",
                  "EVIDENCE_POLICY",
                  "ARCHETYPE_DEFINITION",
                  "TEMPLATE_CONSTRAINT",
                  "VALIDATION_RULE",
                  "DECISION_RULE",
                  "EVENT_SUBTYPE_DEFINITION",
                  "VIEW_SHAPING",
                  "DOCUMENT_ASSEMBLY_SHAPING"
                ]
              }
            }
          }
        },
        "querySupport": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "querySpecificationSchemaRef",
            "queryPlanSchemaRef",
            "supportsGuidedQueryUI",
            "supportsAIMediatedQuery",
            "supportsPublicExpertQuery",
            "supportedResultModes"
          ],
          "properties": {
            "querySpecificationSchemaRef": {
              "type": "string"
            },
            "queryPlanSchemaRef": {
              "type": "string"
            },
            "supportsGuidedQueryUI": {
              "type": "boolean"
            },
            "supportsAIMediatedQuery": {
              "type": "boolean"
            },
            "supportsPublicExpertQuery": {
              "type": "boolean"
            },
            "supportedResultModes": {
              "type": "array",
              "items": {
                "enum": [
                  "RAW_BINDINGS",
                  "OBJECT_GRAPH",
                  "SUMMARY_ROWS",
                  "VIEW_MODULE",
                  "PASSPORT_VIEW",
                  "DOCUMENT_ASSEMBLY_INPUT"
                ]
              }
            }
          }
        },
        "eventSupport": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "supportedEventFamilies",
            "supportedCommitClasses"
          ],
          "properties": {
            "supportedEventFamilies": {
              "type": "array",
              "items": {
                "enum": [
                  "StructureEvent",
                  "ObservationEvent",
                  "OccurrenceEvent",
                  "InterventionEvent",
                  "MaterialEvent",
                  "EvidenceEvent",
                  "GovernanceEvent"
                ]
              }
            },
            "supportedCommitClasses": {
              "type": "array",
              "items": {
                "enum": [
                  "note",
                  "observation assertion",
                  "hypothesis assertion",
                  "structure assertion",
                  "operation claim",
                  "evidence record",
                  "compliance assertion",
                  "governance decision",
                  "advisory output"
                ]
              }
            }
          }
        },
        "authoritySupport": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "supportedAuthorityFamilies",
            "supportedActionClasses",
            "supportsHumanOnlyRestrictions"
          ],
          "properties": {
            "supportedAuthorityFamilies": {
              "type": "array",
              "items": {
                "enum": [
                  "observe/report",
                  "assert/submit",
                  "operate/intervene",
                  "review",
                  "govern/decide",
                  "attest/sign",
                  "context-governance",
                  "share/revoke",
                  "receive/use"
                ]
              }
            },
            "supportedActionClasses": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "supportsHumanOnlyRestrictions": {
              "type": "boolean"
            }
          }
        },
        "importExportSupport": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "declaredSurfaces"
          ],
          "properties": {
            "declaredSurfaces": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "surfaceType",
                  "targetRef",
                  "direction",
                  "status"
                ],
                "properties": {
                  "surfaceType": {
                    "enum": [
                      "IMPORT_MAPPING",
                      "EXPORT_MAPPING",
                      "API_CONTRACT",
                      "EVENT_EXPORT"
                    ]
                  },
                  "targetRef": {
                    "type": "string"
                  },
                  "direction": {
                    "enum": [
                      "IMPORT",
                      "EXPORT",
                      "BIDIRECTIONAL"
                    ]
                  },
                  "status": {
                    "enum": [
                      "SUPPORTED",
                      "PARTIAL",
                      "PLANNED"
                    ]
                  }
                }
              }
            }
          }
        },
        "enforcementSupport": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "supportedGates",
            "supportsMergeResolutionTrace",
            "supportsAuthorizationDecisionTrace",
            "supportsProjectionTraceBack",
            "supportsFreshnessEvaluation"
          ],
          "properties": {
            "supportedGates": {
              "type": "array",
              "items": {
                "enum": [
                  "INGRESS_NORMALIZATION",
                  "AUTHORITY",
                  "VALIDATION",
                  "PACK_APPLICABILITY",
                  "EVIDENCE_SUFFICIENCY",
                  "REVIEW_PROMOTION",
                  "CURRENT_STATE_MATERIALIZATION",
                  "PUBLICATION_EXPORT"
                ]
              }
            },
            "supportsMergeResolutionTrace": {
              "type": "boolean"
            },
            "supportsAuthorizationDecisionTrace": {
              "type": "boolean"
            },
            "supportsProjectionTraceBack": {
              "type": "boolean"
            },
            "supportsFreshnessEvaluation": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "registryRelation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifestRegistryRef",
        "artifactRegistryRef",
        "activeArtifactSetRef",
        "discoveryVisibility"
      ],
      "properties": {
        "manifestRegistryRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "artifactRegistryRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "activeArtifactSetRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "discoveryVisibility": {
          "enum": [
            "PRIVATE",
            "RESTRICTED",
            "PUBLIC"
          ]
        }
      }
    },
    "conformance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimumConformanceLevel"
      ],
      "properties": {
        "minimumConformanceLevel": {
          "enum": [
            "NONE",
            "BASELINE",
            "EXTENDED"
          ]
        },
        "testSuiteRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "declaredProfileRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    }
  },
  "$comment": "Authority family values in capability manifests use slash form. See OFARM_Authority_Family_Normalization_Map_v0_1.json for normalization against underscore-form enums used elsewhere in the package."
}
