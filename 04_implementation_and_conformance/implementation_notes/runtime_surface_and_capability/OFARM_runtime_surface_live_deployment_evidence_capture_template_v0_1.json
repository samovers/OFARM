{
  "templateVersion": "ofarm.runtimesurface.liveevidence.capture.v0.1.impl",
  "templateId": "template:runtimesurface-live-deployment-evidence:v0.1",
  "templateOnly": true,
  "qualifiesAsLiveDeploymentEvidence": false,
  "evidenceClass": "LIVE_DEPLOYMENT_RUNTIME_SURFACE_EVIDENCE_CAPTURE_TEMPLATE",
  "releaseBundleRef": "replace-with-release-bundle-id",
  "releaseLabel": "replace-with-release-label",
  "manifestRef": "replace-with-manifest-id",
  "activeArtifactSetRef": "replace-with-active-artifact-set-id",
  "conformanceClaimSetRef": "replace-with-claimset-id",
  "deploymentScope": {
    "scopeType": "DEPLOYMENT",
    "scopeRef": "replace-with-deployment-id"
  },
  "surfaceContractRef": "replace-with-surface-contract-ref",
  "surfaceIdentityRef": "replace-with-surface-identity-ref",
  "serviceDescriptionRefs": [
    "replace-with-service-description-ref"
  ],
  "observationWindow": {
    "startedAt": "YYYY-MM-DDThh:mm:ssZ",
    "endedAt": "YYYY-MM-DDThh:mm:ssZ"
  },
  "collector": {
    "collectorType": "SYSTEM_OR_OPERATOR",
    "collectorRef": "replace-with-principal-or-system-ref"
  },
  "observedBinding": {
    "bindingKind": "replace-with-binding-kind",
    "bindingValue": "replace-with-runtime-binding"
  },
  "deploymentEvidenceRefs": [
    "replace-with-deployment-emitted-log-or-audit-ref"
  ],
  "validationNotes": [
    "replace-with-proof-that-the-observed-binding-matches-the-governed-release-lane"
  ],
  "notes": "Template only. Copy to a deployment-specific filename only when real deployment evidence exists."
}
