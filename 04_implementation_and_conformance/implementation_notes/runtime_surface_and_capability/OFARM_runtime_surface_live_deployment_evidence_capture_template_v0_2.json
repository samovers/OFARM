  },
  "deploymentEvidenceRefs": [
    "replace-with-deployment-emitted-log-or-audit-ref"
  ],
  "authenticityEnvelope": {
    "captureMode": "LIVE_DEPLOYMENT_OPERATOR_CAPTURE_OR_SYSTEM_EXPORT",
    "artifactOriginClass": "OPERATOR_CAPTURE_OR_DEPLOYMENT_CONTROLLED_EXPORT",
    "repositoryAuthored": false,
    "redactionApplied": true,
    "redactionMethod": "CONTROLLED_ALIAS_OR_BINDING_HASH_OR_MINIMAL_DISCLOSURE",
    "redactionJustification": "replace-with-redaction-justification-or-NONE",
    "sealedMappingHeldOutsidePackage": true,
    "attestedByRef": "replace-with-operator-or-system-principal-ref",
