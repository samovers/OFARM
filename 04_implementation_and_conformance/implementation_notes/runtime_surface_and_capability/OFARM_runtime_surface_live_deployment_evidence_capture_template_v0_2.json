{
  "templateVersion": "ofarm.runtimesurface.liveevidence.capture.v0.2.impl",
  "templateId": "template:runtimesurface-live-deployment-evidence:v0.2",
  "templateOnly": true,
  "qualifiesAsLiveDeploymentEvidence": false,
  "evidenceClass": "LIVE_DEPLOYMENT_RUNTIME_SURFACE_EVIDENCE_CAPTURE_TEMPLATE",
  "releaseBundleRef": "replace-with-release-bundle-id",
