  "negativeLabelRules": [
    {
      "ruleId": "label-rule:no-claim-as-done",
      "unsafePattern": "operation claim labeled as completed/done/verified",
      "whyUnsafe": "A claim has not crossed evidence, authority, and promotion gates.",
      "requiredReplacement": "Submitted work record"
    },
    {
      "ruleId": "label-rule:no-advisory-as-approved",
      "unsafePattern": "recommendation labeled approved/compliant/prescribed",
      "whyUnsafe": "Advisory outputs do not create authority or compliance truth.",
      "requiredReplacement": "Suggested action"
    },
    {
      "ruleId": "label-rule:no-materialization-as-truth",
      "unsafePattern": "current-state materialization labeled source of truth",
      "whyUnsafe": "Materializations are governed derivatives and must carry freshness/basis.",
      "requiredReplacement": "Current status view with freshness and basis"
    },
    {
      "ruleId": "label-rule:no-permission-null",
      "unsafePattern": "permission-limited result rendered as no data exists",
      "whyUnsafe": "Redaction and authority limits are not absence of records.",
      "requiredReplacement": "Restricted details / access required"
    },
    {
      "ruleId": "label-rule:no-passport-bucket",
      "unsafePattern": "every compiled output labeled passport",
      "whyUnsafe": "PassportView and DocumentAssembly have different authority, freeze, and purpose semantics.",
      "requiredReplacement": "Passport preview, report assembly, dossier assembly, or submission assembly as appropriate"
    }
  ],
  "requiredInvariants": [
    "recommendation is not prescription",
    "prescription is not execution",
    "planned intervention/work order is not actual operation",
    "operation claim is not accepted execution",
    "evidence is not accepted consequence",
    "correction is a new historical assertion, not an edit path",
    "dispute remains visible and blocks or annexes high-consequence output until governed resolution",
    "current-state materialization is not canonical truth",
    "PassportView is not the universal compiled-output bucket",
    "permission-limited data must not be fabricated or over-disclosed"
  ],
  "acceptanceChecks": [
    "Each state row has at least one safe app label and at least one forbidden label where state collapse is plausible.",
    "Every claim/evidence/import state forbids being displayed as accepted execution or compliance fact.",
    "Every output state distinguishes preview/frozen/submission posture.",
    "Every current-state row carries freshness/basis display requirements.",
    "Every permission-limited row prevents null-as-absence rendering."
  ],
  "notes": "Candidate implementation-facing matrix for AI-built client apps. It does not create new OFARM law and must be promoted before becoming active companion artifact."
}
