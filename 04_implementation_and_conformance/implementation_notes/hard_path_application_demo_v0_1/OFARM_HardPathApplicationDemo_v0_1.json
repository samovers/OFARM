{
  "schemaVersion": "ofarm.appdemoscenario.v0.1",
  "scenarioId": "ofarm.app_demo.hard_path.offline_dispute.v0.1",
  "title": "Hard path: delayed contractor sync, revocation, partial failure, dispute, correction, and blocked output",
  "scenarioClass": "HARD_PATH",
  "authorityPosture": "CANDIDATE_APP_DEMO",
  "purpose": "Provide a negative/stress workflow that catches unsafe AI shortcuts in offline, correction, dispute, and output behavior.",
  "sourceRecipeRefs": [
    "workflowcase:delayed-contractor-sync:v1",
    "workflowcase:correction-dispute:v1",
    "workflowcase:audit-query-output:v1"
  ],
  "steps": [
    {
      "stepOrder": 1,
      "stepId": "hard:1",
      "actor": "contractor",
      "appAction": "Capture local execution draft offline.",
      "publicOperationRef": "local.outbox.capture",
      "canonicalStateBefore": [
        "work order"
      ],
      "canonicalStateAfter": [
        "offline local draft"
      ],
      "safeLabel": "Offline draft saved",
      "traceRefs": [],
      "mustNotInfer": [
        "offline draft is accepted truth"
      ]
    },
    {
      "stepOrder": 2,
      "stepId": "hard:2",
      "actor": "platform",
      "appAction": "Delegation is revoked and field geometry changes before sync.",
      "publicOperationRef": "platform.governance.change",
      "canonicalStateBefore": [
        "work order",
        "offline local draft"
      ],
      "canonicalStateAfter": [
        "revoked delegation",
        "successor field geometry"
      ],
      "safeLabel": "Authority/scope changed",
      "traceRefs": [
        "trace:authority:revocation:v1",
        "trace:identity:field-split:v1"
      ],
      "mustNotInfer": [
        "old scope remains current"
      ]
    },
    {
      "stepOrder": 3,
      "stepId": "hard:3",
      "actor": "contractor",
      "appAction": "Sync offline draft with idempotency key.",
      "publicOperationRef": "commits.submit",
      "canonicalStateBefore": [
        "offline local draft",
        "revoked delegation"
      ],
      "canonicalStateAfter": [
        "operation claim"
      ],
      "safeLabel": "Submitted synced work record",
      "traceRefs": [
        "trace:commit-ingress:offline-sync:v1"
      ],
      "mustNotInfer": [
        "synced claim accepted"
      ],
      "runtimeProblemRefs": [
        "AUTHORITY_DENIED",
        "MATERIALIZATION_INVALID"
      ]
    },
    {
      "stepOrder": 4,
      "stepId": "hard:4",
      "actor": "platform",
      "appAction": "Promotion requires review because authority/scope changed.",
      "publicOperationRef": "platform.promotion.review",
      "canonicalStateBefore": [
        "operation claim"
      ],
      "canonicalStateAfter": [
        "review-required operation claim"
      ],
      "safeLabel": "Review required",
      "traceRefs": [
        "trace:promotion:offline-sync:v1"
      ],
      "mustNotInfer": [
        "review-required means completed"
      ],
      "runtimeProblemRefs": [
        "HUMAN_APPROVAL_REQUIRED"
      ]
    },
    {
      "stepOrder": 5,
      "stepId": "hard:5",
      "actor": "farm_manager",
      "appAction": "Open dispute and submit correction with counter-evidence.",
      "publicOperationRef": "disputes.submit",
      "canonicalStateBefore": [
        "review-required operation claim"
      ],
      "canonicalStateAfter": [
        "open dispute",
        "correction assertion"
      ],
      "safeLabel": "Under dispute",
      "traceRefs": [
        "trace:dispute:field7:v1",
        "trace:correction:field7:v1"
      ],
      "mustNotInfer": [
        "dispute hidden from output"
      ]
    },
    {
      "stepOrder": 6,
      "stepId": "hard:6",
      "actor": "platform",
      "appAction": "Invalidate or block old current-state materialization.",
      "publicOperationRef": "materializations.get",
      "canonicalStateBefore": [
        "open dispute",
        "successor field geometry"
      ],
      "canonicalStateAfter": [
        "current-state materialization invalidated"
      ],
      "safeLabel": "Current status needs refresh",
      "traceRefs": [
        "trace:materialization:field7:invalidated:v1"
      ],
      "mustNotInfer": [
        "stale view can drive compliance"
      ],
      "runtimeProblemRefs": [
        "MATERIALIZATION_INVALID"
      ]
    },
    {
      "stepOrder": 7,
      "stepId": "hard:7",
      "actor": "inspector",
      "appAction": "Preview compliance dossier with dispute/correction annex; filing is blocked until basis is resolved.",
      "publicOperationRef": "assemblies.dryRun",
      "canonicalStateBefore": [
        "open dispute",
        "current-state materialization invalidated"
      ],
      "canonicalStateAfter": [
        "DocumentAssembly preview"
      ],
      "safeLabel": "Document preview — blocked",
      "traceRefs": [
        "trace:publication:dossier:field7:blocked:v1"
      ],
      "mustNotInfer": [
        "preview is filed submission"
      ],
      "runtimeProblemRefs": [
        "DISPUTE_OPEN",
        "MATERIALIZATION_INVALID"
      ]
    }
  ],
  "expectedOutcomes": [
    "Offline draft and synced claim are preserved but not accepted truth.",
    "Revocation and geometry change force review or refusal.",
    "Materialization is invalidated or blocked for high-consequence output.",
    "Dispute/correction lineage remains visible and can be annexed.",
    "DocumentAssembly preview is blocked or requires annex; it is not filed automatically."
  ],
  "blockedShortcuts": [
    "accept offline draft",
    "ignore revocation at sync",
    "last-write-wins geometry change",
    "hide dispute",
    "file stale dossier",
    "duplicate retry as new fact"
  ],
  "conformanceChecks": [
    "Idempotency key prevents duplicate accepted facts.",
    "Authority is rechecked at sync/promotion.",
    "Current-state materialization is invalidated or blocked.",
    "Output preview exposes dispute and materialization problems."
  ]
}
