+-+        'promotionReadinessFile': PROMOTION_OUT.name,
+-+        'summary': {
+-+            'successRuns': len(success_results),
+-+            'blockedRuns': len(blocked_results),
+-+            'partnerCoverageRecords': len(coverage_records),
+-+            'validatedExamples': len(validations),
