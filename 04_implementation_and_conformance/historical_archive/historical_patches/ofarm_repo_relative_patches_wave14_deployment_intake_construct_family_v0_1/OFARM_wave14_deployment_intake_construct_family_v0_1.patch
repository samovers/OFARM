+-            'linkedExecutorBlockedRunIds': pair.get('linkedExecutorBlockedRunIds', []),
+-            'linkedDeploymentSampleRunIds': pair.get('linkedDeploymentSampleRunIds', []),
+-            'linkedPartnerCoverageRecordId': pair.get('linkedPartnerCoverageRecordId'),
