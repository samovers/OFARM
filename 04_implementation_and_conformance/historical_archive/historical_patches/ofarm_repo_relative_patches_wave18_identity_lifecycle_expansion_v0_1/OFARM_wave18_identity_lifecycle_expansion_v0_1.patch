+            events.append({
+                "eventId": f"evt:{base}:{idx}",
+                "scenarioId": inv["sourceScenarioId"],
+                "triggerId": inv["triggerId"],
+                "eventKind": kind,
+                "subjectClass": "CurrentStateMaterialization",
+                "scopeRef": inv["affectedMaterializationRef"],
+            })
+    return events
