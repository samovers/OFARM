{
  "asyncapi": "3.0.0",
  "info": {
    "title": "OFARM Runtime Events Candidate Phase 7",
    "version": "0.1.0-phase7-draft",
    "description": "Candidate AsyncAPI event contract for AI-agent-ready OFARM runtime notifications. Events are notifications and traces, not canonical truth stores."
  },
  "servers": {
    "runtimeEventBus": {
      "host": "events.example.ofarm.invalid",
      "protocol": "amqp",
      "description": "Placeholder broker."
    }
  },
  "channels": {
    "commit.status.changed": {
      "address": "ofarm.commit.status.changed",
      "messages": {
        "commitStatusChanged": {
          "$ref": "#/components/messages/CommitStatusChanged"
        }
      }
    },
    "query.completed": {
      "address": "ofarm.query.completed",
      "messages": {
        "queryCompleted": {
          "$ref": "#/components/messages/QueryCompleted"
        }
      }
    },
    "materialization.invalidated": {
      "address": "ofarm.materialization.invalidated",
      "messages": {
        "materializationInvalidated": {
          "$ref": "#/components/messages/MaterializationInvalidated"
        }
      }
    },
    "output.assembly.completed": {
      "address": "ofarm.output.assembly.completed",
      "messages": {
        "outputAssemblyCompleted": {
          "$ref": "#/components/messages/OutputAssemblyCompleted"
        }
      }
    },
    "import.candidate.received": {
      "address": "ofarm.import.candidate.received",
      "messages": {
        "importCandidateReceived": {
          "$ref": "#/components/messages/ImportCandidateReceived"
        }
      }
    },
    "sync.replay.completed": {
      "address": "ofarm.sync.replay.completed",
      "messages": {
        "syncReplayCompleted": {
          "$ref": "#/components/messages/SyncReplayCompleted"
        }
      }
    },
    "trace.available": {
      "address": "ofarm.trace.available",
      "messages": {
        "traceAvailable": {
          "$ref": "#/components/messages/TraceAvailable"
        }
      }
    },
    "capabilities.changed": {
      "address": "ofarm.capabilities.changed",
      "messages": {
        "capabilitiesChanged": {
          "$ref": "#/components/messages/CapabilitiesChanged"
        }
      }
    }
  },
  "operations": {
    "subscribeCommitStatusChanged": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/commit.status.changed"
      }
    },
    "subscribeQueryCompleted": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/query.completed"
      }
    },
    "subscribeMaterializationInvalidated": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/materialization.invalidated"
      }
    },
    "subscribeOutputAssemblyCompleted": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/output.assembly.completed"
      }
    },
    "subscribeImportCandidateReceived": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/import.candidate.received"
      }
    },
    "subscribeSyncReplayCompleted": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/sync.replay.completed"
      }
    },
    "subscribeTraceAvailable": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/trace.available"
      }
    },
    "subscribeCapabilitiesChanged": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/capabilities.changed"
      }
    }
  },
  "components": {
    "messages": {
      "CommitStatusChanged": {
        "name": "CommitStatusChanged",
        "title": "CommitStatus Changed",
        "payload": {
          "allOf": [
            {
              "$ref": "#/components/schemas/RuntimeEventEnvelope"
            },
            {
              "type": "object",
              "properties": {
                "eventType": {
                  "const": "commit.status.changed"
                }
              }
            }
          ]
        }
      },
      "QueryCompleted": {
        "name": "QueryCompleted",
        "title": "Query Completed",
        "payload": {
          "allOf": [
            {
              "$ref": "#/components/schemas/RuntimeEventEnvelope"
            },
            {
              "type": "object",
              "properties": {
                "eventType": {
                  "const": "query.completed"
                }
              }
            }
          ]
        }
      },
      "MaterializationInvalidated": {
        "name": "MaterializationInvalidated",
        "title": "MaterializationInvalidated",
        "payload": {
          "allOf": [
            {
              "$ref": "#/components/schemas/RuntimeEventEnvelope"
            },
            {
              "type": "object",
              "properties": {
                "eventType": {
                  "const": "materialization.invalidated"
                }
              }
            }
          ]
        }
      },
      "OutputAssemblyCompleted": {
        "name": "OutputAssemblyCompleted",
        "title": "OutputAssembly Completed",
        "payload": {
          "allOf": [
            {
              "$ref": "#/components/schemas/RuntimeEventEnvelope"
            },
            {
              "type": "object",
              "properties": {
                "eventType": {
                  "const": "output.assembly.completed"
                }
              }
            }
          ]
        }
      },
      "ImportCandidateReceived": {
        "name": "ImportCandidateReceived",
        "title": "ImportCandidate Received",
        "payload": {
          "allOf": [
            {
              "$ref": "#/components/schemas/RuntimeEventEnvelope"
            },
            {
              "type": "object",
              "properties": {
                "eventType": {
                  "const": "import.candidate.received"
                }
              }
            }
          ]
        }
      },
      "SyncReplayCompleted": {
        "name": "SyncReplayCompleted",
        "title": "SyncReplay Completed",
        "payload": {
          "allOf": [
            {
              "$ref": "#/components/schemas/RuntimeEventEnvelope"
            },
            {
              "type": "object",
              "properties": {
                "eventType": {
                  "const": "sync.replay.completed"
                }
              }
            }
          ]
        }
      },
      "TraceAvailable": {
        "name": "TraceAvailable",
        "title": "Trace Available",
        "payload": {
          "allOf": [
            {
              "$ref": "#/components/schemas/RuntimeEventEnvelope"
            },
            {
              "type": "object",
              "properties": {
                "eventType": {
                  "const": "trace.available"
                }
              }
            }
          ]
        }
      },
      "CapabilitiesChanged": {
        "name": "CapabilitiesChanged",
        "title": "Capabilities Changed",
        "payload": {
          "allOf": [
            {
              "$ref": "#/components/schemas/RuntimeEventEnvelope"
            },
            {
              "type": "object",
              "properties": {
                "eventType": {
                  "const": "capabilities.changed"
                }
              }
            }
          ]
        }
      }
    },
    "schemas": {
      "RuntimeEventEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "eventId",
          "eventType",
          "occurredAt",
          "qualification",
          "traceRef"
        ],
        "properties": {
          "schemaVersion": {
            "const": "ofarm.runtimeeventenvelope.v0.1"
          },
          "eventId": {
            "type": "string"
          },
          "eventType": {
            "type": "string"
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time"
          },
          "tenantRef": {
            "type": "string"
          },
          "actorRef": {
            "type": "string"
          },
          "resourceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "qualification": {
            "type": "object",
            "additionalProperties": true
          },
          "traceRef": {
            "type": "string"
          },
          "payload": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "x-ofarm-event-invariant": "Runtime events are notifications and trace hooks. They do not create accepted truth unless a governed commit/promotion path accepts a consequence-bearing record."
}
