    "/.well-known/ofarm-capabilities": {
      "get": {
        "operationId": "capabilities_get",
        "summary": "Get OFARM runtime capabilities",
        "x-ofarm-operation-id": "capabilities.get",
        "x-ofarm-candidate-public": true,
        "responses": {
          "200": {
            "description": "Result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeProblemReasonCodeRegistry"
                }
              }
            }
          },
          "400": {
            "description": "Runtime problem or validation failure"
          },
          "403": {
            "description": "Authority or permission failure"
          }
        }
      }
    },
