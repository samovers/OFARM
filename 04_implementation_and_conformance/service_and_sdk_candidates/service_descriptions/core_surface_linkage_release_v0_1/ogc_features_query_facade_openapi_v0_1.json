{
  "openapi": "3.1.0",
  "info": {
    "title": "OFARM OGC Features / CQL2 query facade",
    "version": "0.1.0-preview",
    "description": "PLANNED outward query facade. This document describes the intended HTTP shape for a future query translation surface. It must not be treated as a live callable interface until the manifest and discovery status move beyond PLANNED."
  },
  "x-ofarm-documentId": "openapi:ogc-features-query:v1",
  "x-ofarm-targetSurfaceRef": "surface:cql2-query-facade:v1",
  "x-ofarm-linkedContractRef": "surface-contract:cql2-query-facade:v0.2-draft",
  "x-ofarm-linkedManifestRef": "manifest:core-deployment:surface-linkage:v1",
  "x-ofarm-surfaceStatus": "PLANNED",
  "x-ofarm-releaseLabel": "core-surface-linkage-2026-04-19",
  "x-ofarm-semanticPreservationPosture": "LOSS_AWARE",
  "servers": [
    {
      "url": "https://api.example.test/query/cql2",
      "description": "Illustrative preview endpoint for the bounded release-traceability lane"
    }
  ],
  "paths": {
    "/query/cql2/collections/{collectionId}/items": {
      "get": {
        "operationId": "queryCollectionItems",
        "summary": "Query collection items using a translated CQL2 filter",
        "description": "Illustrative planned facade. The constitutional query substrate remains QuerySpecification and QueryPlanIR.",
        "parameters": [
          {
            "name": "collectionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Planned CQL2 filter expression translated into governed OFARM query planning."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Projected feature collection items",
            "content": {
              "application/geo+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "const": "FeatureCollection"
                    },
                    "features": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  },
                  "required": [
                    "type",
                    "features"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
