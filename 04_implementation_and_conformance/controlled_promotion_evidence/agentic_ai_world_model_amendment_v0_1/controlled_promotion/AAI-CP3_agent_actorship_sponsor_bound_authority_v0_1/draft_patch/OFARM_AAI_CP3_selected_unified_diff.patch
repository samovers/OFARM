+#!/usr/bin/env python3
+from __future__ import annotations
+import json
+from pathlib import Path
+try:
+    from jsonschema import Draft202012Validator
+except Exception as exc:
+    raise SystemExit(f'jsonschema required: {exc}')
+
+ROOT = Path(__file__).resolve().parents[5]
+PHASE = Path(__file__).resolve().parents[1]
+SCHEMAS = {
+    'ofarm.softwareagentprofile.v0.1': '03_machine_contracts/schemas/authority/OFARM_SoftwareAgentProfile_schema_v0_1.json',
+    'ofarm.agentinstance.v0.1': '03_machine_contracts/schemas/authority/OFARM_AgentInstance_schema_v0_1.json',
+    'ofarm.agentsponsorref.v0.1': '03_machine_contracts/schemas/authority/OFARM_AgentSponsorRef_schema_v0_1.json',
+    'ofarm.agentmodeltoolprofile.v0.1': '03_machine_contracts/schemas/authority/OFARM_AgentModelToolProfile_schema_v0_1.json',
+    'ofarm.agentauthorityenvelope.v0.1': '03_machine_contracts/schemas/authority/OFARM_AgentAuthorityEnvelope_schema_v0_1.json',
+    'ofarm.agentrevocationstate.v0.1': '03_machine_contracts/schemas/authority/OFARM_AgentRevocationState_schema_v0_1.json',
+    'ofarm.agentactorshipbinding.v0.1': '03_machine_contracts/schemas/authority/OFARM_AgentActorshipBinding_schema_v0_1.json',
+    'ofarm.agentauthorizationdecisiontrace.v0.1': '03_machine_contracts/schemas/authority/OFARM_AgentAuthorizationDecisionTrace_schema_v0_1.json'
+}
+EXAMPLE_DIR = ROOT / '04_implementation_and_conformance/examples_and_fixtures/examples/machine_contracts/authority'
+failures = []
+records = []
+validators = {}
+for version, rel in SCHEMAS.items():
+    schema = json.loads((ROOT / rel).read_text(encoding='utf-8'))
+    Draft202012Validator.check_schema(schema)
+    validators[version] = Draft202012Validator(schema)
+
+for path in sorted(EXAMPLE_DIR.glob('OFARM_*_example_*_v0_1.json')):
+    data = json.loads(path.read_text(encoding='utf-8'))
+    version = data.get('schemaVersion')
+    if version not in validators:
+        continue
+    errors = sorted(validators[version].iter_errors(data), key=lambda e: list(e.path))
+    if errors:
+        failures.append({'path': path.relative_to(ROOT).as_posix(), 'errors': [e.message for e in errors]})
+    records.append({'path': path.relative_to(ROOT).as_posix(), 'schemaVersion': version, 'status': 'FAIL' if errors else 'PASS'})
+
+# CP3 semantic guards on the negative/positive traces.
+trace_allow = json.loads((EXAMPLE_DIR/'OFARM_AgentAuthorizationDecisionTrace_example_agent_observation_allow_v0_1.json').read_text(encoding='utf-8'))
+trace_deny = json.loads((EXAMPLE_DIR/'OFARM_AgentAuthorizationDecisionTrace_example_agent_attestation_deny_v0_1.json').read_text(encoding='utf-8'))
+if trace_allow.get('decisionOutcome') != 'ALLOW':
+    failures.append({'path':'allow-trace','errors':['observation trace must allow']})
+if trace_allow.get('actionClassPosture') != 'ALLOWED_WITH_TRACE':
+    failures.append({'path':'allow-trace','errors':['observation trace must be ALLOWED_WITH_TRACE']})
+if trace_deny.get('decisionOutcome') != 'DENY':
+    failures.append({'path':'deny-trace','errors':['attestation trace must deny']})
+if trace_deny.get('actionClassPosture') != 'HUMAN_ONLY':
+    failures.append({'path':'deny-trace','errors':['attestation trace must be HUMAN_ONLY']})
+for label, trace in [('allow', trace_allow), ('deny', trace_deny)]:
+    if trace.get('noSilentDelegationEvaluated') is not True:
+        failures.append({'path':label,'errors':['noSilentDelegationEvaluated must be true']})
+    if trace.get('toolOrModelAuthorityRejected') is not True:
+        failures.append({'path':label,'errors':['toolOrModelAuthorityRejected must be true']})
+
+report = {
+    'schemaVersion':'ofarm.aaiCP3ConformanceValidationReport.v0.1',
+    'phase':'AAI-CP3',
+    'status': 'PASS' if not failures else 'FAIL',
+    'records': len(records),
+    'failures': failures,
+    'validatedSchemas': list(SCHEMAS.values())
+}
+out = PHASE / 'conformance' / 'validation_report.json'
+out.write_text(json.dumps(report, indent=2) + '\n', encoding='utf-8')
+print(json.dumps(report, indent=2))
+raise SystemExit(0 if not failures else 1)
