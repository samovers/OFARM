{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentruntrace/v0.1",
  "title": "OFARM AgentRunTrace v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentRunTraceId",
    "agentRunEnvelopeRef",
    "agentInstanceRef",
    "sponsorPartyRef",
    "startedAt",
    "finalDisposition",
    "traceCompleteness"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentruntrace.v0.1"
    },
    "agentRunTraceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "agentRunEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "agentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sponsorPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "modelToolProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "endedAt": {
      "type": "string",
      "format": "date-time"
    },
    "inputRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "querySpecificationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "queryPlanIRRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "contextSnapshotRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "materializationResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "packActivationSetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "uncertaintyStatements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "toolInvocationTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "generatedArtifactRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "outputDispositionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "blockedActionTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "preflightResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "humanApprovalRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "finalDisposition": {
      "enum": [
        "COMPLETED",
        "COMPLETED_WITH_WARNINGS",
        "BLOCKED",
        "STOPPED_REQUIRES_APPROVAL",
        "STOPPED_REQUIRES_RECHECK",
        "FAILED",
        "ABORTED"
      ]
    },
    "traceCompleteness": {
      "enum": [
        "COMPLETE_FOR_GOVERNANCE",
        "REDACTED_BY_POLICY",
        "INCOMPLETE_REQUIRES_REVIEW"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Draft governance trace for an agent run.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "actionClass": {
      "type": "string",
      "minLength": 1
    },
    "autonomyLevel": {
      "enum": [
        "READ_ONLY",
        "SUGGEST_ONLY",
        "DRAFT_ONLY",
        "PREFLIGHT_ONLY",
        "EXECUTE_WITH_APPROVAL",
        "EXECUTE_WITH_POLICY_AUTHORITY",
        "FORBIDDEN"
      ]
    },
    "outputDisposition": {
      "enum": [
        "EPHEMERAL_SCRATCH",
        "QUERY_PROPOSAL",
        "DRAFT_ARTIFACT",
        "CANDIDATE_EVIDENCE",
        "ADVISORY_OUTPUT",
        "HYPOTHESIS",
        "SCENARIO_RESULT",
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "OUTPUT_PREVIEW",
        "PERMISSION_LIMITED_ANSWER",
        "BLOCKED_ACTION",
        "NO_OUTPUT"
      ]
    },
    "freshnessPosture": {
      "enum": [
        "CURRENT_FOR_PURPOSE",
        "STALE_FOR_PURPOSE",
        "UNKNOWN",
        "REQUIRES_RECHECK",
        "NOT_APPLICABLE"
      ]
    },
    "decision": {
      "enum": [
        "ALLOWED",
        "ALLOWED_WITH_WARNINGS",
        "HUMAN_APPROVAL_REQUIRED",
        "REVIEW_REQUIRED",
        "CANDIDATE_ONLY",
        "BLOCKED",
        "DENIED"
      ]
    }
  }
}
