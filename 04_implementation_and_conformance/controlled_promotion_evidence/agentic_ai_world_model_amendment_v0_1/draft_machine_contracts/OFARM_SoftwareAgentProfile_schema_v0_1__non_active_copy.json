{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/softwareagentprofile/v0.1",
  "title": "OFARM SoftwareAgentProfile v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "softwareAgentProfileId",
    "agentClass",
    "intendedUses",
    "defaultAutonomyLevel",
    "humanOnlyDefaultsAcknowledged",
    "status"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.softwareagentprofile.v0.1"
    },
    "softwareAgentProfileId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "displayName": {
      "type": "string"
    },
    "agentClass": {
      "enum": [
        "CODING_AGENT",
        "RUNTIME_ASSISTANT_AGENT",
        "IMPORT_ADAPTER_AGENT",
        "ADVISORY_AGENT",
        "COMPLIANCE_SUPPORT_AGENT",
        "ORCHESTRATOR_AGENT",
        "EVIDENCE_STEWARD_AGENT",
        "CONTRACTOR_COORDINATION_AGENT",
        "LOT_STORAGE_AGENT",
        "SHARING_SOVEREIGNTY_AGENT",
        "LOCAL_MEMORY_AGENT",
        "WORLD_MODEL_AGENT"
      ]
    },
    "intendedUses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbiddenUses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "defaultAutonomyLevel": {
      "$ref": "#/$defs/autonomyLevel"
    },
    "allowedOutputDispositions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outputDisposition"
      }
    },
    "allowedTargetTwins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/twin"
      }
    },
    "requiresAgentRunEnvelope": {
      "type": "boolean"
    },
    "humanOnlyDefaultsAcknowledged": {
      "const": true
    },
    "status": {
      "enum": [
        "DRAFT",
        "APPROVED_FOR_TEST",
        "APPROVED_FOR_DEPLOYMENT",
        "SUSPENDED",
        "RETIRED"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Draft software-agent profile contract for agent actorship RFC.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "actionClass": {
      "type": "string",
      "minLength": 1
    },
    "autonomyLevel": {
      "enum": [
        "READ_ONLY",
        "SUGGEST_ONLY",
        "DRAFT_ONLY",
        "PREFLIGHT_ONLY",
        "EXECUTE_WITH_APPROVAL",
        "EXECUTE_WITH_POLICY_AUTHORITY",
        "FORBIDDEN"
      ]
    },
    "outputDisposition": {
      "enum": [
        "EPHEMERAL_SCRATCH",
        "QUERY_PROPOSAL",
        "DRAFT_ARTIFACT",
        "CANDIDATE_EVIDENCE",
        "ADVISORY_OUTPUT",
        "HYPOTHESIS",
        "SCENARIO_RESULT",
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "OUTPUT_PREVIEW",
        "PERMISSION_LIMITED_ANSWER",
        "BLOCKED_ACTION",
        "NO_OUTPUT"
      ]
    },
    "freshnessPosture": {
      "enum": [
        "CURRENT_FOR_PURPOSE",
        "STALE_FOR_PURPOSE",
        "UNKNOWN",
        "REQUIRES_RECHECK",
        "NOT_APPLICABLE"
      ]
    },
    "decision": {
      "enum": [
        "ALLOWED",
        "ALLOWED_WITH_WARNINGS",
        "HUMAN_APPROVAL_REQUIRED",
        "REVIEW_REQUIRED",
        "CANDIDATE_ONLY",
        "BLOCKED",
        "DENIED"
      ]
    }
  }
}
