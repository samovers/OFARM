{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentsupportsection/v0.1",
  "title": "OFARM AgentSupportSection v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "supportsAgents",
    "supportedAgentClasses",
    "supportedAutonomyLevels",
    "humanOnlyActionClasses",
    "preflightRequiredActionClasses",
    "supportedRunEnvelopeVersions",
    "supportedTraceVersions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentsupportsection.v0.1"
    },
    "supportsAgents": {
      "type": "boolean"
    },
    "supportedAgentClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedAutonomyLevels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/autonomyLevel"
      }
    },
    "maxAutonomyByActionClass": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/autonomyLevel"
      }
    },
    "humanOnlyActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "preflightRequiredActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "humanApprovalRequiredActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedRunEnvelopeVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedTraceVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedHandoffVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "agentToolManifestRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "offlineAgentSupport": {
      "enum": [
        "NONE",
        "DRAFT_CAPTURE_ONLY",
        "CANDIDATE_CAPTURE_WITH_SYNC_RECHECK",
        "LIMITED_WITH_PREAUTHORIZED_SCOPE"
      ]
    },
    "externalToolUsePolicy": {
      "enum": [
        "FORBIDDEN",
        "ALLOWLIST_ONLY",
        "ALLOWLIST_WITH_PREFLIGHT",
        "TENANT_CONFIGURED_ALLOWLIST"
      ]
    },
    "farmDataLearningPolicy": {
      "enum": [
        "NO_LEARNING",
        "TENANT_LOCAL_ONLY",
        "EXPLICIT_OPT_IN_ONLY",
        "CROSS_FARM_AGGREGATE_WITH_SOVEREIGNTY_CONTROLS"
      ]
    },
    "revocationHandling": {
      "enum": [
        "BLOCK_FINAL_WRITE",
        "ABORT_RUN",
        "RECHECK_BEFORE_PROMOTION",
        "NOT_SUPPORTED"
      ]
    },
    "traceRetentionPolicy": {
      "type": "string"
    },
    "permissionLimitedResultPolicy": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Draft Capability Manifest section for agent support.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "actionClass": {
      "type": "string",
      "minLength": 1
    },
    "autonomyLevel": {
      "enum": [
        "READ_ONLY",
        "SUGGEST_ONLY",
        "DRAFT_ONLY",
        "PREFLIGHT_ONLY",
        "EXECUTE_WITH_APPROVAL",
        "EXECUTE_WITH_POLICY_AUTHORITY",
        "FORBIDDEN"
      ]
    },
    "outputDisposition": {
      "enum": [
        "EPHEMERAL_SCRATCH",
        "QUERY_PROPOSAL",
        "DRAFT_ARTIFACT",
        "CANDIDATE_EVIDENCE",
        "ADVISORY_OUTPUT",
        "HYPOTHESIS",
        "SCENARIO_RESULT",
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "OUTPUT_PREVIEW",
        "PERMISSION_LIMITED_ANSWER",
        "BLOCKED_ACTION",
        "NO_OUTPUT"
      ]
    },
    "freshnessPosture": {
      "enum": [
        "CURRENT_FOR_PURPOSE",
        "STALE_FOR_PURPOSE",
        "UNKNOWN",
        "REQUIRES_RECHECK",
        "NOT_APPLICABLE"
      ]
    },
    "decision": {
      "enum": [
        "ALLOWED",
        "ALLOWED_WITH_WARNINGS",
        "HUMAN_APPROVAL_REQUIRED",
        "REVIEW_REQUIRED",
        "CANDIDATE_ONLY",
        "BLOCKED",
        "DENIED"
      ]
    }
  }
}
