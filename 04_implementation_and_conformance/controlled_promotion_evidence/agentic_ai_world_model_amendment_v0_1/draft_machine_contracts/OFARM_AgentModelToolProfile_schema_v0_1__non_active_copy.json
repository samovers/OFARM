{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentmodeltoolprofile/v0.1",
  "title": "OFARM AgentModelToolProfile v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentModelToolProfileId",
    "profileKind",
    "intendedUse",
    "approvalStatus"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentmodeltoolprofile.v0.1"
    },
    "agentModelToolProfileId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "profileKind": {
      "enum": [
        "MODEL",
        "TOOLCHAIN",
        "RUNTIME_SERVICE",
        "MIXED_STACK"
      ]
    },
    "vendorOrProvider": {
      "type": "string"
    },
    "modelOrToolName": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "intendedUse": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbiddenUse": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "inputClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approvalStatus": {
      "enum": [
        "UNREVIEWED",
        "APPROVED_FOR_ADVISORY",
        "APPROVED_FOR_DRAFTING",
        "APPROVED_FOR_PREFLIGHT",
        "APPROVED_FOR_EXECUTION_WITH_APPROVAL",
        "SUSPENDED",
        "RETIRED"
      ]
    },
    "evaluationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Draft model/tool profile contract for agent run traceability.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "actionClass": {
      "type": "string",
      "minLength": 1
    },
    "autonomyLevel": {
      "enum": [
        "READ_ONLY",
        "SUGGEST_ONLY",
        "DRAFT_ONLY",
        "PREFLIGHT_ONLY",
        "EXECUTE_WITH_APPROVAL",
        "EXECUTE_WITH_POLICY_AUTHORITY",
        "FORBIDDEN"
      ]
    },
    "outputDisposition": {
      "enum": [
        "EPHEMERAL_SCRATCH",
        "QUERY_PROPOSAL",
        "DRAFT_ARTIFACT",
        "CANDIDATE_EVIDENCE",
        "ADVISORY_OUTPUT",
        "HYPOTHESIS",
        "SCENARIO_RESULT",
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "OUTPUT_PREVIEW",
        "PERMISSION_LIMITED_ANSWER",
        "BLOCKED_ACTION",
        "NO_OUTPUT"
      ]
    },
    "freshnessPosture": {
      "enum": [
        "CURRENT_FOR_PURPOSE",
        "STALE_FOR_PURPOSE",
        "UNKNOWN",
        "REQUIRES_RECHECK",
        "NOT_APPLICABLE"
      ]
    },
    "decision": {
      "enum": [
        "ALLOWED",
        "ALLOWED_WITH_WARNINGS",
        "HUMAN_APPROVAL_REQUIRED",
        "REVIEW_REQUIRED",
        "CANDIDATE_ONLY",
        "BLOCKED",
        "DENIED"
      ]
    }
  }
}
