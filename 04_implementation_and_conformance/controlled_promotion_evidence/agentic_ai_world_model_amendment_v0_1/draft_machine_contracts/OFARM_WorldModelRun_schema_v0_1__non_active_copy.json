{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/worldmodelrun/v0.1",
  "title": "OFARM WorldModelRun v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelRunId",
    "objective",
    "targetTwin",
    "targetScopes",
    "advisoryOnly",
    "startedAt",
    "outputDisposition"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelrun.v0.1"
    },
    "worldModelRunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "agentRunEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "targetTwin": {
      "const": "ADVISORY"
    },
    "targetScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT",
              "PARTY",
              "DOCUMENT",
              "PACK",
              "QUERY",
              "WORLD_MODEL",
              "SCENARIO"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "advisoryOnly": {
      "const": true
    },
    "inputRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "querySpecificationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "contextSnapshotRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "materializationResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "packActivationSetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "modelMethodRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "assumptionSetRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "uncertaintyStatementRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "staleInputMarkers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missingEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "competingInterpretations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "worldModelStateRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scenarioSpecRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "scenarioResultSetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "bridgeCandidateRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "invalidationRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "endedAt": {
      "type": "string",
      "format": "date-time"
    },
    "outputDisposition": {
      "$ref": "#/$defs/outputDisposition"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Draft advisory-only world-model run contract.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "actionClass": {
      "type": "string",
      "minLength": 1
    },
    "autonomyLevel": {
      "enum": [
        "READ_ONLY",
        "SUGGEST_ONLY",
        "DRAFT_ONLY",
        "PREFLIGHT_ONLY",
        "EXECUTE_WITH_APPROVAL",
        "EXECUTE_WITH_POLICY_AUTHORITY",
        "FORBIDDEN"
      ]
    },
    "outputDisposition": {
      "enum": [
        "EPHEMERAL_SCRATCH",
        "QUERY_PROPOSAL",
        "DRAFT_ARTIFACT",
        "CANDIDATE_EVIDENCE",
        "ADVISORY_OUTPUT",
        "HYPOTHESIS",
        "SCENARIO_RESULT",
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "OUTPUT_PREVIEW",
        "PERMISSION_LIMITED_ANSWER",
        "BLOCKED_ACTION",
        "NO_OUTPUT"
      ]
    },
    "freshnessPosture": {
      "enum": [
        "CURRENT_FOR_PURPOSE",
        "STALE_FOR_PURPOSE",
        "UNKNOWN",
        "REQUIRES_RECHECK",
        "NOT_APPLICABLE"
      ]
    },
    "decision": {
      "enum": [
        "ALLOWED",
        "ALLOWED_WITH_WARNINGS",
        "HUMAN_APPROVAL_REQUIRED",
        "REVIEW_REQUIRED",
        "CANDIDATE_ONLY",
        "BLOCKED",
        "DENIED"
      ]
    }
  }
}
