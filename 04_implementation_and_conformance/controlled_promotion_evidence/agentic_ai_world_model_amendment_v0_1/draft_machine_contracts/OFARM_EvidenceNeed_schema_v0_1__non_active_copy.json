{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/evidenceneed/v0.1",
  "title": "OFARM EvidenceNeed v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evidenceNeedId",
    "targetTwin",
    "targetScopes",
    "evidenceGap",
    "reason",
    "severity",
    "posture",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.evidenceneed.v0.1"
    },
    "evidenceNeedId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetTwin": {
      "$ref": "#/$defs/twin"
    },
    "targetScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT",
              "PARTY",
              "DOCUMENT",
              "PACK",
              "QUERY",
              "WORLD_MODEL",
              "SCENARIO"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "linkedPackRuleRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "linkedOutputRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "linkedPlanRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "linkedScenarioRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "linkedPromotionPathRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "evidenceGap": {
      "type": "string",
      "minLength": 1
    },
    "acceptableEvidenceOptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "consequence": {
      "type": "string"
    },
    "deadlineOrRelevanceWindow": {
      "type": "string"
    },
    "posture": {
      "enum": [
        "ADVISORY",
        "OPERATIONAL",
        "EVIDENCE_SUFFICIENCY_RELATED",
        "COMPLIANCE_BLOCKING"
      ]
    },
    "requestingAgentRunRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestingWorldModelRunRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "reviewOrPromotionPathRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "OPEN",
        "SATISFIED",
        "WAIVED_BY_REVIEW",
        "EXPIRED",
        "SUPERSEDED",
        "REJECTED"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Draft evidence gap/request contract.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "actionClass": {
      "type": "string",
      "minLength": 1
    },
    "autonomyLevel": {
      "enum": [
        "READ_ONLY",
        "SUGGEST_ONLY",
        "DRAFT_ONLY",
        "PREFLIGHT_ONLY",
        "EXECUTE_WITH_APPROVAL",
        "EXECUTE_WITH_POLICY_AUTHORITY",
        "FORBIDDEN"
      ]
    },
    "outputDisposition": {
      "enum": [
        "EPHEMERAL_SCRATCH",
        "QUERY_PROPOSAL",
        "DRAFT_ARTIFACT",
        "CANDIDATE_EVIDENCE",
        "ADVISORY_OUTPUT",
        "HYPOTHESIS",
        "SCENARIO_RESULT",
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "OUTPUT_PREVIEW",
        "PERMISSION_LIMITED_ANSWER",
        "BLOCKED_ACTION",
        "NO_OUTPUT"
      ]
    },
    "freshnessPosture": {
      "enum": [
        "CURRENT_FOR_PURPOSE",
        "STALE_FOR_PURPOSE",
        "UNKNOWN",
        "REQUIRES_RECHECK",
        "NOT_APPLICABLE"
      ]
    },
    "decision": {
      "enum": [
        "ALLOWED",
        "ALLOWED_WITH_WARNINGS",
        "HUMAN_APPROVAL_REQUIRED",
        "REVIEW_REQUIRED",
        "CANDIDATE_ONLY",
        "BLOCKED",
        "DENIED"
      ]
    }
  }
}
