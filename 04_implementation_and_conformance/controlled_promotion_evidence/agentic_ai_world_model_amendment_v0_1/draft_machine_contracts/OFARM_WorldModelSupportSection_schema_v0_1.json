{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/worldmodelsupportsection/v0.1",
  "title": "OFARM WorldModelSupportSection v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "supportsWorldModel",
    "advisoryOnlyEnforced",
    "supportedWorldModelRunVersions",
    "supportedWorldModelStateVersions",
    "supportedScenarioSpecVersions",
    "supportedScenarioResultSetVersions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelsupportsection.v0.1"
    },
    "supportsWorldModel": {
      "type": "boolean"
    },
    "advisoryOnlyEnforced": {
      "const": true
    },
    "supportedWorldModelRunVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedWorldModelStateVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedScenarioSpecVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedScenarioResultSetVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowedTargetScopes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT",
              "PARTY",
              "DOCUMENT",
              "PACK",
              "QUERY",
              "WORLD_MODEL",
              "SCENARIO"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "invalidationSupport": {
      "type": "boolean"
    },
    "bridgeGenerationSupport": {
      "type": "boolean"
    },
    "evidenceNeedSupport": {
      "type": "boolean"
    },
    "observationRequestSupport": {
      "type": "boolean"
    },
    "highConsequenceUseRule": {
      "enum": [
        "RECHECK_REQUIRED",
        "FORBIDDEN",
        "REVIEW_REQUIRED"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Draft Capability Manifest section for world-model support.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "actionClass": {
      "type": "string",
      "minLength": 1
    },
    "autonomyLevel": {
      "enum": [
        "READ_ONLY",
        "SUGGEST_ONLY",
        "DRAFT_ONLY",
        "PREFLIGHT_ONLY",
        "EXECUTE_WITH_APPROVAL",
        "EXECUTE_WITH_POLICY_AUTHORITY",
        "FORBIDDEN"
      ]
    },
    "outputDisposition": {
      "enum": [
        "EPHEMERAL_SCRATCH",
        "QUERY_PROPOSAL",
        "DRAFT_ARTIFACT",
        "CANDIDATE_EVIDENCE",
        "ADVISORY_OUTPUT",
        "HYPOTHESIS",
        "SCENARIO_RESULT",
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "OUTPUT_PREVIEW",
        "PERMISSION_LIMITED_ANSWER",
        "BLOCKED_ACTION",
        "NO_OUTPUT"
      ]
    },
    "freshnessPosture": {
      "enum": [
        "CURRENT_FOR_PURPOSE",
        "STALE_FOR_PURPOSE",
        "UNKNOWN",
        "REQUIRES_RECHECK",
        "NOT_APPLICABLE"
      ]
    },
    "decision": {
      "enum": [
        "ALLOWED",
        "ALLOWED_WITH_WARNINGS",
        "HUMAN_APPROVAL_REQUIRED",
        "REVIEW_REQUIRED",
        "CANDIDATE_ONLY",
        "BLOCKED",
        "DENIED"
      ]
    }
  }
}
