{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/scenarioresultset/v0.1",
  "title": "OFARM ScenarioResultSet v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scenarioResultSetId",
    "scenarioSpecRef",
    "originTwin",
    "advisoryOnly",
    "resultSummary",
    "outputDispositions",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.scenarioresultset.v0.1"
    },
    "scenarioResultSetId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scenarioSpecRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "worldModelRunRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "originTwin": {
      "const": "ADVISORY"
    },
    "advisoryOnly": {
      "const": true
    },
    "resultSummary": {
      "type": "string"
    },
    "uncertaintyStatementRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "evidenceNeedRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "observationRequestRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "bridgeCandidateRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "outputDispositions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outputDisposition"
      }
    },
    "observedOutcomeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "freshnessPosture": {
      "$ref": "#/$defs/freshnessPosture"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Draft advisory scenario result set contract.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "actionClass": {
      "type": "string",
      "minLength": 1
    },
    "autonomyLevel": {
      "enum": [
        "READ_ONLY",
        "SUGGEST_ONLY",
        "DRAFT_ONLY",
        "PREFLIGHT_ONLY",
        "EXECUTE_WITH_APPROVAL",
        "EXECUTE_WITH_POLICY_AUTHORITY",
        "FORBIDDEN"
      ]
    },
    "outputDisposition": {
      "enum": [
        "EPHEMERAL_SCRATCH",
        "QUERY_PROPOSAL",
        "DRAFT_ARTIFACT",
        "CANDIDATE_EVIDENCE",
        "ADVISORY_OUTPUT",
        "HYPOTHESIS",
        "SCENARIO_RESULT",
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "OUTPUT_PREVIEW",
        "PERMISSION_LIMITED_ANSWER",
        "BLOCKED_ACTION",
        "NO_OUTPUT"
      ]
    },
    "freshnessPosture": {
      "enum": [
        "CURRENT_FOR_PURPOSE",
        "STALE_FOR_PURPOSE",
        "UNKNOWN",
        "REQUIRES_RECHECK",
        "NOT_APPLICABLE"
      ]
    },
    "decision": {
      "enum": [
        "ALLOWED",
        "ALLOWED_WITH_WARNINGS",
        "HUMAN_APPROVAL_REQUIRED",
        "REVIEW_REQUIRED",
        "CANDIDATE_ONLY",
        "BLOCKED",
        "DENIED"
      ]
    }
  }
}
