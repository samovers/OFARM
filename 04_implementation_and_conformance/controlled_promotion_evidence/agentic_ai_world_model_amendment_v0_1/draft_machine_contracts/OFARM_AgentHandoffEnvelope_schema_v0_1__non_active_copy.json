{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agenthandoffenvelope/v0.1",
  "title": "OFARM AgentHandoffEnvelope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentHandoffEnvelopeId",
    "sourceAgentInstanceRef",
    "receivingAgentInstanceRef",
    "sourceAgentRunEnvelopeRef",
    "handoffPurpose",
    "authorityTransfers",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenthandoffenvelope.v0.1"
    },
    "agentHandoffEnvelopeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceAgentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "receivingAgentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceAgentRunEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "receivingAgentRunEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "handoffPurpose": {
      "type": "string",
      "minLength": 1
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "contextSnapshotRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "materializationResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "scenarioResultSetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "unresolvedConflictRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "staleBasisMarkers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockedActionTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "requiredHumanDecisionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "traceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "authorityTransfers": {
      "const": false
    },
    "receivingAgentMustRecheck": {
      "type": "array",
      "items": {
        "enum": [
          "AUTHORITY",
          "SCOPE",
          "FRESHNESS",
          "SHARING",
          "TARGET_TWIN",
          "WRITE_SURFACE",
          "PREFLIGHT",
          "PACK_BASIS",
          "MATERIALIZATION_BASIS"
        ]
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Draft handoff envelope that transfers context but not authority.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "actionClass": {
      "type": "string",
      "minLength": 1
    },
    "autonomyLevel": {
      "enum": [
        "READ_ONLY",
        "SUGGEST_ONLY",
        "DRAFT_ONLY",
        "PREFLIGHT_ONLY",
        "EXECUTE_WITH_APPROVAL",
        "EXECUTE_WITH_POLICY_AUTHORITY",
        "FORBIDDEN"
      ]
    },
    "outputDisposition": {
      "enum": [
        "EPHEMERAL_SCRATCH",
        "QUERY_PROPOSAL",
        "DRAFT_ARTIFACT",
        "CANDIDATE_EVIDENCE",
        "ADVISORY_OUTPUT",
        "HYPOTHESIS",
        "SCENARIO_RESULT",
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "OUTPUT_PREVIEW",
        "PERMISSION_LIMITED_ANSWER",
        "BLOCKED_ACTION",
        "NO_OUTPUT"
      ]
    },
    "freshnessPosture": {
      "enum": [
        "CURRENT_FOR_PURPOSE",
        "STALE_FOR_PURPOSE",
        "UNKNOWN",
        "REQUIRES_RECHECK",
        "NOT_APPLICABLE"
      ]
    },
    "decision": {
      "enum": [
        "ALLOWED",
        "ALLOWED_WITH_WARNINGS",
        "HUMAN_APPROVAL_REQUIRED",
        "REVIEW_REQUIRED",
        "CANDIDATE_ONLY",
        "BLOCKED",
        "DENIED"
      ]
    }
  }
}
