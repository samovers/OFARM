{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/supporting/OFARM_FarmerValueScenarioFixture_supporting_schema_v0_1.json",
  "title": "OFARM Farmer Value Scenario Fixture supporting schema v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixtureId",
    "fixtureVersion",
    "phase",
    "status",
    "fixtureType",
    "scenarioFamily",
    "title",
    "farmerValue",
    "activeOFARMAreas",
    "phaseDependencies",
    "actorModel",
    "setup",
    "workflowSteps",
    "expectedOutputs",
    "guardrails",
    "mustNotHappen",
    "expectedConformanceAssertions",
    "runtimeStatus",
    "promotionStatus"
  ],
  "properties": {
    "fixtureId": {
      "type": "string",
      "minLength": 3
    },
    "fixtureVersion": {
      "type": "string"
    },
    "phase": {
      "const": "AAI-P8"
    },
    "status": {
      "const": "SUPPORTING_REVIEW_ONLY_NOT_PROMOTED"
    },
    "fixtureType": {
      "enum": [
        "POSITIVE",
        "NEGATIVE",
        "MIXED"
      ]
    },
    "scenarioFamily": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "farmerValue": {
      "type": "string"
    },
    "sourceResearchSignals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "activeOFARMAreas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "phaseDependencies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "actorModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "humanActors",
        "agentRoles",
        "externalParties"
      ],
      "properties": {
        "humanActors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agentRoles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "externalParties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "setup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context",
        "canonicalTruthRefs",
        "advisoryRefs",
        "authorityRefs",
        "packRefs",
        "sharingRefs"
      ],
      "properties": {
        "context": {
          "type": "string"
        },
        "canonicalTruthRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "advisoryRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authorityRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "packRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sharingRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "workflowSteps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stepId",
          "actor",
          "action",
          "targetTwin",
          "producedObjects",
          "requiredChecks",
          "expectedDisposition"
        ],
        "properties": {
          "stepId": {
            "type": "string"
          },
          "actor": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "targetTwin": {
            "enum": [
              "COMPLIANCE",
              "ADVISORY",
              "RUNTIME",
              "PUBLIC_SURFACE",
              "MIXED"
            ]
          },
          "producedObjects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requiredChecks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expectedDisposition": {
            "type": "string"
          }
        }
      }
    },
    "expectedOutputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "guardrails": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mustNotHappen": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "expectedConformanceAssertions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "negativeCompanionFixtureRef": {
      "type": "string"
    },
    "runtimeStatus": {
      "const": "NOT_RUN_NO_IMPLEMENTATION"
    },
    "promotionStatus": {
      "const": "NOT_PROMOTED"
    }
  }
}
