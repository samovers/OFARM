{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agenttoolmanifest/v0.1",
  "title": "OFARM AgentToolManifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestId",
    "status",
    "agentUsePolicyRef",
    "tools"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenttoolmanifest.v0.1"
    },
    "manifestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "agentUsePolicyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "toolId",
          "operationId",
          "allowedAutonomy",
          "requiresPreflight",
          "requiresHumanApproval"
        ],
        "properties": {
          "toolId": {
            "type": "string",
            "pattern": "^[a-z][A-Za-z0-9.:-]*$"
          },
          "operationId": {
            "type": "string"
          },
          "publicOperationRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "allowedAutonomy": {
            "enum": [
              "SUGGEST_ONLY",
              "PREFLIGHT_ONLY",
              "EXECUTE_WITH_APPROVAL",
              "EXECUTE_WITH_POLICY_AUTHORITY",
              "FORBIDDEN"
            ]
          },
          "requiresPreflight": {
            "type": "boolean"
          },
          "preflightOperationId": {
            "type": "string"
          },
          "requiresHumanApproval": {
            "type": "boolean"
          },
          "traceTypes": {
            "type": "array",
            "items": {
              "enum": [
                "AUTHORIZATION",
                "PROMOTION",
                "QUERY",
                "MATERIALIZATION",
                "PUBLICATION",
                "PACK_ACTIVATION",
                "IMPORT",
                "CALCULATION",
                "PREFLIGHT",
                "COMMIT",
                "EVIDENCE",
                "IDENTITY",
                "CORRECTION_DISPUTE",
                "SYNC",
                "OUTPUT_ASSEMBLY"
              ]
            }
          },
          "refusalReasonCodes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z0-9_:-]+$"
            }
          },
          "safeDisplayStates": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
