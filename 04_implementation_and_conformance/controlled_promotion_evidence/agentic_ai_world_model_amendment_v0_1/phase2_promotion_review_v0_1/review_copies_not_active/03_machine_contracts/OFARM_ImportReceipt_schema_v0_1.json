{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/importreceipt/v0.1",
  "title": "OFARM ImportReceipt v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "importReceiptId",
    "adapterRef",
    "receiptStatus",
    "sourceFidelityEnvelopeRef",
    "candidateRefs",
    "idempotency"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.importreceipt.v0.1"
    },
    "importReceiptId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "adapterRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "receiptStatus": {
      "enum": [
        "RECEIVED_CANDIDATE",
        "DUPLICATE_REPLAY_REUSED",
        "REVIEW_REQUIRED",
        "REJECTED",
        "FAILED_VALIDATION"
      ]
    },
    "sourceFidelityEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "candidateRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idempotencyKey",
        "outcome"
      ],
      "properties": {
        "idempotencyKey": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "outcome": {
          "enum": [
            "NEW_RECEIPT",
            "REUSED_EXISTING_RECEIPT",
            "CONFLICTING_REPLAY_BLOCKED"
          ]
        }
      }
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "traceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
