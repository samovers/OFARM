{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/application-workflow-state-matrix/v0.1",
  "title": "OFARM ApplicationWorkflowStateMatrix v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "matrixId",
    "status",
    "authorityPosture",
    "effectiveDate",
    "sourceAuthorityRefs",
    "stateRows",
    "negativeLabelRules",
    "requiredInvariants",
    "acceptanceChecks"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.applicationworkflowstatematrix.v0.1"
    },
    "matrixId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "CANDIDATE_APP_GUIDANCE",
        "ACCEPTED_APP_GUIDANCE",
        "DEPRECATED"
      ]
    },
    "authorityPosture": {
      "enum": [
        "IMPLEMENTATION_SUPPORT_ONLY",
        "CANDIDATE_COMPANION_ARTIFACT",
        "ACCEPTED_COMPANION_ARTIFACT"
      ]
    },
    "effectiveDate": {
      "type": "string",
      "format": "date"
    },
    "sourceAuthorityRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "stateRows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stateRow"
      }
    },
    "negativeLabelRules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/negativeLabelRule"
      }
    },
    "requiredInvariants": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptanceChecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "stateRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stateId",
        "canonicalState",
        "stateFamily",
        "twinScope",
        "truthPosture",
        "safeAppLabels",
        "forbiddenAppLabels",
        "mayDrive",
        "mustNotDrive",
        "requiredTraceRefs",
        "displayQualificationRequirements",
        "allowedNextCanonicalStates"
      ],
      "properties": {
        "stateId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "canonicalState": {
          "type": "string"
        },
        "stateFamily": {
          "enum": [
            "SETUP",
            "OBSERVATION",
            "ADVISORY",
            "INTENT",
            "WORK_MANAGEMENT",
            "CLAIM",
            "EVIDENCE",
            "ACCEPTED_CONSEQUENCE",
            "CORRECTION",
            "DISPUTE",
            "OUTCOME",
            "INVENTORY",
            "CURRENT_STATE",
            "OUTPUT",
            "IMPORT",
            "PERMISSION",
            "OTHER"
          ]
        },
        "twinScope": {
          "enum": [
            "COMPLIANCE",
            "ADVISORY",
            "BOTH",
            "NONE",
            "MIXED"
          ]
        },
        "truthPosture": {
          "enum": [
            "DRAFT_ONLY",
            "CANDIDATE_ONLY",
            "ADVISORY_ONLY",
            "INTENT_ONLY",
            "CLAIM_ONLY",
            "EVIDENCE_ONLY",
            "ACCEPTED_HISTORY",
            "GOVERNED_MATERIALIZATION",
            "COMPILED_OUTPUT",
            "PERMISSION_LIMITED",
            "UNKNOWN_OR_MIXED"
          ]
        },
        "safeAppLabels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "forbiddenAppLabels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mayDrive": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mustNotDrive": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredTraceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "displayQualificationRequirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "publicSurfaceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowedNextCanonicalStates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "negativeLabelRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "unsafePattern",
        "whyUnsafe",
        "requiredReplacement"
      ],
      "properties": {
        "ruleId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "unsafePattern": {
          "type": "string"
        },
        "whyUnsafe": {
          "type": "string"
        },
        "requiredReplacement": {
          "type": "string"
        }
      }
    }
  }
}
