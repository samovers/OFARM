{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/importlossmap/v0.1",
  "title": "OFARM ImportLossMap v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "importLossMapId",
    "sourceFidelityEnvelopeRef",
    "lossSummary",
    "lossItems",
    "highConsequencePolicy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.importlossmap.v0.1"
    },
    "importLossMapId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sourceFidelityEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "lossMapRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "lossSummary": {
      "enum": [
        "MINIMAL",
        "MANAGED",
        "MATERIAL",
        "HIGH_RISK"
      ]
    },
    "lossItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourcePath",
          "lossClass",
          "impactLevel"
        ],
        "properties": {
          "sourcePath": {
            "type": "string"
          },
          "ofarmTargetRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "lossClass": {
            "enum": [
              "DROPPED",
              "APPROXIMATED",
              "COLLAPSED",
              "ASSUMED",
              "UNREPRESENTABLE",
              "SPLIT",
              "REDACTED",
              "UNRESOLVED"
            ]
          },
          "impactLevel": {
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "mitigationStatus": {
            "enum": [
              "NOT_REQUIRED",
              "REVIEW_REQUIRED",
              "EVIDENCE_REQUIRED",
              "BLOCKS_HIGH_CONSEQUENCE_USE"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "highConsequencePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocksHighConsequenceUse"
      ],
      "properties": {
        "blocksHighConsequenceUse": {
          "type": "boolean"
        },
        "allowedLowConsequenceUses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredReviewRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
