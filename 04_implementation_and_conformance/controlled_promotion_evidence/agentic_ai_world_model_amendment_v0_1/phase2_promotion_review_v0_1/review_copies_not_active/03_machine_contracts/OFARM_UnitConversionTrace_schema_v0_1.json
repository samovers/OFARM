{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/unitconversiontrace/v0.1",
  "title": "OFARM UnitConversionTrace v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "traceId",
    "conversionStatus",
    "sourceQuantity",
    "targetQuantity",
    "conversionBasis",
    "rounding"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.unitconversiontrace.v0.1"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "conversionStatus": {
      "enum": [
        "SUCCESS",
        "REFUSED",
        "REVIEW_REQUIRED",
        "NOT_NEEDED"
      ]
    },
    "sourceQuantity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "quantityKindRef",
        "unitRef",
        "valueStatus"
      ],
      "properties": {
        "role": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "quantityKindRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "unitRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "value": {
          "type": "number"
        },
        "valueStatus": {
          "enum": [
            "PROVIDED",
            "DERIVED",
            "UNRESOLVED",
            "NOT_APPLICABLE"
          ]
        },
        "sourceRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "uncertainty": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "targetQuantity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "quantityKindRef",
        "unitRef",
        "valueStatus"
      ],
      "properties": {
        "role": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "quantityKindRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "unitRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "value": {
          "type": "number"
        },
        "valueStatus": {
          "enum": [
            "PROVIDED",
            "DERIVED",
            "UNRESOLVED",
            "NOT_APPLICABLE"
          ]
        },
        "sourceRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "uncertainty": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "conversionBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basisRef",
        "basisStatus"
      ],
      "properties": {
        "basisRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "basisStatus": {
          "enum": [
            "GOVERNED",
            "PROFILE_DEFINED",
            "MISSING",
            "REJECTED"
          ]
        },
        "basisNote": {
          "type": "string"
        }
      }
    },
    "rounding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roundingPolicyRef",
        "roundingStage"
      ],
      "properties": {
        "roundingPolicyRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "roundingStage": {
          "type": "string"
        },
        "displayPrecision": {
          "type": "string"
        }
      }
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
