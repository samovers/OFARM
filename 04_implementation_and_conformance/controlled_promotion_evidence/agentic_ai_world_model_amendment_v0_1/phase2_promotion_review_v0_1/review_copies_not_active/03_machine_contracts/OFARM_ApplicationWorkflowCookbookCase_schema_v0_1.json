{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/application-workflow-cookbook-case/v0.1",
  "title": "OFARM ApplicationWorkflowCookbookCase v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "caseId",
    "title",
    "workflowFamily",
    "authorityPosture",
    "scenarioSummary",
    "intendedBuilderUse",
    "sourceAuthorityRefs",
    "startingAssumptions",
    "steps",
    "expectedFinalState",
    "stateCollapseGuards",
    "safeDisplayRules",
    "forbiddenAgentBehaviors",
    "acceptanceChecks"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.applicationworkflowcookbookcase.v0.1"
    },
    "caseId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "title": {
      "type": "string"
    },
    "workflowFamily": {
      "enum": [
        "FIELD_SETUP",
        "CROP_CYCLE_SETUP",
        "OBSERVATION_TO_DECISION",
        "INTENT_TO_WORK_ORDER",
        "EXECUTION_AND_PROMOTION",
        "CORRECTION_AND_DISPUTE",
        "OFFLINE_SYNC",
        "INVENTORY_UPDATE",
        "QUERY_AND_OUTPUT",
        "OTHER"
      ]
    },
    "authorityPosture": {
      "enum": [
        "IMPLEMENTATION_SUPPORT_ONLY",
        "CANDIDATE_APP_RECIPE",
        "ACCEPTED_APP_RECIPE"
      ]
    },
    "scenarioSummary": {
      "type": "string"
    },
    "intendedBuilderUse": {
      "type": "string"
    },
    "sourceAuthorityRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "startingAssumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflowStep"
      }
    },
    "expectedFinalState": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stateCollapseGuards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safeDisplayRules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbiddenAgentBehaviors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptanceChecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "workflowStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stepId",
        "stepOrder",
        "actor",
        "userVisibleStep",
        "canonicalStateBefore",
        "canonicalStateAfter",
        "operationClass",
        "publicOperationRef",
        "commitOrEventClass",
        "requiresPreflight",
        "requiresHumanApproval",
        "inputRefs",
        "outputRefs",
        "emittedTraceRefs",
        "safeAppLabel",
        "forbiddenAppLabels",
        "runtimeProblemRefs",
        "nextAllowedActions"
      ],
      "properties": {
        "stepId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "stepOrder": {
          "type": "integer",
          "minimum": 1
        },
        "actor": {
          "enum": [
            "FARM_OWNER",
            "FARM_MANAGER",
            "ADVISOR",
            "CONTRACTOR",
            "MACHINE_ADAPTER",
            "PLATFORM",
            "AI_ASSISTANT",
            "INSPECTOR",
            "OTHER"
          ]
        },
        "userVisibleStep": {
          "type": "string"
        },
        "canonicalStateBefore": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalStateAfter": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operationClass": {
          "enum": [
            "DRAFT_CAPTURE",
            "PREFLIGHT",
            "SUBMIT_COMMIT",
            "REGISTER_EVIDENCE",
            "QUERY",
            "MATERIALIZATION_READ",
            "PROMOTION_REVIEW",
            "ASSEMBLY_PREVIEW",
            "CORRECTION",
            "DISPUTE",
            "IMPORT_CANDIDATE",
            "IDENTITY_RESOLUTION",
            "OTHER"
          ]
        },
        "publicOperationRef": {
          "type": "string"
        },
        "commitOrEventClass": {
          "type": "string"
        },
        "requiresPreflight": {
          "type": "boolean"
        },
        "requiresHumanApproval": {
          "type": "boolean"
        },
        "inputRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "emittedTraceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "safeAppLabel": {
          "type": "string"
        },
        "forbiddenAppLabels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runtimeProblemRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nextAllowedActions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
