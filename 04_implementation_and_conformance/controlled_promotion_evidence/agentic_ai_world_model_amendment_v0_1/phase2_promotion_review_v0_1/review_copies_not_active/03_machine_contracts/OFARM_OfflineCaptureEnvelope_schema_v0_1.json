{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/offlinecaptureenvelope/v0.1",
  "title": "OFARM OfflineCaptureEnvelope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "offlineCaptureEnvelopeId",
    "localDraftId",
    "captureActorRef",
    "captureDeviceRef",
    "captureTimes",
    "localAuthoritySnapshot",
    "payload",
    "idempotency",
    "syncPolicy",
    "offlineTruthPosture"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.offlinecaptureenvelope.v0.1"
    },
    "offlineCaptureEnvelopeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "localDraftId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "captureActorRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "captureDeviceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "captureTimes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "localCapturedAt",
        "assertedEffectiveTime",
        "deviceClockConfidence"
      ],
      "properties": {
        "localCapturedAt": {
          "type": "string",
          "format": "date-time"
        },
        "assertedEffectiveTime": {
          "type": "string",
          "format": "date-time"
        },
        "deviceClockConfidence": {
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW",
            "UNKNOWN"
          ]
        },
        "receivedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "localAuthoritySnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grantRef",
        "snapshotTakenAt",
        "snapshotStatus"
      ],
      "properties": {
        "grantRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "snapshotTakenAt": {
          "type": "string",
          "format": "date-time"
        },
        "snapshotStatus": {
          "enum": [
            "PRESENT",
            "ABSENT",
            "STALE",
            "UNKNOWN"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payloadClass",
        "payloadRef"
      ],
      "properties": {
        "payloadClass": {
          "enum": [
            "OPERATION_CLAIM",
            "OBSERVATION_ASSERTION",
            "EVIDENCE_REFERENCE",
            "INVENTORY_NOTE",
            "OTHER"
          ]
        },
        "payloadRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idempotencyKey",
        "fingerprint"
      ],
      "properties": {
        "idempotencyKey": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "fingerprint": {
          "type": "string"
        }
      }
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mustRecheckAuthorityAtSync",
        "duplicateDetectionRequired"
      ],
      "properties": {
        "mustRecheckAuthorityAtSync": {
          "type": "boolean"
        },
        "duplicateDetectionRequired": {
          "type": "boolean"
        },
        "blockHighConsequenceUntilAccepted": {
          "type": "boolean"
        }
      }
    },
    "offlineTruthPosture": {
      "enum": [
        "DRAFT_ONLY",
        "CANDIDATE_ONLY",
        "CLAIM_ONLY"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
