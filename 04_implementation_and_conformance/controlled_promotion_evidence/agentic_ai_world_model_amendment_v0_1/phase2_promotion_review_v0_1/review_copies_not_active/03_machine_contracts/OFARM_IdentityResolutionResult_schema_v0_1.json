{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/identityresolutionresult/v0.1",
  "title": "OFARM IdentityResolutionResult v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "resultId",
    "requestRef",
    "resolutionStatus",
    "candidateBindings",
    "reasonCodes",
    "allowedNextActions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.identityresolutionresult.v0.1"
    },
    "resultId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "resolutionStatus": {
      "enum": [
        "RESOLVED",
        "AMBIGUOUS",
        "UNRESOLVED",
        "DUPLICATE_CANDIDATE",
        "REVIEW_REQUIRED",
        "REFUSED"
      ]
    },
    "resolvedIdentityRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "candidateBindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidateIdentityRef",
          "bindingStatus",
          "confidence"
        ],
        "properties": {
          "candidateIdentityRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "bindingStatus": {
            "enum": [
              "PROPOSED",
              "ACCEPTED",
              "REJECTED",
              "NEEDS_REVIEW",
              "DUPLICATE_SUSPECT"
            ]
          },
          "confidence": {
            "type": "number"
          },
          "basisRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:/#-]+$"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "duplicateRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "allowedNextActions": {
      "type": "array",
      "items": {
        "enum": [
          "USE_FOR_LOW_CONSEQUENCE_DISPLAY",
          "SUBMIT_BINDING_REVIEW",
          "BLOCK_HIGH_CONSEQUENCE_USE",
          "ATTACH_MORE_EVIDENCE",
          "REUSE_EXISTING_RECEIPT",
          "REJECT_IMPORT"
        ]
      }
    },
    "traceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
