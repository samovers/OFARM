{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/output-assembly-preview-request/v0.1",
  "title": "OFARM OutputAssemblyPreviewRequest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "requestedAt",
    "requestedByPartyRef",
    "previewAction",
    "outputKind",
    "targetScopes",
    "requestedUseClass",
    "resultQualificationRequired"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.outputassemblypreviewrequest.v0.1"
    },
    "requestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "requestedByPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestedByAgentRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "previewAction": {
      "enum": [
        "PREVIEW_PASSPORT_VIEW",
        "PREVIEW_DOCUMENT_ASSEMBLY",
        "DRY_RUN_FREEZE_DOCUMENT_ASSEMBLY",
        "DRY_RUN_ATTEST_DOCUMENT_ASSEMBLY",
        "DRY_RUN_FILE_SUBMISSION_ASSEMBLY",
        "DRY_RUN_EXPORT_API_PAYLOAD"
      ]
    },
    "outputKind": {
      "enum": [
        "PASSPORT_VIEW",
        "REPORT_ASSEMBLY",
        "DOSSIER_ASSEMBLY",
        "SUBMISSION_ASSEMBLY",
        "EXPORT_PAYLOAD"
      ]
    },
    "outputMetadataRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "targetScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        }
      }
    },
    "requestedUseClass": {
      "enum": [
        "ADVISORY_DISPLAY",
        "INFORMATIONAL_DASHBOARD",
        "COMPLIANCE_REVIEW",
        "COMPLIANCE_OUTPUT_INPUT",
        "HIGH_CONSEQUENCE_DECISION",
        "EXPORT_API_PAYLOAD"
      ]
    },
    "sourceQueryResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "materializationResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "evidenceSufficiencyCaseRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "freshnessRequirement": {
      "enum": [
        "REQUIRE_FRESH",
        "ALLOW_STALE_INFORMATIONAL",
        "NO_CURRENT_STATE_DEPENDENCY"
      ]
    },
    "evidenceReturnPolicy": {
      "enum": [
        "SUMMARY_ONLY",
        "EVIDENCE_REFS_ONLY",
        "EVIDENCE_WITH_REDACTION",
        "FULL_EVIDENCE_WHERE_AUTHORIZED",
        "NO_EVIDENCE_RETURNED"
      ]
    },
    "includeDisputeAnnex": {
      "type": "boolean"
    },
    "resultQualificationRequired": {
      "const": true
    },
    "reason": {
      "type": "string"
    }
  }
}
