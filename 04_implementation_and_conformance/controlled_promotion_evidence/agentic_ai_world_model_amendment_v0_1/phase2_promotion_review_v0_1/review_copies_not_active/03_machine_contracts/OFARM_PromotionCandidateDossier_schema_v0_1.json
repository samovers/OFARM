{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_PromotionCandidateDossier_schema_v0_1.json",
  "title": "OFARM Promotion Candidate Dossier",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "dossierId",
    "date",
    "status",
    "promotionBatches"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.promotioncandidate.dossier.v0.1"
    },
    "dossierId": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "promotionBatches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "batchId",
          "targetAuthorityLayer",
          "promotionReadiness",
          "candidates",
          "prerequisites"
        ],
        "properties": {
          "batchId": {
            "type": "string"
          },
          "targetAuthorityLayer": {
            "type": "string",
            "enum": [
              "root_navigation_guardrail",
              "01_companion_artifacts",
              "02_accepted_rfcs",
              "03_machine_contracts",
              "04_implementation_and_conformance",
              "hold_non_default"
            ]
          },
          "promotionReadiness": {
            "type": "string",
            "enum": [
              "ready_for_review",
              "hold_until_runtime_evidence",
              "remain_supporting",
              "do_not_promote"
            ]
          },
          "candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "source",
                "target",
                "decision",
                "reason"
              ],
              "properties": {
                "source": {
                  "type": "string"
                },
                "target": {
                  "type": "string"
                },
                "decision": {
                  "type": "string",
                  "enum": [
                    "promote_after_review",
                    "promote_after_runtime_evidence",
                    "keep_supporting",
                    "do_not_promote"
                  ]
                },
                "reason": {
                  "type": "string"
                },
                "risk": {
                  "type": "string"
                }
              }
            }
          },
          "prerequisites": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
