{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/publicapplicationsurfacemanifest/v0.1",
  "title": "OFARM PublicApplicationSurfaceManifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestId",
    "status",
    "effectiveDate",
    "authorityPosture",
    "operations",
    "nonCallableInternals",
    "requiredInvariants"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.publicapplicationsurfacemanifest.v0.1"
    },
    "manifestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "CANDIDATE_PUBLIC_SURFACE",
        "ACTIVE_PUBLIC_SURFACE",
        "DEPRECATED"
      ]
    },
    "effectiveDate": {
      "type": "string",
      "format": "date"
    },
    "authorityPosture": {
      "enum": [
        "IMPLEMENTATION_SUPPORT_ONLY",
        "CANDIDATE_PUBLIC_SURFACE",
        "ACCEPTED_PUBLIC_SURFACE"
      ]
    },
    "capabilityManifestRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "publicSchemaCatalogRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "internalSchemaCatalogRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "operations": {
      "type": "array",
      "items": {
        "$ref": "https://ofarm.dev/schema/publicoperationdescriptor/v0.1"
      }
    },
    "nonCallableInternals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiredInvariants": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
