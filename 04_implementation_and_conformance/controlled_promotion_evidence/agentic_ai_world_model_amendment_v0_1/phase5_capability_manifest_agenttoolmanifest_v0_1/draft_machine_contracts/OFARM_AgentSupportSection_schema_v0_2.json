{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentSupportSection v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "agentSupportStatus",
    "supportedAgentClasses",
    "supportedAutonomyLevels",
    "supportedTargetTwins",
    "supportedRunEnvelopeVersions",
    "supportedRunTraceVersions",
    "supportedHandoffEnvelopeVersions",
    "agentToolManifestRefs",
    "manifestDoesNotGrantAuthority",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.2"
    },
    "agentSupportStatus": {
      "enum": [
        "NOT_SUPPORTED",
        "DECLARED_ONLY",
        "STATIC_VALIDATED",
        "IMPLEMENTATION_PRESENT_NOT_TESTED",
        "RUNTIME_TESTED"
      ]
    },
    "supportedAgentClasses": {
      "type": "array",
      "items": {
        "enum": [
          "READ_ASSISTANT",
          "EVIDENCE_STEWARD",
          "COMPLIANCE_STEWARD",
          "ADVISORY_AGRONOMY",
          "CONTRACTOR_COORDINATION",
          "LOT_STORAGE",
          "SHARING_SOVEREIGNTY",
          "DISPUTE_RECONSTRUCTION",
          "LOCAL_MEMORY",
          "WORLD_MODEL_SCENARIO"
        ]
      },
      "minItems": 0
    },
    "supportedAutonomyLevels": {
      "type": "array",
      "items": {
        "enum": [
          "READ_ONLY",
          "DRAFT_ONLY",
          "PREFLIGHT_ONLY",
          "HUMAN_APPROVAL_REQUIRED",
          "POLICY_BOUNDED_EXECUTION",
          "HUMAN_GOVERNED_ONLY"
        ]
      },
      "minItems": 0
    },
    "maxAutonomyByActionClass": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "authorityActionClass",
          "maxAutonomyLevel"
        ],
        "properties": {
          "authorityActionClass": {
            "type": "string",
            "minLength": 1
          },
          "maxAutonomyLevel": {
            "enum": [
              "READ_ONLY",
              "DRAFT_ONLY",
              "PREFLIGHT_ONLY",
              "HUMAN_APPROVAL_REQUIRED",
              "POLICY_BOUNDED_EXECUTION",
              "HUMAN_GOVERNED_ONLY",
              "NOT_AGENT_CALLABLE"
            ]
          }
        }
      },
      "minItems": 0
    },
    "requiresPreflightByActionClass": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "authorityActionClass",
          "preflightRequired"
        ],
        "properties": {
          "authorityActionClass": {
            "type": "string",
            "minLength": 1
          },
          "preflightRequired": {
            "type": "boolean"
          }
        }
      },
      "minItems": 0
    },
    "requiresHumanApprovalByActionClass": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "authorityActionClass",
          "humanApprovalRequired"
        ],
        "properties": {
          "authorityActionClass": {
            "type": "string",
            "minLength": 1
          },
          "humanApprovalRequired": {
            "type": "boolean"
          }
        }
      },
      "minItems": 0
    },
    "supportedTargetTwins": {
      "type": "array",
      "items": {
        "enum": [
          "COMPLIANCE",
          "ADVISORY",
          "BOTH_READ_ONLY"
        ]
      },
      "minItems": 0
    },
    "supportedWriteSurfaces": {
      "type": "array",
      "items": {
        "enum": [
          "NONE",
          "DRAFT_STORE",
          "ADVISORY_WORKSPACE",
          "EVIDENCE_CANDIDATE_STORE",
          "REVIEW_QUEUE",
          "BRIDGECANDIDATE_QUEUE",
          "OUTPUT_PREVIEW_STORE",
          "HANDOFF_CONTEXT_STORE"
        ]
      },
      "minItems": 0
    },
    "supportedOutputDispositions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "supportedRunEnvelopeVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "supportedRunTraceVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "supportedHandoffEnvelopeVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "agentToolManifestRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "externalCallPolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "farmDataLearningPolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "traceRetentionPolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "redactionAndPermissionLimitedResultPolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "revocationHandling": {
      "enum": [
        "NOT_APPLICABLE",
        "RECHECK_AT_RUN_START",
        "RECHECK_BEFORE_STATE_AFFECTING_STEP",
        "RECHECK_EVERY_TOOL_CALL"
      ]
    },
    "manifestDoesNotGrantAuthority": {
      "const": true
    },
    "runtimeConformanceClaimed": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
