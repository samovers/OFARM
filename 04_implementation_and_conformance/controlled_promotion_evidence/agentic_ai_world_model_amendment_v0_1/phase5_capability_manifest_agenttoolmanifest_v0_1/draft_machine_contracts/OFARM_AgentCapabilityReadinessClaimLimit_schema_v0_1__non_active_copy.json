{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentCapabilityReadinessClaimLimit v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "claimId",
    "capabilityRef",
    "claimLevel",
    "runtimeEvidenceRequiredForHigherClaim",
    "runtimeEvidenceRefs"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "claimId": {
      "type": "string",
      "minLength": 1
    },
    "capabilityRef": {
      "type": "string",
      "minLength": 1
    },
    "claimLevel": {
      "enum": [
        "DECLARED_ONLY",
        "STATIC_SCHEMA_VALIDATED",
        "STATIC_EXAMPLE_VALIDATED",
        "IMPLEMENTATION_PRESENT_NOT_TESTED",
        "RUNTIME_EXECUTED",
        "RUNTIME_PASSED",
        "TWO_AGENT_COMPATIBILITY_PASSED",
        "EXTERNAL_CONFORMANCE_REVIEWED"
      ]
    },
    "runtimeEvidenceRequiredForHigherClaim": {
      "type": "boolean"
    },
    "runtimeEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "conformanceSuiteRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "notes": {
      "type": "string"
    }
  }
}
