{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM RedactionAndPermissionLimitedResultPolicy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "policyId",
    "permissionLimitedAnswersMustBeQualified",
    "redactionRequiredForExternalDisclosure",
    "noRecordsDoesNotMeanNoRecordsExist"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "policyId": {
      "type": "string",
      "minLength": 1
    },
    "permissionLimitedAnswersMustBeQualified": {
      "type": "boolean"
    },
    "redactionRequiredForExternalDisclosure": {
      "type": "boolean"
    },
    "sharingGrantRefsRequired": {
      "type": "boolean"
    },
    "noRecordsDoesNotMeanNoRecordsExist": {
      "type": "boolean"
    },
    "allowedRedactionProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "notes": {
      "type": "string"
    }
  }
}
