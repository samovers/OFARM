{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentToolDescriptor v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "toolId",
    "toolVersion",
    "operationId",
    "targetTwin",
    "authorityActionClass",
    "effectClass",
    "inputSchemaRef",
    "outputSchemaRef",
    "requiredAuthorityBasis",
    "approvalRequirementRef",
    "semanticPreconditionRefs",
    "declaredHintSetRef",
    "traceRetentionPolicyRef",
    "allowedOutputDispositions",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "toolId": {
      "type": "string",
      "minLength": 1
    },
    "toolVersion": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string"
    },
    "operationId": {
      "type": "string",
      "minLength": 1
    },
    "publicOperationDescriptorRef": {
      "type": "string",
      "minLength": 1
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "NONE_READ_ONLY"
      ]
    },
    "authorityActionClass": {
      "type": "string",
      "minLength": 1
    },
    "effectClass": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "OFARM AgentToolEffectClassification v0.1",
      "type": "string",
      "enum": [
        "READ_ONLY",
        "QUALIFIED_READ",
        "DRAFT_CREATE",
        "EVIDENCE_CANDIDATE_CREATE",
        "ADVISORY_CREATE",
        "BRIDGE_CANDIDATE_CREATE",
        "REVIEW_REQUEST_CREATE",
        "OUTPUT_PREVIEW_CREATE",
        "EXTERNAL_DISCLOSURE_PREPARE",
        "STATE_AFFECTING_GOVERNED_OPERATION",
        "PROHIBITED_FOR_AGENT_USE"
      ]
    },
    "inputSchemaRef": {
      "type": "string",
      "minLength": 1
    },
    "outputSchemaRef": {
      "type": "string",
      "minLength": 1
    },
    "requiredAuthorityBasis": {
      "enum": [
        "NONE_READ_ONLY",
        "SHARING_GRANT",
        "AGENT_AUTHORITY_ENVELOPE",
        "HUMAN_APPROVAL_GATE",
        "HUMAN_GOVERNED_ONLY",
        "NOT_AGENT_CALLABLE"
      ]
    },
    "approvalRequirementRef": {
      "type": "string",
      "minLength": 1
    },
    "semanticPreconditionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "declaredHintSetRef": {
      "type": "string",
      "minLength": 1
    },
    "externalCallPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "farmDataLearningPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "redactionAndPermissionLimitedResultPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "traceRetentionPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "allowedOutputDispositions": {
      "type": "array",
      "items": {
        "enum": [
          "NO_ARTIFACT_CREATED",
          "READ_RESULT",
          "QUALIFIED_READ_RESULT",
          "ADVISORY_TEXT",
          "HYPOTHESIS",
          "DRAFT_ASSERTION",
          "DRAFT_OBSERVATION",
          "EVIDENCE_ATTACHMENT_CANDIDATE",
          "PLANNED_INTERVENTION_DRAFT",
          "OPERATION_CLAIM_DRAFT",
          "BRIDGE_CANDIDATE",
          "REVIEW_REQUEST",
          "PREFLIGHT_RESULT",
          "OUTPUT_PREVIEW",
          "HANDOFF_CONTEXT",
          "BLOCKED_ACTION_RECORD"
        ]
      },
      "minItems": 1
    },
    "blockedActionReasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "runtimeConformanceClaimed": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
