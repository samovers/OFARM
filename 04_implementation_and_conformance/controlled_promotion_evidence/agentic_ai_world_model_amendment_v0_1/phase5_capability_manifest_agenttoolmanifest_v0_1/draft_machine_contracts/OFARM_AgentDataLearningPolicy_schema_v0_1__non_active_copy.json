{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentDataLearningPolicy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "learningPolicyId",
    "learningMode",
    "explicitGrantRequired",
    "crossFarmLearningDefault"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "learningPolicyId": {
      "type": "string",
      "minLength": 1
    },
    "learningMode": {
      "enum": [
        "NO_LEARNING",
        "TENANT_LOCAL_ONLY",
        "EXPLICIT_OPT_IN_ONLY",
        "CROSS_FARM_AGGREGATED_ONLY_WITH_GRANT",
        "PROHIBITED"
      ]
    },
    "explicitGrantRequired": {
      "type": "boolean"
    },
    "crossFarmLearningDefault": {
      "enum": [
        "PROHIBITED",
        "EXPLICIT_OPT_IN_ONLY"
      ]
    },
    "retentionPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "revocationBehavior": {
      "enum": [
        "STOP_FUTURE_USE",
        "STOP_AND_DELETE_WHERE_POSSIBLE",
        "NOT_APPLICABLE"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
