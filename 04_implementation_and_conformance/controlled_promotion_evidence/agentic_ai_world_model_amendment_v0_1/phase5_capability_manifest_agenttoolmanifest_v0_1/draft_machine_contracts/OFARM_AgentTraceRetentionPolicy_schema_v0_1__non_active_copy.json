{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentTraceRetentionPolicy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "traceRetentionPolicyId",
    "minimumRetentionClass",
    "blockedActionTraceRequired",
    "toolInvocationTraceRequired",
    "protectedReferenceAllowed"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "traceRetentionPolicyId": {
      "type": "string",
      "minLength": 1
    },
    "minimumRetentionClass": {
      "enum": [
        "SESSION_ONLY_NOT_FOR_GOVERNED_RUNS",
        "GOVERNED_RUN_MINIMUM",
        "OUTPUT_BASIS_RETENTION",
        "DISPUTE_READY_RETENTION"
      ]
    },
    "blockedActionTraceRequired": {
      "type": "boolean"
    },
    "toolInvocationTraceRequired": {
      "type": "boolean"
    },
    "protectedReferenceAllowed": {
      "type": "boolean"
    },
    "rawPromptRetentionRequired": {
      "type": "boolean"
    },
    "chainOfThoughtRetentionRequired": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
