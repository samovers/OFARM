{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgenticCapabilityManifestOverlay v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "overlayId",
    "baseCapabilityManifestRef",
    "agentSupportSectionRef",
    "worldModelSupportSectionRef",
    "agentToolManifestRefs",
    "readinessClaimRefs",
    "overlayDoesNotGrantAuthority",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "overlayId": {
      "type": "string",
      "minLength": 1
    },
    "baseCapabilityManifestRef": {
      "type": "string",
      "minLength": 1
    },
    "agentSupportSectionRef": {
      "type": "string",
      "minLength": 1
    },
    "worldModelSupportSectionRef": {
      "type": "string",
      "minLength": 1
    },
    "agentToolManifestRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "readinessClaimRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "overlayDoesNotGrantAuthority": {
      "const": true
    },
    "runtimeConformanceClaimed": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
