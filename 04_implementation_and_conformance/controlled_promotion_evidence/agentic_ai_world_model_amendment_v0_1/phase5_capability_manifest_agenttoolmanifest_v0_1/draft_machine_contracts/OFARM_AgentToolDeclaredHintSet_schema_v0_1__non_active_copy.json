{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentToolDeclaredHintSet v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "hintSetId",
    "hintsAreAuthoritative"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "hintSetId": {
      "type": "string",
      "minLength": 1
    },
    "readOnlyHint": {
      "type": "boolean"
    },
    "destructiveHint": {
      "type": "boolean"
    },
    "idempotentHint": {
      "type": "boolean"
    },
    "openWorldHint": {
      "type": "boolean"
    },
    "externalDisclosureHint": {
      "type": "boolean"
    },
    "draftOnlyHint": {
      "type": "boolean"
    },
    "agentSafeHint": {
      "type": "boolean"
    },
    "hintsAreAuthoritative": {
      "const": false
    },
    "hintSourceRef": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
