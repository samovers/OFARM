{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentToolManifest v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "manifestId",
    "manifestPurpose",
    "deploymentOrTenantRef",
    "agentSupportSectionRef",
    "toolDescriptorRefs",
    "defaultExternalCallPolicyRef",
    "defaultFarmDataLearningPolicyRef",
    "defaultTraceRetentionPolicyRef",
    "defaultRedactionPolicyRef",
    "readinessClaimRefs",
    "manifestDoesNotGrantAuthority",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.2"
    },
    "manifestId": {
      "type": "string",
      "minLength": 1
    },
    "manifestPurpose": {
      "enum": [
        "AGENT_TOOL_DISCOVERY",
        "AGENT_RUNTIME_SELF_DESCRIPTION",
        "IMPLEMENTER_REVIEW",
        "CONFORMANCE_FIXTURE"
      ]
    },
    "deploymentOrTenantRef": {
      "type": "string",
      "minLength": 1
    },
    "capabilityManifestRef": {
      "type": "string",
      "minLength": 1
    },
    "agentSupportSectionRef": {
      "type": "string",
      "minLength": 1
    },
    "toolDescriptorRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "toolManifestDigest": {
      "type": "string",
      "minLength": 1
    },
    "defaultExternalCallPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "defaultFarmDataLearningPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "defaultTraceRetentionPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "defaultRedactionPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "readinessClaimRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "manifestDoesNotGrantAuthority": {
      "const": true
    },
    "toolHintsAreNonAuthoritative": {
      "const": true
    },
    "runtimeConformanceClaimed": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
