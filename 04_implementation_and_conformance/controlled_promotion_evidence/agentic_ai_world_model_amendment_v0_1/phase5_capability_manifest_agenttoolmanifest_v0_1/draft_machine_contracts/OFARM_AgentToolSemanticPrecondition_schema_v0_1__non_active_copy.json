{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentToolSemanticPrecondition v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "preconditionId",
    "authorityCheckRequired",
    "targetTwinCheckRequired",
    "scopeCheckRequired",
    "freshnessCheckRequired",
    "packApplicabilityCheckRequired",
    "sharingCheckRequired",
    "traceCheckRequired"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "preconditionId": {
      "type": "string",
      "minLength": 1
    },
    "authorityCheckRequired": {
      "type": "boolean"
    },
    "targetTwinCheckRequired": {
      "type": "boolean"
    },
    "scopeCheckRequired": {
      "type": "boolean"
    },
    "freshnessCheckRequired": {
      "type": "boolean"
    },
    "evidenceSufficiencyCheckRequired": {
      "type": "boolean"
    },
    "packApplicabilityCheckRequired": {
      "type": "boolean"
    },
    "sharingCheckRequired": {
      "type": "boolean"
    },
    "redactionCheckRequired": {
      "type": "boolean"
    },
    "outputDispositionCheckRequired": {
      "type": "boolean"
    },
    "traceCheckRequired": {
      "type": "boolean"
    },
    "mustBlockIfUnsatisfied": {
      "type": "boolean"
    },
    "relatedRuntimeProblemReasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "notes": {
      "type": "string"
    }
  }
}
