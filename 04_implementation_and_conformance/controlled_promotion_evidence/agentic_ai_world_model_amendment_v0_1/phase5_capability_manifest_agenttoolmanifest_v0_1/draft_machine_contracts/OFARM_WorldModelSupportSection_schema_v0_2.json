{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM WorldModelSupportSection v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "worldModelSupportStatus",
    "advisoryOnly",
    "prohibitedTargetTwins",
    "supportedScenarioPurposes",
    "uncertaintyStatementSupport",
    "invalidationRuleSupport",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.2"
    },
    "worldModelSupportStatus": {
      "enum": [
        "NOT_SUPPORTED",
        "DECLARED_ONLY",
        "STATIC_VALIDATED",
        "IMPLEMENTATION_PRESENT_NOT_TESTED",
        "RUNTIME_TESTED"
      ]
    },
    "advisoryOnly": {
      "const": true
    },
    "prohibitedTargetTwins": {
      "type": "array",
      "items": {
        "enum": [
          "COMPLIANCE"
        ]
      },
      "minItems": 1
    },
    "supportedScenarioPurposes": {
      "type": "array",
      "items": {
        "enum": [
          "CROP_RISK",
          "IRRIGATION_PLANNING",
          "NUTRIENT_PLANNING",
          "PEST_DISEASE_RISK",
          "HARVEST_TIMING",
          "STORAGE_LOT_RISK",
          "BUYER_READINESS",
          "DISPUTE_RECONSTRUCTION",
          "EVIDENCE_PRIORITIZATION"
        ]
      },
      "minItems": 0
    },
    "uncertaintyStatementSupport": {
      "type": "boolean"
    },
    "invalidationRuleSupport": {
      "type": "boolean"
    },
    "calibrationEvidenceSupport": {
      "type": "boolean"
    },
    "observedOutcomeReconciliationSupport": {
      "type": "boolean"
    },
    "worldModelRunSchemaRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "readinessClaimRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "runtimeConformanceClaimed": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
