{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentToolApprovalRequirement v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "approvalClass",
    "preflightRequired",
    "humanApprovalRequired",
    "approvalReasonCodes"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "approvalClass": {
      "enum": [
        "NO_APPROVAL_READ_ONLY",
        "PRECHECK_ONLY",
        "HUMAN_APPROVAL_REQUIRED",
        "HUMAN_GOVERNED_ONLY",
        "NOT_AGENT_CALLABLE"
      ]
    },
    "preflightRequired": {
      "type": "boolean"
    },
    "humanApprovalRequired": {
      "type": "boolean"
    },
    "humanGovernedOnly": {
      "type": "boolean"
    },
    "approvalReasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "allowedApproverRoleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "notes": {
      "type": "string"
    }
  }
}
