{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentExternalCallPolicy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "externalCallPolicyId",
    "externalCallMode",
    "allowedDomainsOrServiceRefs",
    "redactionRequiredBeforeExternalCall"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "externalCallPolicyId": {
      "type": "string",
      "minLength": 1
    },
    "externalCallMode": {
      "enum": [
        "NO_EXTERNAL_CALLS",
        "DECLARED_SERVICES_ONLY",
        "DECLARED_SERVICES_WITH_REDACTION",
        "OPEN_WORLD_PROHIBITED",
        "OPEN_WORLD_ALLOWED_ONLY_WITH_HUMAN_APPROVAL"
      ]
    },
    "allowedDomainsOrServiceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "redactionRequiredBeforeExternalCall": {
      "type": "boolean"
    },
    "sharingGrantRequired": {
      "type": "boolean"
    },
    "auditRequired": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  }
}
