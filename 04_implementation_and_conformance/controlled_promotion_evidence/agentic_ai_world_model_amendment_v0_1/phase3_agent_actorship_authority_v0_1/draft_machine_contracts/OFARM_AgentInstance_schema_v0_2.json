{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_AgentInstance_schema_v0_2.json",
  "title": "OFARM_AgentInstance_schema_v0_2",
  "description": "Candidate schema for a concrete deployed software-agent instance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentInstanceId",
    "softwareAgentProfileRef",
    "sponsorRef",
    "lifecycleState",
    "deploymentScope",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.2"
    },
    "agentInstanceId": {
      "type": "string",
      "minLength": 1
    },
    "softwareAgentProfileRef": {
      "type": "string",
      "minLength": 1
    },
    "sponsorRef": {
      "type": "string",
      "minLength": 1
    },
    "modelToolProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "lifecycleState": {
      "type": "string",
      "enum": [
        "REGISTERED",
        "ACTIVE",
        "SUSPENDED",
        "REVOKED",
        "RETIRED"
      ]
    },
    "deploymentScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeRefs"
      ],
      "properties": {
        "scopeRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "targetTwins": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "COMPLIANCE",
              "ADVISORY",
              "BOTH_READ_ONLY"
            ]
          }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "activatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "suspendedAt": {
      "type": "string",
      "format": "date-time"
    },
    "revokedAt": {
      "type": "string",
      "format": "date-time"
    },
    "revocationStateRef": {
      "type": "string"
    },
    "runtimeSurfaceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "notes": {
      "type": "string"
    }
  }
}
