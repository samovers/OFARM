{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_AgentAuthorityEnvelope_schema_v0_2.json",
  "title": "OFARM_AgentAuthorityEnvelope_schema_v0_2",
  "description": "Candidate schema for a scoped authority envelope constraining an agent action.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentAuthorityEnvelopeId",
    "agentInstanceRef",
    "sponsorRef",
    "requestedActionClass",
    "allowedActionClasses",
    "targetTwin",
    "targetScopeRefs",
    "validFrom",
    "validUntil",
    "approvalRequirement",
    "allowedOutputDispositions",
    "revocationCheckRequired"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.2"
    },
    "agentAuthorityEnvelopeId": {
      "type": "string",
      "minLength": 1
    },
    "agentInstanceRef": {
      "type": "string",
      "minLength": 1
    },
    "sponsorRef": {
      "type": "string",
      "minLength": 1
    },
    "actorshipBindingRef": {
      "type": "string"
    },
    "authorityGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "delegationEnvelopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "sharingGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "requestedActionClass": {
      "type": "string",
      "enum": [
        "OBSERVE_CREATE_OBSERVATION",
        "OBSERVE_ATTACH_EVIDENCE",
        "ASSERT_STRUCTURE",
        "ASSERT_OPERATION_CLAIM",
        "ASSERT_COMPLIANCE",
        "OPERATE_PLAN_INTERVENTION",
        "OPERATE_REPORT_EXECUTION",
        "REVIEW_REQUEST",
        "REVIEW_ACCEPT",
        "REVIEW_REJECT_OR_CONTEST",
        "REVIEW_SUPERSEDE",
        "CONTEXT_INSTALL_PACK",
        "CONTEXT_ACTIVATE_PACK",
        "CONTEXT_DEACTIVATE_PACK",
        "OUTPUT_APPROVE_DOCUMENT_ASSEMBLY",
        "OUTPUT_ATTEST_DOCUMENT_ASSEMBLY",
        "OUTPUT_FILE_SUBMISSION_ASSEMBLY",
        "SHARE_GRANT_ACCESS",
        "SHARE_REVOKE_ACCESS",
        "RECEIVE_READ_DATA"
      ]
    },
    "allowedActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "OBSERVE_CREATE_OBSERVATION",
          "OBSERVE_ATTACH_EVIDENCE",
          "ASSERT_STRUCTURE",
          "ASSERT_OPERATION_CLAIM",
          "ASSERT_COMPLIANCE",
          "OPERATE_PLAN_INTERVENTION",
          "OPERATE_REPORT_EXECUTION",
          "REVIEW_REQUEST",
          "REVIEW_ACCEPT",
          "REVIEW_REJECT_OR_CONTEST",
          "REVIEW_SUPERSEDE",
          "CONTEXT_INSTALL_PACK",
          "CONTEXT_ACTIVATE_PACK",
          "CONTEXT_DEACTIVATE_PACK",
          "OUTPUT_APPROVE_DOCUMENT_ASSEMBLY",
          "OUTPUT_ATTEST_DOCUMENT_ASSEMBLY",
          "OUTPUT_FILE_SUBMISSION_ASSEMBLY",
          "SHARE_GRANT_ACCESS",
          "SHARE_REVOKE_ACCESS",
          "RECEIVE_READ_DATA"
        ]
      },
      "uniqueItems": true
    },
    "forbiddenActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "OBSERVE_CREATE_OBSERVATION",
          "OBSERVE_ATTACH_EVIDENCE",
          "ASSERT_STRUCTURE",
          "ASSERT_OPERATION_CLAIM",
          "ASSERT_COMPLIANCE",
          "OPERATE_PLAN_INTERVENTION",
          "OPERATE_REPORT_EXECUTION",
          "REVIEW_REQUEST",
          "REVIEW_ACCEPT",
          "REVIEW_REJECT_OR_CONTEST",
          "REVIEW_SUPERSEDE",
          "CONTEXT_INSTALL_PACK",
          "CONTEXT_ACTIVATE_PACK",
          "CONTEXT_DEACTIVATE_PACK",
          "OUTPUT_APPROVE_DOCUMENT_ASSEMBLY",
          "OUTPUT_ATTEST_DOCUMENT_ASSEMBLY",
          "OUTPUT_FILE_SUBMISSION_ASSEMBLY",
          "SHARE_GRANT_ACCESS",
          "SHARE_REVOKE_ACCESS",
          "RECEIVE_READ_DATA"
        ]
      },
      "uniqueItems": true
    },
    "targetTwin": {
      "type": "string",
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH_READ_ONLY"
      ]
    },
    "targetScopeRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scopeInheritanceMode": {
      "type": "string",
      "enum": [
        "EXACT_ONLY",
        "DESCENDANT_SCOPES",
        "DERIVED_LINEAGE_SCOPES",
        "NO_INHERIT"
      ]
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "approvalRequirement": {
      "type": "string",
      "enum": [
        "NONE",
        "PLATFORM_POLICY_APPROVAL",
        "HUMAN_APPROVAL_REQUIRED",
        "HUMAN_GOVERNED_PATH_REQUIRED",
        "REVIEW_REQUIRED"
      ]
    },
    "preflightRequired": {
      "type": "boolean"
    },
    "runEnvelopeRequired": {
      "type": "boolean"
    },
    "revocationCheckRequired": {
      "const": true
    },
    "revocationStateRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "allowedOutputDispositions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "READ_RESULT",
          "ADVISORY_TEXT",
          "HYPOTHESIS",
          "DRAFT_ASSERTION",
          "DRAFT_OBSERVATION",
          "EVIDENCE_ATTACHMENT_CANDIDATE",
          "PLANNED_INTERVENTION_DRAFT",
          "OPERATION_CLAIM_DRAFT",
          "BRIDGE_CANDIDATE",
          "REVIEW_REQUEST",
          "PREFLIGHT_RESULT",
          "OUTPUT_PREVIEW",
          "DENIED_NO_ARTIFACT_CREATED",
          "SHARING_REQUEST_DRAFT"
        ]
      },
      "uniqueItems": true
    },
    "dataSovereigntyConstraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "externalDisclosureAllowed": {
          "type": "boolean"
        },
        "permissionLimitedResultPolicy": {
          "type": "string",
          "enum": [
            "QUALIFY",
            "REDACT",
            "DENY"
          ]
        },
        "policyRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
