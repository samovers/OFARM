{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_SoftwareAgentProfile_schema_v0_2.json",
  "title": "OFARM_SoftwareAgentProfile_schema_v0_2",
  "description": "Candidate schema for governed software agent profiles.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "softwareAgentProfileId",
    "profileVersion",
    "agentClass",
    "intendedUses",
    "defaultAutonomyPosture",
    "sponsorRequired",
    "defaultAllowedActionClasses",
    "defaultForbiddenActionClasses",
    "tracePolicy",
    "humanGovernedDefaultAcknowledgement"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.2"
    },
    "softwareAgentProfileId": {
      "type": "string",
      "minLength": 1
    },
    "profileVersion": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "agentClass": {
      "type": "string",
      "enum": [
        "ORCHESTRATOR",
        "EVIDENCE_STEWARD",
        "COMPLIANCE_STEWARD",
        "ADVISORY_AGRONOMY",
        "CONTRACTOR_COORDINATION",
        "LOT_STORAGE",
        "SHARING_SOVEREIGNTY",
        "DISPUTE_RECONSTRUCTION",
        "LOCAL_MEMORY",
        "WORLD_MODEL",
        "IMPORT_STEWARD",
        "CUSTOM"
      ]
    },
    "description": {
      "type": "string"
    },
    "intendedUses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibitedUses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "defaultAutonomyPosture": {
      "type": "string",
      "enum": [
        "READ_ONLY",
        "SUGGEST_ONLY",
        "DRAFT_ONLY",
        "PREFLIGHT_ONLY",
        "REQUEST_REVIEW_ONLY",
        "EXECUTE_WITH_APPROVAL",
        "EXECUTE_WITH_POLICY_AUTHORITY",
        "FORBIDDEN"
      ]
    },
    "sponsorRequired": {
      "const": true
    },
    "defaultAllowedActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "OBSERVE_CREATE_OBSERVATION",
          "OBSERVE_ATTACH_EVIDENCE",
          "ASSERT_STRUCTURE",
          "ASSERT_OPERATION_CLAIM",
          "ASSERT_COMPLIANCE",
          "OPERATE_PLAN_INTERVENTION",
          "OPERATE_REPORT_EXECUTION",
          "REVIEW_REQUEST",
          "REVIEW_ACCEPT",
          "REVIEW_REJECT_OR_CONTEST",
          "REVIEW_SUPERSEDE",
          "CONTEXT_INSTALL_PACK",
          "CONTEXT_ACTIVATE_PACK",
          "CONTEXT_DEACTIVATE_PACK",
          "OUTPUT_APPROVE_DOCUMENT_ASSEMBLY",
          "OUTPUT_ATTEST_DOCUMENT_ASSEMBLY",
          "OUTPUT_FILE_SUBMISSION_ASSEMBLY",
          "SHARE_GRANT_ACCESS",
          "SHARE_REVOKE_ACCESS",
          "RECEIVE_READ_DATA"
        ]
      },
      "uniqueItems": true
    },
    "defaultForbiddenActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "OBSERVE_CREATE_OBSERVATION",
          "OBSERVE_ATTACH_EVIDENCE",
          "ASSERT_STRUCTURE",
          "ASSERT_OPERATION_CLAIM",
          "ASSERT_COMPLIANCE",
          "OPERATE_PLAN_INTERVENTION",
          "OPERATE_REPORT_EXECUTION",
          "REVIEW_REQUEST",
          "REVIEW_ACCEPT",
          "REVIEW_REJECT_OR_CONTEST",
          "REVIEW_SUPERSEDE",
          "CONTEXT_INSTALL_PACK",
          "CONTEXT_ACTIVATE_PACK",
          "CONTEXT_DEACTIVATE_PACK",
          "OUTPUT_APPROVE_DOCUMENT_ASSEMBLY",
          "OUTPUT_ATTEST_DOCUMENT_ASSEMBLY",
          "OUTPUT_FILE_SUBMISSION_ASSEMBLY",
          "SHARE_GRANT_ACCESS",
          "SHARE_REVOKE_ACCESS",
          "RECEIVE_READ_DATA"
        ]
      },
      "uniqueItems": true
    },
    "humanGovernedDefaultAcknowledgement": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "REVIEW_ACCEPT",
          "REVIEW_REJECT_OR_CONTEST",
          "REVIEW_SUPERSEDE",
          "CONTEXT_INSTALL_PACK",
          "CONTEXT_ACTIVATE_PACK",
          "CONTEXT_DEACTIVATE_PACK",
          "OUTPUT_APPROVE_DOCUMENT_ASSEMBLY",
          "OUTPUT_ATTEST_DOCUMENT_ASSEMBLY",
          "OUTPUT_FILE_SUBMISSION_ASSEMBLY"
        ]
      },
      "minItems": 9,
      "uniqueItems": true
    },
    "perActionClassMaxPosture": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "authorityActionClass",
          "maxAutonomyPosture"
        ],
        "properties": {
          "authorityActionClass": {
            "type": "string",
            "enum": [
              "OBSERVE_CREATE_OBSERVATION",
              "OBSERVE_ATTACH_EVIDENCE",
              "ASSERT_STRUCTURE",
              "ASSERT_OPERATION_CLAIM",
              "ASSERT_COMPLIANCE",
              "OPERATE_PLAN_INTERVENTION",
              "OPERATE_REPORT_EXECUTION",
              "REVIEW_REQUEST",
              "REVIEW_ACCEPT",
              "REVIEW_REJECT_OR_CONTEST",
              "REVIEW_SUPERSEDE",
              "CONTEXT_INSTALL_PACK",
              "CONTEXT_ACTIVATE_PACK",
              "CONTEXT_DEACTIVATE_PACK",
              "OUTPUT_APPROVE_DOCUMENT_ASSEMBLY",
              "OUTPUT_ATTEST_DOCUMENT_ASSEMBLY",
              "OUTPUT_FILE_SUBMISSION_ASSEMBLY",
              "SHARE_GRANT_ACCESS",
              "SHARE_REVOKE_ACCESS",
              "RECEIVE_READ_DATA"
            ]
          },
          "maxAutonomyPosture": {
            "type": "string",
            "enum": [
              "READ_ONLY",
              "SUGGEST_ONLY",
              "DRAFT_ONLY",
              "PREFLIGHT_ONLY",
              "REQUEST_REVIEW_ONLY",
              "EXECUTE_WITH_APPROVAL",
              "EXECUTE_WITH_POLICY_AUTHORITY",
              "FORBIDDEN"
            ]
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "requiresRunEnvelopeForStateAffectingActions": {
      "type": "boolean",
      "default": true
    },
    "tracePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agentAuthorizationTraceRequired",
        "runTraceRequiredForStateAffectingActions"
      ],
      "properties": {
        "agentAuthorizationTraceRequired": {
          "type": "boolean"
        },
        "runTraceRequiredForStateAffectingActions": {
          "type": "boolean"
        },
        "traceRetentionPolicyRef": {
          "type": "string"
        }
      }
    },
    "dataUsePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "farmDataLearningAllowed",
        "externalDisclosureAllowed"
      ],
      "properties": {
        "farmDataLearningAllowed": {
          "type": "boolean"
        },
        "externalDisclosureAllowed": {
          "type": "boolean"
        },
        "dataUsePolicyRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "modelToolProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "lifecyclePolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "notes": {
      "type": "string"
    }
  }
}
