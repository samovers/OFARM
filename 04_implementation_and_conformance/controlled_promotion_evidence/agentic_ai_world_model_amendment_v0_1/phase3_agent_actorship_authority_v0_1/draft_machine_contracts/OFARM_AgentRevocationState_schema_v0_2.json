{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_AgentRevocationState_schema_v0_2.json",
  "title": "OFARM_AgentRevocationState_schema_v0_2",
  "description": "Candidate schema for agent-relevant revocation state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentRevocationStateId",
    "subjectType",
    "subjectRef",
    "revocationStatus",
    "checkedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.2"
    },
    "agentRevocationStateId": {
      "type": "string",
      "minLength": 1
    },
    "subjectType": {
      "type": "string",
      "enum": [
        "SOFTWARE_AGENT_PROFILE",
        "AGENT_INSTANCE",
        "AGENT_SPONSOR_RELATION",
        "AUTHORITY_GRANT",
        "DELEGATION_ENVELOPE",
        "SHARING_GRANT",
        "MODEL_TOOL_PROFILE",
        "TOOL_PERMISSION"
      ]
    },
    "subjectRef": {
      "type": "string",
      "minLength": 1
    },
    "revocationStatus": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "SUSPENDED",
        "REVOKED",
        "EXPIRED",
        "UNKNOWN_REQUIRES_REVIEW"
      ]
    },
    "checkedAt": {
      "type": "string",
      "format": "date-time"
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date-time"
    },
    "effectiveUntil": {
      "type": "string",
      "format": "date-time"
    },
    "revocationDecisionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "reason": {
      "type": "string"
    },
    "finalActionAllowed": {
      "type": "boolean"
    }
  }
}
