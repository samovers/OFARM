{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_AgentAuthorizationDecisionTrace_schema_v0_1.json",
  "title": "OFARM_AgentAuthorizationDecisionTrace_schema_v0_1",
  "description": "Candidate schema for an agent-specific authorization decision trace.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentAuthorizationDecisionTraceId",
    "requestedActionClass",
    "decisionOutcome",
    "agentInstanceRef",
    "sponsorRef",
    "targetTwin",
    "targetScopeRefs",
    "decisionAt",
    "reasonCodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1"
    },
    "agentAuthorizationDecisionTraceId": {
      "type": "string",
      "minLength": 1
    },
    "requestedActionClass": {
      "type": "string",
      "enum": [
        "OBSERVE_CREATE_OBSERVATION",
        "OBSERVE_ATTACH_EVIDENCE",
        "ASSERT_STRUCTURE",
        "ASSERT_OPERATION_CLAIM",
        "ASSERT_COMPLIANCE",
        "OPERATE_PLAN_INTERVENTION",
        "OPERATE_REPORT_EXECUTION",
        "REVIEW_REQUEST",
        "REVIEW_ACCEPT",
        "REVIEW_REJECT_OR_CONTEST",
        "REVIEW_SUPERSEDE",
        "CONTEXT_INSTALL_PACK",
        "CONTEXT_ACTIVATE_PACK",
        "CONTEXT_DEACTIVATE_PACK",
        "OUTPUT_APPROVE_DOCUMENT_ASSEMBLY",
        "OUTPUT_ATTEST_DOCUMENT_ASSEMBLY",
        "OUTPUT_FILE_SUBMISSION_ASSEMBLY",
        "SHARE_GRANT_ACCESS",
        "SHARE_REVOKE_ACCESS",
        "RECEIVE_READ_DATA"
      ]
    },
    "decisionOutcome": {
      "type": "string",
      "enum": [
        "ALLOW",
        "DENY",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL"
      ]
    },
    "agentInstanceRef": {
      "type": "string",
      "minLength": 1
    },
    "softwareAgentProfileRef": {
      "type": "string"
    },
    "sponsorRef": {
      "type": "string",
      "minLength": 1
    },
    "actorshipBindingRef": {
      "type": "string"
    },
    "agentAuthorityEnvelopeRef": {
      "type": "string"
    },
    "targetTwin": {
      "type": "string",
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH_READ_ONLY"
      ]
    },
    "targetScopeRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "targetTime": {
      "type": "string",
      "format": "date-time"
    },
    "decisionAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "delegationBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "sharingGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "revocationStateRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "scopeInheritanceModeApplied": {
      "type": "string",
      "enum": [
        "EXACT_ONLY",
        "DESCENDANT_SCOPES",
        "DERIVED_LINEAGE_SCOPES",
        "NO_INHERIT"
      ]
    },
    "humanApprovalRequirement": {
      "type": "string",
      "enum": [
        "NONE",
        "REQUIRED",
        "HUMAN_GOVERNED_PATH_REQUIRED",
        "NOT_APPLICABLE"
      ]
    },
    "allowedOutputDisposition": {
      "type": "string",
      "enum": [
        "READ_RESULT",
        "ADVISORY_TEXT",
        "HYPOTHESIS",
        "DRAFT_ASSERTION",
        "DRAFT_OBSERVATION",
        "EVIDENCE_ATTACHMENT_CANDIDATE",
        "PLANNED_INTERVENTION_DRAFT",
        "OPERATION_CLAIM_DRAFT",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "PREFLIGHT_RESULT",
        "OUTPUT_PREVIEW",
        "DENIED_NO_ARTIFACT_CREATED",
        "SHARING_REQUEST_DRAFT"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "AGENT_AUTHORITY_ALLOWED",
          "AGENT_SPONSOR_MISSING",
          "ACCOUNTABLE_PARTY_AMBIGUOUS",
          "AGENT_INSTANCE_UNKNOWN",
          "AGENT_INSTANCE_NOT_ACTIVE",
          "MODEL_TOOL_PROFILE_NOT_APPROVED",
          "ACTION_CLASS_HUMAN_GOVERNED_DEFAULT",
          "ACTION_SCOPE_OUTSIDE_GRANT",
          "AUTHORITY_EXPIRED",
          "AUTHORITY_REVOKED",
          "DELEGATION_REVOKED",
          "SHARING_GRANT_REQUIRED",
          "PERMISSION_LIMITED_RESULT",
          "HUMAN_APPROVAL_REQUIRED",
          "REVIEW_REQUIRED",
          "OUTPUT_DISPOSITION_NOT_ALLOWED",
          "TOOL_CALL_NOT_GOVERNANCE_SUCCESS"
        ]
      }
    },
    "explanation": {
      "type": "string"
    },
    "tracebackRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    }
  }
}
