{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_AgentModelToolProfile_schema_v0_2.json",
  "title": "OFARM_AgentModelToolProfile_schema_v0_2",
  "description": "Candidate schema for model/tool profile used by an agent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentModelToolProfileId",
    "profileVersion",
    "componentType",
    "intendedUse",
    "approvalStatus",
    "permittedOutputPostures",
    "externalCallsAllowed",
    "farmDataLearningAllowed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.2"
    },
    "agentModelToolProfileId": {
      "type": "string",
      "minLength": 1
    },
    "profileVersion": {
      "type": "string",
      "minLength": 1
    },
    "componentType": {
      "type": "string",
      "enum": [
        "MODEL",
        "TOOLCHAIN",
        "SERVICE",
        "AGENT_RUNTIME",
        "EXTERNAL_TOOL_SET",
        "MIXED"
      ]
    },
    "providerOrOwnerRef": {
      "type": "string"
    },
    "modelOrToolIdentifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "intendedUse": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approvalStatus": {
      "type": "string",
      "enum": [
        "UNREVIEWED",
        "APPROVED_FOR_ADVISORY",
        "APPROVED_FOR_DRAFT",
        "APPROVED_FOR_PREFLIGHT",
        "APPROVED_FOR_POLICY_EXECUTION",
        "SUSPENDED",
        "REVOKED"
      ]
    },
    "permittedOutputPostures": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "READ_RESULT",
          "ADVISORY_ONLY",
          "DRAFT_ONLY",
          "PREFLIGHT_ONLY",
          "REVIEW_REQUEST_ONLY",
          "POLICY_EXECUTION_ALLOWED"
        ]
      },
      "uniqueItems": true
    },
    "externalCallsAllowed": {
      "type": "boolean"
    },
    "farmDataLearningAllowed": {
      "type": "boolean"
    },
    "retentionPolicyRef": {
      "type": "string"
    },
    "evaluationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "riskNotes": {
      "type": "string"
    }
  }
}
