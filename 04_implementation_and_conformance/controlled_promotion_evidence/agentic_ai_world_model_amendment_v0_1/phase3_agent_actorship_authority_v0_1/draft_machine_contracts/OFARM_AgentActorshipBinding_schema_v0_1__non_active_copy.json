{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_AgentActorshipBinding_schema_v0_1.json",
  "title": "OFARM_AgentActorshipBinding_schema_v0_1",
  "description": "Candidate schema joining accountable party, sponsor, profile, instance, and model/tool basis.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentActorshipBindingId",
    "accountablePartyRef",
    "sponsorRef",
    "softwareAgentProfileRef",
    "agentInstanceRef",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1"
    },
    "agentActorshipBindingId": {
      "type": "string",
      "minLength": 1
    },
    "accountablePartyRef": {
      "type": "string",
      "minLength": 1
    },
    "sponsorRef": {
      "type": "string",
      "minLength": 1
    },
    "softwareAgentProfileRef": {
      "type": "string",
      "minLength": 1
    },
    "agentInstanceRef": {
      "type": "string",
      "minLength": 1
    },
    "modelToolProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "authorityEnvelopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "basisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "notes": {
      "type": "string"
    }
  }
}
