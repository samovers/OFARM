{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/OFARM_AgentSponsorRef_schema_v0_2.json",
  "title": "OFARM_AgentSponsorRef_schema_v0_2",
  "description": "Candidate schema for the accountable sponsor of an agent action/instance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentSponsorRefId",
    "accountablePartyRef",
    "sponsorRole",
    "authorityBasisRefs",
    "dataSovereigntyResponsibility"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.2"
    },
    "agentSponsorRefId": {
      "type": "string",
      "minLength": 1
    },
    "accountablePartyRef": {
      "type": "string",
      "minLength": 1
    },
    "sponsorRole": {
      "type": "string",
      "enum": [
        "FARMER",
        "FARM_ORGANIZATION",
        "CONTRACTOR",
        "ADVISOR",
        "BUYER",
        "CERTIFIER",
        "PLATFORM_OPERATOR",
        "OTHER"
      ]
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "delegationBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "sharingGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "dataSovereigntyResponsibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "responsibleForAgentUse",
        "responsibleForExternalDisclosure"
      ],
      "properties": {
        "responsibleForAgentUse": {
          "type": "boolean"
        },
        "responsibleForExternalDisclosure": {
          "type": "boolean"
        },
        "policyRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
