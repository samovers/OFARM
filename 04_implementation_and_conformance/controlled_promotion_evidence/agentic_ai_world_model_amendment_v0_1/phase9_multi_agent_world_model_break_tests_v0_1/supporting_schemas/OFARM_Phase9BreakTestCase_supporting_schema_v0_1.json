{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/supporting/OFARM_Phase9BreakTestCase_supporting_schema_v0_1.json",
  "title": "OFARM Phase 9 Break Test Case Supporting Schema v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "testId",
    "title",
    "status",
    "testFamily",
    "severity",
    "targetInvariant",
    "attackPattern",
    "attemptedShortcut",
    "requiredBlockers",
    "expectedOutcome",
    "requiredTraceAssertions",
    "relatedPhases",
    "runtimeExecutionStatus"
  ],
  "properties": {
    "schemaVersion": {
      "const": "OFARM_Phase9BreakTestCase_supporting_schema_v0_1"
    },
    "testId": {
      "type": "string",
      "pattern": "^AAI-P9-[A-Z0-9_]+$"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "DEFINED_NOT_EXECUTED"
      ]
    },
    "testFamily": {
      "enum": [
        "IDENTITY_AUTHORITY",
        "HANDOFF",
        "TOOL_MANIFEST",
        "EXTERNAL_DATA_IMPORT",
        "HIDDEN_TRUTH_STORE",
        "PACK_SEMANTICS",
        "QUERY_SHARING",
        "WORLD_MODEL",
        "MEMORY",
        "BENCHMARKING",
        "TRACE",
        "OFFLINE_SYNC",
        "BRIDGE_CANDIDATE",
        "OUTPUT_ASSEMBLY",
        "REQUESTS",
        "CAPABILITY_MANIFEST",
        "REVIEW_PROMOTION",
        "FRESHNESS"
      ]
    },
    "severity": {
      "enum": [
        "BLOCKER",
        "HIGH",
        "MEDIUM"
      ]
    },
    "targetInvariant": {
      "type": "string"
    },
    "attackPattern": {
      "type": "string"
    },
    "attemptedShortcut": {
      "type": "string"
    },
    "inputSignals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiredBlockers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "expectedOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disposition",
        "mustPrevent",
        "mustAllowIfAny"
      ],
      "properties": {
        "disposition": {
          "enum": [
            "BLOCK",
            "REFUSE",
            "DOWNGRADE_TO_DRAFT",
            "REQUIRE_RECHECK",
            "REDACT_OR_PERMISSION_LIMIT",
            "RETAIN_AS_CANDIDATE"
          ]
        },
        "mustPrevent": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "mustAllowIfAny": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "requiredTraceAssertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "relatedPhases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "AAI-P1",
          "AAI-P2",
          "AAI-P3",
          "AAI-P4",
          "AAI-P5",
          "AAI-P6",
          "AAI-P7",
          "AAI-P8",
          "AAI-P9"
        ]
      }
    },
    "relatedConcepts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "farmerValueProtected": {
      "type": "string"
    },
    "runtimeExecutionStatus": {
      "const": "NOT_RUN_NO_IMPLEMENTATION"
    },
    "readinessClaimImpact": {
      "type": "string"
    }
  }
}