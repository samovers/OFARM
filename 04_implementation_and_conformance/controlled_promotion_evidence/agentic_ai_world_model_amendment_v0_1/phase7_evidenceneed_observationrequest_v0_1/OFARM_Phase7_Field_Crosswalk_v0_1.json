{
  "schemaVersion": "ofarm.phase7.fieldcrosswalk.v0.1",
  "phase": "AAI-P7",
  "status": "SUPPORTING_REVIEW_ONLY_NOT_PROMOTED",
  "objects": {
    "EvidenceNeed": {
      "corePurpose": "semantic missing-evidence statement",
      "mustNotBe": [
        "evidence",
        "accepted assertion",
        "promotion decision",
        "attestation"
      ],
      "requiredLinks": [
        "requestingBasis",
        "targetScopes",
        "acceptableEvidenceOptions",
        "completionCriteria",
        "noiseControl"
      ]
    },
    "ObservationRequest": {
      "corePurpose": "actionable request to capture or inspect a real-world condition",
      "mustNotBe": [
        "accepted observation",
        "sensor record",
        "compliance fact",
        "current state"
      ],
      "requiredLinks": [
        "targetScopes",
        "acceptableCollectionMethods",
        "acceptableArtifactForms",
        "completionCriteria",
        "burdenEstimate"
      ]
    },
    "RequestSatisfactionTrace": {
      "corePurpose": "records how a request was satisfied, waived, expired, rejected, or collapsed",
      "mustNotBe": [
        "automatic promotion",
        "evidence sufficiency case substitute"
      ]
    }
  },
  "researchDrivers": [
    "bounded work items",
    "severity/code/details/diagnostics style reporting",
    "farmer burden visibility",
    "local knowledge annotation",
    "stop conditions to prevent overwhelming requests"
  ]
}
