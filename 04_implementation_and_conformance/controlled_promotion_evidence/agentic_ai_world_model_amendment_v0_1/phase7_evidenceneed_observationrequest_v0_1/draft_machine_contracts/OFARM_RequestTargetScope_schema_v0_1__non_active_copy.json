{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requesttargetscope-v0.1/v0.1",
  "title": "OFARM RequestTargetScope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scopeType",
    "scopeRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requesttargetscope.v0.1"
    },
    "scopeType": {
      "enum": [
        "FARM",
        "SITE",
        "FIELD",
        "ZONE",
        "CROP_CYCLE",
        "LOT",
        "BIN",
        "STORAGE_FACILITY",
        "FACILITY",
        "OPERATION",
        "MATERIAL",
        "PRODUCT",
        "DOCUMENT",
        "OUTPUT_ASSEMBLY",
        "PACK",
        "QUERY",
        "WORLD_MODEL",
        "SCENARIO",
        "AGENT_RUN",
        "PARTY",
        "TENANT",
        "OTHER"
      ]
    },
    "scopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "scopeLabel": {
      "type": "string"
    },
    "geometryBasisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
