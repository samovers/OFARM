{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestnoisecontrolenvelope-v0.1/v0.1",
  "title": "OFARM RequestNoiseControlEnvelope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deduplicationKey",
    "noiseAction",
    "rationale"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestnoisecontrolenvelope.v0.1"
    },
    "deduplicationKey": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "duplicateOfRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "noiseAction": {
      "enum": [
        "EMIT",
        "COLLAPSE_DUPLICATES",
        "SUPPRESS_LOW_VALUE",
        "EXPIRE_STALE",
        "REVIEW_REQUIRED",
        "ESCALATE_HIGH_CONSEQUENCE"
      ]
    },
    "maxPerScopePerWindow": {
      "type": "integer",
      "minimum": 1
    },
    "suppressUntilAfter": {
      "type": "string",
      "format": "date-time"
    },
    "farmerVisibleSummary": {
      "type": "string"
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
