{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestdisplayenvelope-v0.1/v0.1",
  "title": "OFARM RequestDisplayEnvelope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "displayEnvelopeId",
    "requestRef",
    "requestType",
    "farmerFacingTitle",
    "actionText",
    "priority",
    "burdenEstimate",
    "dueText",
    "consequenceText",
    "qualification"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestdisplayenvelope.v0.1"
    },
    "displayEnvelopeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestType": {
      "enum": [
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST"
      ]
    },
    "farmerFacingTitle": {
      "type": "string",
      "minLength": 1
    },
    "conciseReason": {
      "type": "string"
    },
    "actionText": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "enum": [
        "P0_NOW",
        "P1_TODAY",
        "P2_THIS_WEEK",
        "P3_THIS_SEASON",
        "P4_OPTIONAL"
      ]
    },
    "burdenEstimate": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestburdenestimate-v0.1/v0.1",
      "title": "OFARM RequestBurdenEstimate v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "burdenLevel",
        "estimatedEffort",
        "operatorType"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestburdenestimate.v0.1"
        },
        "burdenLevel": {
          "enum": [
            "TRIVIAL",
            "LOW",
            "MODERATE",
            "HIGH",
            "VERY_HIGH"
          ]
        },
        "estimatedEffort": {
          "type": "string",
          "minLength": 1
        },
        "operatorType": {
          "enum": [
            "FARMER",
            "WORKER",
            "CONTRACTOR",
            "ADVISOR",
            "SENSOR_PROCESS",
            "AGENT",
            "ANY_AUTHORIZED"
          ]
        },
        "requiresTravel": {
          "type": "boolean"
        },
        "requiresEquipment": {
          "type": "boolean"
        },
        "safetyNote": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "dueText": {
      "type": "string",
      "minLength": 1
    },
    "consequenceText": {
      "type": "string",
      "minLength": 1
    },
    "qualification": {
      "enum": [
        "ADVISORY_ONLY",
        "OPERATIONAL_TASK",
        "EVIDENCE_RELATED",
        "COMPLIANCE_BLOCKING_WITH_BASIS",
        "PERMISSION_LIMITED",
        "REVIEW_REQUIRED"
      ]
    },
    "hiddenTechnicalRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
