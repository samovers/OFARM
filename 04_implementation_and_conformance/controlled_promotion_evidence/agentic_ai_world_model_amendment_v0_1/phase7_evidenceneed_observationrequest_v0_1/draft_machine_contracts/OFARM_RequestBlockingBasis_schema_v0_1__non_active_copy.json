{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestblockingbasis-v0.1/v0.1",
  "title": "OFARM RequestBlockingBasis v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "basisType",
    "basisRef",
    "blockingEffect",
    "basisRationale"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestblockingbasis.v0.1"
    },
    "basisType": {
      "enum": [
        "ACTIVE_PACK_RULE",
        "EVIDENCE_SUFFICIENCY_POLICY",
        "AUTHORITY_REQUIREMENT",
        "OUTPUT_PUBLICATION_GATE",
        "PROMOTION_PATH_REQUIREMENT",
        "ACCEPTED_RFC_REQUIREMENT",
        "HUMAN_REVIEW_DECISION"
      ]
    },
    "basisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "blockingEffect": {
      "enum": [
        "BLOCKS_PROMOTION",
        "BLOCKS_OUTPUT_APPROVAL",
        "BLOCKS_FILING",
        "BLOCKS_ATTESTATION",
        "BLOCKS_EXECUTION_ACCEPTANCE",
        "REQUIRES_REVIEW"
      ]
    },
    "basisRationale": {
      "type": "string",
      "minLength": 1
    },
    "reviewPathRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
