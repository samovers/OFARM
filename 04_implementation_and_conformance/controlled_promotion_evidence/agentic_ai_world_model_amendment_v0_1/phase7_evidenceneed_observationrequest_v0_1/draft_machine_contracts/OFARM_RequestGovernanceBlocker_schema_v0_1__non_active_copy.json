{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestgovernanceblocker-v0.1/v0.1",
  "title": "OFARM RequestGovernanceBlocker v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "blockerId",
    "blockedRequestRef",
    "blockerType",
    "reason",
    "expectedDisposition"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestgovernanceblocker.v0.1"
    },
    "blockerId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "blockedRequestRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "blockerType": {
      "enum": [
        "MISSING_CONSEQUENCE",
        "MISSING_BLOCKING_BASIS",
        "TASK_SPAM",
        "IMPLIES_ACCEPTED_FACT",
        "REQUEST_USED_AS_EVIDENCE",
        "WAIVER_USED_AS_EVIDENCE",
        "LOCAL_KNOWLEDGE_PROMOTED_WITHOUT_REVIEW",
        "UNKNOWN"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "expectedDisposition": {
      "enum": [
        "BLOCK",
        "DOWNGRADE",
        "REVIEW_REQUIRED",
        "COLLAPSE_DUPLICATE",
        "EXPIRE",
        "QUALIFY_OUTPUT"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
