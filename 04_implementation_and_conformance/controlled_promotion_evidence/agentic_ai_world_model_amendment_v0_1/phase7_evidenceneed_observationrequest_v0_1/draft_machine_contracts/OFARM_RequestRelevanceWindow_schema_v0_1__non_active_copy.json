{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestrelevancewindow-v0.1/v0.1",
  "title": "OFARM RequestRelevanceWindow v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "windowType",
    "startsAt",
    "endsAt",
    "expiryConsequence"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestrelevancewindow.v0.1"
    },
    "windowType": {
      "enum": [
        "FIXED_TIME",
        "CROP_STAGE",
        "OPERATION_WINDOW",
        "PACK_DEADLINE",
        "OUTPUT_ASSEMBLY_WINDOW",
        "ADVISORY_VALIDITY",
        "OTHER"
      ]
    },
    "startsAt": {
      "type": "string",
      "format": "date-time"
    },
    "endsAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiryConsequence": {
      "enum": [
        "EXPIRE_REQUEST",
        "REQUIRES_REVIEW",
        "DOWNGRADE_TO_ADVISORY",
        "BLOCK_OUTPUT",
        "NO_AUTOMATIC_EFFECT"
      ]
    },
    "linkedValidityWindowRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
