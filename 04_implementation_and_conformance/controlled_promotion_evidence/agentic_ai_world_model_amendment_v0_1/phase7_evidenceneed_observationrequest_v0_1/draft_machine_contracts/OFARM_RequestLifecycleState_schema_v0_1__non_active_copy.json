{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestlifecyclestate-v0.1/v0.1",
  "title": "OFARM RequestLifecycleState v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "lastChangedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestlifecyclestate.v0.1"
    },
    "status": {
      "enum": [
        "OPEN",
        "IN_PROGRESS",
        "SATISFIED_PENDING_REVIEW",
        "SATISFIED_ACCEPTED",
        "WAIVED_BY_REVIEW",
        "EXPIRED",
        "SUPERSEDED",
        "REJECTED",
        "DUPLICATE_COLLAPSED",
        "BLOCKED_INVALID"
      ]
    },
    "lastChangedAt": {
      "type": "string",
      "format": "date-time"
    },
    "changedByRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "reasonCode": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
