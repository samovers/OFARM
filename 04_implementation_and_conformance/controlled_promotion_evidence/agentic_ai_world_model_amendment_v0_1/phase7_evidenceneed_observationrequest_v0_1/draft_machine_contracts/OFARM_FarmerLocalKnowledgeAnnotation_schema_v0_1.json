{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-farmerlocalknowledgeannotation-v0.1/v0.1",
  "title": "OFARM FarmerLocalKnowledgeAnnotation v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "annotationId",
    "requestRef",
    "authorPartyRef",
    "narrative",
    "createdAt",
    "posture"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.farmerlocalknowledgeannotation.v0.1"
    },
    "annotationId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "authorPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "narrative": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "UNKNOWN"
      ]
    },
    "posture": {
      "enum": [
        "LOCAL_KNOWLEDGE_ADVISORY",
        "CANDIDATE_EVIDENCE",
        "CONTEXT_NOTE",
        "CONTESTS_REQUEST",
        "SATISFACTION_INPUT"
      ]
    },
    "requiresReview": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
