{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestcompletioncriteria-v0.1/v0.1",
  "title": "OFARM RequestCompletionCriteria v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "criteriaId",
    "requiredArtifactClasses",
    "reviewRequired",
    "unacceptableCompletion"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestcompletioncriteria.v0.1"
    },
    "criteriaId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requiredArtifactClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "minimumCount": {
      "type": "integer",
      "minimum": 1
    },
    "reviewRequired": {
      "type": "boolean"
    },
    "authorityRequired": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "promotionEffect": {
      "enum": [
        "NO_AUTOMATIC_PROMOTION",
        "MAY_UNBLOCK_REVIEW",
        "MAY_UNBLOCK_PREFLIGHT",
        "MAY_UNBLOCK_OUTPUT_PREVIEW",
        "MAY_UNBLOCK_PROMOTION_PATH"
      ]
    },
    "unacceptableCompletion": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
