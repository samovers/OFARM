{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-observationrequest-v0.2/v0.1",
  "title": "OFARM ObservationRequest v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "observationRequestId",
    "targetTwin",
    "targetScopes",
    "requestingBasis",
    "observationType",
    "reason",
    "severity",
    "priority",
    "posture",
    "acceptableCollectionMethods",
    "acceptableArtifactForms",
    "completionCriteria",
    "burdenEstimate",
    "relevanceWindow",
    "noiseControl",
    "createdAt",
    "lifecycleState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.observationrequest.v0.2"
    },
    "observationRequestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "targetScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://ofarm.dev/schema/ofarm-requesttargetscope-v0.1/v0.1",
        "title": "OFARM RequestTargetScope v0.1",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "schemaVersion": {
            "const": "ofarm.requesttargetscope.v0.1"
          },
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "BIN",
              "STORAGE_FACILITY",
              "FACILITY",
              "OPERATION",
              "MATERIAL",
              "PRODUCT",
              "DOCUMENT",
              "OUTPUT_ASSEMBLY",
              "PACK",
              "QUERY",
              "WORLD_MODEL",
              "SCENARIO",
              "AGENT_RUN",
              "PARTY",
              "TENANT",
              "OTHER"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "scopeLabel": {
            "type": "string"
          },
          "geometryBasisRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "notes": {
            "type": "string"
          }
        },
        "$defs": {},
        "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
      }
    },
    "requestingBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "sourceRef",
        "rationale"
      ],
      "properties": {
        "sourceType": {
          "enum": [
            "AGENT_RUN",
            "WORLD_MODEL_RUN",
            "PREFLIGHT",
            "PACK_RULE",
            "OUTPUT_ASSEMBLY",
            "HUMAN_USER",
            "REVIEW",
            "IMPORT",
            "CURRENT_STATE_RECHECK",
            "BRIDGE_CANDIDATE",
            "OTHER"
          ]
        },
        "sourceRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "traceRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "linkedEvidenceNeedRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "linkedRefs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packRuleRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "outputRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "planRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "scenarioRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "promotionPathRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "worldModelRunRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "agentRunRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "bridgeCandidateRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "evidenceSufficiencyCaseRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "authorityDecisionTraceRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "observationType": {
      "enum": [
        "SCOUTING_PHOTO",
        "FIELD_INSPECTION",
        "CROP_STAGE_CHECK",
        "PEST_DISEASE_CHECK",
        "SOIL_MOISTURE_CHECK",
        "BIN_TEMPERATURE_CHECK",
        "LOT_TRANSFER_CHECK",
        "PRODUCT_LABEL_PHOTO",
        "SAMPLE_COLLECTION",
        "LOCAL_NARRATIVE",
        "SENSOR_READING",
        "OTHER"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "consequenceIfMissing": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "priority": {
      "enum": [
        "P0_NOW",
        "P1_TODAY",
        "P2_THIS_WEEK",
        "P3_THIS_SEASON",
        "P4_OPTIONAL"
      ]
    },
    "posture": {
      "enum": [
        "ADVISORY",
        "OPERATIONAL",
        "EVIDENCE_SUFFICIENCY_RELATED",
        "COMPLIANCE_BLOCKING"
      ]
    },
    "acceptableCollectionMethods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptableArtifactForms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "minimumAcceptableCapture": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "preferredCapture": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authorityRequiredToSatisfy": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "completionCriteria": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestcompletioncriteria-v0.1/v0.1",
      "title": "OFARM RequestCompletionCriteria v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "criteriaId",
        "requiredArtifactClasses",
        "reviewRequired",
        "unacceptableCompletion"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestcompletioncriteria.v0.1"
        },
        "criteriaId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "requiredArtifactClasses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "minimumCount": {
          "type": "integer",
          "minimum": 1
        },
        "reviewRequired": {
          "type": "boolean"
        },
        "authorityRequired": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "promotionEffect": {
          "enum": [
            "NO_AUTOMATIC_PROMOTION",
            "MAY_UNBLOCK_REVIEW",
            "MAY_UNBLOCK_PREFLIGHT",
            "MAY_UNBLOCK_OUTPUT_PREVIEW",
            "MAY_UNBLOCK_PROMOTION_PATH"
          ]
        },
        "unacceptableCompletion": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "burdenEstimate": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestburdenestimate-v0.1/v0.1",
      "title": "OFARM RequestBurdenEstimate v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "burdenLevel",
        "estimatedEffort",
        "operatorType"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestburdenestimate.v0.1"
        },
        "burdenLevel": {
          "enum": [
            "TRIVIAL",
            "LOW",
            "MODERATE",
            "HIGH",
            "VERY_HIGH"
          ]
        },
        "estimatedEffort": {
          "type": "string",
          "minLength": 1
        },
        "operatorType": {
          "enum": [
            "FARMER",
            "WORKER",
            "CONTRACTOR",
            "ADVISOR",
            "SENSOR_PROCESS",
            "AGENT",
            "ANY_AUTHORIZED"
          ]
        },
        "requiresTravel": {
          "type": "boolean"
        },
        "requiresEquipment": {
          "type": "boolean"
        },
        "safetyNote": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "relevanceWindow": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestrelevancewindow-v0.1/v0.1",
      "title": "OFARM RequestRelevanceWindow v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "windowType",
        "startsAt",
        "endsAt",
        "expiryConsequence"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestrelevancewindow.v0.1"
        },
        "windowType": {
          "enum": [
            "FIXED_TIME",
            "CROP_STAGE",
            "OPERATION_WINDOW",
            "PACK_DEADLINE",
            "OUTPUT_ASSEMBLY_WINDOW",
            "ADVISORY_VALIDITY",
            "OTHER"
          ]
        },
        "startsAt": {
          "type": "string",
          "format": "date-time"
        },
        "endsAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiryConsequence": {
          "enum": [
            "EXPIRE_REQUEST",
            "REQUIRES_REVIEW",
            "DOWNGRADE_TO_ADVISORY",
            "BLOCK_OUTPUT",
            "NO_AUTOMATIC_EFFECT"
          ]
        },
        "linkedValidityWindowRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "notes": {
          "type": "string"
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "noiseControl": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestnoisecontrolenvelope-v0.1/v0.1",
      "title": "OFARM RequestNoiseControlEnvelope v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "deduplicationKey",
        "noiseAction",
        "rationale"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestnoisecontrolenvelope.v0.1"
        },
        "deduplicationKey": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "duplicateOfRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "noiseAction": {
          "enum": [
            "EMIT",
            "COLLAPSE_DUPLICATES",
            "SUPPRESS_LOW_VALUE",
            "EXPIRE_STALE",
            "REVIEW_REQUIRED",
            "ESCALATE_HIGH_CONSEQUENCE"
          ]
        },
        "maxPerScopePerWindow": {
          "type": "integer",
          "minimum": 1
        },
        "suppressUntilAfter": {
          "type": "string",
          "format": "date-time"
        },
        "farmerVisibleSummary": {
          "type": "string"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "localKnowledgeAnnotationAllowed": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycleState": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestlifecyclestate-v0.1/v0.1",
      "title": "OFARM RequestLifecycleState v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "status",
        "lastChangedAt"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestlifecyclestate.v0.1"
        },
        "status": {
          "enum": [
            "OPEN",
            "IN_PROGRESS",
            "SATISFIED_PENDING_REVIEW",
            "SATISFIED_ACCEPTED",
            "WAIVED_BY_REVIEW",
            "EXPIRED",
            "SUPERSEDED",
            "REJECTED",
            "DUPLICATE_COLLAPSED",
            "BLOCKED_INVALID"
          ]
        },
        "lastChangedAt": {
          "type": "string",
          "format": "date-time"
        },
        "changedByRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "reasonCode": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
