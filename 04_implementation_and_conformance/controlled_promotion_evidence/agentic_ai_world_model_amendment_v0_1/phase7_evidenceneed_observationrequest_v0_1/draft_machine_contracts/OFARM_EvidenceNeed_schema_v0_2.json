{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-evidenceneed-v0.2/v0.1",
  "title": "OFARM EvidenceNeed v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evidenceNeedId",
    "targetTwin",
    "targetScopes",
    "requestingBasis",
    "evidenceGap",
    "insufficiencyReason",
    "severity",
    "priority",
    "posture",
    "acceptableEvidenceOptions",
    "consequenceIfUnresolved",
    "relevanceWindow",
    "completionCriteria",
    "noiseControl",
    "createdAt",
    "lifecycleState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.evidenceneed.v0.2"
    },
    "evidenceNeedId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "targetScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://ofarm.dev/schema/ofarm-requesttargetscope-v0.1/v0.1",
        "title": "OFARM RequestTargetScope v0.1",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "schemaVersion": {
            "const": "ofarm.requesttargetscope.v0.1"
          },
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "BIN",
              "STORAGE_FACILITY",
              "FACILITY",
              "OPERATION",
              "MATERIAL",
              "PRODUCT",
              "DOCUMENT",
              "OUTPUT_ASSEMBLY",
              "PACK",
              "QUERY",
              "WORLD_MODEL",
              "SCENARIO",
              "AGENT_RUN",
              "PARTY",
              "TENANT",
              "OTHER"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "scopeLabel": {
            "type": "string"
          },
          "geometryBasisRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "notes": {
            "type": "string"
          }
        },
        "$defs": {},
        "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
      }
    },
    "requestingBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "sourceRef",
        "rationale"
      ],
      "properties": {
        "sourceType": {
          "enum": [
            "AGENT_RUN",
            "WORLD_MODEL_RUN",
            "PREFLIGHT",
            "PACK_RULE",
            "OUTPUT_ASSEMBLY",
            "HUMAN_USER",
            "REVIEW",
            "IMPORT",
            "CURRENT_STATE_RECHECK",
            "BRIDGE_CANDIDATE",
            "OTHER"
          ]
        },
        "sourceRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "traceRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "blockedClaimOrDecisionRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "linkedRefs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packRuleRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "outputRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "planRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "scenarioRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "promotionPathRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "worldModelRunRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "agentRunRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "bridgeCandidateRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "evidenceSufficiencyCaseRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "authorityDecisionTraceRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "evidenceGap": {
      "type": "string",
      "minLength": 1
    },
    "insufficiencyReason": {
      "type": "string",
      "minLength": 1
    },
    "decisionSensitivity": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "UNKNOWN"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "priority": {
      "enum": [
        "P0_NOW",
        "P1_TODAY",
        "P2_THIS_WEEK",
        "P3_THIS_SEASON",
        "P4_OPTIONAL"
      ]
    },
    "posture": {
      "enum": [
        "ADVISORY",
        "OPERATIONAL",
        "EVIDENCE_SUFFICIENCY_RELATED",
        "COMPLIANCE_BLOCKING"
      ]
    },
    "acceptableEvidenceOptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://ofarm.dev/schema/ofarm-evidenceoption-v0.1/v0.1",
        "title": "OFARM EvidenceOption v0.1",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "optionId",
          "evidenceClass",
          "acceptableArtifactTypes",
          "minimumQuality"
        ],
        "properties": {
          "schemaVersion": {
            "const": "ofarm.evidenceoption.v0.1"
          },
          "optionId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "evidenceClass": {
            "enum": [
              "PHOTO",
              "DOCUMENT",
              "SENSOR_READING",
              "MACHINE_LOG",
              "INVOICE",
              "LABEL_PHOTO",
              "LAB_RESULT",
              "CONTRACTOR_ATTESTATION",
              "FIELD_OBSERVATION",
              "STORAGE_OBSERVATION",
              "LOT_TRANSFER_RECORD",
              "BUYER_DOCUMENT",
              "LOCAL_NARRATIVE",
              "OTHER"
            ]
          },
          "acceptableArtifactTypes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "minimumQuality": {
            "type": "string",
            "minLength": 1
          },
          "authorityRequired": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "externalEvidenceRequired": {
            "type": "boolean"
          },
          "reviewRequired": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "$defs": {},
        "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
      }
    },
    "externalEvidenceMandatoryBeforePromotion": {
      "type": "boolean"
    },
    "complianceBlockingBasis": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestblockingbasis-v0.1/v0.1",
      "title": "OFARM RequestBlockingBasis v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "basisType",
        "basisRef",
        "blockingEffect",
        "basisRationale"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestblockingbasis.v0.1"
        },
        "basisType": {
          "enum": [
            "ACTIVE_PACK_RULE",
            "EVIDENCE_SUFFICIENCY_POLICY",
            "AUTHORITY_REQUIREMENT",
            "OUTPUT_PUBLICATION_GATE",
            "PROMOTION_PATH_REQUIREMENT",
            "ACCEPTED_RFC_REQUIREMENT",
            "HUMAN_REVIEW_DECISION"
          ]
        },
        "basisRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "blockingEffect": {
          "enum": [
            "BLOCKS_PROMOTION",
            "BLOCKS_OUTPUT_APPROVAL",
            "BLOCKS_FILING",
            "BLOCKS_ATTESTATION",
            "BLOCKS_EXECUTION_ACCEPTANCE",
            "REQUIRES_REVIEW"
          ]
        },
        "basisRationale": {
          "type": "string",
          "minLength": 1
        },
        "reviewPathRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "notes": {
          "type": "string"
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "consequenceIfUnresolved": {
      "type": "string",
      "minLength": 1
    },
    "relevanceWindow": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestrelevancewindow-v0.1/v0.1",
      "title": "OFARM RequestRelevanceWindow v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "windowType",
        "startsAt",
        "endsAt",
        "expiryConsequence"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestrelevancewindow.v0.1"
        },
        "windowType": {
          "enum": [
            "FIXED_TIME",
            "CROP_STAGE",
            "OPERATION_WINDOW",
            "PACK_DEADLINE",
            "OUTPUT_ASSEMBLY_WINDOW",
            "ADVISORY_VALIDITY",
            "OTHER"
          ]
        },
        "startsAt": {
          "type": "string",
          "format": "date-time"
        },
        "endsAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiryConsequence": {
          "enum": [
            "EXPIRE_REQUEST",
            "REQUIRES_REVIEW",
            "DOWNGRADE_TO_ADVISORY",
            "BLOCK_OUTPUT",
            "NO_AUTOMATIC_EFFECT"
          ]
        },
        "linkedValidityWindowRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "notes": {
          "type": "string"
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "completionCriteria": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestcompletioncriteria-v0.1/v0.1",
      "title": "OFARM RequestCompletionCriteria v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "criteriaId",
        "requiredArtifactClasses",
        "reviewRequired",
        "unacceptableCompletion"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestcompletioncriteria.v0.1"
        },
        "criteriaId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "requiredArtifactClasses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "minimumCount": {
          "type": "integer",
          "minimum": 1
        },
        "reviewRequired": {
          "type": "boolean"
        },
        "authorityRequired": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "promotionEffect": {
          "enum": [
            "NO_AUTOMATIC_PROMOTION",
            "MAY_UNBLOCK_REVIEW",
            "MAY_UNBLOCK_PREFLIGHT",
            "MAY_UNBLOCK_OUTPUT_PREVIEW",
            "MAY_UNBLOCK_PROMOTION_PATH"
          ]
        },
        "unacceptableCompletion": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "noiseControl": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestnoisecontrolenvelope-v0.1/v0.1",
      "title": "OFARM RequestNoiseControlEnvelope v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "deduplicationKey",
        "noiseAction",
        "rationale"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestnoisecontrolenvelope.v0.1"
        },
        "deduplicationKey": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "duplicateOfRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "noiseAction": {
          "enum": [
            "EMIT",
            "COLLAPSE_DUPLICATES",
            "SUPPRESS_LOW_VALUE",
            "EXPIRE_STALE",
            "REVIEW_REQUIRED",
            "ESCALATE_HIGH_CONSEQUENCE"
          ]
        },
        "maxPerScopePerWindow": {
          "type": "integer",
          "minimum": 1
        },
        "suppressUntilAfter": {
          "type": "string",
          "format": "date-time"
        },
        "farmerVisibleSummary": {
          "type": "string"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "localKnowledgeAllowed": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycleState": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://ofarm.dev/schema/ofarm-requestlifecyclestate-v0.1/v0.1",
      "title": "OFARM RequestLifecycleState v0.1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "status",
        "lastChangedAt"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.requestlifecyclestate.v0.1"
        },
        "status": {
          "enum": [
            "OPEN",
            "IN_PROGRESS",
            "SATISFIED_PENDING_REVIEW",
            "SATISFIED_ACCEPTED",
            "WAIVED_BY_REVIEW",
            "EXPIRED",
            "SUPERSEDED",
            "REJECTED",
            "DUPLICATE_COLLAPSED",
            "BLOCKED_INVALID"
          ]
        },
        "lastChangedAt": {
          "type": "string",
          "format": "date-time"
        },
        "changedByRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "reasonCode": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "$defs": {},
      "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
