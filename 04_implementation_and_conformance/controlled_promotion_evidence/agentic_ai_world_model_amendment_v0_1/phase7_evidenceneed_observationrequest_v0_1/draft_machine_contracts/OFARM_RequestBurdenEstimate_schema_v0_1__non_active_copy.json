{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestburdenestimate-v0.1/v0.1",
  "title": "OFARM RequestBurdenEstimate v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "burdenLevel",
    "estimatedEffort",
    "operatorType"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestburdenestimate.v0.1"
    },
    "burdenLevel": {
      "enum": [
        "TRIVIAL",
        "LOW",
        "MODERATE",
        "HIGH",
        "VERY_HIGH"
      ]
    },
    "estimatedEffort": {
      "type": "string",
      "minLength": 1
    },
    "operatorType": {
      "enum": [
        "FARMER",
        "WORKER",
        "CONTRACTOR",
        "ADVISOR",
        "SENSOR_PROCESS",
        "AGENT",
        "ANY_AUTHORIZED"
      ]
    },
    "requiresTravel": {
      "type": "boolean"
    },
    "requiresEquipment": {
      "type": "boolean"
    },
    "safetyNote": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
