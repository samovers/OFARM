{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestsatisfactiontrace-v0.1/v0.1",
  "title": "OFARM RequestSatisfactionTrace v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "satisfactionTraceId",
    "requestRef",
    "requestType",
    "satisfactionOutcome",
    "satisfyingArtifacts",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestsatisfactiontrace.v0.1"
    },
    "satisfactionTraceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestType": {
      "enum": [
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST"
      ]
    },
    "satisfactionOutcome": {
      "enum": [
        "SATISFIED_PENDING_REVIEW",
        "SATISFIED_ACCEPTED",
        "PARTIALLY_SATISFIED",
        "WAIVED_BY_REVIEW",
        "REJECTED",
        "EXPIRED",
        "SUPERSEDED"
      ]
    },
    "satisfyingArtifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifactRef",
          "artifactClass"
        ],
        "properties": {
          "artifactRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "artifactClass": {
            "type": "string",
            "minLength": 1
          },
          "candidateOnly": {
            "type": "boolean"
          }
        }
      }
    },
    "reviewRequired": {
      "type": "boolean"
    },
    "reviewDecisionRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "promotionEffect": {
      "enum": [
        "NO_AUTOMATIC_PROMOTION",
        "MAY_UNBLOCK_REVIEW",
        "MAY_UNBLOCK_PREFLIGHT",
        "MAY_UNBLOCK_OUTPUT_PREVIEW",
        "MAY_UNBLOCK_PROMOTION_PATH"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
