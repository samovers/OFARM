{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestpriorityclassification-v0.1/v0.1",
  "title": "OFARM RequestPriorityClassification v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "priority",
    "severity",
    "rationale"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestpriorityclassification.v0.1"
    },
    "priority": {
      "enum": [
        "P0_NOW",
        "P1_TODAY",
        "P2_THIS_WEEK",
        "P3_THIS_SEASON",
        "P4_OPTIONAL"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "farmerFacingLabel": {
      "type": "string"
    },
    "escalationAllowed": {
      "type": "boolean"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
