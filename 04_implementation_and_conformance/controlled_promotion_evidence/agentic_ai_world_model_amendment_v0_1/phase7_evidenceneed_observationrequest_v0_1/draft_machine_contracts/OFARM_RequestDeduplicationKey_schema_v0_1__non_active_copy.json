{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-requestdeduplicationkey-v0.1/v0.1",
  "title": "OFARM RequestDeduplicationKey v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deduplicationKey",
    "targetScopeRefs",
    "requestKind",
    "basisHash"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestdeduplicationkey.v0.1"
    },
    "deduplicationKey": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetScopeRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "requestKind": {
      "enum": [
        "EVIDENCE_NEED",
        "OBSERVATION_REQUEST"
      ]
    },
    "basisHash": {
      "type": "string",
      "minLength": 1
    },
    "timeBucket": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
