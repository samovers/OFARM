{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-evidenceoption-v0.1/v0.1",
  "title": "OFARM EvidenceOption v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "optionId",
    "evidenceClass",
    "acceptableArtifactTypes",
    "minimumQuality"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.evidenceoption.v0.1"
    },
    "optionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "evidenceClass": {
      "enum": [
        "PHOTO",
        "DOCUMENT",
        "SENSOR_READING",
        "MACHINE_LOG",
        "INVOICE",
        "LABEL_PHOTO",
        "LAB_RESULT",
        "CONTRACTOR_ATTESTATION",
        "FIELD_OBSERVATION",
        "STORAGE_OBSERVATION",
        "LOT_TRANSFER_RECORD",
        "BUYER_DOCUMENT",
        "LOCAL_NARRATIVE",
        "OTHER"
      ]
    },
    "acceptableArtifactTypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "minimumQuality": {
      "type": "string",
      "minLength": 1
    },
    "authorityRequired": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "externalEvidenceRequired": {
      "type": "boolean"
    },
    "reviewRequired": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {},
  "$comment": "Phase 7 candidate contract; supporting only; not active until promoted."
}
