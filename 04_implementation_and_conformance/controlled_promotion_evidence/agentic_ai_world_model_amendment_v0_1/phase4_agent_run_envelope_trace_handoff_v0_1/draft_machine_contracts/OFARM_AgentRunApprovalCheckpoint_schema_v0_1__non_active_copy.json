{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentRunApprovalCheckpoint v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "checkpointType",
    "approvalState",
    "requiredForActionClasses"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "checkpointType": {
      "enum": [
        "HUMAN_APPROVAL",
        "PLATFORM_POLICY_APPROVAL",
        "REVIEW_QUEUE_ACCEPTANCE",
        "SHARING_APPROVAL",
        "OUTPUT_APPROVAL",
        "PREFLIGHT_ACKNOWLEDGEMENT"
      ]
    },
    "approvalState": {
      "enum": [
        "NOT_REQUIRED",
        "PENDING",
        "APPROVED",
        "DENIED",
        "EXPIRED",
        "REVOKED"
      ]
    },
    "requiredForActionClasses": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "approverPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "decisionTraceRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
