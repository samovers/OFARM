{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentRunInputBundle v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "bundlePurpose",
    "inputRefs",
    "qualificationSummary"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "bundlePurpose": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "inputRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "querySpecificationRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "queryPlanIRRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "contextSnapshotRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "materializationResultRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "packActivationSetRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "qualificationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshnessState",
        "permissionState",
        "redactionState",
        "advisoryState"
      ],
      "properties": {
        "freshnessState": {
          "enum": [
            "FRESH",
            "STALE",
            "UNKNOWN",
            "NOT_APPLICABLE"
          ]
        },
        "permissionState": {
          "enum": [
            "FULL",
            "PERMISSION_LIMITED",
            "UNKNOWN"
          ]
        },
        "redactionState": {
          "enum": [
            "NONE",
            "REDACTED",
            "UNKNOWN"
          ]
        },
        "advisoryState": {
          "enum": [
            "COMPLIANCE_BASIS",
            "ADVISORY_ONLY",
            "DRAFT_ONLY",
            "MIXED"
          ]
        }
      }
    }
  }
}
