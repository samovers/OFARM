{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentBlockedActionTrace v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "runRef",
    "attemptedActionClass",
    "attemptedOperationRef",
    "targetTwin",
    "targetScopeRefs",
    "blockingReasonCodes",
    "requiredResponse",
    "acceptedFarmFactCreated"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "schemaVersion": {
      "const": "0.2"
    },
    "runRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "toolInvocationTraceRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "attemptedActionClass": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "attemptedOperationRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "UNKNOWN"
      ]
    },
    "targetScopeRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "blockingReasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "violatedEnvelopeConstraint": {
      "type": "string"
    },
    "violatedAuthorityConstraint": {
      "type": "string"
    },
    "violatedFreshnessConstraint": {
      "type": "string"
    },
    "violatedSharingConstraint": {
      "type": "string"
    },
    "violatedPackOrEvidenceConstraint": {
      "type": "string"
    },
    "requiredResponse": {
      "enum": [
        "BLOCK_ACTION",
        "STOP_RUN",
        "REQUEST_HUMAN_APPROVAL",
        "REQUEST_REVIEW",
        "DOWNGRADE_TO_ADVISORY",
        "REQUERY_OR_RECOMPUTE"
      ]
    },
    "draftMaterialRetained": {
      "type": "boolean"
    },
    "acceptedFarmFactCreated": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
