{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentHandoffEnvelope v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "handoffId",
    "sourceRunRef",
    "sourceAgentInstanceRef",
    "handoffPurpose",
    "includedContextRefs",
    "permissionsTransferred",
    "authorityTransferred",
    "receivingAgentMustReauthorize",
    "expiresAt"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "schemaVersion": {
      "const": "0.2"
    },
    "handoffId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "sourceRunRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "sourceAgentInstanceRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "receivingAgentProfileRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "receivingAgentInstanceRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "handoffPurpose": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "includedContextRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "includedArtifactRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "includedInputBundleRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "includedOutputDispositionRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "redactedOrExcludedRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "permissionLimitedMarkers": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "staleBasisMarkers": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "unresolvedConflictRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "blockedActionTraceRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "requiredHumanDecisionRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "permissionsTransferred": {
      "const": false
    },
    "authorityTransferred": {
      "const": false
    },
    "permissionsExplicitlyNotTransferred": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "receivingAgentMustReauthorize": {
      "const": true
    },
    "receivingAgentPreflightRequired": {
      "type": "boolean"
    },
    "traceRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
