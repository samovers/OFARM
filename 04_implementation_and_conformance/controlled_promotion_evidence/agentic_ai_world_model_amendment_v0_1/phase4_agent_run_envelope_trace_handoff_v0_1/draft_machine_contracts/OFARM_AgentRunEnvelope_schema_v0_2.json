{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentRunEnvelope v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "runId",
    "runPurpose",
    "actorshipBindingRef",
    "sponsorRef",
    "objective",
    "targetTwin",
    "targetScopeRefs",
    "requestedActionClasses",
    "allowedActionClasses",
    "authorityEnvelopeRefs",
    "allowedToolOrOperationRefs",
    "allowedWriteSurfaces",
    "allowedOutputDispositions",
    "preflightRequired",
    "humanApprovalRequired",
    "freshnessRequirementRefs",
    "stopConditionRefs",
    "traceRequired",
    "expiresAt",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "schemaVersion": {
      "const": "0.2"
    },
    "runId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "runPurpose": {
      "enum": [
        "READ_ASSISTANCE",
        "EVIDENCE_CAPTURE",
        "COMPLIANCE_PREFLIGHT",
        "ADVISORY_ANALYSIS",
        "PLANNING",
        "CONTRACTOR_COORDINATION",
        "LOT_STORAGE_TRACE",
        "SHARING_PREPARATION",
        "DISPUTE_RECONSTRUCTION",
        "WORLD_MODEL_SCENARIO",
        "HANDOFF_RECEIVER"
      ]
    },
    "actorshipBindingRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "sponsorRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "initiatingSurfaceRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH"
      ]
    },
    "targetScopeRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "scopeInheritanceMode": {
      "enum": [
        "EXPLICIT_ONLY",
        "ALLOW_CHILD_SCOPES",
        "ALLOW_DECLARED_GRAPH_SCOPE"
      ]
    },
    "requestedActionClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "allowedActionClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "forbiddenActionClasses": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "authorityEnvelopeRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "permittedQuerySpecificationRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "permittedQueryClasses": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "allowedToolOrOperationRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "allowedWriteSurfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "NONE",
          "DRAFT_STORE",
          "ADVISORY_WORKSPACE",
          "EVIDENCE_CANDIDATE_STORE",
          "REVIEW_QUEUE",
          "BRIDGECANDIDATE_QUEUE",
          "OUTPUT_PREVIEW_STORE",
          "HANDOFF_CONTEXT_STORE"
        ]
      }
    },
    "allowedOutputDispositions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "NO_ARTIFACT_CREATED",
          "READ_RESULT",
          "QUALIFIED_READ_RESULT",
          "ADVISORY_TEXT",
          "HYPOTHESIS",
          "DRAFT_ASSERTION",
          "DRAFT_OBSERVATION",
          "EVIDENCE_ATTACHMENT_CANDIDATE",
          "PLANNED_INTERVENTION_DRAFT",
          "OPERATION_CLAIM_DRAFT",
          "BRIDGE_CANDIDATE",
          "REVIEW_REQUEST",
          "PREFLIGHT_RESULT",
          "OUTPUT_PREVIEW",
          "HANDOFF_CONTEXT",
          "BLOCKED_ACTION_RECORD"
        ]
      }
    },
    "preflightRequired": {
      "type": "boolean"
    },
    "humanApprovalRequired": {
      "type": "boolean"
    },
    "approvalCheckpointRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "inputBundleRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "contextSnapshotRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "materializationResultRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "packActivationSetRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "freshnessRequirementRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "sharingAndDataSovereigntyLimits": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "externalCallPolicy": {
      "enum": [
        "NO_EXTERNAL_CALLS",
        "DECLARED_TOOLS_ONLY",
        "DECLARED_TOOLS_WITH_REDACTION",
        "NOT_APPLICABLE"
      ]
    },
    "farmDataLearningPolicy": {
      "enum": [
        "NO_LEARNING",
        "TENANT_LOCAL_ONLY",
        "EXPLICIT_OPT_IN_ONLY",
        "NOT_APPLICABLE"
      ]
    },
    "stopConditionRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "traceRequired": {
      "const": true
    },
    "handoffAllowed": {
      "type": "boolean"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "runtimeConformanceClaimed": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
