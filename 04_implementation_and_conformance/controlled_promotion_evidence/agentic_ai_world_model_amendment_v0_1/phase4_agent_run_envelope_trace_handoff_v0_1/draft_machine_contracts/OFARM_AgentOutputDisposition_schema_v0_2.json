{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentOutputDisposition v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "runRef",
    "dispositionKind",
    "targetTwin",
    "outputPosture",
    "artifactRefs",
    "promotionPath",
    "generatedByAgentProvenanceOnly"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "schemaVersion": {
      "const": "0.2"
    },
    "runRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "toolInvocationTraceRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "dispositionKind": {
      "enum": [
        "NO_ARTIFACT_CREATED",
        "READ_RESULT",
        "QUALIFIED_READ_RESULT",
        "ADVISORY_TEXT",
        "HYPOTHESIS",
        "DRAFT_ASSERTION",
        "DRAFT_OBSERVATION",
        "EVIDENCE_ATTACHMENT_CANDIDATE",
        "PLANNED_INTERVENTION_DRAFT",
        "OPERATION_CLAIM_DRAFT",
        "BRIDGE_CANDIDATE",
        "REVIEW_REQUEST",
        "PREFLIGHT_RESULT",
        "OUTPUT_PREVIEW",
        "HANDOFF_CONTEXT",
        "BLOCKED_ACTION_RECORD"
      ]
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "NOT_APPLICABLE"
      ]
    },
    "outputPosture": {
      "enum": [
        "READ_ONLY",
        "ADVISORY_ONLY",
        "DRAFT_ONLY",
        "REVIEW_REQUIRED",
        "HUMAN_APPROVAL_REQUIRED",
        "PROMOTABLE_AFTER_GATES",
        "DENIED",
        "BLOCKED"
      ]
    },
    "artifactRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "draftRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "reviewRequestRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "promotionPath": {
      "enum": [
        "NONE",
        "NORMAL_OFARM_GATES",
        "BRIDGECANDIDATE_TO_REVIEW",
        "HUMAN_APPROVAL_THEN_GATES",
        "BLOCKED_NO_PATH"
      ]
    },
    "requiresReview": {
      "type": "boolean"
    },
    "requiresHumanApproval": {
      "type": "boolean"
    },
    "freshnessPosture": {
      "enum": [
        "FRESH",
        "STALE",
        "UNKNOWN",
        "NOT_APPLICABLE"
      ]
    },
    "evidencePosture": {
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "NOT_EVALUATED",
        "NOT_APPLICABLE"
      ]
    },
    "handoffAllowed": {
      "type": "boolean"
    },
    "permissionLimited": {
      "type": "boolean"
    },
    "generatedByAgentProvenanceOnly": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  }
}
