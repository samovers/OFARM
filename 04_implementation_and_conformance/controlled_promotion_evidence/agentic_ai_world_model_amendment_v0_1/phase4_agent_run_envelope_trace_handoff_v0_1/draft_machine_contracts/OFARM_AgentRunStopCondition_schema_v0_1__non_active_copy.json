{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentRunStopCondition v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "conditionType",
    "severity",
    "requiredResponse"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "conditionType": {
      "enum": [
        "ENVELOPE_EXPIRED",
        "SCOPE_EXCEEDED",
        "TARGET_TWIN_MISMATCH",
        "UNAUTHORIZED_ACTION",
        "TOOL_NOT_ALLOWED",
        "PREFLIGHT_FAILED",
        "APPROVAL_MISSING",
        "FRESHNESS_INSUFFICIENT",
        "SHARING_LIMIT_EXCEEDED",
        "REVOCATION_DETECTED",
        "EVIDENCE_INSUFFICIENT",
        "PACK_CONTEXT_MISMATCH",
        "UNRESOLVED_CONFLICT",
        "OUTPUT_DISPOSITION_NOT_ALLOWED",
        "HUMAN_GOVERNED_ACTION_ATTEMPTED"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "WARNING",
        "BLOCKING",
        "TERMINAL"
      ]
    },
    "requiredResponse": {
      "enum": [
        "CONTINUE_WITH_QUALIFICATION",
        "DEGRADE",
        "REQUEST_APPROVAL",
        "REQUEST_REVIEW",
        "REQUERY_OR_RECOMPUTE",
        "BLOCK_ACTION",
        "STOP_RUN"
      ]
    },
    "reasonCodeRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
