{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentToolInvocationTrace v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "runRef",
    "toolOrOperationRef",
    "requestedActionClass",
    "targetTwin",
    "targetScopeRefs",
    "sideEffectClass",
    "authorizationPosture",
    "toolResultState",
    "governanceOutcome"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "schemaVersion": {
      "const": "0.2"
    },
    "runRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "toolOrOperationRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "requestedActionClass": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "NOT_APPLICABLE"
      ]
    },
    "targetScopeRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "inputBundleRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "inputSummary": {
      "type": "string"
    },
    "authorizationDecisionTraceRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "preflightResultRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "approvalCheckpointRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "sideEffectClass": {
      "enum": [
        "READ_ONLY",
        "DRAFT_WRITE",
        "CANDIDATE_WRITE",
        "ADVISORY_WRITE",
        "STATE_AFFECTING_WRITE",
        "EXTERNAL_CALL",
        "OUTPUT_PREVIEW",
        "NO_SIDE_EFFECT"
      ]
    },
    "authorizationPosture": {
      "enum": [
        "ALLOWED",
        "DENIED",
        "REVIEW_REQUIRED",
        "HUMAN_APPROVAL_REQUIRED",
        "NOT_EVALUATED"
      ]
    },
    "toolResultState": {
      "enum": [
        "SUCCEEDED",
        "FAILED",
        "PARTIAL",
        "BLOCKED",
        "DEGRADED"
      ]
    },
    "governanceOutcome": {
      "enum": [
        "ALLOWED",
        "BLOCKED",
        "REVIEW_REQUIRED",
        "HUMAN_APPROVAL_REQUIRED",
        "DOWNGRADED",
        "NO_ARTIFACT_CREATED"
      ]
    },
    "outputDispositionRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "runtimeProblemReasonCodeRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM reference"
      }
    },
    "resultQualificationRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "notes": {
      "type": "string"
    }
  }
}
