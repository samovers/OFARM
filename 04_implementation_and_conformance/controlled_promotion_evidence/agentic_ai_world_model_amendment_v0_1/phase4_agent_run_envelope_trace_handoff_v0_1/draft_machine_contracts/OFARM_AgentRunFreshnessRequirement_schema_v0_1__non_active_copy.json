{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OFARM AgentRunFreshnessRequirement v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "schemaVersion",
    "targetUse",
    "requiredFreshnessPosture",
    "onFailure"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "targetUse": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "requiredFreshnessPosture": {
      "enum": [
        "CURRENT_REQUIRED",
        "STALE_ALLOWED_WITH_WARNING",
        "ADVISORY_ONLY_ALLOWED",
        "NOT_APPLICABLE"
      ]
    },
    "freshnessPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM reference"
    },
    "evaluatedState": {
      "enum": [
        "FRESH",
        "STALE",
        "UNKNOWN",
        "NOT_EVALUATED"
      ]
    },
    "onFailure": {
      "enum": [
        "BLOCK",
        "REQUERY",
        "RECOMPUTE",
        "DOWNGRADE_TO_ADVISORY",
        "REQUEST_REVIEW",
        "ALLOW_WITH_QUALIFICATION"
      ]
    }
  }
}
