{
  "schemaVersion": "ofarm.phase6.fieldcrosswalk.v0.1",
  "phase": "AAI-P6",
  "researchSevenQuestions": [
    {
      "question": "Which observations grounded the state?",
      "contract": "WorldModelObservationBasis",
      "field": "observations"
    },
    {
      "question": "Which assumptions extended beyond observations?",
      "contract": "WorldModelAssumptionSet",
      "field": "assumptions"
    },
    {
      "question": "Which model and tool profile produced it?",
      "contract": "WorldModelRun",
      "field": "modelMethodRef + agentRunEnvelopeRef"
    },
    {
      "question": "What uncertainty and intended-use statement applies?",
      "contract": "WorldModelUncertaintyStatement",
      "field": "decisionUseLimit"
    },
    {
      "question": "What validity window applies?",
      "contract": "WorldModelValidityWindow",
      "field": "validFrom/validUntil/recheckRequiredOn"
    },
    {
      "question": "What invalidates it?",
      "contract": "WorldModelInvalidationRule",
      "field": "triggerType/action"
    },
    {
      "question": "How are observed outcomes reconciled?",
      "contract": "WorldModelReconciliationRecord",
      "field": "observedOutcomeRefs/divergencePosture"
    }
  ],
  "activeOFARMBoundaries": [
    "Advisory Twin only",
    "not current-state materialization",
    "not Compliance Twin state",
    "not third twin",
    "normal BridgeCandidate and promotion law unchanged"
  ]
}
