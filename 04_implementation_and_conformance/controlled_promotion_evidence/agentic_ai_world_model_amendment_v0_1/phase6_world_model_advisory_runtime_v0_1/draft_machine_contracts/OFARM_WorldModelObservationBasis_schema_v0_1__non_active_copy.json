{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodelobservationbasis-v0.1",
  "title": "OFARM WorldModelObservationBasis v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "observationBasisId",
    "targetUseTwin",
    "observations",
    "freshnessPosture",
    "notEvidenceSufficiencyDecision"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelobservationbasis.v0.1"
    },
    "observationBasisId": {
      "$ref": "#/$defs/id"
    },
    "targetUseTwin": {
      "const": "ADVISORY"
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "observationRef",
          "observationType",
          "targetScopes",
          "capturedAt",
          "evidencePosture"
        ],
        "properties": {
          "observationRef": {
            "$ref": "#/$defs/ref"
          },
          "observationType": {
            "enum": [
              "SCOUTING_NOTE",
              "PHOTO",
              "SENSOR_READING",
              "EO_SIGNAL",
              "MACHINE_LOG",
              "WEATHER_FORECAST",
              "WEATHER_OBSERVATION",
              "LOCAL_MEMORY",
              "LAB_RESULT",
              "CONTRACTOR_REPORT",
              "OTHER"
            ]
          },
          "targetScopes": {
            "$ref": "#/$defs/scopes"
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time"
          },
          "sourcePosture": {
            "enum": [
              "CANONICAL_ACCEPTED",
              "DRAFT_OR_CANDIDATE",
              "EXTERNAL_UNPROMOTED",
              "ADVISORY_ONLY",
              "LOCAL_MEMORY"
            ]
          },
          "evidencePosture": {
            "enum": [
              "EVIDENCE_SUFFICIENT_FOR_DECLARED_ADVISORY_USE",
              "EVIDENCE_WEAK",
              "EVIDENCE_MISSING_FOR_PROMOTION",
              "NOT_EVIDENCE_FOR_COMPLIANCE",
              "UNKNOWN"
            ]
          },
          "freshnessPosture": {
            "$ref": "#/$defs/freshnessPosture"
          }
        }
      }
    },
    "freshnessPosture": {
      "$ref": "#/$defs/freshnessPosture"
    },
    "notEvidenceSufficiencyDecision": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: describes observations used by a world model without deciding compliance evidence sufficiency.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
