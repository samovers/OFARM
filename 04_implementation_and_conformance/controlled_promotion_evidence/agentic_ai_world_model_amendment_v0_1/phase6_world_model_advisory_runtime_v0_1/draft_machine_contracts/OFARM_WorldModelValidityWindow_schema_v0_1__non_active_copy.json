{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodelvaliditywindow-v0.1",
  "title": "OFARM WorldModelValidityWindow v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "validityWindowId",
    "validFrom",
    "validUntil",
    "advisoryUseOnly",
    "recheckRequiredOn",
    "expiredDisposition"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelvaliditywindow.v0.1"
    },
    "validityWindowId": {
      "$ref": "#/$defs/id"
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "advisoryUseOnly": {
      "const": true
    },
    "recheckRequiredOn": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "TIME_EXPIRY",
          "NEW_OBSERVATION",
          "OBSERVATION_STALENESS",
          "FORECAST_UPDATE",
          "CROP_STAGE_CHANGE",
          "MANAGEMENT_ACTION",
          "PACK_PROFILE_CHANGE",
          "MATERIALIZATION_REFRESH",
          "AUTHORITY_OR_SHARING_CHANGE",
          "MODEL_VERSION_CHANGE",
          "MANUAL_REVIEW"
        ]
      }
    },
    "expiredDisposition": {
      "enum": [
        "MARK_REQUIRES_RECHECK",
        "MARK_INVALIDATED",
        "RECOMPUTE_REQUIRED",
        "RETIRE_RESULT"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: validity window for advisory world-model state or scenario result.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
