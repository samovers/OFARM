{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodelinputbasis-v0.1",
  "title": "OFARM WorldModelInputBasis v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "inputBasisId",
    "targetUseTwin",
    "readBasis",
    "freshnessPosture",
    "permissionPosture",
    "notTruthSource"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelinputbasis.v0.1"
    },
    "inputBasisId": {
      "$ref": "#/$defs/id"
    },
    "targetUseTwin": {
      "const": "ADVISORY"
    },
    "readBasis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "basisRef",
          "basisType",
          "sourceTwin"
        ],
        "properties": {
          "basisRef": {
            "$ref": "#/$defs/ref"
          },
          "basisType": {
            "enum": [
              "CANONICAL_ASSERTION_HISTORY",
              "CURRENT_STATE_MATERIALIZATION",
              "QUERY_RESULT",
              "CONTEXT_SNAPSHOT",
              "PACK_ACTIVATION_SET",
              "LOCAL_MEMORY_ARTIFACT",
              "EXTERNAL_IMPORT_CANDIDATE",
              "OBSERVATION",
              "EVIDENCE",
              "OTHER"
            ]
          },
          "sourceTwin": {
            "$ref": "#/$defs/twin"
          },
          "digest": {
            "type": "string",
            "minLength": 1
          },
          "asOf": {
            "type": "string",
            "format": "date-time"
          },
          "permissionGrantRef": {
            "$ref": "#/$defs/ref"
          }
        }
      }
    },
    "querySpecificationRefs": {
      "$ref": "#/$defs/refs"
    },
    "queryPlanIRRefs": {
      "$ref": "#/$defs/refs"
    },
    "materializationResultRefs": {
      "$ref": "#/$defs/refs"
    },
    "contextSnapshotRefs": {
      "$ref": "#/$defs/refs"
    },
    "packActivationSetRefs": {
      "$ref": "#/$defs/refs"
    },
    "freshnessPosture": {
      "$ref": "#/$defs/freshnessPosture"
    },
    "permissionPosture": {
      "enum": [
        "FULLY_PERMITTED_FOR_DECLARED_USE",
        "PERMISSION_LIMITED_RESULT",
        "REDACTED_FOR_DECLARED_USE",
        "REQUIRES_ADDITIONAL_GRANT",
        "UNKNOWN_PERMISSION_POSTURE"
      ]
    },
    "notTruthSource": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: declares the governed input basis for an advisory world-model run. It is not a truth source.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
