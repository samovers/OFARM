{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodelassumptionset-v0.2",
  "title": "OFARM WorldModelAssumptionSet v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "assumptionSetId",
    "originTwin",
    "assumptions",
    "advisoryOnly"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelassumptionset.v0.2"
    },
    "assumptionSetId": {
      "$ref": "#/$defs/id"
    },
    "originTwin": {
      "const": "ADVISORY"
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assumptionId",
          "statement",
          "assumptionType",
          "status"
        ],
        "properties": {
          "assumptionId": {
            "$ref": "#/$defs/id"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "assumptionType": {
            "enum": [
              "MODEL",
              "AGRONOMIC",
              "WEATHER_FORECAST",
              "LOCAL_KNOWLEDGE",
              "OPERATIONAL",
              "PACK_OR_POLICY",
              "DATA_QUALITY",
              "EXTERNAL_CONTEXT",
              "OTHER"
            ]
          },
          "basisRefs": {
            "$ref": "#/$defs/refs"
          },
          "confidencePosture": {
            "$ref": "#/$defs/qualitativeLevel"
          },
          "status": {
            "enum": [
              "DECLARED",
              "WEAK",
              "CONTESTED",
              "INVALIDATED",
              "RETIRED"
            ]
          },
          "invalidationTriggerRefs": {
            "$ref": "#/$defs/refs"
          },
          "promotionPosture": {
            "enum": [
              "NOT_PROMOTABLE_AS_FACT",
              "MAY_INFORM_BRIDGE_CANDIDATE",
              "REQUIRES_EVIDENCE_BEFORE_PROMOTION"
            ]
          }
        }
      }
    },
    "advisoryOnly": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: explicit assumption set for Advisory Twin world-model or scenario work.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
