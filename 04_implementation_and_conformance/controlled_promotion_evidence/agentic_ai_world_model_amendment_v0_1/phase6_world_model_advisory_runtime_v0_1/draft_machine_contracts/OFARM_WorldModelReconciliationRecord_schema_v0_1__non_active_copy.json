{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodelreconciliationrecord-v0.1",
  "title": "OFARM WorldModelReconciliationRecord v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reconciliationRecordId",
    "scenarioResultSetRef",
    "observedOutcomeRefs",
    "reconciliationSummary",
    "divergencePosture",
    "canonicalMutationProhibited"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelreconciliationrecord.v0.1"
    },
    "reconciliationRecordId": {
      "$ref": "#/$defs/id"
    },
    "scenarioResultSetRef": {
      "$ref": "#/$defs/ref"
    },
    "observedOutcomeRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "reconciliationSummary": {
      "type": "string",
      "minLength": 1
    },
    "divergencePosture": {
      "enum": [
        "CONSISTENT_WITH_SCENARIO",
        "PARTIAL_DIVERGENCE",
        "MATERIAL_DIVERGENCE",
        "INSUFFICIENT_OBSERVED_OUTCOME",
        "NOT_EVALUATED"
      ]
    },
    "calibrationImpact": {
      "enum": [
        "NO_CHANGE",
        "FLAG_FOR_REVIEW",
        "MODEL_RECALIBRATION_RECOMMENDED",
        "MODEL_RETIREMENT_RECOMMENDED",
        "UNKNOWN"
      ]
    },
    "resultingArtifactRefs": {
      "$ref": "#/$defs/refs"
    },
    "canonicalMutationProhibited": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: observed-outcome reconciliation for advisory scenarios; never mutates canonical history by itself.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
