{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-scenariospec-v0.2",
  "title": "OFARM ScenarioSpec v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scenarioSpecId",
    "originTwin",
    "advisoryOnly",
    "scenarioPurpose",
    "scenarioQuestion",
    "scenarioType",
    "targetScopes",
    "createdAt",
    "prohibitedUses"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.scenariospec.v0.2"
    },
    "scenarioSpecId": {
      "$ref": "#/$defs/id"
    },
    "originTwin": {
      "const": "ADVISORY"
    },
    "advisoryOnly": {
      "const": true
    },
    "scenarioPurpose": {
      "type": "string",
      "minLength": 1
    },
    "scenarioQuestion": {
      "type": "string",
      "minLength": 1
    },
    "scenarioType": {
      "enum": [
        "DISEASE_RISK",
        "IRRIGATION_TIMING",
        "NUTRIENT_PLAN",
        "HARVEST_TIMING",
        "STORAGE_RISK",
        "LOT_LINEAGE_RECONSTRUCTION",
        "BUYER_READINESS",
        "DISPUTE_RECONSTRUCTION",
        "EVIDENCE_GAP_PRIORITIZATION",
        "OTHER"
      ]
    },
    "targetScopes": {
      "$ref": "#/$defs/scopes"
    },
    "inputBasisRef": {
      "$ref": "#/$defs/ref"
    },
    "observationBasisRef": {
      "$ref": "#/$defs/ref"
    },
    "assumptionSetRef": {
      "$ref": "#/$defs/ref"
    },
    "modelMethodRef": {
      "$ref": "#/$defs/ref"
    },
    "requestedOutputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outputDispositionCode"
      }
    },
    "prohibitedUses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "COMPLIANCE_FACT",
          "CURRENT_STATE_MATERIALIZATION",
          "PACK_ACTIVATION",
          "ATTESTATION",
          "FILING_SUBMISSION",
          "AUTOMATIC_PROMOTION",
          "OPERATION_EXECUTION_CLAIM"
        ]
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: advisory scenario specification.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
