{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodelrun-v0.2",
  "title": "OFARM WorldModelRun v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelRunId",
    "objective",
    "targetTwin",
    "targetScopes",
    "advisoryOnly",
    "cannotPromoteDirectly",
    "startedAt",
    "outputPosture"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelrun.v0.2"
    },
    "worldModelRunId": {
      "$ref": "#/$defs/id"
    },
    "agentRunEnvelopeRef": {
      "$ref": "#/$defs/ref"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "targetTwin": {
      "const": "ADVISORY"
    },
    "targetScopes": {
      "$ref": "#/$defs/scopes"
    },
    "advisoryOnly": {
      "const": true
    },
    "cannotPromoteDirectly": {
      "const": true
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "inputBasisRef": {
      "$ref": "#/$defs/ref"
    },
    "observationBasisRef": {
      "$ref": "#/$defs/ref"
    },
    "scenarioSpecRefs": {
      "$ref": "#/$defs/refs"
    },
    "scenarioResultSetRefs": {
      "$ref": "#/$defs/refs"
    },
    "worldModelStateRefs": {
      "$ref": "#/$defs/refs"
    },
    "modelMethodRef": {
      "$ref": "#/$defs/ref"
    },
    "assumptionSetRef": {
      "$ref": "#/$defs/ref"
    },
    "uncertaintyStatementRefs": {
      "$ref": "#/$defs/refs"
    },
    "invalidationRuleRefs": {
      "$ref": "#/$defs/refs"
    },
    "outputDispositionRefs": {
      "$ref": "#/$defs/refs"
    },
    "blockerRefs": {
      "$ref": "#/$defs/refs"
    },
    "reconciliationPolicy": {
      "enum": [
        "RECONCILE_WHEN_OBSERVED_OUTCOME_AVAILABLE",
        "NO_RECONCILIATION_REQUIRED_FOR_THIS_ADVISORY_RUN",
        "REVIEW_REQUIRED_BEFORE_RECONCILIATION"
      ]
    },
    "outputPosture": {
      "enum": [
        "ADVISORY_ONLY",
        "ADVISORY_WITH_BRIDGE_CANDIDATE",
        "BLOCKED_FOR_GOVERNED_USE",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: world-model run envelope/result references. Advisory-only, cannot promote directly.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
