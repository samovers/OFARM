{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodelgovernanceblocker-v0.1",
  "title": "OFARM WorldModelGovernanceBlocker v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelGovernanceBlockerId",
    "blockedUse",
    "reasonCode",
    "targetRefs",
    "resolutionPath",
    "advisoryOnly"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelgovernanceblocker.v0.1"
    },
    "worldModelGovernanceBlockerId": {
      "$ref": "#/$defs/id"
    },
    "blockedUse": {
      "enum": [
        "COMPLIANCE_PROMOTION",
        "CURRENT_STATE_MATERIALIZATION",
        "PACK_ACTIVATION",
        "ATTESTATION",
        "FILING_SUBMISSION",
        "OUTPUT_FREEZE",
        "EXTERNAL_DISCLOSURE",
        "TOOL_CALL",
        "WORLD_MODEL_AS_TRUTH",
        "THIRD_TWIN_CREATION",
        "OTHER"
      ]
    },
    "reasonCode": {
      "type": "string",
      "pattern": "^[A-Z0-9_:-]+$"
    },
    "targetRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "severity": {
      "$ref": "#/$defs/severity"
    },
    "resolutionPath": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "RECHECK_FRESHNESS",
          "COLLECT_EVIDENCE",
          "COLLECT_OBSERVATION",
          "CREATE_BRIDGE_CANDIDATE",
          "REQUEST_HUMAN_REVIEW",
          "REFUSE_USE",
          "RECOMPUTE_WORLD_MODEL_RUN",
          "UPDATE_SHARING_GRANT",
          "RETIRE_OUTPUT"
        ]
      }
    },
    "advisoryOnly": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: explicit blocker for unsafe use of advisory world-model material.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
