{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodeloutputdisposition-v0.1",
  "title": "OFARM WorldModelOutputDisposition v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelOutputDispositionId",
    "outputRef",
    "disposition",
    "advisoryOnly",
    "prohibitedUses"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodeloutputdisposition.v0.1"
    },
    "worldModelOutputDispositionId": {
      "$ref": "#/$defs/id"
    },
    "outputRef": {
      "$ref": "#/$defs/ref"
    },
    "disposition": {
      "$ref": "#/$defs/outputDispositionCode"
    },
    "advisoryOnly": {
      "const": true
    },
    "mayCreateBridgeCandidate": {
      "type": "boolean"
    },
    "requiresHumanApprovalForBridge": {
      "type": "boolean"
    },
    "prohibitedUses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "COMPLIANCE_FACT",
          "CURRENT_STATE_MATERIALIZATION",
          "PACK_ACTIVATION",
          "ATTESTATION",
          "FILING_SUBMISSION",
          "AUTOMATIC_PROMOTION",
          "HIDDEN_TRUTH_STORE",
          "DATA_SHARING_WITHOUT_GRANT",
          "OPERATION_EXECUTION_CLAIM"
        ]
      }
    },
    "allowedNextSteps": {
      "type": "array",
      "items": {
        "enum": [
          "DISPLAY_ADVISORY_RESULT",
          "REQUEST_OBSERVATION",
          "REQUEST_EVIDENCE",
          "CREATE_BRIDGE_CANDIDATE",
          "REQUEST_HUMAN_REVIEW",
          "RECOMPUTE",
          "RETIRE",
          "BLOCK"
        ]
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: output disposition for advisory world-model outputs.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
