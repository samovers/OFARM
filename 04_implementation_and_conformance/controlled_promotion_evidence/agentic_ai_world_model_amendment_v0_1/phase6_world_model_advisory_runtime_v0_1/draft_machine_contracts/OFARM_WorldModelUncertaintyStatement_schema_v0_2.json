{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodeluncertaintystatement-v0.2",
  "title": "OFARM WorldModelUncertaintyStatement v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "uncertaintyStatementId",
    "targetRef",
    "uncertaintyKind",
    "qualitativeLevel",
    "decisionUseLimit",
    "notEvidenceSufficiency"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodeluncertaintystatement.v0.2"
    },
    "uncertaintyStatementId": {
      "$ref": "#/$defs/id"
    },
    "targetRef": {
      "$ref": "#/$defs/ref"
    },
    "uncertaintyKind": {
      "enum": [
        "MODEL_UNCERTAINTY",
        "INPUT_UNCERTAINTY",
        "FORECAST_UNCERTAINTY",
        "SPATIAL_UNCERTAINTY",
        "TEMPORAL_UNCERTAINTY",
        "AUTHORITY_OR_PERMISSION_LIMIT",
        "MISSING_EVIDENCE",
        "CONFLICTING_EVIDENCE",
        "OTHER"
      ]
    },
    "qualitativeLevel": {
      "$ref": "#/$defs/qualitativeLevel"
    },
    "quantitativeStatement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metric": {
          "type": "string"
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "lowerBound": {
          "type": "number"
        },
        "upperBound": {
          "type": "number"
        },
        "confidenceIntervalLabel": {
          "type": "string"
        }
      }
    },
    "inputSensitivity": {
      "type": "string"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decisionUseLimit": {
      "type": "string",
      "minLength": 1
    },
    "notEvidenceSufficiency": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: uncertainty statement; uncertainty or confidence does not equal evidence sufficiency.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
