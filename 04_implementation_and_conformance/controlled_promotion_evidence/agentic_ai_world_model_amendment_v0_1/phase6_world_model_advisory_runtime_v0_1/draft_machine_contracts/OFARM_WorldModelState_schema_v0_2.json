{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodelstate-v0.2",
  "title": "OFARM WorldModelState v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelStateId",
    "originTwin",
    "truthPosture",
    "createdByWorldModelRunRef",
    "targetScopes",
    "stateSummary",
    "validityPosture",
    "notCurrentStateMaterialization",
    "notComplianceState",
    "notThirdTwin"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelstate.v0.2"
    },
    "worldModelStateId": {
      "$ref": "#/$defs/id"
    },
    "originTwin": {
      "const": "ADVISORY"
    },
    "truthPosture": {
      "const": "ADVISORY_ONLY_NOT_CANONICAL_TRUTH"
    },
    "createdByWorldModelRunRef": {
      "$ref": "#/$defs/ref"
    },
    "targetScopes": {
      "$ref": "#/$defs/scopes"
    },
    "stateSummary": {
      "type": "string",
      "minLength": 1
    },
    "inputBasisRef": {
      "$ref": "#/$defs/ref"
    },
    "observationBasisRef": {
      "$ref": "#/$defs/ref"
    },
    "assumptionSetRef": {
      "$ref": "#/$defs/ref"
    },
    "uncertaintyStatementRefs": {
      "$ref": "#/$defs/refs"
    },
    "validityWindowRef": {
      "$ref": "#/$defs/ref"
    },
    "invalidationRuleRefs": {
      "$ref": "#/$defs/refs"
    },
    "outputDispositionRef": {
      "$ref": "#/$defs/ref"
    },
    "validityPosture": {
      "$ref": "#/$defs/validityPosture"
    },
    "notCurrentStateMaterialization": {
      "const": true
    },
    "notComplianceState": {
      "const": true
    },
    "notThirdTwin": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: advisory-only world-model state. It is not Compliance Twin state and not current-state materialization.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
