{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/ofarm-worldmodelinvalidationrule-v0.2",
  "title": "OFARM WorldModelInvalidationRule v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "invalidationRuleId",
    "targetRefs",
    "triggerType",
    "triggerDescription",
    "action",
    "advisoryOnly"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelinvalidationrule.v0.2"
    },
    "invalidationRuleId": {
      "$ref": "#/$defs/id"
    },
    "targetRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "triggerType": {
      "enum": [
        "TIME_EXPIRY",
        "OBSERVATION_STALENESS",
        "NEW_OBSERVATION",
        "FORECAST_DIVERGENCE",
        "CROP_STAGE_CHANGE",
        "MANAGEMENT_ACTION_OUTSIDE_SCENARIO",
        "PACK_PROFILE_CHANGE",
        "MODEL_VERSION_SUPERSESSION",
        "MATERIALIZATION_STALE",
        "EVIDENCE_CONFLICT",
        "AUTHORITY_OR_SHARING_CHANGE",
        "MANUAL_REVIEW",
        "OTHER"
      ]
    },
    "triggerDescription": {
      "type": "string",
      "minLength": 1
    },
    "threshold": {
      "type": "object",
      "additionalProperties": true
    },
    "action": {
      "enum": [
        "MARK_REQUIRES_RECHECK",
        "MARK_INVALIDATED",
        "RETIRE_RESULT",
        "REQUEST_RECOMPUTE",
        "CREATE_GOVERNANCE_BLOCKER",
        "REQUEST_OBSERVATION"
      ]
    },
    "advisoryOnly": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Phase 6 supporting draft: invalidation rule for advisory world-model state or scenario output.",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "twin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "PARTY",
            "DOCUMENT",
            "PACK",
            "QUERY",
            "WORLD_MODEL",
            "SCENARIO",
            "MATERIALIZATION",
            "OBSERVATION",
            "EVIDENCE",
            "CONTRACTOR",
            "BUYER",
            "STORAGE_BIN"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scope"
      }
    },
    "freshnessPosture": {
      "enum": [
        "FRESH_FOR_DECLARED_USE",
        "STALE_FOR_DECLARED_USE",
        "UNKNOWN_FRESHNESS",
        "REQUIRES_RECHECK",
        "INVALIDATED"
      ]
    },
    "truthPosture": {
      "enum": [
        "ADVISORY_ONLY_NOT_CANONICAL_TRUTH",
        "CANONICAL_REFERENCE_USED_AS_INPUT",
        "DRAFT_ONLY",
        "NON_PROMOTABLE"
      ]
    },
    "outputDispositionCode": {
      "enum": [
        "SIMULATION_ONLY",
        "ADVISORY_EXPLANATION",
        "HYPOTHESIS",
        "RISK_FLAG",
        "ADVISORY_DRAFT",
        "OBSERVATION_REQUEST",
        "EVIDENCE_NEED",
        "BRIDGE_CANDIDATE_PROPOSAL",
        "REVIEW_PROMPT",
        "BLOCKED",
        "NON_PROMOTABLE"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "qualitativeLevel": {
      "enum": [
        "VERY_LOW",
        "LOW",
        "MEDIUM",
        "HIGH",
        "VERY_HIGH",
        "UNKNOWN"
      ]
    },
    "validityPosture": {
      "enum": [
        "CURRENT_FOR_ADVISORY_PURPOSE",
        "STALE_FOR_ADVISORY_PURPOSE",
        "INVALIDATED",
        "REQUIRES_RECHECK",
        "RETIRED"
      ]
    }
  }
}
