{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.example/schemas/folder.status.schema.json",
  "title": "OFARM folder status sidecar",
  "type": "object",
  "required": [
    "schemaVersion",
    "path",
    "authority_rank",
    "material_status",
    "folder_class",
    "active_law"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "authority_rank": {
      "type": "integer"
    },
    "material_status": {
      "type": "string"
    },
    "folder_class": {
      "type": "string"
    },
    "active_law": {
      "type": "boolean"
    }
  }
}
