{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ofarm.farmReviewOutput.v0.2",
  "title": "OFARM farm review output schema",
  "description": "Structured output schema for OFARM standalone reviewer prompts. This schema validates common field shape and value domains; reviewer-specific prompts may add stricter count rules.",
  "type": "object",
  "required": [
    "meta",
    "verdict",
    "scorecard",
    "cross_cutting_themes",
    "findings",
    "reviewer_questions",
    "notes"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "reviewer_id",
        "reviewer_name",
        "review_date",
        "review_mode",
        "project_name",
        "package_scope",
        "delta_summary",
        "files_changed",
        "impacted_artifacts"
      ],
      "properties": {
        "reviewer_id": {
          "type": "string"
        },
        "reviewer_name": {
          "type": "string"
        },
        "review_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "review_mode": {
          "enum": [
            "daily-delta",
            "weekly-full",
            "milestone",
            "ad-hoc",
            "final-clean-gate"
          ]
        },
        "project_name": {
          "type": "string"
        },
        "package_scope": {
          "type": "string"
        },
        "delta_summary": {
          "type": "string"
        },
        "files_changed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "impacted_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "verdict": {
      "type": "object",
      "required": [
        "direction_assessment",
        "executive_summary",
        "most_important_next_move",
        "highest_risk_if_ignored"
      ],
      "properties": {
        "direction_assessment": {
          "enum": [
            "directionally_wrong",
            "directionally_right_poorly_expressed",
            "directionally_right_poorly_organized",
            "directionally_right_premature"
          ]
        },
        "executive_summary": {
          "type": "string"
        },
        "most_important_next_move": {
          "type": "string"
        },
        "highest_risk_if_ignored": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "scorecard": {
      "type": "object",
      "properties": {
        "conceptual_integrity": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            {
              "type": "null"
            }
          ]
        },
        "semantic_clarity": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            {
              "type": "null"
            }
          ]
        },
        "implementability": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            {
              "type": "null"
            }
          ]
        },
        "auditability": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            {
              "type": "null"
            }
          ]
        },
        "farm_practicality": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            {
              "type": "null"
            }
          ]
        },
        "repo_hygiene": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "cross_cutting_themes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "finding_type",
          "title",
          "category",
          "severity",
          "confidence",
          "effort",
          "why_it_matters",
          "affected_artifacts",
          "evidence",
          "recommended_action",
          "owner_hint",
          "time_horizon"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "finding_type": {
            "enum": [
              "weakness",
              "opportunity",
              "assumption",
              "change",
              "break_test",
              "preserve",
              "hygiene_issue",
              "stale_doc_risk",
              "duplicate_truth",
              "structure_action",
              "navigation_gap"
            ]
          },
          "title": {
            "type": "string"
          },
          "category": {
            "enum": [
              "conceptual",
              "semantic-model",
              "architecture",
              "governance",
              "interoperability",
              "regulatory",
              "code",
              "ux",
              "structure",
              "naming",
              "freshness",
              "traceability",
              "docs",
              "examples",
              "adr",
              "operations",
              "repository",
              "other"
            ]
          },
          "severity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "confidence": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "effort": {
            "enum": [
              "S",
              "M",
              "L"
            ]
          },
          "why_it_matters": {
            "type": "string"
          },
          "affected_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "artifact",
                "artifact_type",
                "location",
                "note"
              ],
              "properties": {
                "artifact": {
                  "type": "string"
                },
                "artifact_type": {
                  "enum": [
                    "file",
                    "folder",
                    "adr",
                    "schema",
                    "diagram",
                    "example",
                    "glossary",
                    "code",
                    "other",
                    "insufficient_evidence"
                  ]
                },
                "location": {
                  "type": "string"
                },
                "note": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "recommended_action": {
            "type": "string"
          },
          "owner_hint": {
            "enum": [
              "ontology",
              "platform",
              "repo",
              "docs",
              "governance",
              "product",
              "data",
              "architecture",
              "unknown"
            ]
          },
          "time_horizon": {
            "enum": [
              "now",
              "next",
              "later"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "reviewer_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
