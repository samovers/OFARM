{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missionplan/v0.1/phase7-2",
  "title": "MissionPlan",
  "description": "CP12 draft/non-default remediated schema for MissionPlan. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "MissionPlan"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionCandidateRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "missionClass": {
      "enum": [
        "SCOUTING",
        "MECHANICAL_WEEDING",
        "SPRAYING",
        "IRRIGATION",
        "HARVEST_LOGISTICS",
        "SOIL_SAMPLING",
        "GENERAL_MACHINE_TASK"
      ]
    },
    "missionScopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "physicalActorRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "plannedStepRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "safetyConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "cp11ApplicabilityState": {
      "enum": [
        "APPLICABLE_TRACE_REQUIRED",
        "NOT_APPLICABLE_WITH_REASON",
        "UNKNOWN_BLOCKING"
      ]
    },
    "cp11CharterTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "cp11NotApplicableReason": {
      "type": "string",
      "minLength": 1
    },
    "currentStateFreshness": {
      "enum": [
        "FRESH",
        "STALE_BLOCKING",
        "UNKNOWN_BLOCKING"
      ]
    },
    "planDisposition": {
      "enum": [
        "DRAFT",
        "READY_FOR_PREFLIGHT",
        "BLOCKED",
        "REVIEW_REQUIRED"
      ]
    },
    "isNotCommandEnvelope": {
      "const": true
    },
    "doesNotCreateCanonicalTruth": {
      "const": true
    },
    "doesNotAuthorizeExecutionByItself": {
      "const": true
    },
    "doesNotBypassAuthorityLaw": {
      "const": true
    },
    "doesNotBypassCurrentStateFreshness": {
      "const": true
    },
    "doesNotBypassCP11WhereApplicable": {
      "const": true
    },
    "doesNotTreatTelemetryAsAcceptedTruth": {
      "const": true
    },
    "doesNotTreatReceiptAsVerification": {
      "const": true
    },
    "doesNotTreatVendorPayloadAsOFARMLaw": {
      "const": true
    },
    "doesNotCreateComplianceFactByItself": {
      "const": true
    },
    "doesNotCreateDispatchAuthorityByItself": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionCandidateRef",
    "missionClass",
    "missionScopeRef",
    "physicalActorRefs",
    "plannedStepRefs",
    "cp11ApplicabilityState",
    "currentStateFreshness",
    "planDisposition",
    "isNotCommandEnvelope",
    "doesNotCreateCanonicalTruth",
    "doesNotAuthorizeExecutionByItself",
    "doesNotBypassAuthorityLaw",
    "doesNotBypassCurrentStateFreshness",
    "doesNotBypassCP11WhereApplicable",
    "doesNotTreatTelemetryAsAcceptedTruth",
    "doesNotTreatReceiptAsVerification",
    "doesNotTreatVendorPayloadAsOFARMLaw",
    "doesNotCreateComplianceFactByItself",
    "doesNotCreateDispatchAuthorityByItself"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "cp11ApplicabilityState": {
            "const": "APPLICABLE_TRACE_REQUIRED"
          }
        }
      },
      "then": {
        "required": [
          "cp11CharterTraceRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "cp11ApplicabilityState": {
            "const": "NOT_APPLICABLE_WITH_REASON"
          }
        }
      },
      "then": {
        "required": [
          "cp11NotApplicableReason"
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}