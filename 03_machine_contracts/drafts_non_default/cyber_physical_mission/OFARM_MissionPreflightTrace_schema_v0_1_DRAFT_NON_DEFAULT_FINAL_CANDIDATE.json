              "BLOCKED",
              "INSUFFICIENT_BASIS",
              "REQUIRE_REVIEW",
              "REQUIRE_HUMAN_APPROVAL",
              "NOT_APPLICABLE"
            ]
          },
          "blocking": {
            "type": "boolean"
          },
          "basisRef": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(ofarm:|urn:|https?://|ref:)"
          },
          "limitation": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "checkClass",
          "result",
          "blocking"
        ],
        "allOf": [
          {
            "if": {
              "properties": {
                "result": {
                  "const": "NOT_APPLICABLE"
                }
              },
              "required": [
                "result"
              ]
            },
            "then": {
              "required": [
                "basisRef"
              ]
            }
          }
        ]
      },
      "minItems": 1,
      "uniqueItems": true
