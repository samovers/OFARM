{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/autonomyleveldeclaration/v0.1/phase7-2",
  "title": "AutonomyLevelDeclaration",
  "description": "CP12 draft/non-default remediated schema for AutonomyLevelDeclaration. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "AutonomyLevelDeclaration"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionClass": {
      "enum": [
        "SCOUTING",
        "MECHANICAL_WEEDING",
        "SPRAYING",
        "IRRIGATION",
        "HARVEST_LOGISTICS",
        "SOIL_SAMPLING",
        "GENERAL_MACHINE_TASK"
      ]
    },
    "physicalActorRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "declaredAutonomyLevel": {
      "enum": [
        "M0_NO_AUTONOMY",
        "M1_ADVISORY_ONLY",
        "M2_HUMAN_APPROVED_EXECUTION_PACKAGE",
        "M3_SUPERVISED_BOUNDED_EXECUTION",
        "M4_POLICY_BOUNDED_EXECUTION"
      ]
    },
    "scopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "humanOverridePolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "emergencyStopPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "localFallbackPolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "supervisionRequired": {
      "type": "boolean"
    },
    "downgradePathRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "policyAuthorityRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "revocable": {
      "const": true
    },
    "downgradeable": {
      "const": true
    },
    "softwareAgentCannotSelfUpgrade": {
      "const": true
    },
    "m5FullyAutonomousFarmCoordinationOutOfScope": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionClass",
    "physicalActorRef",
    "declaredAutonomyLevel",
    "scopeRef",
    "authorityDecisionTraceRef",
    "revocable",
    "downgradeable",
    "softwareAgentCannotSelfUpgrade",
    "m5FullyAutonomousFarmCoordinationOutOfScope"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "declaredAutonomyLevel": {
            "const": "M3_SUPERVISED_BOUNDED_EXECUTION"
          }
        }
      },
      "then": {
        "required": [
          "humanOverridePolicyRef",
          "emergencyStopPolicyRef",
          "localFallbackPolicyRefs",
          "downgradePathRef",
          "supervisionRequired"
        ],
        "properties": {
          "supervisionRequired": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "declaredAutonomyLevel": {
            "const": "M4_POLICY_BOUNDED_EXECUTION"
          }
        }
      },
      "then": {
        "required": [
          "humanOverridePolicyRef",
          "emergencyStopPolicyRef",
          "localFallbackPolicyRefs",
          "downgradePathRef",
          "supervisionRequired",
          "policyAuthorityRef"
        ],
        "properties": {
          "supervisionRequired": {
            "const": true
          }
        }
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}