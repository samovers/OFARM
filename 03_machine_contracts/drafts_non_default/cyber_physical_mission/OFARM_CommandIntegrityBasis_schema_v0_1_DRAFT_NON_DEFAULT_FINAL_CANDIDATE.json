{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/commandintegritybasis/v0.1/phase7-2",
  "title": "CommandIntegrityBasis",
  "description": "CP12 draft/non-default remediated schema for CommandIntegrityBasis. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "CommandIntegrityBasis"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "integrityMethod": {
      "enum": [
        "DIGITAL_SIGNATURE",
        "AUTHENTICATED_CHANNEL_WITH_PAYLOAD_DIGEST",
        "HARDWARE_SECURE_CHANNEL"
      ]
    },
    "signingKeyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "signatureRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "channelBindingRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "replayProtectionNonce": {
      "type": "string",
      "minLength": 1
    },
    "recipientBindingRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "commandPayloadDigestRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAtCommandTime": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "signatureCovers": {
      "type": "array",
      "items": {
        "enum": [
          "commandPayload",
          "missionEnvelopeRef",
          "missionDispatchAuthorizationRef",
          "recipientActorRef",
          "notBefore",
          "notAfter",
          "replayProtectionNonce"
        ]
      },
      "uniqueItems": true,
      "minItems": 7
    },
    "requiresReplayProtection": {
      "const": true
    },
    "requiresExpiry": {
      "const": true
    },
    "resolvedRecipientActorRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "integrityMethod",
    "signingKeyRef",
    "signatureRef",
    "replayProtectionNonce",
    "recipientBindingRef",
    "commandPayloadDigestRef",
    "createdAtCommandTime",
    "expiresAt",
    "signatureCovers",
    "requiresReplayProtection",
    "requiresExpiry"
  ],
  "allOf": [
    {
      "properties": {
        "signatureCovers": {
          "contains": {
            "const": "commandPayload"
          }
        }
      }
    },
    {
      "properties": {
        "signatureCovers": {
          "contains": {
            "const": "missionEnvelopeRef"
          }
        }
      }
    },
    {
      "properties": {
        "signatureCovers": {
          "contains": {
            "const": "missionDispatchAuthorizationRef"
          }
        }
      }
    },
    {
      "properties": {
        "signatureCovers": {
          "contains": {
            "const": "recipientActorRef"
          }
        }
      }
    },
    {
      "properties": {
        "signatureCovers": {
          "contains": {
            "const": "notBefore"
          }
        }
      }
    },
    {
      "properties": {
        "signatureCovers": {
          "contains": {
            "const": "notAfter"
          }
        }
      }
    },
    {
      "properties": {
        "signatureCovers": {
          "contains": {
            "const": "replayProtectionNonce"
          }
        }
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}