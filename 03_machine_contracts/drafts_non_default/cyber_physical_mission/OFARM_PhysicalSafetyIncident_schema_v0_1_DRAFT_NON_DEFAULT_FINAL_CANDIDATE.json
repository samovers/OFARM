{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/physicalsafetyincident/v0.1/phase7-2",
  "title": "PhysicalSafetyIncident",
  "description": "CP12 draft/non-default remediated schema for PhysicalSafetyIncident. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "PhysicalSafetyIncident"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "recordedByRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "incidentClass": {
      "enum": [
        "HUMAN_SAFETY",
        "ANIMAL_SAFETY",
        "PROPERTY_DAMAGE",
        "ENVIRONMENTAL_HARM",
        "MACHINE_DAMAGE",
        "OTHER"
      ]
    },
    "severity": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL",
        "FATAL"
      ]
    },
    "incidentState": {
      "enum": [
        "SUSPECTED",
        "CONFIRMED",
        "CONTESTED",
        "RESOLVED",
        "FALSE_POSITIVE"
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "reviewDecisionRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "doesNotCreateComplianceFactByItself": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionEnvelopeRef",
    "recordedByRef",
    "recordedAt",
    "incidentClass",
    "severity",
    "incidentState",
    "doesNotCreateComplianceFactByItself"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "incidentState": {
            "enum": [
              "CONFIRMED",
              "RESOLVED"
            ]
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "required": [
              "reviewDecisionRef"
            ]
          },
          {
            "required": [
              "authorityDecisionTraceRef"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "severity": {
            "enum": [
              "CRITICAL",
              "FATAL"
            ]
          }
        }
      },
      "then": {
        "required": [
          "reviewDecisionRef"
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}