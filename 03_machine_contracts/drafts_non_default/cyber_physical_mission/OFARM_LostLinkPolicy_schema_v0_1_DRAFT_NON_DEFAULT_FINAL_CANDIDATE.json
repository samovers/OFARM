{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/lostlinkpolicy/v0.1/phase7-2",
  "title": "LostLinkPolicy",
  "description": "Lost-link policy defining mission behaviour when communications or control links degrade. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "LostLinkPolicy"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "lostLinkTriggerSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "lostLinkAction": {
      "type": "string",
      "enum": [
        "STOP_IN_PLACE",
        "RETURN_TO_SAFE_ZONE",
        "PAUSE_AND_WAIT",
        "ABORT_MISSION",
        "SAFE_SHUTDOWN"
      ]
    },
    "reconnectPolicy": {
      "type": "string",
      "enum": [
        "REQUIRE_HUMAN_REAUTHORISATION",
        "ALLOW_RESUME_IF_WITHIN_WINDOW",
        "NEVER_RESUME_AUTOMATICALLY"
      ]
    },
    "requiredBeforeDispatch": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "lostLinkTriggerSeconds",
    "lostLinkAction",
    "reconnectPolicy",
    "requiredBeforeDispatch"
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}