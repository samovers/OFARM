{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/humanoverridepolicy/v0.1/phase7-2",
  "title": "HumanOverridePolicy",
  "description": "CP12 draft/non-default remediated schema for HumanOverridePolicy. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "HumanOverridePolicy"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "physicalActorRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "overrideMode": {
      "enum": [
        "DIRECT_HUMAN_CONTROL",
        "REMOTE_TAKEOVER",
        "SUPERVISED_OVERRIDE",
        "MANUAL_ABORT_ONLY"
      ]
    },
    "authorisedHumanPartyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "activationConditionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "supervisionRequired": {
      "const": true
    },
    "overrideReadinessState": {
      "enum": [
        "FRESH",
        "STALE_BLOCKING",
        "UNKNOWN_BLOCKING"
      ]
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "notDelegableToAgentByDefault": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "physicalActorRef",
    "overrideMode",
    "authorisedHumanPartyRefs",
    "supervisionRequired",
    "overrideReadinessState",
    "authorityDecisionTraceRef",
    "notDelegableToAgentByDefault"
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}