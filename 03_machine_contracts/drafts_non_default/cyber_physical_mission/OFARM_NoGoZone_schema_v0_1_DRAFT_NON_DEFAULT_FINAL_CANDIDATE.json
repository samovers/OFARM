{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/nogozone/v0.1/phase7-2",
  "title": "NoGoZone",
  "description": "Prohibited or restricted geometry for a physical mission. Hard no-go zones must override routes/geofences. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "NoGoZone"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "geometryRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "missionGeometryBasisRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "noGoState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "EXPIRED",
        "REVOKED",
        "SUPERSEDED"
      ]
    },
    "reasonClass": {
      "type": "string",
      "enum": [
        "WATERCOURSE_BUFFER",
        "HABITAT_PROTECTION",
        "HUMAN_SAFETY",
        "ANIMAL_SAFETY",
        "INFRASTRUCTURE",
        "SLOPE_OR_SOIL_RISK",
        "LEGAL_RESTRICTION",
        "UNKNOWN_RISK",
        "OTHER"
      ]
    },
    "enforcementLevel": {
      "type": "string",
      "enum": [
        "HARD",
        "REVIEW_REQUIRED",
        "ADVISORY_ONLY"
      ]
    },
    "minimumBufferMeters": {
      "type": "number",
      "minimum": 0
    },
    "cp11ConstraintRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "mayBeOverriddenOnlyByException": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "geometryRef",
    "missionGeometryBasisRef",
    "noGoState",
    "reasonClass",
    "enforcementLevel",
    "mayBeOverriddenOnlyByException"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "noGoState": {
            "const": "ACTIVE"
          },
          "enforcementLevel": {
            "const": "HARD"
          }
        }
      },
      "then": {
        "required": [
          "cp11ConstraintRef"
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}