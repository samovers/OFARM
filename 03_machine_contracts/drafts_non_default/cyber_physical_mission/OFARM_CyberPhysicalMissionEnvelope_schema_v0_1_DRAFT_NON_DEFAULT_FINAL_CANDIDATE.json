{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/cyberphysicalmissionenvelope/v0.1/phase7-2",
  "title": "CyberPhysicalMissionEnvelope",
  "description": "CP12 draft/non-default remediated schema for CyberPhysicalMissionEnvelope. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "CyberPhysicalMissionEnvelope"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionLifecycleState": {
      "enum": [
        "INTENT",
        "CANDIDATE",
        "PLANNED",
        "PREFLIGHTED",
        "AUTHORISED",
        "COMMAND_PACKAGED",
        "DISPATCHED",
        "ACKNOWLEDGED",
        "IN_PROGRESS",
        "COMPLETED_REPORTED",
        "VERIFIED",
        "CLOSED",
        "ABORTED"
      ]
    },
    "missionIntentRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "missionCandidateRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "missionPlanRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "missionScopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "missionPreflightTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "missionDispatchAuthorizationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "commandEnvelopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "commandAcknowledgementRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "telemetryEnvelopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "executionReceiptRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "missionVerificationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "abortEventRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "emergencyStopActivationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "closureReviewDecisionRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "incidentRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "targetTwinPosture": {
      "enum": [
        "ADVISORY",
        "COMPLIANCE_CANDIDATE",
        "MIXED_BY_STAGE"
      ]
    },
    "doesNotCreateCanonicalTruth": {
      "const": true
    },
    "doesNotAuthorizeExecutionByItself": {
      "const": true
    },
    "doesNotBypassAuthorityLaw": {
      "const": true
    },
    "doesNotBypassCurrentStateFreshness": {
      "const": true
    },
    "doesNotBypassCP11WhereApplicable": {
      "const": true
    },
    "doesNotTreatTelemetryAsAcceptedTruth": {
      "const": true
    },
    "doesNotTreatReceiptAsVerification": {
      "const": true
    },
    "doesNotTreatVendorPayloadAsOFARMLaw": {
      "const": true
    },
    "doesNotCreateComplianceFactByItself": {
      "const": true
    },
    "doesNotCreateDispatchAuthorityByItself": {
      "const": true
    },
    "abortedAfterDispatch": {
      "type": "boolean",
      "description": "True when mission was aborted after dispatch/command packaging; requires preservation of dispatch/command refs."
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionLifecycleState",
    "missionIntentRef",
    "missionScopeRef",
    "targetTwinPosture",
    "doesNotCreateCanonicalTruth",
    "doesNotAuthorizeExecutionByItself",
    "doesNotBypassAuthorityLaw",
    "doesNotBypassCurrentStateFreshness",
    "doesNotBypassCP11WhereApplicable",
    "doesNotTreatTelemetryAsAcceptedTruth",
    "doesNotTreatReceiptAsVerification",
    "doesNotTreatVendorPayloadAsOFARMLaw",
    "doesNotCreateComplianceFactByItself",
    "doesNotCreateDispatchAuthorityByItself"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "CANDIDATE"
          }
        }
      },
      "then": {
        "required": [
          "missionCandidateRef"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "PLANNED"
          }
        }
      },
      "then": {
        "required": [
          "missionPlanRef"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "PREFLIGHTED"
          }
        }
      },
      "then": {
        "required": [
          "missionPlanRef",
          "missionPreflightTraceRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "AUTHORISED"
          }
        }
      },
      "then": {
        "required": [
          "missionPlanRef",
          "missionPreflightTraceRefs",
          "missionDispatchAuthorizationRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "COMMAND_PACKAGED"
          }
        }
      },
      "then": {
        "required": [
          "missionPlanRef",
          "missionPreflightTraceRefs",
          "missionDispatchAuthorizationRefs",
          "commandEnvelopeRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "DISPATCHED"
          }
        }
      },
      "then": {
        "required": [
          "missionPlanRef",
          "missionPreflightTraceRefs",
          "missionDispatchAuthorizationRefs",
          "commandEnvelopeRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "ACKNOWLEDGED"
          }
        }
      },
      "then": {
        "required": [
          "missionPlanRef",
          "missionPreflightTraceRefs",
          "missionDispatchAuthorizationRefs",
          "commandEnvelopeRefs",
          "commandAcknowledgementRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "IN_PROGRESS"
          }
        }
      },
      "then": {
        "required": [
          "missionPlanRef",
          "missionPreflightTraceRefs",
          "missionDispatchAuthorizationRefs",
          "commandEnvelopeRefs"
        ],
        "anyOf": [
          {
            "required": [
              "telemetryEnvelopeRefs"
            ]
          },
          {
            "required": [
              "executionReceiptRefs"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "COMPLETED_REPORTED"
          }
        }
      },
      "then": {
        "required": [
          "missionPlanRef",
          "missionPreflightTraceRefs",
          "missionDispatchAuthorizationRefs",
          "commandEnvelopeRefs",
          "executionReceiptRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "VERIFIED"
          }
        }
      },
      "then": {
        "required": [
          "missionPlanRef",
          "missionPreflightTraceRefs",
          "missionDispatchAuthorizationRefs",
          "commandEnvelopeRefs",
          "executionReceiptRefs",
          "missionVerificationRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "CLOSED"
          }
        }
      },
      "then": {
        "required": [
          "missionPlanRef",
          "missionPreflightTraceRefs",
          "missionDispatchAuthorizationRefs",
          "commandEnvelopeRefs",
          "executionReceiptRefs"
        ],
        "anyOf": [
          {
            "required": [
              "missionVerificationRefs"
            ]
          },
          {
            "required": [
              "closureReviewDecisionRef"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "ABORTED"
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "required": [
              "abortEventRefs"
            ]
          },
          {
            "required": [
              "emergencyStopActivationRefs"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missionLifecycleState": {
            "const": "ABORTED"
          },
          "abortedAfterDispatch": {
            "const": true
          }
        },
        "required": [
          "missionLifecycleState",
          "abortedAfterDispatch"
        ]
      },
      "then": {
        "required": [
          "missionDispatchAuthorizationRefs",
          "commandEnvelopeRefs"
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}