{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missionintent/v0.1/phase7-2",
  "title": "MissionIntent",
  "description": "Human- or policy-originated intent for a physical mission. It is intent only and does not authorise dispatch. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "MissionIntent"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "intentClass": {
      "type": "string",
      "enum": [
        "SCOUTING",
        "MECHANICAL_WEEDING",
        "SPRAYING",
        "IRRIGATION",
        "HARVEST_LOGISTICS",
        "SOIL_SAMPLING",
        "OTHER"
      ]
    },
    "intentStatement": {
      "type": "string",
      "minLength": 1
    },
    "requestedByPartyRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "targetFieldRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "targetCropCycleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "desiredOutcome": {
      "type": "string"
    },
    "missionUseClass": {
      "type": "string",
      "enum": [
        "ADVISORY_PREPARATION",
        "PREFLIGHT",
        "DISPATCH_AUTHORIZATION",
        "COMMAND_DISPATCH",
        "TELEMETRY_INGESTION",
        "EXECUTION_RECEIPT",
        "VERIFICATION",
        "OUTPUT_REPORTING",
        "INCIDENT_HANDLING"
      ]
    },
    "doesNotAuthorizeDispatch": {
      "type": "boolean",
      "const": true
    },
    "advisoryOrPlanningOnly": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "intentClass",
    "intentStatement",
    "requestedByPartyRef",
    "targetFieldRefs",
    "missionUseClass",
    "doesNotAuthorizeDispatch",
    "advisoryOrPlanningOnly"
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}