{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missionoutputqualification/v0.1/phase7-2",
  "title": "MissionOutputQualification",
  "description": "CP12 draft/non-default remediated schema for MissionOutputQualification. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "MissionOutputQualification"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "outputRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "outputDisposition": {
      "enum": [
        "ADVISORY_ONLY",
        "MISSION_REPORT",
        "FILED_SUBMISSION",
        "EXECUTION_TRUTH_CANDIDATE",
        "COMPLIANCE_FACT_CANDIDATE"
      ]
    },
    "allowedUseClasses": {
      "type": "array",
      "items": {
        "enum": [
          "MISSION_REPORT",
          "CLAIM_BEARING_OUTPUT",
          "ATTESTATION_CANDIDATE",
          "FILED_SUBMISSION",
          "EXECUTION_TRUTH",
          "COMPLIANCE_FACT"
        ]
      },
      "uniqueItems": true
    },
    "blockedUseClasses": {
      "type": "array",
      "items": {
        "enum": [
          "MISSION_REPORT",
          "CLAIM_BEARING_OUTPUT",
          "ATTESTATION_CANDIDATE",
          "FILED_SUBMISSION",
          "DISPATCH_AUTHORITY",
          "EXECUTION_TRUTH",
          "COMPLIANCE_FACT"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "basisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "telemetryIsEvidenceCandidateOnly": {
      "const": true
    },
    "receiptIsNotVerification": {
      "const": true
    },
    "executionTruthPromotionBasisRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "complianceTwinPromotionBasisRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionEnvelopeRef",
    "outputRef",
    "outputDisposition",
    "allowedUseClasses",
    "blockedUseClasses",
    "basisRefs",
    "telemetryIsEvidenceCandidateOnly",
    "receiptIsNotVerification"
  ],
  "allOf": [
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "DISPATCH_AUTHORITY"
            }
          }
        },
        "required": [
          "allowedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "MISSION_REPORT"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "MISSION_REPORT"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "CLAIM_BEARING_OUTPUT"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "CLAIM_BEARING_OUTPUT"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "ATTESTATION_CANDIDATE"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "ATTESTATION_CANDIDATE"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "FILED_SUBMISSION"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "FILED_SUBMISSION"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "DISPATCH_AUTHORITY"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "DISPATCH_AUTHORITY"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "EXECUTION_TRUTH"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "EXECUTION_TRUTH"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "COMPLIANCE_FACT"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "COMPLIANCE_FACT"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "outputDisposition": {
            "const": "ADVISORY_ONLY"
          }
        }
      },
      "then": {
        "allOf": [
          {
            "not": {
              "properties": {
                "allowedUseClasses": {
                  "contains": {
                    "const": "CLAIM_BEARING_OUTPUT"
                  }
                }
              },
              "required": [
                "allowedUseClasses"
              ]
            }
          },
          {
            "not": {
              "properties": {
                "allowedUseClasses": {
                  "contains": {
                    "const": "ATTESTATION_CANDIDATE"
                  }
                }
              },
              "required": [
                "allowedUseClasses"
              ]
            }
          },
          {
            "not": {
              "properties": {
                "allowedUseClasses": {
                  "contains": {
                    "const": "FILED_SUBMISSION"
                  }
                }
              },
              "required": [
                "allowedUseClasses"
              ]
            }
          },
          {
            "not": {
              "properties": {
                "allowedUseClasses": {
                  "contains": {
                    "const": "DISPATCH_AUTHORITY"
                  }
                }
              },
              "required": [
                "allowedUseClasses"
              ]
            }
          },
          {
            "not": {
              "properties": {
                "allowedUseClasses": {
                  "contains": {
                    "const": "EXECUTION_TRUTH"
                  }
                }
              },
              "required": [
                "allowedUseClasses"
              ]
            }
          },
          {
            "not": {
              "properties": {
                "allowedUseClasses": {
                  "contains": {
                    "const": "COMPLIANCE_FACT"
                  }
                }
              },
              "required": [
                "allowedUseClasses"
              ]
            }
          }
        ],
        "properties": {
          "blockedUseClasses": {
            "allOf": [
              {
                "contains": {
                  "const": "CLAIM_BEARING_OUTPUT"
                }
              },
              {
                "contains": {
                  "const": "ATTESTATION_CANDIDATE"
                }
              },
              {
                "contains": {
                  "const": "FILED_SUBMISSION"
                }
              },
              {
                "contains": {
                  "const": "DISPATCH_AUTHORITY"
                }
              },
              {
                "contains": {
                  "const": "EXECUTION_TRUTH"
                }
              },
              {
                "contains": {
                  "const": "COMPLIANCE_FACT"
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outputDisposition": {
            "const": "MISSION_REPORT"
          }
        }
      },
      "then": {
        "properties": {
          "allowedUseClasses": {
            "type": "array",
            "items": {
              "const": "MISSION_REPORT"
            },
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true
          }
        }
      }
    },
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "outputDisposition": {
                "const": "EXECUTION_TRUTH_CANDIDATE"
              }
            }
          },
          {
            "properties": {
              "allowedUseClasses": {
                "contains": {
                  "const": "EXECUTION_TRUTH"
                }
              }
            },
            "required": [
              "allowedUseClasses"
            ]
          }
        ]
      },
      "then": {
        "required": [
          "executionTruthPromotionBasisRef"
        ]
      }
    },
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "outputDisposition": {
                "const": "COMPLIANCE_FACT_CANDIDATE"
              }
            }
          },
          {
            "properties": {
              "allowedUseClasses": {
                "contains": {
                  "const": "COMPLIANCE_FACT"
                }
              }
            },
            "required": [
              "allowedUseClasses"
            ]
          }
        ]
      },
      "then": {
        "required": [
          "complianceTwinPromotionBasisRef"
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}