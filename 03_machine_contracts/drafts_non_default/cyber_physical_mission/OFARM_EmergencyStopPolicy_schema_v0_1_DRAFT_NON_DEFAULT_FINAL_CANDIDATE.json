{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/emergencystoppolicy/v0.1/phase7-2",
  "title": "EmergencyStopPolicy",
  "description": "CP12 draft/non-default remediated schema for EmergencyStopPolicy. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "EmergencyStopPolicy"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "physicalActorRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "stopMechanismClass": {
      "enum": [
        "HARDWARE_ESTOP",
        "REMOTE_ESTOP",
        "SOFTWARE_SAFE_STOP_WITH_HARDWARE_BACKSTOP",
        "LOCAL_OPERATOR_STOP"
      ]
    },
    "safeStateRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "testEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "lastTestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "readinessFreshnessState": {
      "enum": [
        "FRESH",
        "STALE_BLOCKING",
        "UNKNOWN_BLOCKING"
      ]
    },
    "dispatchBoundUse": {
      "type": "boolean"
    },
    "availableDuringMission": {
      "const": true
    },
    "notOrdinaryAgentTool": {
      "const": true
    },
    "evaluationTime": {
      "type": "string",
      "format": "date-time",
      "description": "Optional explicit evaluation time for freshness checks."
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "physicalActorRef",
    "stopMechanismClass",
    "safeStateRef",
    "testEvidenceRefs",
    "lastTestedAt",
    "readinessFreshnessState",
    "availableDuringMission",
    "notOrdinaryAgentTool"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "dispatchBoundUse": {
            "const": true
          }
        },
        "required": [
          "dispatchBoundUse"
        ]
      },
      "then": {
        "properties": {
          "readinessFreshnessState": {
            "const": "FRESH"
          }
        }
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}