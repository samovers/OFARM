{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missiongeometrybasis/v0.1/phase7-2",
  "title": "MissionGeometryBasis",
  "description": "Geometry basis for geofence, no-go-zone, route, and mission-scope decisions. Geometry freshness and source/provenance are explicit. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "MissionGeometryBasis"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "geometryBasisClass": {
      "type": "string",
      "enum": [
        "SURVEYED_BOUNDARY",
        "GIS_IMPORT",
        "MACHINE_REPORTED",
        "DRONE_ORTHOMOSAIC",
        "SATELLITE_DERIVED",
        "MANUAL_DRAWN",
        "VENDOR_PAYLOAD_MAPPING"
      ]
    },
    "geometryRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "crsRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "materializationBasisRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "mappingCoverageStatementRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "geometryFreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALID_BLOCKING",
        "UNKNOWN_BLOCKING",
        "NOT_APPLICABLE"
      ]
    },
    "sourceProvenanceRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "lossMapRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "useLimitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "geometryBasisClass",
    "geometryRef",
    "crsRef",
    "geometryFreshnessState",
    "sourceProvenanceRef"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "geometryFreshnessState": {
            "enum": [
              "STALE_BLOCKING",
              "INVALID_BLOCKING",
              "UNKNOWN_BLOCKING"
            ]
          }
        }
      },
      "then": {
        "required": [
          "useLimitations"
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}