{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/remotetakeoverevent/v0.1/phase7-2",
  "title": "RemoteTakeoverEvent",
  "description": "Remote takeover/human override event during a CP12 mission. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "RemoteTakeoverEvent"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "missionEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "takeoverAt": {
      "type": "string",
      "format": "date-time"
    },
    "takeoverByPartyRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "overridePolicyRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "reasonClass": {
      "type": "string",
      "enum": [
        "SAFETY_RISK",
        "OPERATIONAL_ADJUSTMENT",
        "FAULT_RESPONSE",
        "LOST_LINK_RECOVERY",
        "TEST",
        "OTHER"
      ]
    },
    "takeoverState": {
      "type": "string",
      "enum": [
        "REQUESTED",
        "ACCEPTED",
        "REJECTED",
        "ACTIVE",
        "RELEASED",
        "FAILED"
      ]
    },
    "handoffTraceRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "telemetryEnvelopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "requiresReview": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionEnvelopeRef",
    "takeoverAt",
    "takeoverByPartyRef",
    "overridePolicyRef",
    "reasonClass",
    "takeoverState"
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}