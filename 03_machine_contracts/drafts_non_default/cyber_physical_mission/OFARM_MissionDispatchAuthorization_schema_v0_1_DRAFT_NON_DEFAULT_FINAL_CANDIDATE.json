{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missiondispatchauthorization/v0.1/phase7-2",
  "title": "MissionDispatchAuthorization",
  "description": "CP12 draft/non-default remediated schema for MissionDispatchAuthorization. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "MissionDispatchAuthorization"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "missionPlanRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "missionPreflightTraceRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "authorisedActionClass": {
      "enum": [
        "MISSION_APPROVE_DISPATCH",
        "MISSION_DISPATCH_COMMAND"
      ]
    },
    "physicalActorRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "missionScopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "executionWindowRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "autonomyLevelRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "emergencyStopPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "humanOverridePolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "localFallbackPolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "capabilityCompatibilityResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "cp11ApplicabilityState": {
      "enum": [
        "APPLICABLE_TRACE_REQUIRED",
        "NOT_APPLICABLE_WITH_REASON",
        "UNKNOWN_BLOCKING"
      ]
    },
    "cp11CharterTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "cp11NotApplicableReason": {
      "type": "string",
      "minLength": 1
    },
    "currentStateFreshness": {
      "enum": [
        "FRESH"
      ]
    },
    "authorizationState": {
      "enum": [
        "PROPOSED",
        "APPROVED",
        "ACTIVE",
        "REVOKED",
        "EXPIRED",
        "DENIED"
      ]
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "doesNotCreateExecutionTruth": {
      "const": true
    },
    "doesNotBypassCommandIntegrity": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionEnvelopeRef",
    "missionPlanRef",
    "missionPreflightTraceRef",
    "authorityDecisionTraceRef",
    "authorisedActionClass",
    "physicalActorRefs",
    "missionScopeRef",
    "executionWindowRef",
    "autonomyLevelRef",
    "emergencyStopPolicyRef",
    "humanOverridePolicyRef",
    "localFallbackPolicyRefs",
    "capabilityCompatibilityResultRefs",
    "cp11ApplicabilityState",
    "currentStateFreshness",
    "authorizationState",
    "doesNotCreateExecutionTruth",
    "doesNotBypassCommandIntegrity"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "authorizationState": {
            "enum": [
              "APPROVED",
              "ACTIVE"
            ]
          }
        }
      },
      "then": {
        "required": [
          "validFrom",
          "validUntil",
          "authorityDecisionTraceRef",
          "missionPreflightTraceRef",
          "capabilityCompatibilityResultRefs",
          "emergencyStopPolicyRef",
          "humanOverridePolicyRef",
          "localFallbackPolicyRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "cp11ApplicabilityState": {
            "const": "APPLICABLE_TRACE_REQUIRED"
          }
        }
      },
      "then": {
        "required": [
          "cp11CharterTraceRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "cp11ApplicabilityState": {
            "const": "NOT_APPLICABLE_WITH_REASON"
          }
        }
      },
      "then": {
        "required": [
          "cp11NotApplicableReason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "cp11ApplicabilityState": {
            "const": "UNKNOWN_BLOCKING"
          }
        }
      },
      "then": {
        "not": {
          "properties": {
            "authorizationState": {
              "enum": [
                "APPROVED",
                "ACTIVE"
              ]
            }
          }
        }
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}