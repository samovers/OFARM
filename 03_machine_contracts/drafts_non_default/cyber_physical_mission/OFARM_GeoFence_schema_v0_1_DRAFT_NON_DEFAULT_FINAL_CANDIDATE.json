{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/geofence/v0.1/phase7-2",
  "title": "GeoFence",
  "description": "Allowed operating geometry for a physical mission. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "GeoFence"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "geometryRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "missionGeometryBasisRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "geofenceState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "EXPIRED",
        "REVOKED",
        "SUPERSEDED"
      ]
    },
    "allowedAreaPolicy": {
      "type": "string",
      "enum": [
        "STRICT_INSIDE_ONLY",
        "BUFFERED_INSIDE_ONLY",
        "ROUTE_CONSTRAINED",
        "ADVISORY_ONLY"
      ]
    },
    "bufferMeters": {
      "type": "number",
      "minimum": 0
    },
    "crsRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "doesNotOverrideNoGoZones": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "geometryRef",
    "missionGeometryBasisRef",
    "geofenceState",
    "allowedAreaPolicy",
    "doesNotOverrideNoGoZones"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "geofenceState": {
            "const": "ACTIVE"
          }
        }
      },
      "then": {
        "not": {
          "properties": {
            "allowedAreaPolicy": {
              "const": "ADVISORY_ONLY"
            }
          }
        }
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}