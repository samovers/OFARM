    "dispatchAuthorizationValidFrom": {
      "type": "string",
      "format": "date-time"
    },
    "dispatchAuthorizationValidUntil": {
      "type": "string",
      "format": "date-time"
    },
    "notBefore": {
      "type": "string",
      "format": "date-time"
    },
    "notAfter": {
      "type": "string",
      "format": "date-time"
    },
    "commandPayloadRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
