{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missionscope/v0.1/phase7-2",
  "title": "MissionScope",
  "description": "CP12 draft/non-default remediated schema for MissionScope. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "MissionScope"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionClass": {
      "enum": [
        "SCOUTING",
        "MECHANICAL_WEEDING",
        "SPRAYING",
        "IRRIGATION",
        "HARVEST_LOGISTICS",
        "SOIL_SAMPLING",
        "GENERAL_MACHINE_TASK"
      ]
    },
    "riskClass": {
      "enum": [
        "LOW_PHYSICAL_RISK",
        "MATERIAL_PHYSICAL_RISK",
        "HIGH_RISK_ACTUATION"
      ]
    },
    "fieldOrZoneRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "geoFenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "noGoZoneRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "routeConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "missionGeometryValidationResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "executionWindowRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "physicalActorRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "autonomyLevelRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "safetyConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "cp11ApplicabilityState": {
      "enum": [
        "APPLICABLE_TRACE_REQUIRED",
        "NOT_APPLICABLE_WITH_REASON",
        "UNKNOWN_BLOCKING"
      ]
    },
    "cp11CharterTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "cp11NotApplicableReason": {
      "type": "string",
      "minLength": 1
    },
    "currentStateFreshness": {
      "enum": [
        "FRESH",
        "STALE_BLOCKING",
        "UNKNOWN_BLOCKING"
      ]
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionClass",
    "riskClass",
    "fieldOrZoneRefs",
    "geoFenceRefs",
    "missionGeometryValidationResultRefs",
    "executionWindowRef",
    "physicalActorRefs",
    "autonomyLevelRef",
    "safetyConstraintRefs",
    "cp11ApplicabilityState",
    "currentStateFreshness"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "cp11ApplicabilityState": {
            "const": "APPLICABLE_TRACE_REQUIRED"
          }
        }
      },
      "then": {
        "required": [
          "cp11CharterTraceRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "cp11ApplicabilityState": {
            "const": "NOT_APPLICABLE_WITH_REASON"
          }
        }
      },
      "then": {
        "required": [
          "cp11NotApplicableReason"
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}