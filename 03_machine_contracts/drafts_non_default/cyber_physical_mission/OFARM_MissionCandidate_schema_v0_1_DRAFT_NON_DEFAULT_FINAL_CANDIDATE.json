{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missioncandidate/v0.1/phase7-2",
  "title": "MissionCandidate",
  "description": "CP12 draft/non-default remediated schema for MissionCandidate. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "MissionCandidate"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionIntentRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "candidatePreparedByRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "preparedByActorClass": {
      "enum": [
        "HUMAN",
        "SOFTWARE_AGENT",
        "SERVICE",
        "MACHINE_IMPORTED"
      ]
    },
    "agentRunTraceRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "agentAuthorityEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "agentBlockedActionTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "missionClass": {
      "enum": [
        "SCOUTING",
        "MECHANICAL_WEEDING",
        "SPRAYING",
        "IRRIGATION",
        "HARVEST_LOGISTICS",
        "SOIL_SAMPLING",
        "GENERAL_MACHINE_TASK"
      ]
    },
    "missionScopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "candidateDisposition": {
      "enum": [
        "DRAFT",
        "READY_FOR_PLAN",
        "BLOCKED",
        "REVIEW_REQUIRED"
      ]
    },
    "requiredReviewRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "doesNotAuthorizeDispatch": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionIntentRef",
    "candidatePreparedByRef",
    "preparedByActorClass",
    "missionClass",
    "missionScopeRef",
    "candidateDisposition",
    "doesNotAuthorizeDispatch"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "preparedByActorClass": {
            "const": "SOFTWARE_AGENT"
          }
        }
      },
      "then": {
        "required": [
          "agentRunTraceRef",
          "agentAuthorityEnvelopeRef"
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}