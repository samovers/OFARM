{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missiongeometryvalidationresult/v0.1/phase7-2",
  "title": "MissionGeometryValidationResult",
  "description": "CP12 draft/non-default remediated schema for MissionGeometryValidationResult. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "MissionGeometryValidationResult"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionScopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "geoFenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "noGoZoneRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "routeOrCoverageGeometryRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "crsCompatibilityState": {
      "enum": [
        "COMPATIBLE",
        "MISMATCH_BLOCKING",
        "UNKNOWN_BLOCKING"
      ]
    },
    "geometryFreshnessState": {
      "enum": [
        "FRESH",
        "STALE_BLOCKING",
        "UNKNOWN_BLOCKING"
      ]
    },
    "containmentResult": {
      "enum": [
        "CONTAINED",
        "NOT_CONTAINED_BLOCKING",
        "UNKNOWN_BLOCKING"
      ]
    },
    "overlapResult": {
      "enum": [
        "NO_OVERLAP",
        "OVERLAPS_NO_GO_ZONE",
        "UNKNOWN_BLOCKING"
      ]
    },
    "mappingCoverageRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "lossMapRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "blocking": {
      "type": "boolean"
    },
    "resultDisposition": {
      "enum": [
        "PASS",
        "FAIL",
        "BLOCKED",
        "REQUIRE_REVIEW",
        "INSUFFICIENT_BASIS"
      ]
    },
    "doesNotAuthorizeDispatch": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionScopeRef",
    "geoFenceRefs",
    "routeOrCoverageGeometryRef",
    "crsCompatibilityState",
    "geometryFreshnessState",
    "containmentResult",
    "overlapResult",
    "blocking",
    "resultDisposition",
    "doesNotAuthorizeDispatch"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "overlapResult": {
            "const": "OVERLAPS_NO_GO_ZONE"
          }
        }
      },
      "then": {
        "not": {
          "properties": {
            "resultDisposition": {
              "const": "PASS"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "crsCompatibilityState": {
            "enum": [
              "MISMATCH_BLOCKING",
              "UNKNOWN_BLOCKING"
            ]
          }
        }
      },
      "then": {
        "not": {
          "properties": {
            "resultDisposition": {
              "const": "PASS"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "geometryFreshnessState": {
            "enum": [
              "STALE_BLOCKING",
              "UNKNOWN_BLOCKING"
            ]
          }
        }
      },
      "then": {
        "not": {
          "properties": {
            "resultDisposition": {
              "const": "PASS"
            }
          }
        }
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}