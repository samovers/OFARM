{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missiontelemetryenvelope/v0.1/phase7-2",
  "title": "MissionTelemetryEnvelope",
  "description": "Telemetry envelope from a physical mission. Telemetry is evidence candidate, not accepted execution truth. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "MissionTelemetryEnvelope"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "missionEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "physicalActorRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "telemetryType": {
      "type": "string",
      "enum": [
        "POSITION",
        "STATUS",
        "SENSOR_READING",
        "ACTUATOR_STATE",
        "FAULT",
        "SAFETY_EVENT",
        "ENERGY_STATE",
        "TASK_PROGRESS",
        "OTHER"
      ]
    },
    "telemetryTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "telemetryPayloadRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "integrityState": {
      "type": "string",
      "enum": [
        "VERIFIED",
        "UNVERIFIED",
        "INVALID",
        "UNKNOWN_BLOCKING"
      ]
    },
    "sourceClockState": {
      "type": "string",
      "enum": [
        "SYNCED",
        "DRIFT_SUSPECTED",
        "UNKNOWN"
      ]
    },
    "doesNotCreateAcceptedExecutionTruth": {
      "type": "boolean",
      "const": true
    },
    "maySupportVerification": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionEnvelopeRef",
    "physicalActorRef",
    "telemetryType",
    "telemetryTimestamp",
    "telemetryPayloadRef",
    "integrityState",
    "doesNotCreateAcceptedExecutionTruth",
    "maySupportVerification"
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}