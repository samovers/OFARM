{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/routeconstraint/v0.1/phase7-2",
  "title": "RouteConstraint",
  "description": "Route, speed, deviation, and path constraints for mission execution. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "RouteConstraint"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "routeGeometryRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "missionGeometryBasisRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "routeState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "EXPIRED",
        "REVOKED"
      ]
    },
    "maxDeviationMeters": {
      "type": "number",
      "minimum": 0
    },
    "maxSpeedMps": {
      "type": "number",
      "minimum": 0
    },
    "routeConstraintClass": {
      "type": "string",
      "enum": [
        "STRICT_ROUTE",
        "ALLOW_WITHIN_GEOFENCE",
        "AVOID_NO_GO_BUFFER",
        "HEADLAND_ONLY",
        "OTHER"
      ]
    },
    "noGoZoneRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "routeGeometryRef",
    "missionGeometryBasisRef",
    "routeState",
    "maxDeviationMeters",
    "maxSpeedMps",
    "routeConstraintClass"
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}