{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missionabortevent/v0.1/phase7-2",
  "title": "MissionAbortEvent",
  "description": "Mission abort event. Abort record is not a compliance fact by itself but may trigger review, incident handling, or current-state consequences through normal gates. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "MissionAbortEvent"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "missionEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "abortAt": {
      "type": "string",
      "format": "date-time"
    },
    "abortClass": {
      "type": "string",
      "enum": [
        "HUMAN_ABORT",
        "EMERGENCY_STOP",
        "LOCAL_FALLBACK",
        "LOST_LINK",
        "SAFETY_CONSTRAINT_TRIGGERED",
        "GEOFENCE_BREACH",
        "NO_GO_ZONE_RISK",
        "ACTOR_FAULT",
        "WEATHER_CHANGE",
        "UNKNOWN"
      ]
    },
    "initiatedByRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "telemetryEnvelopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "postAbortState": {
      "type": "string",
      "enum": [
        "STOPPED_SAFE",
        "STOPPED_UNVERIFIED",
        "RETURNED_TO_SAFE_ZONE",
        "FAILED_TO_STOP",
        "UNKNOWN_REQUIRES_REVIEW"
      ]
    },
    "requiresReview": {
      "type": "boolean"
    },
    "doesNotCreateComplianceFact": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionEnvelopeRef",
    "abortAt",
    "abortClass",
    "postAbortState",
    "requiresReview",
    "doesNotCreateComplianceFact"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "abortClass": {
            "enum": [
              "HUMAN_ABORT",
              "EMERGENCY_STOP"
            ]
          }
        }
      },
      "then": {
        "required": [
          "initiatedByRef"
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}