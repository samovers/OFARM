{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/physicalactorcapabilityprofile/v0.1/phase7-2",
  "title": "PhysicalActorCapabilityProfile",
  "description": "CP12 draft/non-default remediated schema for PhysicalActorCapabilityProfile. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "PhysicalActorCapabilityProfile"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "actorRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "actorKind": {
      "enum": [
        "ROBOT",
        "TRACTOR",
        "IMPLEMENT",
        "DRONE",
        "ACTUATOR",
        "MACHINE_SERVICE"
      ]
    },
    "capabilityState": {
      "enum": [
        "DECLARED_ONLY",
        "VERIFIED",
        "STALE",
        "REVOKED",
        "UNKNOWN_BLOCKING"
      ]
    },
    "supportedMissionClasses": {
      "type": "array",
      "items": {
        "enum": [
          "SCOUTING",
          "MECHANICAL_WEEDING",
          "SPRAYING",
          "IRRIGATION",
          "HARVEST_LOGISTICS",
          "SOIL_SAMPLING",
          "GENERAL_MACHINE_TASK"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "supportedAutonomyLevels": {
      "type": "array",
      "items": {
        "enum": [
          "M0_NO_AUTONOMY",
          "M1_ADVISORY_ONLY",
          "M2_HUMAN_APPROVED_EXECUTION_PACKAGE",
          "M3_SUPERVISED_BOUNDED_EXECUTION",
          "M4_POLICY_BOUNDED_EXECUTION"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "safetyControlRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "commandChannelRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "vendorProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "lastVerifiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "capabilityDeclarationIsNotAuthority": {
      "const": true
    },
    "capabilityDeclarationIsNotSafetyProof": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "actorRef",
    "actorKind",
    "capabilityState",
    "supportedMissionClasses",
    "supportedAutonomyLevels",
    "capabilityDeclarationIsNotAuthority",
    "capabilityDeclarationIsNotSafetyProof"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "capabilityState": {
            "const": "VERIFIED"
          }
        }
      },
      "then": {
        "required": [
          "lastVerifiedAt",
          "safetyControlRefs",
          "commandChannelRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "supportedAutonomyLevels": {
            "contains": {
              "const": "M4_POLICY_BOUNDED_EXECUTION"
            }
          }
        }
      },
      "then": {
        "properties": {
          "capabilityState": {
            "const": "VERIFIED"
          }
        },
        "required": [
          "lastVerifiedAt",
          "safetyControlRefs",
          "commandChannelRefs"
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}