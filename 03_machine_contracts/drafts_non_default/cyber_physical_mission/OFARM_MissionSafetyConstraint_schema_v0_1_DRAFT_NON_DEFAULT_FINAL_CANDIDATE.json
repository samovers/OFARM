{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missionsafetyconstraint/v0.1/phase7-2",
  "title": "MissionSafetyConstraint",
  "description": "CP12 draft/non-default remediated schema for MissionSafetyConstraint. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "MissionSafetyConstraint"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "constraintClass": {
      "enum": [
        "EMERGENCY_STOP_REQUIRED",
        "HUMAN_OVERRIDE_REQUIRED",
        "LOCAL_FALLBACK_REQUIRED",
        "COMMAND_INTEGRITY_REQUIRED",
        "GEOFENCE_REQUIRED",
        "NO_GO_ZONE_REQUIRED",
        "SPEED_LIMIT",
        "HUMAN_PROXIMITY_LIMIT",
        "ANIMAL_PROXIMITY_LIMIT",
        "WEATHER_LIMIT",
        "SOIL_CONDITION_LIMIT",
        "ADVISORY_HAZARD"
      ]
    },
    "constraintStrength": {
      "enum": [
        "HARD_BLOCKING",
        "HUMAN_APPROVAL_REQUIRED_FLOOR",
        "ADVISORY_WARNING"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "thresholdValue": {
      "type": [
        "number",
        "string"
      ]
    },
    "unitRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "evidenceRequirementRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "appliesToMissionClass": {
      "enum": [
        "SCOUTING",
        "MECHANICAL_WEEDING",
        "SPRAYING",
        "IRRIGATION",
        "HARVEST_LOGISTICS",
        "SOIL_SAMPLING",
        "GENERAL_MACHINE_TASK"
      ]
    },
    "exceptionAllowed": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "constraintClass",
    "constraintStrength",
    "description",
    "appliesToMissionClass"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "constraintClass": {
            "enum": [
              "EMERGENCY_STOP_REQUIRED",
              "HUMAN_OVERRIDE_REQUIRED",
              "LOCAL_FALLBACK_REQUIRED",
              "COMMAND_INTEGRITY_REQUIRED",
              "GEOFENCE_REQUIRED",
              "NO_GO_ZONE_REQUIRED"
            ]
          }
        }
      },
      "then": {
        "not": {
          "properties": {
            "constraintStrength": {
              "const": "ADVISORY_WARNING"
            }
          }
        }
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}