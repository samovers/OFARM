{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/localfallbackpolicy/v0.1/phase7-2",
  "title": "LocalFallbackPolicy",
  "description": "Local safe-state and fallback requirements for loss of cloud, uncertain state, actuator fault, geofence breach, or other mission hazard. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "LocalFallbackPolicy"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "fallbackTriggers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "CLOUD_UNAVAILABLE",
          "LINK_LOST",
          "POSITION_UNCERTAIN",
          "GEOFENCE_BREACH",
          "NO_GO_ZONE_PROXIMITY",
          "OBSTACLE_DETECTED",
          "HUMAN_DETECTED",
          "LOW_POWER",
          "ACTUATOR_FAULT",
          "WEATHER_CHANGED"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "fallbackActions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "STOP_IN_PLACE",
          "SAFE_SHUTDOWN",
          "RETURN_TO_SAFE_ZONE",
          "PAUSE_AND_WAIT",
          "RAISE_HUMAN_ALERT",
          "ABORT_MISSION",
          "DISABLE_ACTUATION"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "safeZoneRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "requiredBeforeDispatch": {
      "type": "boolean",
      "const": true
    },
    "doesNotRelyOnCloudForSafety": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "fallbackTriggers",
    "fallbackActions",
    "requiredBeforeDispatch",
    "doesNotRelyOnCloudForSafety"
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}