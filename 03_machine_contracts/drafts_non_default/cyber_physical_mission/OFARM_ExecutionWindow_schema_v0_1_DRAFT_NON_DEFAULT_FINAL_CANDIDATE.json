{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/executionwindow/v0.1/phase7-2",
  "title": "ExecutionWindow",
  "description": "CP12 draft/non-default remediated schema for ExecutionWindow. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "ExecutionWindow"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "notBefore": {
      "type": "string",
      "format": "date-time"
    },
    "notAfter": {
      "type": "string",
      "format": "date-time"
    },
    "timezone": {
      "type": "string",
      "minLength": 1
    },
    "weatherConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "preflightValidUntil": {
      "type": "string",
      "format": "date-time"
    },
    "temporalCoherenceRequired": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "notBefore",
    "notAfter",
    "timezone",
    "temporalCoherenceRequired"
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}