{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missionverification/v0.1/phase7-2",
  "title": "MissionVerification",
  "description": "CP12 draft/non-default remediated schema for MissionVerification. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "MissionVerification"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "executionReceiptRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "verifiedByRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "verifiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "verificationDisposition": {
      "enum": [
        "VERIFIED_AS_REPORTED",
        "PARTIALLY_VERIFIED",
        "FAILED_VERIFICATION",
        "NOT_VERIFIED",
        "DISPUTED"
      ]
    },
    "verificationEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "acceptedConsequenceCandidateRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "uniqueItems": true
    },
    "noAcceptedConsequencesReason": {
      "type": "string",
      "minLength": 1
    },
    "doesNotPromoteWithoutReview": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionEnvelopeRef",
    "executionReceiptRef",
    "verifiedByRef",
    "verifiedAt",
    "verificationDisposition",
    "verificationEvidenceRefs",
    "doesNotPromoteWithoutReview"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "verificationDisposition": {
            "enum": [
              "FAILED_VERIFICATION",
              "NOT_VERIFIED",
              "DISPUTED"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "acceptedConsequenceCandidateRefs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verificationDisposition": {
            "const": "VERIFIED_AS_REPORTED"
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "acceptedConsequenceCandidateRefs": {
                "minItems": 1
              }
            }
          },
          {
            "required": [
              "noAcceptedConsequencesReason"
            ]
          }
        ]
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}