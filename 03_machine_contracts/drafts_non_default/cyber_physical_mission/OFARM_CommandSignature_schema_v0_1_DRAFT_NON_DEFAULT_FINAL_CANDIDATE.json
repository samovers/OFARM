{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/commandsignature/v0.1/phase7-2",
  "title": "CommandSignature",
  "description": "Signature/integrity basis for a command envelope. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "CommandSignature"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "commandEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "signatureAlgorithm": {
      "type": "string",
      "enum": [
        "Ed25519",
        "ECDSA_P256",
        "RSA_PSS",
        "EXTERNAL_VENDOR_SIGNATURE"
      ]
    },
    "keyRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "signedPayloadDigest": {
      "type": "string",
      "minLength": 8
    },
    "signedAt": {
      "type": "string",
      "format": "date-time"
    },
    "signerPartyRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "integrityResult": {
      "type": "string",
      "enum": [
        "VALID",
        "INVALID",
        "UNKNOWN_BLOCKING"
      ]
    },
    "replayProtectionNonce": {
      "type": "string",
      "minLength": 8
    },
    "signaturePurpose": {
      "type": "string",
      "const": "COMMAND_INTEGRITY"
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "commandEnvelopeRef",
    "signatureAlgorithm",
    "keyRef",
    "signedPayloadDigest",
    "signedAt",
    "signerPartyRef",
    "integrityResult",
    "replayProtectionNonce",
    "signaturePurpose"
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}