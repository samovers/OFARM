{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missioncapabilitycompatibilityresult/v0.1/phase7-2",
  "title": "MissionCapabilityCompatibilityResult",
  "description": "CP12 draft/non-default remediated schema for MissionCapabilityCompatibilityResult. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "const": "MissionCapabilityCompatibilityResult"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "missionPlanRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "physicalActorCapabilityProfileRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "compatibilityDisposition": {
      "enum": [
        "COMPATIBLE",
        "INCOMPATIBLE",
        "REQUIRES_REVIEW",
        "UNKNOWN_BLOCKING"
      ]
    },
    "capabilityStateAtCheck": {
      "enum": [
        "VERIFIED",
        "DECLARED_ONLY",
        "STALE",
        "REVOKED",
        "UNKNOWN_BLOCKING"
      ]
    },
    "capabilityFreshnessState": {
      "enum": [
        "FRESH",
        "STALE_BLOCKING",
        "UNKNOWN_BLOCKING"
      ]
    },
    "checkedMissionClass": {
      "enum": [
        "SCOUTING",
        "MECHANICAL_WEEDING",
        "SPRAYING",
        "IRRIGATION",
        "HARVEST_LOGISTICS",
        "SOIL_SAMPLING",
        "GENERAL_MACHINE_TASK"
      ]
    },
    "checkedAutonomyLevelRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(ofarm:|urn:|https?://|ref:)"
    },
    "checkedSafetyConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(ofarm:|urn:|https?://|ref:)"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "commandChannelCompatibilityState": {
      "enum": [
        "COMPATIBLE",
        "INCOMPATIBLE",
        "UNKNOWN_BLOCKING"
      ]
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "doesNotAuthorizeDispatch": {
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionPlanRef",
    "physicalActorCapabilityProfileRef",
    "compatibilityDisposition",
    "capabilityStateAtCheck",
    "capabilityFreshnessState",
    "checkedMissionClass",
    "checkedAutonomyLevelRef",
    "commandChannelCompatibilityState",
    "doesNotAuthorizeDispatch"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "compatibilityDisposition": {
            "const": "COMPATIBLE"
          }
        }
      },
      "then": {
        "properties": {
          "capabilityStateAtCheck": {
            "const": "VERIFIED"
          },
          "capabilityFreshnessState": {
            "const": "FRESH"
          },
          "commandChannelCompatibilityState": {
            "const": "COMPATIBLE"
          }
        },
        "required": [
          "checkedSafetyConstraintRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "capabilityStateAtCheck": {
            "enum": [
              "STALE",
              "REVOKED",
              "UNKNOWN_BLOCKING"
            ]
          }
        }
      },
      "then": {
        "not": {
          "properties": {
            "compatibilityDisposition": {
              "const": "COMPATIBLE"
            }
          }
        }
      }
    }
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}