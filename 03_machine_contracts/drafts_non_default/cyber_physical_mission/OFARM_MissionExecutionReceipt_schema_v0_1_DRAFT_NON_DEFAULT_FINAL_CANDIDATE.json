{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/cyber_physical_mission/missionexecutionreceipt/v0.1/phase7-2",
  "title": "MissionExecutionReceipt",
  "description": "Machine-, adapter-, or operator-reported execution receipt. It is evidence candidate, not accepted execution consequence by itself. Phase 7.1 final-gate-hardening draft/non-default schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp12-v0.1-draft-phase7-2-cross-record-dispatch-output-authority-hardening"
    },
    "contractType": {
      "type": "string",
      "const": "MissionExecutionReceipt"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "missionEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "reportedByRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "reportedAt": {
      "type": "string",
      "format": "date-time"
    },
    "receiptSourceClass": {
      "type": "string",
      "enum": [
        "MACHINE_REPORTED",
        "ADAPTER_REPORTED",
        "OPERATOR_REPORTED",
        "MIXED"
      ]
    },
    "reportedStatus": {
      "type": "string",
      "enum": [
        "STARTED",
        "COMPLETED_REPORTED",
        "PARTIAL_REPORTED",
        "ABORTED_REPORTED",
        "FAILED_REPORTED",
        "UNKNOWN"
      ]
    },
    "telemetryEnvelopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      },
      "uniqueItems": true
    },
    "commandAcknowledgementRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "doesNotCreateAcceptedExecutionTruth": {
      "type": "boolean",
      "const": true
    },
    "requiresVerificationForAcceptedCompletion": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "contractType",
    "id",
    "createdAt",
    "missionEnvelopeRef",
    "reportedByRef",
    "reportedAt",
    "receiptSourceClass",
    "reportedStatus",
    "doesNotCreateAcceptedExecutionTruth",
    "requiresVerificationForAcceptedCompletion"
  ],
  "x-ofarm-final-candidate-package": "CP12_Phase7_Final_Amendment_Package",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT",
  "x-ofarm-phase": "CP12_PHASE7_1_FINAL_GATE_HARDENING"
}