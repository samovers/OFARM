{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ofarm.runtimesurfacecontract.v0.2.draft",
  "title": "OFARM RuntimeSurfaceContract v0.2 draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractId",
    "surfaceIdentityRef",
    "status",
    "surfaceKind",
    "direction",
    "protocolFamily",
    "targetStandardRef",
    "semanticPreservationPosture",
    "surfaceBinding",
    "versionPosture",
    "authPosture",
    "deliverySemantics",
    "idempotencyPosture"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.runtimesurfacecontract.v0.2.draft"
    },
    "contractId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "surfaceIdentityRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "surfaceKind": {
      "enum": [
        "API",
        "EVENT",
        "QUERY_FACADE",
        "DISCOVERY"
      ]
    },
    "direction": {
      "enum": [
        "IMPORT",
        "EXPORT",
        "BIDIRECTIONAL"
      ]
    },
    "protocolFamily": {
      "enum": [
        "HTTP",
        "MESSAGE_BUS",
        "FILE_EXCHANGE",
        "WEBHOOK",
        "OTHER"
      ]
    },
    "targetStandardRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "semanticPreservationPosture": {
      "enum": [
        "PROJECTION_ONLY",
        "LOSS_AWARE",
        "STRUCTURE_PRESERVING"
      ]
    },
    "surfaceBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingKind",
        "bindingValue"
      ],
      "properties": {
        "bindingKind": {
          "enum": [
            "HTTP_PATH",
            "TOPIC_NAMESPACE",
            "QUERY_NAMESPACE",
            "DISCOVERY_PATH",
            "FILE_PATTERN",
            "OTHER"
          ]
        },
        "bindingValue": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "versionPosture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surfaceVersionLabel",
        "compatibilityPosture"
      ],
      "properties": {
        "surfaceVersionLabel": {
          "type": "string",
          "minLength": 1
        },
        "compatibilityPosture": {
          "enum": [
            "COMPATIBLE_EXTENSION",
            "BREAKING_VARIANT",
            "DECLARED_SUBSET",
            "EXPERIMENTAL_NON_DEFAULT"
          ]
        },
        "supersedesContractRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "deprecationNotice": {
          "type": "string"
        }
      }
    },
    "authPosture": {
      "enum": [
        "PUBLIC",
        "AUTHENTICATED",
        "PARTNER_SCOPED",
        "MUTUAL_CHANNEL",
        "OUT_OF_BAND_CONTROLLED"
      ]
    },
    "deliverySemantics": {
      "enum": [
        "REQUEST_RESPONSE",
        "DISCOVERY_LOOKUP",
        "AT_LEAST_ONCE_STREAM",
        "BATCH_FILE_EXPORT",
        "OTHER"
      ]
    },
    "idempotencyPosture": {
      "enum": [
        "SAFE_RETRY_SAME_RESULT",
        "CONSUMER_DEDUP_REQUIRED",
        "RETRY_MAY_CREATE_NEW_ARTIFACT",
        "NOT_APPLICABLE"
      ]
    },
    "mappingModuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "serviceDescriptionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "discoveryRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "surfaceKind": {
            "const": "DISCOVERY"
          }
        }
      },
      "then": {
        "properties": {
          "surfaceBinding": {
            "properties": {
              "bindingKind": {
                "const": "DISCOVERY_PATH"
              }
            }
          },
          "deliverySemantics": {
            "const": "DISCOVERY_LOOKUP"
          },
          "idempotencyPosture": {
            "const": "SAFE_RETRY_SAME_RESULT"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "surfaceKind": {
            "const": "QUERY_FACADE"
          }
        }
      },
      "then": {
        "properties": {
          "protocolFamily": {
            "const": "HTTP"
          },
          "surfaceBinding": {
            "properties": {
              "bindingKind": {
                "const": "QUERY_NAMESPACE"
              }
            }
          },
          "deliverySemantics": {
            "const": "REQUEST_RESPONSE"
          },
          "idempotencyPosture": {
            "const": "SAFE_RETRY_SAME_RESULT"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "surfaceKind": {
            "const": "EVENT"
          }
        }
      },
      "then": {
        "properties": {
          "surfaceBinding": {
            "properties": {
              "bindingKind": {
                "const": "TOPIC_NAMESPACE"
              }
            }
          },
          "deliverySemantics": {
            "const": "AT_LEAST_ONCE_STREAM"
          },
          "idempotencyPosture": {
            "const": "CONSUMER_DEDUP_REQUIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "protocolFamily": {
            "const": "FILE_EXCHANGE"
          }
        }
      },
      "then": {
        "properties": {
          "surfaceBinding": {
            "properties": {
              "bindingKind": {
                "const": "FILE_PATTERN"
              }
            }
          },
          "deliverySemantics": {
            "const": "BATCH_FILE_EXPORT"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "surfaceKind": {
            "const": "API"
          },
          "protocolFamily": {
            "const": "HTTP"
          }
        },
        "required": [
          "surfaceKind",
          "protocolFamily"
        ]
      },
      "then": {
        "properties": {
          "surfaceBinding": {
            "properties": {
              "bindingKind": {
                "const": "HTTP_PATH"
              }
            }
          },
          "deliverySemantics": {
            "const": "REQUEST_RESPONSE"
          }
        }
      }
    }
  ],
  "$comment": "Draft extension for meaning-bearing runtime-surface fields; v0.1 remains the default current contract until separately promoted."
}
