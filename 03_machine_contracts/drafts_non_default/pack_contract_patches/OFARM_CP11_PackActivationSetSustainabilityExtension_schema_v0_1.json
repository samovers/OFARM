{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/pack_contract_patches/OFARM_CP11_PackActivationSetSustainabilityExtension_schema_v0_1.json",
  "title": "OFARM CP11 PackActivationSetSustainabilityExtension draft patch schema v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "activationExtensionId",
    "packActivationSetRef",
    "declaredAt",
    "sustainabilitySurfaceDeclarations",
    "noCoreMeaningMutation",
    "noAuthorityCreation"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "activationExtensionId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "packActivationSetRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "declaredAt": {
      "type": "string",
      "format": "date-time"
    },
    "sustainabilitySurfaceDeclarations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surfaceFamily",
          "surfaceDeclarationRef"
        ],
        "properties": {
          "surfaceFamily": {
            "type": "string",
            "enum": [
              "SUSTAINABILITY_CONSTRAINT",
              "SUSTAINABILITY_OBJECTIVE",
              "SUSTAINABILITY_OBJECTIVE_PRIORITY",
              "SUSTAINABILITY_TRADEOFF_POLICY",
              "SUSTAINABILITY_EVIDENCE_POLICY",
              "SUSTAINABILITY_METRIC_PROFILE",
              "SUSTAINABILITY_CLAIM_RULE",
              "CHARTER_EXCEPTION_POLICY",
              "CHARTER_BREACH_POLICY"
            ]
          },
          "surfaceDeclarationRef": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        }
      }
    },
    "noCoreMeaningMutation": {
      "const": true
    },
    "noAuthorityCreation": {
      "const": true
    }
  },
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING",
  "x-ofarm-cp": "CP11"
}
