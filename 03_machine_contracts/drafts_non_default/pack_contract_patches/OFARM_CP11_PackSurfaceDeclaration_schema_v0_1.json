{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/pack_contract_patches/OFARM_CP11_PackSurfaceDeclaration_schema_v0_1.json",
  "title": "OFARM CP11 PackSurfaceDeclaration draft patch schema v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "surfaceDeclarationId",
    "declaredAt",
    "packRef",
    "surfaceFamily",
    "mergeMode",
    "ruleRefs",
    "mayWeakenCoreMeaning",
    "mayCreateAuthority"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "surfaceDeclarationId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "declaredAt": {
      "type": "string",
      "format": "date-time"
    },
    "packRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "surfaceFamily": {
      "type": "string",
      "enum": [
        "SUSTAINABILITY_CONSTRAINT",
        "SUSTAINABILITY_OBJECTIVE",
        "SUSTAINABILITY_OBJECTIVE_PRIORITY",
        "SUSTAINABILITY_TRADEOFF_POLICY",
        "SUSTAINABILITY_EVIDENCE_POLICY",
        "SUSTAINABILITY_METRIC_PROFILE",
        "SUSTAINABILITY_CLAIM_RULE",
        "CHARTER_EXCEPTION_POLICY",
        "CHARTER_BREACH_POLICY"
      ]
    },
    "mergeMode": {
      "type": "string",
      "enum": [
        "CONSTRAINT_INTERSECTION",
        "STRONGEST_REQUIREMENT",
        "ORDERED_COMPOSITION",
        "IDENTICAL_ONLY",
        "HARD_FAIL",
        "REQUIRE_GOVERNANCE",
        "ADDITIVE_UNION"
      ]
    },
    "ruleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "mayWeakenCoreMeaning": {
      "const": false
    },
    "mayCreateAuthority": {
      "const": false
    }
  },
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING",
  "x-ofarm-cp": "CP11"
}
