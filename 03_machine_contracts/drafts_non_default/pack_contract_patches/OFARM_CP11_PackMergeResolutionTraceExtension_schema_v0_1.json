{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/pack_contract_patches/OFARM_CP11_PackMergeResolutionTraceExtension_schema_v0_1.json",
  "title": "OFARM CP11 PackMergeResolutionTraceExtension draft patch schema v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mergeTraceExtensionId",
    "evaluatedAt",
    "packMergeResolutionTraceRef",
    "surfaceFamily",
    "inputPackRefs",
    "conflictDetected",
    "mergeOutcome"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "mergeTraceExtensionId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "packMergeResolutionTraceRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "surfaceFamily": {
      "type": "string",
      "enum": [
        "SUSTAINABILITY_CONSTRAINT",
        "SUSTAINABILITY_OBJECTIVE",
        "SUSTAINABILITY_OBJECTIVE_PRIORITY",
        "SUSTAINABILITY_TRADEOFF_POLICY",
        "SUSTAINABILITY_EVIDENCE_POLICY",
        "SUSTAINABILITY_METRIC_PROFILE",
        "SUSTAINABILITY_CLAIM_RULE",
        "CHARTER_EXCEPTION_POLICY",
        "CHARTER_BREACH_POLICY"
      ]
    },
    "inputPackRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "conflictDetected": {
      "type": "boolean"
    },
    "conflictReasonCodes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "mergeOutcome": {
      "type": "string",
      "enum": [
        "MERGED",
        "STRONGER_REQUIREMENT_SELECTED",
        "HARD_FAIL",
        "REQUIRE_GOVERNANCE"
      ]
    },
    "selectedRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "uniqueItems": true
    },
    "blockedRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "uniqueItems": true
    },
    "governanceDecisionRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    }
  },
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING",
  "x-ofarm-cp": "CP11",
  "allOf": [
    {
      "if": {
        "properties": {
          "conflictDetected": {
            "const": true
          }
        },
        "required": [
          "conflictDetected"
        ]
      },
      "then": {
        "properties": {
          "mergeOutcome": {
            "enum": [
              "HARD_FAIL",
              "REQUIRE_GOVERNANCE"
            ]
          }
        },
        "required": [
          "conflictReasonCodes"
        ]
      }
    }
  ]
}
