{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_SustainabilityMetricProfile_schema_v0_1.json",
  "title": "OFARM SustainabilityMetricProfile v0.1",
  "$comment": "Draft CP11 machine contract for sustainability metric method, unit, uncertainty and claim-eligibility posture.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "metricProfileId",
    "declaredAt",
    "metricName",
    "metricClass",
    "quantityKindRef",
    "unitRef",
    "methodBasis",
    "claimEligibility",
    "profileState",
    "evidenceSourceClass",
    "evidenceQualityState",
    "freshnessState",
    "noStatusAsSourceClass"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "metricProfileId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "declaredAt": {
      "type": "string",
      "format": "date-time"
    },
    "declaringPartyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "charterRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "metricName": {
      "type": "string",
      "minLength": 1
    },
    "metricClass": {
      "enum": [
        "SOIL_HEALTH",
        "SOIL_CARBON",
        "WATER_USE",
        "WATER_QUALITY",
        "NITROGEN_USE",
        "PESTICIDE_RISK",
        "BIODIVERSITY",
        "HABITAT",
        "EMISSIONS",
        "ENERGY",
        "RESILIENCE",
        "OTHER"
      ]
    },
    "quantityKindRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "unitRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "methodBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "methodType",
        "methodRef"
      ],
      "properties": {
        "methodType": {
          "enum": [
            "MEASUREMENT",
            "MODEL",
            "ESTIMATE",
            "PROXY",
            "CERTIFICATION_METHOD",
            "EXTERNAL_STANDARD_PROFILE",
            "OTHER"
          ]
        },
        "methodRef": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "methodVersion": {
          "type": "string"
        },
        "externalStandardRole": {
          "enum": [
            "NONE",
            "SEMANTIC_ANCHOR",
            "SEMANTIC_PROFILE",
            "EXCHANGE_MAPPING",
            "ATTESTATION_WRAPPER"
          ]
        }
      }
    },
    "uncertaintyStatement": {
      "type": "string"
    },
    "temporalResolution": {
      "type": "string"
    },
    "spatialResolution": {
      "type": "string"
    },
    "claimEligibility": {
      "enum": [
        "NOT_CLAIM_ELIGIBLE",
        "ADVISORY_ONLY",
        "CLAIM_ELIGIBLE_REVIEW_REQUIRED",
        "CLAIM_ELIGIBLE_ATTESTATION_REQUIRED",
        "CERTIFIED_ONLY"
      ]
    },
    "profileState": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "RETIRED",
        "SUPERSEDED"
      ]
    },
    "notes": {
      "type": "string"
    },
    "evidenceSourceClass": {
      "$ref": "#/$defs/EvidenceSourceClass"
    },
    "evidenceQualityState": {
      "$ref": "#/$defs/EvidenceQualityState"
    },
    "freshnessState": {
      "$ref": "#/$defs/FreshnessState"
    },
    "noStatusAsSourceClass": {
      "const": true
    }
  },
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING",
  "$defs": {
    "EvidenceSourceClass": {
      "type": "string",
      "enum": [
        "MEASURED",
        "OBSERVED",
        "SAMPLED",
        "LAB_CONFIRMED",
        "MACHINE_REPORTED",
        "SENSOR_DERIVED",
        "SATELLITE_DERIVED",
        "MODELLED",
        "INFERRED",
        "ESTIMATED",
        "SELF_DECLARED",
        "EXTERNALLY_ATTESTED",
        "CERTIFIED"
      ]
    },
    "EvidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "DISPUTED",
        "STALE",
        "INVALIDATED",
        "PARTIAL",
        "UNKNOWN"
      ]
    },
    "FreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALID_BLOCKING",
        "UNKNOWN_BLOCKING",
        "NOT_APPLICABLE"
      ]
    }
  }
}
