{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_TradeoffPolicy_schema_v0_1.json",
  "title": "OFARM TradeoffPolicy CP11 schema v0.1 phase 7.3 final boundary and claim-disposition hardening draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "tradeoffPolicyId",
    "declaredAt",
    "appliesToContextRefs",
    "tradeoffRules",
    "defaultOutcome",
    "policyState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "tradeoffPolicyId": {
      "$ref": "#/$defs/OfarmRef"
    },
    "declaredAt": {
      "$ref": "#/$defs/Timestamp"
    },
    "declaringPartyRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "charterRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "appliesToContextRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/OfarmRef"
      }
    },
    "tradeoffRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/TradeoffRule"
      }
    },
    "defaultOutcome": {
      "type": "string",
      "enum": [
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL",
        "REFUSE",
        "INSUFFICIENT_BASIS",
        "EMERGENCY_EXCEPTION_ONLY"
      ]
    },
    "policyState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED",
        "DISABLED"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "OfarmRef": {
      "type": "string",
      "minLength": 1,
      "description": "Reference to an OFARM artifact, party, event, schema, trace, pack, decision, materialisation, or external role-bound identifier."
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "TargetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeClass",
        "scopeRef"
      ],
      "properties": {
        "scopeClass": {
          "type": "string",
          "enum": [
            "FARM",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "OPERATION",
            "OUTPUT",
            "CLAIM",
            "PACK",
            "REGION",
            "ORGANISATION",
            "OTHER"
          ]
        },
        "scopeRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "TimeInterval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intervalClass"
      ],
      "properties": {
        "intervalClass": {
          "type": "string",
          "enum": [
            "EXPLICIT",
            "OPEN_START",
            "OPEN_END",
            "EVENT_BOUNDED",
            "SEASONAL",
            "NOT_APPLICABLE"
          ]
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "eventRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "seasonRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "Subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subjectClass",
        "subjectRef"
      ],
      "properties": {
        "subjectClass": {
          "type": "string",
          "enum": [
            "RECOMMENDATION",
            "PLAN",
            "OUTPUT",
            "CLAIM",
            "EXCEPTION",
            "BREACH",
            "AGENT_RUN",
            "WORLD_MODEL_RUN",
            "QUERY_RESULT",
            "PACK_ACTIVATION",
            "BUDGET",
            "OTHER"
          ]
        },
        "subjectRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "ExternalSchemeRole": {
      "type": "string",
      "enum": [
        "SEMANTIC_ANCHOR",
        "SEMANTIC_PROFILE",
        "EXCHANGE_MAPPING",
        "EVIDENCE_SOURCE",
        "ATTESTATION_WRAPPER",
        "AUTHORITY_SOURCE_BY_EXPLICIT_GRANT",
        "REFERENCE_ONLY"
      ]
    },
    "EvidenceSourceClass": {
      "type": "string",
      "enum": [
        "MEASURED",
        "OBSERVED",
        "SAMPLED",
        "LAB_CONFIRMED",
        "MACHINE_REPORTED",
        "SENSOR_DERIVED",
        "SATELLITE_DERIVED",
        "MODELLED",
        "INFERRED",
        "ESTIMATED",
        "SELF_DECLARED",
        "EXTERNALLY_ATTESTED",
        "CERTIFIED"
      ]
    },
    "EvidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "DISPUTED",
        "STALE",
        "INVALIDATED",
        "PARTIAL",
        "UNKNOWN"
      ]
    },
    "FreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALID_BLOCKING",
        "UNKNOWN_BLOCKING",
        "NOT_APPLICABLE"
      ]
    },
    "UseClass": {
      "type": "string",
      "enum": [
        "ADVISORY_DISPLAY",
        "INFORMATIONAL_DASHBOARD",
        "FARMER_WORKFLOW_HINT",
        "HIGH_CONSEQUENCE_DECISION",
        "CLAIM_BEARING_OUTPUT",
        "ATTESTATION_CANDIDATE",
        "FILED_SUBMISSION",
        "EXECUTION_BOUND_PREPARATION",
        "PARTNER_DISCLOSURE",
        "PUBLIC_DISCLOSURE"
      ]
    },
    "TradeoffRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "trigger",
        "outcome"
      ],
      "properties": {
        "ruleId": {
          "$ref": "#/$defs/OfarmRef"
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "enum": [
            "ALLOW",
            "ALLOW_WITH_QUALIFICATION",
            "REQUIRE_REVIEW",
            "REQUIRE_HUMAN_APPROVAL",
            "REFUSE",
            "EMERGENCY_EXCEPTION_ONLY",
            "INSUFFICIENT_BASIS"
          ]
        },
        "advisoryOnlyEligibility": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "targetTwin",
            "noHardConstraintImplicated",
            "noClaimBearingOutput",
            "noExecutionBoundPreparation",
            "requiresOutputQualification"
          ],
          "properties": {
            "targetTwin": {
              "const": "ADVISORY"
            },
            "noHardConstraintImplicated": {
              "const": true
            },
            "noClaimBearingOutput": {
              "const": true
            },
            "noExecutionBoundPreparation": {
              "const": true
            },
            "requiresOutputQualification": {
              "const": true
            }
          }
        },
        "approvalGateRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "allowBasis": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "noHardConstraintImplicated": {
              "const": true
            },
            "completeEvaluationTraceRef": {
              "$ref": "#/$defs/OfarmRef"
            },
            "allImplicatedConstraintsPassedTraceRef": {
              "$ref": "#/$defs/OfarmRef"
            }
          },
          "anyOf": [
            {
              "required": [
                "noHardConstraintImplicated"
              ]
            },
            {
              "required": [
                "completeEvaluationTraceRef"
              ]
            },
            {
              "required": [
                "allImplicatedConstraintsPassedTraceRef"
              ]
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "outcome": {
                "const": "ALLOW_WITH_QUALIFICATION"
              }
            },
            "required": [
              "outcome"
            ]
          },
          "then": {
            "required": [
              "advisoryOnlyEligibility"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "outcome": {
                "const": "ALLOW"
              }
            },
            "required": [
              "outcome"
            ]
          },
          "then": {
            "required": [
              "allowBasis"
            ]
          }
        }
      ]
    }
  },
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING"
}
