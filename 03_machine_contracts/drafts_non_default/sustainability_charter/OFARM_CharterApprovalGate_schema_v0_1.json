{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_CharterApprovalGate_schema_v0_1.json",
  "title": "OFARM CharterApprovalGate CP11 schema v0.1 phase 7.3 final boundary and claim-disposition hardening draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "approvalGateId",
    "declaredAt",
    "authorityActionClass",
    "gateClass",
    "requiredAuthorityActionClass",
    "gateState",
    "agentMayApproveByDefault"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "approvalGateId": {
      "$ref": "#/$defs/OfarmRef"
    },
    "declaredAt": {
      "$ref": "#/$defs/Timestamp"
    },
    "declaringPartyRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "charterRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "authorityActionClass": {
      "type": "string",
      "enum": [
        "CHARTER_APPROVE_EXCEPTION",
        "CHARTER_ATTEST_SUSTAINABILITY_CLAIM",
        "CHARTER_SET_OBJECTIVE_PRIORITY",
        "CHARTER_ACTIVATE_POLICY_PACK",
        "CHARTER_ACCEPT_BREACH_FINDING",
        "CHARTER_RESOLVE_BREACH_FINDING",
        "CHARTER_APPROVE_RISK_BUDGET",
        "CHARTER_APPROVE_REGRET_BUDGET",
        "CHARTER_APPROVE_TRADEOFF",
        "CHARTER_APPROVE_CLAIM_BASIS",
        "CHARTER_CONTEST_BREACH_FINDING",
        "CHARTER_REQUEST_EVIDENCE",
        "CHARTER_PREPARE_REVIEW_PACKAGE",
        "CHARTER_EVALUATE_ADVISORY"
      ]
    },
    "gateClass": {
      "type": "string",
      "enum": [
        "HUMAN_ONLY",
        "HUMAN_APPROVAL_REQUIRED",
        "POLICY_APPROVAL_REQUIRED",
        "AGENT_ALLOWED_LOW_CONSEQUENCE_ONLY",
        "NOT_APPLICABLE"
      ]
    },
    "requiredAuthorityActionClass": {
      "type": "string",
      "enum": [
        "CHARTER_APPROVE_EXCEPTION",
        "CHARTER_ATTEST_SUSTAINABILITY_CLAIM",
        "CHARTER_SET_OBJECTIVE_PRIORITY",
        "CHARTER_ACTIVATE_POLICY_PACK",
        "CHARTER_ACCEPT_BREACH_FINDING",
        "CHARTER_RESOLVE_BREACH_FINDING",
        "CHARTER_APPROVE_RISK_BUDGET",
        "CHARTER_APPROVE_REGRET_BUDGET",
        "CHARTER_APPROVE_TRADEOFF",
        "CHARTER_APPROVE_CLAIM_BASIS",
        "CHARTER_CONTEST_BREACH_FINDING",
        "CHARTER_REQUEST_EVIDENCE",
        "CHARTER_PREPARE_REVIEW_PACKAGE",
        "CHARTER_EVALUATE_ADVISORY"
      ]
    },
    "approverRoleRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OfarmRef"
      }
    },
    "evidenceRequirementRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OfarmRef"
      }
    },
    "preflightRequired": {
      "type": "boolean"
    },
    "traceRequired": {
      "type": "boolean"
    },
    "policyApprovalDefinitionRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "policyApprovalRequiresAuthorityDecisionTrace": {
      "type": "boolean"
    },
    "lowConsequenceConditions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetTwin",
        "noClaimBearingOutput",
        "noExecutionBoundPreparation",
        "noHardConstraintOverride",
        "requiresOutputQualification"
      ],
      "properties": {
        "targetTwin": {
          "const": "ADVISORY"
        },
        "noClaimBearingOutput": {
          "const": true
        },
        "noExecutionBoundPreparation": {
          "const": true
        },
        "noHardConstraintOverride": {
          "const": true
        },
        "requiresOutputQualification": {
          "const": true
        }
      }
    },
    "agentMayApproveByDefault": {
      "const": false
    },
    "gateState": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "DRAFT",
        "SUPERSEDED",
        "DISABLED"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "OfarmRef": {
      "type": "string",
      "minLength": 1,
      "description": "Reference to an OFARM artifact, party, event, schema, trace, pack, decision, materialisation, or external role-bound identifier."
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "TargetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeClass",
        "scopeRef"
      ],
      "properties": {
        "scopeClass": {
          "type": "string",
          "enum": [
            "FARM",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "OPERATION",
            "OUTPUT",
            "CLAIM",
            "PACK",
            "REGION",
            "ORGANISATION",
            "OTHER"
          ]
        },
        "scopeRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "TimeInterval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intervalClass"
      ],
      "properties": {
        "intervalClass": {
          "type": "string",
          "enum": [
            "EXPLICIT",
            "OPEN_START",
            "OPEN_END",
            "EVENT_BOUNDED",
            "SEASONAL",
            "NOT_APPLICABLE"
          ]
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "eventRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "seasonRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "Subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subjectClass",
        "subjectRef"
      ],
      "properties": {
        "subjectClass": {
          "type": "string",
          "enum": [
            "RECOMMENDATION",
            "PLAN",
            "OUTPUT",
            "CLAIM",
            "EXCEPTION",
            "BREACH",
            "AGENT_RUN",
            "WORLD_MODEL_RUN",
            "QUERY_RESULT",
            "PACK_ACTIVATION",
            "BUDGET",
            "OTHER"
          ]
        },
        "subjectRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "ExternalSchemeRole": {
      "type": "string",
      "enum": [
        "SEMANTIC_ANCHOR",
        "SEMANTIC_PROFILE",
        "EXCHANGE_MAPPING",
        "EVIDENCE_SOURCE",
        "ATTESTATION_WRAPPER",
        "AUTHORITY_SOURCE_BY_EXPLICIT_GRANT",
        "REFERENCE_ONLY"
      ]
    },
    "EvidenceSourceClass": {
      "type": "string",
      "enum": [
        "MEASURED",
        "OBSERVED",
        "SAMPLED",
        "LAB_CONFIRMED",
        "MACHINE_REPORTED",
        "SENSOR_DERIVED",
        "SATELLITE_DERIVED",
        "MODELLED",
        "INFERRED",
        "ESTIMATED",
        "SELF_DECLARED",
        "EXTERNALLY_ATTESTED",
        "CERTIFIED"
      ]
    },
    "EvidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "DISPUTED",
        "STALE",
        "INVALIDATED",
        "PARTIAL",
        "UNKNOWN"
      ]
    },
    "FreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALID_BLOCKING",
        "UNKNOWN_BLOCKING",
        "NOT_APPLICABLE"
      ]
    },
    "UseClass": {
      "type": "string",
      "enum": [
        "ADVISORY_DISPLAY",
        "INFORMATIONAL_DASHBOARD",
        "FARMER_WORKFLOW_HINT",
        "HIGH_CONSEQUENCE_DECISION",
        "CLAIM_BEARING_OUTPUT",
        "ATTESTATION_CANDIDATE",
        "FILED_SUBMISSION",
        "EXECUTION_BOUND_PREPARATION",
        "PARTNER_DISCLOSURE",
        "PUBLIC_DISCLOSURE"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "authorityActionClass": {
            "enum": [
              "CHARTER_APPROVE_EXCEPTION",
              "CHARTER_ATTEST_SUSTAINABILITY_CLAIM",
              "CHARTER_SET_OBJECTIVE_PRIORITY",
              "CHARTER_ACTIVATE_POLICY_PACK",
              "CHARTER_ACCEPT_BREACH_FINDING",
              "CHARTER_RESOLVE_BREACH_FINDING",
              "CHARTER_APPROVE_RISK_BUDGET",
              "CHARTER_APPROVE_REGRET_BUDGET",
              "CHARTER_APPROVE_TRADEOFF",
              "CHARTER_APPROVE_CLAIM_BASIS"
            ]
          }
        },
        "required": [
          "authorityActionClass"
        ]
      },
      "then": {
        "properties": {
          "gateClass": {
            "enum": [
              "HUMAN_ONLY",
              "HUMAN_APPROVAL_REQUIRED",
              "POLICY_APPROVAL_REQUIRED"
            ]
          }
        },
        "required": [
          "traceRequired"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "gateClass": {
            "const": "POLICY_APPROVAL_REQUIRED"
          }
        },
        "required": [
          "gateClass"
        ]
      },
      "then": {
        "required": [
          "policyApprovalDefinitionRef",
          "policyApprovalRequiresAuthorityDecisionTrace"
        ],
        "properties": {
          "policyApprovalRequiresAuthorityDecisionTrace": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "gateClass": {
            "const": "AGENT_ALLOWED_LOW_CONSEQUENCE_ONLY"
          }
        },
        "required": [
          "gateClass"
        ]
      },
      "then": {
        "required": [
          "lowConsequenceConditions"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "authorityActionClass": {
            "enum": [
              "CHARTER_APPROVE_EXCEPTION",
              "CHARTER_ATTEST_SUSTAINABILITY_CLAIM",
              "CHARTER_SET_OBJECTIVE_PRIORITY",
              "CHARTER_ACTIVATE_POLICY_PACK",
              "CHARTER_ACCEPT_BREACH_FINDING",
              "CHARTER_RESOLVE_BREACH_FINDING",
              "CHARTER_APPROVE_RISK_BUDGET",
              "CHARTER_APPROVE_REGRET_BUDGET",
              "CHARTER_APPROVE_TRADEOFF",
              "CHARTER_APPROVE_CLAIM_BASIS"
            ]
          }
        },
        "required": [
          "authorityActionClass"
        ]
      },
      "then": {
        "required": [
          "traceRequired"
        ],
        "properties": {
          "traceRequired": {
            "const": true
          }
        }
      }
    }
  ],
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING"
}
