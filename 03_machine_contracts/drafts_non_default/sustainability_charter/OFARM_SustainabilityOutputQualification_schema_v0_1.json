{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_SustainabilityOutputQualification_schema_v0_1.json",
  "title": "OFARM SustainabilityOutputQualification CP11 schema v0.1 phase 7.3 final boundary and claim-disposition hardening draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sustainabilityOutputQualificationId",
    "qualifiedAt",
    "outputRef",
    "outputClass",
    "charterRef",
    "claimBasisRefs",
    "evidenceSufficiency",
    "stalenessClass",
    "uncertaintyClass",
    "advisoryOnly",
    "allowedUseClasses",
    "blockedUseClasses",
    "dataSharingPosture"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "sustainabilityOutputQualificationId": {
      "$ref": "#/$defs/OfarmRef"
    },
    "qualifiedAt": {
      "$ref": "#/$defs/Timestamp"
    },
    "outputRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "outputClass": {
      "type": "string",
      "enum": [
        "PASSPORT_VIEW",
        "DOCUMENT_ASSEMBLY",
        "API_RESPONSE",
        "GENERATED_SUMMARY",
        "DASHBOARD",
        "DOSSIER",
        "SUBMISSION",
        "OTHER"
      ]
    },
    "charterRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "claimBasisRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OfarmRef"
      },
      "uniqueItems": true
    },
    "policyEvaluationTraceRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OfarmRef"
      },
      "uniqueItems": true
    },
    "resultQualificationEnvelopeRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "evidenceSufficiency": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "MISSING",
        "PARTIAL",
        "NOT_APPLICABLE"
      ]
    },
    "stalenessClass": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALIDATED",
        "UNKNOWN",
        "NOT_APPLICABLE"
      ]
    },
    "uncertaintyClass": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "UNKNOWN",
        "NOT_APPLICABLE"
      ]
    },
    "advisoryOnly": {
      "type": "boolean"
    },
    "allowedUseClasses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/UseClass"
      },
      "uniqueItems": true
    },
    "blockedUseClasses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/UseClass"
      },
      "uniqueItems": true
    },
    "requiredDisplayLimitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dataSharingPosture": {
      "type": "string",
      "enum": [
        "NOT_SHAREABLE",
        "INTERNAL_ONLY",
        "SHARING_GRANT_REQUIRED",
        "PARTNER_DISCLOSURE_ALLOWED",
        "PUBLIC_ALLOWED",
        "AGGREGATED_ONLY",
        "REDACTED"
      ]
    },
    "sharingGrantRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OfarmRef"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "publicAuthorityBasisRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "dataSovereigntyBoundaryRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "recipientClass": {
      "type": "string",
      "enum": [
        "FARM_INTERNAL",
        "ADVISOR",
        "CONTRACTOR",
        "BUYER",
        "CERTIFIER",
        "REGULATOR",
        "PUBLIC",
        "NEIGHBOURING_FARM",
        "DATA_SPACE",
        "OTHER"
      ]
    },
    "sharePurpose": {
      "type": "string"
    },
    "retentionLimitRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "redactionPolicyRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "commercialUseRestrictionRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "revocationPolicyRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "aggregationFloorRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "OfarmRef": {
      "type": "string",
      "minLength": 1,
      "description": "Reference to an OFARM artifact, party, event, schema, trace, pack, decision, materialisation, or external role-bound identifier."
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "TargetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeClass",
        "scopeRef"
      ],
      "properties": {
        "scopeClass": {
          "type": "string",
          "enum": [
            "FARM",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "OPERATION",
            "OUTPUT",
            "CLAIM",
            "PACK",
            "REGION",
            "ORGANISATION",
            "OTHER"
          ]
        },
        "scopeRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "TimeInterval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intervalClass"
      ],
      "properties": {
        "intervalClass": {
          "type": "string",
          "enum": [
            "EXPLICIT",
            "OPEN_START",
            "OPEN_END",
            "EVENT_BOUNDED",
            "SEASONAL",
            "NOT_APPLICABLE"
          ]
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "eventRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "seasonRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "Subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subjectClass",
        "subjectRef"
      ],
      "properties": {
        "subjectClass": {
          "type": "string",
          "enum": [
            "RECOMMENDATION",
            "PLAN",
            "OUTPUT",
            "CLAIM",
            "EXCEPTION",
            "BREACH",
            "AGENT_RUN",
            "WORLD_MODEL_RUN",
            "QUERY_RESULT",
            "PACK_ACTIVATION",
            "BUDGET",
            "OTHER"
          ]
        },
        "subjectRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "ExternalSchemeRole": {
      "type": "string",
      "enum": [
        "SEMANTIC_ANCHOR",
        "SEMANTIC_PROFILE",
        "EXCHANGE_MAPPING",
        "EVIDENCE_SOURCE",
        "ATTESTATION_WRAPPER",
        "AUTHORITY_SOURCE_BY_EXPLICIT_GRANT",
        "REFERENCE_ONLY"
      ]
    },
    "EvidenceSourceClass": {
      "type": "string",
      "enum": [
        "MEASURED",
        "OBSERVED",
        "SAMPLED",
        "LAB_CONFIRMED",
        "MACHINE_REPORTED",
        "SENSOR_DERIVED",
        "SATELLITE_DERIVED",
        "MODELLED",
        "INFERRED",
        "ESTIMATED",
        "SELF_DECLARED",
        "EXTERNALLY_ATTESTED",
        "CERTIFIED"
      ]
    },
    "EvidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "DISPUTED",
        "STALE",
        "INVALIDATED",
        "PARTIAL",
        "UNKNOWN"
      ]
    },
    "FreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALID_BLOCKING",
        "UNKNOWN_BLOCKING",
        "NOT_APPLICABLE"
      ]
    },
    "UseClass": {
      "type": "string",
      "enum": [
        "ADVISORY_DISPLAY",
        "INFORMATIONAL_DASHBOARD",
        "FARMER_WORKFLOW_HINT",
        "HIGH_CONSEQUENCE_DECISION",
        "CLAIM_BEARING_OUTPUT",
        "ATTESTATION_CANDIDATE",
        "FILED_SUBMISSION",
        "EXECUTION_BOUND_PREPARATION",
        "PARTNER_DISCLOSURE",
        "PUBLIC_DISCLOSURE"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "advisoryOnly": {
            "const": true
          }
        },
        "required": [
          "advisoryOnly"
        ]
      },
      "then": {
        "properties": {
          "blockedUseClasses": {
            "allOf": [
              {
                "contains": {
                  "const": "HIGH_CONSEQUENCE_DECISION"
                }
              },
              {
                "contains": {
                  "const": "CLAIM_BEARING_OUTPUT"
                }
              },
              {
                "contains": {
                  "const": "ATTESTATION_CANDIDATE"
                }
              },
              {
                "contains": {
                  "const": "EXECUTION_BOUND_PREPARATION"
                }
              },
              {
                "contains": {
                  "const": "PARTNER_DISCLOSURE"
                }
              },
              {
                "contains": {
                  "const": "PUBLIC_DISCLOSURE"
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "evidenceSufficiency": {
            "enum": [
              "INSUFFICIENT",
              "MISSING"
            ]
          }
        },
        "required": [
          "evidenceSufficiency"
        ]
      },
      "then": {
        "properties": {
          "blockedUseClasses": {
            "allOf": [
              {
                "contains": {
                  "const": "CLAIM_BEARING_OUTPUT"
                }
              },
              {
                "contains": {
                  "const": "ATTESTATION_CANDIDATE"
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "stalenessClass": {
            "enum": [
              "STALE_BLOCKING",
              "INVALIDATED",
              "UNKNOWN"
            ]
          }
        },
        "required": [
          "stalenessClass"
        ]
      },
      "then": {
        "properties": {
          "blockedUseClasses": {
            "allOf": [
              {
                "contains": {
                  "const": "HIGH_CONSEQUENCE_DECISION"
                }
              },
              {
                "contains": {
                  "const": "CLAIM_BEARING_OUTPUT"
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "dataSharingPosture": {
            "enum": [
              "PARTNER_DISCLOSURE_ALLOWED",
              "PUBLIC_ALLOWED"
            ]
          }
        },
        "required": [
          "dataSharingPosture"
        ]
      },
      "then": {
        "required": [
          "dataSovereigntyBoundaryRef",
          "recipientClass",
          "sharePurpose"
        ],
        "anyOf": [
          {
            "required": [
              "sharingGrantRefs"
            ]
          },
          {
            "required": [
              "publicAuthorityBasisRef"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "dataSharingPosture": {
            "const": "AGGREGATED_ONLY"
          }
        },
        "required": [
          "dataSharingPosture"
        ]
      },
      "then": {
        "required": [
          "aggregationFloorRef"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "dataSharingPosture": {
            "const": "REDACTED"
          }
        },
        "required": [
          "dataSharingPosture"
        ]
      },
      "then": {
        "required": [
          "redactionPolicyRef"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "ADVISORY_DISPLAY"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "ADVISORY_DISPLAY"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "INFORMATIONAL_DASHBOARD"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "INFORMATIONAL_DASHBOARD"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "FARMER_WORKFLOW_HINT"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "FARMER_WORKFLOW_HINT"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "HIGH_CONSEQUENCE_DECISION"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "HIGH_CONSEQUENCE_DECISION"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "CLAIM_BEARING_OUTPUT"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "CLAIM_BEARING_OUTPUT"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "ATTESTATION_CANDIDATE"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "ATTESTATION_CANDIDATE"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "FILED_SUBMISSION"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "FILED_SUBMISSION"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "EXECUTION_BOUND_PREPARATION"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "EXECUTION_BOUND_PREPARATION"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "PARTNER_DISCLOSURE"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "PARTNER_DISCLOSURE"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "not": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "PUBLIC_DISCLOSURE"
            }
          },
          "blockedUseClasses": {
            "contains": {
              "const": "PUBLIC_DISCLOSURE"
            }
          }
        },
        "required": [
          "allowedUseClasses",
          "blockedUseClasses"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "CLAIM_BEARING_OUTPUT"
            }
          }
        },
        "required": [
          "allowedUseClasses"
        ]
      },
      "then": {
        "properties": {
          "claimBasisRefs": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/OfarmRef"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "required": [
          "claimBasisRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "ATTESTATION_CANDIDATE"
            }
          }
        },
        "required": [
          "allowedUseClasses"
        ]
      },
      "then": {
        "properties": {
          "claimBasisRefs": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/OfarmRef"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "required": [
          "claimBasisRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "FILED_SUBMISSION"
            }
          }
        },
        "required": [
          "allowedUseClasses"
        ]
      },
      "then": {
        "properties": {
          "claimBasisRefs": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/OfarmRef"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "required": [
          "claimBasisRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "PARTNER_DISCLOSURE"
            }
          }
        },
        "required": [
          "allowedUseClasses"
        ]
      },
      "then": {
        "properties": {
          "dataSharingPosture": {
            "const": "PARTNER_DISCLOSURE_ALLOWED"
          }
        },
        "required": [
          "dataSharingPosture",
          "dataSovereigntyBoundaryRef",
          "recipientClass",
          "sharePurpose"
        ],
        "anyOf": [
          {
            "required": [
              "sharingGrantRefs"
            ]
          },
          {
            "required": [
              "publicAuthorityBasisRef"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "allowedUseClasses": {
            "contains": {
              "const": "PUBLIC_DISCLOSURE"
            }
          }
        },
        "required": [
          "allowedUseClasses"
        ]
      },
      "then": {
        "properties": {
          "dataSharingPosture": {
            "const": "PUBLIC_ALLOWED"
          }
        },
        "required": [
          "dataSharingPosture",
          "dataSovereigntyBoundaryRef",
          "recipientClass",
          "sharePurpose"
        ],
        "anyOf": [
          {
            "required": [
              "sharingGrantRefs"
            ]
          },
          {
            "required": [
              "publicAuthorityBasisRef"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "dataSharingPosture": {
            "const": "INTERNAL_ONLY"
          }
        },
        "required": [
          "dataSharingPosture"
        ]
      },
      "then": {
        "not": {
          "properties": {
            "allowedUseClasses": {
              "anyOf": [
                {
                  "contains": {
                    "const": "PARTNER_DISCLOSURE"
                  }
                },
                {
                  "contains": {
                    "const": "PUBLIC_DISCLOSURE"
                  }
                }
              ]
            }
          },
          "required": [
            "allowedUseClasses"
          ]
        }
      }
    },
    {
      "not": {
        "properties": {
          "advisoryOnly": {
            "const": true
          },
          "allowedUseClasses": {
            "contains": {
              "const": "PUBLIC_DISCLOSURE"
            }
          }
        },
        "required": [
          "advisoryOnly",
          "allowedUseClasses"
        ]
      }
    }
  ],
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING"
}
