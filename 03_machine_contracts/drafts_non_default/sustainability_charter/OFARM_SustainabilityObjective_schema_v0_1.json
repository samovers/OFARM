{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_SustainabilityObjective_schema_v0_1.json",
  "title": "OFARM SustainabilityObjective v0.1",
  "$comment": "Draft CP11 machine contract for optimisable sustainability objectives subordinate to constraints.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "objectiveId",
    "declaredAt",
    "objectiveClass",
    "objectiveDirection",
    "targetScopes",
    "objectiveExpression",
    "objectiveState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "objectiveId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "declaredAt": {
      "type": "string",
      "format": "date-time"
    },
    "declaringPartyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "charterRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "applicabilityContextRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "uniqueItems": true
    },
    "objectiveClass": {
      "enum": [
        "YIELD_STABILITY",
        "PROFITABILITY",
        "SOIL_HEALTH_IMPROVEMENT",
        "WATER_USE_EFFICIENCY",
        "NUTRIENT_USE_EFFICIENCY",
        "PESTICIDE_RISK_REDUCTION",
        "BIODIVERSITY_IMPROVEMENT",
        "EMISSIONS_REDUCTION",
        "ENERGY_EFFICIENCY",
        "RESILIENCE",
        "LABOUR_MACHINE_EFFICIENCY",
        "RISK_REDUCTION",
        "OTHER"
      ]
    },
    "objectiveDirection": {
      "enum": [
        "MAXIMISE",
        "MINIMISE",
        "TARGET",
        "MAINTAIN",
        "BALANCE"
      ]
    },
    "targetScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "OUTPUT",
              "AGENT_RUN",
              "PACK_ACTIVATION",
              "TENANT",
              "REGION",
              "CERTIFICATION_CONTEXT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        }
      }
    },
    "objectiveExpression": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expressionLanguage",
        "expression"
      ],
      "properties": {
        "expressionLanguage": {
          "enum": [
            "OFARM_RULE_REF",
            "SHACL",
            "SPARQL_ASK",
            "JSON_LOGIC",
            "TEXTUAL_POLICY_REF",
            "OTHER"
          ]
        },
        "expression": {
          "type": "string",
          "minLength": 1
        },
        "parameterRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "uniqueItems": true
        },
        "metricProfileRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "metricProfileRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "priorityRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "evidenceRequirementRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "uniqueItems": true
    },
    "weight": {
      "type": "number"
    },
    "objectiveState": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "RETIRED",
        "SUPERSEDED"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING",
  "$defs": {}
}
