{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_SustainabilityConstraint_schema_v0_1.json",
  "title": "OFARM SustainabilityConstraint v0.1",
  "$comment": "CP11 final draft: report-only posture belongs to objective, metric, or priority surfaces, not hard constraints.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "constraintId",
    "declaredAt",
    "constraintClass",
    "constraintStrength",
    "targetScopes",
    "constraintExpression",
    "evidenceRequirementRefs",
    "exceptionAllowed",
    "constraintState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "constraintId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "declaredAt": {
      "type": "string",
      "format": "date-time"
    },
    "declaringPartyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "charterRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "applicabilityContextRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "uniqueItems": true
    },
    "constraintClass": {
      "enum": [
        "SOIL_HEALTH",
        "WATER_STEWARDSHIP",
        "BIODIVERSITY",
        "HABITAT",
        "CHEMICAL_INPUT",
        "EROSION",
        "BUFFER_ZONE",
        "RESIDUE_CONTAMINATION",
        "CLIMATE_ENERGY",
        "DATA_SOVEREIGNTY",
        "LEGAL_REGULATORY",
        "SAFETY",
        "OTHER"
      ]
    },
    "constraintStrength": {
      "enum": [
        "HARD",
        "NON_TRADEABLE_FLOOR",
        "REVIEW_REQUIRED_FLOOR"
      ]
    },
    "targetScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "OUTPUT",
              "AGENT_RUN",
              "PACK_ACTIVATION",
              "TENANT",
              "REGION",
              "CERTIFICATION_CONTEXT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        }
      }
    },
    "constraintExpression": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expressionLanguage",
        "expression"
      ],
      "properties": {
        "expressionLanguage": {
          "enum": [
            "OFARM_RULE_REF",
            "SHACL",
            "SPARQL_ASK",
            "JSON_LOGIC",
            "TEXTUAL_POLICY_REF",
            "OTHER"
          ]
        },
        "expression": {
          "type": "string",
          "minLength": 1
        },
        "parameterRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "uniqueItems": true
        },
        "metricProfileRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unitRef"
      ],
      "properties": {
        "value": {
          "type": "number"
        },
        "unitRef": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "quantityKindRef": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        }
      }
    },
    "prohibitionText": {
      "type": "string"
    },
    "requiredConditionText": {
      "type": "string"
    },
    "evidenceRequirementRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "metricProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "uniqueItems": true
    },
    "exceptionAllowed": {
      "type": "boolean"
    },
    "exceptionPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "breachSeverity": {
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "constraintState": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "RETIRED",
        "SUPERSEDED"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING",
  "$defs": {}
}
