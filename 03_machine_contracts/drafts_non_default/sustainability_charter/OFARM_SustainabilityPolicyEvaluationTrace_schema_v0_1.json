{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_SustainabilityPolicyEvaluationTrace_schema_v0_1.json",
  "title": "OFARM SustainabilityPolicyEvaluationTrace CP11 schema v0.1 phase 7.3 final boundary and claim-disposition hardening draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evaluationTraceId",
    "evaluatedAt",
    "subject",
    "charterRef",
    "applicabilityContextRef",
    "evaluationCompleteness",
    "constraintResults",
    "objectiveResults",
    "tradeoffResults",
    "evidenceResults",
    "resultDisposition",
    "noCurrentStateMutation",
    "doesNotAuthorizeExecution",
    "doesNotAuthorizeRobotMission",
    "doesNotAuthorizeMachineCommand"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "evaluationTraceId": {
      "$ref": "#/$defs/OfarmRef"
    },
    "evaluatedAt": {
      "$ref": "#/$defs/Timestamp"
    },
    "subject": {
      "$ref": "#/$defs/Subject"
    },
    "charterRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "applicabilityContextRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "materializationBasisRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "materializationSnapshotRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "agentRunTraceRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "worldModelRunRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "authorityDecisionTraceRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "evaluationCompleteness": {
      "type": "string",
      "enum": [
        "COMPLETE",
        "PARTIAL",
        "INSUFFICIENT_CONTEXT",
        "INSUFFICIENT_EVIDENCE",
        "PACK_CONFLICT_BLOCKED",
        "AUTHORITY_BLOCKED"
      ]
    },
    "missingEvaluationElements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "constraintRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OfarmRef"
          },
          "uniqueItems": true
        },
        "objectiveRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OfarmRef"
          },
          "uniqueItems": true
        },
        "evidenceRequirementRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OfarmRef"
          },
          "uniqueItems": true
        },
        "contextRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OfarmRef"
          },
          "uniqueItems": true
        },
        "authorityRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OfarmRef"
          },
          "uniqueItems": true
        }
      }
    },
    "constraintResults": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ConstraintEvaluationResult"
      },
      "uniqueItems": true
    },
    "objectiveResults": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ObjectiveEvaluationResult"
      },
      "uniqueItems": true
    },
    "tradeoffResults": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TradeoffEvaluationResult"
      },
      "uniqueItems": true
    },
    "evidenceResults": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EvidenceEvaluationResult"
      },
      "uniqueItems": true
    },
    "approvalGateRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OfarmRef"
      },
      "uniqueItems": true
    },
    "claimBasisRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "outputQualificationRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "blockedReasonCodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lowConsequenceAdvisoryExceptionBasis": {
      "type": "string"
    },
    "resultDisposition": {
      "type": "string",
      "enum": [
        "ALLOW",
        "ALLOW_WITH_QUALIFICATION",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL",
        "REFUSE",
        "EMERGENCY_EXCEPTION_ONLY",
        "INSUFFICIENT_BASIS",
        "BLOCKED_BY_PACK_CONFLICT",
        "BLOCKED_BY_AUTHORITY",
        "BLOCKED"
      ]
    },
    "noCurrentStateMutation": {
      "const": true
    },
    "doesNotAuthorizeExecution": {
      "const": true
    },
    "doesNotAuthorizeRobotMission": {
      "const": true
    },
    "doesNotAuthorizeMachineCommand": {
      "const": true
    },
    "notes": {
      "type": "string"
    },
    "noApplicableRulesBasis": {
      "type": "string",
      "minLength": 1,
      "description": "Required when a complete ALLOW evaluation has no typed result objects because no charter rules applied."
    }
  },
  "$defs": {
    "OfarmRef": {
      "type": "string",
      "minLength": 1,
      "description": "Reference to an OFARM artifact, party, event, schema, trace, pack, decision, materialisation, or external role-bound identifier."
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "TargetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeClass",
        "scopeRef"
      ],
      "properties": {
        "scopeClass": {
          "type": "string",
          "enum": [
            "FARM",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "OPERATION",
            "OUTPUT",
            "CLAIM",
            "PACK",
            "REGION",
            "ORGANISATION",
            "OTHER"
          ]
        },
        "scopeRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "TimeInterval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intervalClass"
      ],
      "properties": {
        "intervalClass": {
          "type": "string",
          "enum": [
            "EXPLICIT",
            "OPEN_START",
            "OPEN_END",
            "EVENT_BOUNDED",
            "SEASONAL",
            "NOT_APPLICABLE"
          ]
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "eventRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "seasonRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "Subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subjectClass",
        "subjectRef"
      ],
      "properties": {
        "subjectClass": {
          "type": "string",
          "enum": [
            "RECOMMENDATION",
            "PLAN",
            "OUTPUT",
            "CLAIM",
            "EXCEPTION",
            "BREACH",
            "AGENT_RUN",
            "WORLD_MODEL_RUN",
            "QUERY_RESULT",
            "PACK_ACTIVATION",
            "BUDGET",
            "OTHER"
          ]
        },
        "subjectRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "ExternalSchemeRole": {
      "type": "string",
      "enum": [
        "SEMANTIC_ANCHOR",
        "SEMANTIC_PROFILE",
        "EXCHANGE_MAPPING",
        "EVIDENCE_SOURCE",
        "ATTESTATION_WRAPPER",
        "AUTHORITY_SOURCE_BY_EXPLICIT_GRANT",
        "REFERENCE_ONLY"
      ]
    },
    "EvidenceSourceClass": {
      "type": "string",
      "enum": [
        "MEASURED",
        "OBSERVED",
        "SAMPLED",
        "LAB_CONFIRMED",
        "MACHINE_REPORTED",
        "SENSOR_DERIVED",
        "SATELLITE_DERIVED",
        "MODELLED",
        "INFERRED",
        "ESTIMATED",
        "SELF_DECLARED",
        "EXTERNALLY_ATTESTED",
        "CERTIFIED"
      ]
    },
    "EvidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "DISPUTED",
        "STALE",
        "INVALIDATED",
        "PARTIAL",
        "UNKNOWN"
      ]
    },
    "FreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALID_BLOCKING",
        "UNKNOWN_BLOCKING",
        "NOT_APPLICABLE"
      ]
    },
    "UseClass": {
      "type": "string",
      "enum": [
        "ADVISORY_DISPLAY",
        "INFORMATIONAL_DASHBOARD",
        "FARMER_WORKFLOW_HINT",
        "HIGH_CONSEQUENCE_DECISION",
        "CLAIM_BEARING_OUTPUT",
        "ATTESTATION_CANDIDATE",
        "FILED_SUBMISSION",
        "EXECUTION_BOUND_PREPARATION",
        "PARTNER_DISCLOSURE",
        "PUBLIC_DISCLOSURE"
      ]
    },
    "ConstraintEvaluationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constraintRef",
        "result",
        "blocking",
        "requiresReview"
      ],
      "properties": {
        "constraintRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "result": {
          "type": "string",
          "enum": [
            "PASSED",
            "FAILED",
            "NOT_APPLICABLE",
            "INSUFFICIENT_BASIS",
            "REQUIRES_REVIEW",
            "BLOCKED"
          ]
        },
        "blocking": {
          "type": "boolean"
        },
        "requiresReview": {
          "type": "boolean"
        },
        "basisRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OfarmRef"
          },
          "uniqueItems": true
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "ObjectiveEvaluationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objectiveRef",
        "result",
        "blocking",
        "requiresReview"
      ],
      "properties": {
        "objectiveRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "result": {
          "type": "string",
          "enum": [
            "PASSED",
            "FAILED",
            "NOT_APPLICABLE",
            "INSUFFICIENT_BASIS",
            "REQUIRES_REVIEW",
            "BLOCKED"
          ]
        },
        "blocking": {
          "type": "boolean"
        },
        "requiresReview": {
          "type": "boolean"
        },
        "basisRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OfarmRef"
          },
          "uniqueItems": true
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "TradeoffEvaluationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tradeoffRuleRef",
        "result",
        "blocking",
        "requiresReview"
      ],
      "properties": {
        "tradeoffRuleRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "result": {
          "type": "string",
          "enum": [
            "PASSED",
            "FAILED",
            "NOT_APPLICABLE",
            "INSUFFICIENT_BASIS",
            "REQUIRES_REVIEW",
            "BLOCKED"
          ]
        },
        "blocking": {
          "type": "boolean"
        },
        "requiresReview": {
          "type": "boolean"
        },
        "basisRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OfarmRef"
          },
          "uniqueItems": true
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "EvidenceEvaluationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceRequirementRef",
        "result",
        "blocking",
        "requiresReview"
      ],
      "properties": {
        "evidenceRequirementRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "result": {
          "type": "string",
          "enum": [
            "PASSED",
            "FAILED",
            "NOT_APPLICABLE",
            "INSUFFICIENT_BASIS",
            "REQUIRES_REVIEW",
            "BLOCKED"
          ]
        },
        "blocking": {
          "type": "boolean"
        },
        "requiresReview": {
          "type": "boolean"
        },
        "basisRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OfarmRef"
          },
          "uniqueItems": true
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "evaluationCompleteness": {
            "not": {
              "const": "COMPLETE"
            }
          }
        },
        "required": [
          "evaluationCompleteness"
        ]
      },
      "then": {
        "required": [
          "missingEvaluationElements"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "evaluationCompleteness": {
            "not": {
              "const": "COMPLETE"
            }
          },
          "resultDisposition": {
            "enum": [
              "ALLOW",
              "ALLOW_WITH_QUALIFICATION"
            ]
          }
        },
        "required": [
          "evaluationCompleteness",
          "resultDisposition"
        ]
      },
      "then": {
        "required": [
          "lowConsequenceAdvisoryExceptionBasis"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "constraintResults": {
            "contains": {
              "type": "object",
              "properties": {
                "blocking": {
                  "const": true
                },
                "result": {
                  "enum": [
                    "FAILED",
                    "BLOCKED",
                    "INSUFFICIENT_BASIS",
                    "REQUIRES_REVIEW"
                  ]
                }
              },
              "required": [
                "blocking",
                "result"
              ]
            }
          }
        },
        "required": [
          "constraintResults"
        ]
      },
      "then": {
        "properties": {
          "resultDisposition": {
            "enum": [
              "REFUSE",
              "REQUIRE_REVIEW",
              "REQUIRE_HUMAN_APPROVAL",
              "INSUFFICIENT_BASIS",
              "BLOCKED",
              "BLOCKED_BY_PACK_CONFLICT",
              "BLOCKED_BY_AUTHORITY"
            ]
          }
        },
        "required": [
          "resultDisposition"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "objectiveResults": {
            "contains": {
              "type": "object",
              "properties": {
                "blocking": {
                  "const": true
                },
                "result": {
                  "enum": [
                    "FAILED",
                    "BLOCKED",
                    "INSUFFICIENT_BASIS",
                    "REQUIRES_REVIEW"
                  ]
                }
              },
              "required": [
                "blocking",
                "result"
              ]
            }
          }
        },
        "required": [
          "objectiveResults"
        ]
      },
      "then": {
        "properties": {
          "resultDisposition": {
            "enum": [
              "REFUSE",
              "REQUIRE_REVIEW",
              "REQUIRE_HUMAN_APPROVAL",
              "INSUFFICIENT_BASIS",
              "BLOCKED",
              "BLOCKED_BY_PACK_CONFLICT",
              "BLOCKED_BY_AUTHORITY"
            ]
          }
        },
        "required": [
          "resultDisposition"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "tradeoffResults": {
            "contains": {
              "type": "object",
              "properties": {
                "blocking": {
                  "const": true
                },
                "result": {
                  "enum": [
                    "FAILED",
                    "BLOCKED",
                    "INSUFFICIENT_BASIS",
                    "REQUIRES_REVIEW"
                  ]
                }
              },
              "required": [
                "blocking",
                "result"
              ]
            }
          }
        },
        "required": [
          "tradeoffResults"
        ]
      },
      "then": {
        "properties": {
          "resultDisposition": {
            "enum": [
              "REFUSE",
              "REQUIRE_REVIEW",
              "REQUIRE_HUMAN_APPROVAL",
              "INSUFFICIENT_BASIS",
              "BLOCKED",
              "BLOCKED_BY_PACK_CONFLICT",
              "BLOCKED_BY_AUTHORITY"
            ]
          }
        },
        "required": [
          "resultDisposition"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "evidenceResults": {
            "contains": {
              "type": "object",
              "properties": {
                "blocking": {
                  "const": true
                },
                "result": {
                  "enum": [
                    "FAILED",
                    "BLOCKED",
                    "INSUFFICIENT_BASIS",
                    "REQUIRES_REVIEW"
                  ]
                }
              },
              "required": [
                "blocking",
                "result"
              ]
            }
          }
        },
        "required": [
          "evidenceResults"
        ]
      },
      "then": {
        "properties": {
          "resultDisposition": {
            "enum": [
              "REFUSE",
              "REQUIRE_REVIEW",
              "REQUIRE_HUMAN_APPROVAL",
              "INSUFFICIENT_BASIS",
              "BLOCKED",
              "BLOCKED_BY_PACK_CONFLICT",
              "BLOCKED_BY_AUTHORITY"
            ]
          }
        },
        "required": [
          "resultDisposition"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "evaluationCompleteness": {
            "const": "COMPLETE"
          },
          "resultDisposition": {
            "enum": [
              "ALLOW",
              "ALLOW_WITH_QUALIFICATION"
            ]
          }
        },
        "required": [
          "evaluationCompleteness",
          "resultDisposition"
        ]
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "constraintResults": {
                "minItems": 1
              }
            },
            "required": [
              "constraintResults"
            ]
          },
          {
            "properties": {
              "objectiveResults": {
                "minItems": 1
              }
            },
            "required": [
              "objectiveResults"
            ]
          },
          {
            "properties": {
              "tradeoffResults": {
                "minItems": 1
              }
            },
            "required": [
              "tradeoffResults"
            ]
          },
          {
            "properties": {
              "evidenceResults": {
                "minItems": 1
              }
            },
            "required": [
              "evidenceResults"
            ]
          },
          {
            "required": [
              "noApplicableRulesBasis"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "constraintResults": {
            "contains": {
              "type": "object",
              "properties": {
                "result": {
                  "enum": [
                    "FAILED",
                    "BLOCKED",
                    "INSUFFICIENT_BASIS"
                  ]
                }
              },
              "required": [
                "result"
              ]
            }
          }
        },
        "required": [
          "constraintResults"
        ]
      },
      "then": {
        "not": {
          "properties": {
            "resultDisposition": {
              "enum": [
                "ALLOW",
                "ALLOW_WITH_QUALIFICATION"
              ]
            }
          },
          "required": [
            "resultDisposition"
          ]
        }
      }
    }
  ],
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING"
}
