{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_ObjectivePriority_schema_v0_1.json",
  "title": "OFARM ObjectivePriority v0.1",
  "$comment": "Draft CP11 machine contract for priority hierarchy among constraints, objectives and indicators.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "priorityId",
    "declaredAt",
    "targetContextRefs",
    "priorityRules",
    "conflictResolutionDefault",
    "priorityState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "priorityId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "declaredAt": {
      "type": "string",
      "format": "date-time"
    },
    "declaringPartyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "charterRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "targetContextRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "priorityRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ruleId",
          "subjectType",
          "subjectRef",
          "priorityClass"
        ],
        "properties": {
          "ruleId": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "subjectType": {
            "enum": [
              "SUSTAINABILITY_CONSTRAINT",
              "SUSTAINABILITY_OBJECTIVE",
              "SUSTAINABILITY_METRIC",
              "EXPERIMENTAL_OBJECTIVE",
              "EXTERNAL_REQUIREMENT"
            ]
          },
          "subjectRef": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "priorityClass": {
            "enum": [
              "NON_TRADEABLE_FLOOR",
              "REVIEW_REQUIRED_PRIORITY",
              "OPTIMISABLE_OBJECTIVE",
              "REPORT_ONLY_INDICATOR",
              "EXPERIMENTAL_OBJECTIVE"
            ]
          },
          "priorityOrder": {
            "type": "integer",
            "minimum": 0
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    },
    "conflictResolutionDefault": {
      "enum": [
        "STRONGER_CONSTRAINT_WINS",
        "REVIEW_REQUIRED",
        "HARD_FAIL",
        "LOWER_CONFIDENCE_BLOCKS"
      ]
    },
    "priorityState": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "RETIRED",
        "SUPERSEDED"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING",
  "$defs": {}
}
