{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_SustainableFarmingCharter_schema_v0_1.json",
  "title": "OFARM SustainableFarmingCharter CP11 schema v0.1 phase 7.3 final boundary and claim-disposition hardening draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "charterId",
    "charterVersion",
    "declaredAt",
    "declaredByPartyRef",
    "authoritySourceRefs",
    "applicabilityContextRefs",
    "ruleSetRefs",
    "nonBypassClauses",
    "explicitDeferrals",
    "defaultTwinPosture",
    "charterState",
    "doesNotCreateCanonicalTruth",
    "doesNotAuthorizeExecution",
    "doesNotOverrideAuthorityLaw",
    "doesNotOverridePackLaw",
    "doesNotAuthorizeRobotMission",
    "doesNotAuthorizeMachineCommand",
    "cp12RequiredForExecution"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "charterId": {
      "$ref": "#/$defs/OfarmRef"
    },
    "charterVersion": {
      "type": "string",
      "minLength": 1
    },
    "declaredAt": {
      "$ref": "#/$defs/Timestamp"
    },
    "declaredByPartyRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "authoritySourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/OfarmRef"
      }
    },
    "applicabilityContextRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/OfarmRef"
      }
    },
    "effectiveFrom": {
      "$ref": "#/$defs/Timestamp"
    },
    "effectiveUntil": {
      "$ref": "#/$defs/Timestamp"
    },
    "supersedesCharterRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "supersededByCharterRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "activationDecisionRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "authorityDecisionTraceRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "activeArtifactSetRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "packActivationSetRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "ruleSetRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/OfarmRef"
      }
    },
    "nonBypassClauses": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "NO_TRUTH_BYPASS",
          "NO_AUTHORITY_BYPASS",
          "NO_EVIDENCE_BYPASS",
          "NO_FRESHNESS_BYPASS",
          "NO_ADVISORY_TO_COMPLIANCE_SHORTCUT",
          "NO_AGENT_GOVERNANCE_BY_DEFAULT",
          "NO_ROBOT_EXECUTION_AUTHORITY",
          "NO_PACK_CORE_MUTATION"
        ]
      }
    },
    "explicitDeferrals": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "CP12_CYBER_PHYSICAL_MISSION",
          "CP13_LEARNING_EXPERIMENTATION_FARM_MEMORY",
          "CP14_FARM_TO_FARM_INTELLIGENCE",
          "CP15_AGENTIC_SOFTWARE_DELIVERY"
        ]
      }
    },
    "defaultTwinPosture": {
      "type": "string",
      "enum": [
        "ADVISORY_BY_DEFAULT",
        "COMPLIANCE_ONLY_BY_GATE",
        "MIXED_BY_RULE_WITH_RULE_LEVEL_DISPOSITION"
      ]
    },
    "charterState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUSPENDED",
        "SUPERSEDED",
        "RETIRED"
      ]
    },
    "doesNotCreateCanonicalTruth": {
      "const": true
    },
    "doesNotAuthorizeExecution": {
      "const": true
    },
    "doesNotOverrideAuthorityLaw": {
      "const": true
    },
    "doesNotOverridePackLaw": {
      "const": true
    },
    "doesNotAuthorizeRobotMission": {
      "const": true
    },
    "doesNotAuthorizeMachineCommand": {
      "const": true
    },
    "cp12RequiredForExecution": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "OfarmRef": {
      "type": "string",
      "minLength": 1,
      "description": "Reference to an OFARM artifact, party, event, schema, trace, pack, decision, materialisation, or external role-bound identifier."
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "TargetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeClass",
        "scopeRef"
      ],
      "properties": {
        "scopeClass": {
          "type": "string",
          "enum": [
            "FARM",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "OPERATION",
            "OUTPUT",
            "CLAIM",
            "PACK",
            "REGION",
            "ORGANISATION",
            "OTHER"
          ]
        },
        "scopeRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "TimeInterval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intervalClass"
      ],
      "properties": {
        "intervalClass": {
          "type": "string",
          "enum": [
            "EXPLICIT",
            "OPEN_START",
            "OPEN_END",
            "EVENT_BOUNDED",
            "SEASONAL",
            "NOT_APPLICABLE"
          ]
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "eventRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "seasonRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "Subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subjectClass",
        "subjectRef"
      ],
      "properties": {
        "subjectClass": {
          "type": "string",
          "enum": [
            "RECOMMENDATION",
            "PLAN",
            "OUTPUT",
            "CLAIM",
            "EXCEPTION",
            "BREACH",
            "AGENT_RUN",
            "WORLD_MODEL_RUN",
            "QUERY_RESULT",
            "PACK_ACTIVATION",
            "BUDGET",
            "OTHER"
          ]
        },
        "subjectRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "ExternalSchemeRole": {
      "type": "string",
      "enum": [
        "SEMANTIC_ANCHOR",
        "SEMANTIC_PROFILE",
        "EXCHANGE_MAPPING",
        "EVIDENCE_SOURCE",
        "ATTESTATION_WRAPPER",
        "AUTHORITY_SOURCE_BY_EXPLICIT_GRANT",
        "REFERENCE_ONLY"
      ]
    },
    "EvidenceSourceClass": {
      "type": "string",
      "enum": [
        "MEASURED",
        "OBSERVED",
        "SAMPLED",
        "LAB_CONFIRMED",
        "MACHINE_REPORTED",
        "SENSOR_DERIVED",
        "SATELLITE_DERIVED",
        "MODELLED",
        "INFERRED",
        "ESTIMATED",
        "SELF_DECLARED",
        "EXTERNALLY_ATTESTED",
        "CERTIFIED"
      ]
    },
    "EvidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "DISPUTED",
        "STALE",
        "INVALIDATED",
        "PARTIAL",
        "UNKNOWN"
      ]
    },
    "FreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALID_BLOCKING",
        "UNKNOWN_BLOCKING",
        "NOT_APPLICABLE"
      ]
    },
    "UseClass": {
      "type": "string",
      "enum": [
        "ADVISORY_DISPLAY",
        "INFORMATIONAL_DASHBOARD",
        "FARMER_WORKFLOW_HINT",
        "HIGH_CONSEQUENCE_DECISION",
        "CLAIM_BEARING_OUTPUT",
        "ATTESTATION_CANDIDATE",
        "FILED_SUBMISSION",
        "EXECUTION_BOUND_PREPARATION",
        "PARTNER_DISCLOSURE",
        "PUBLIC_DISCLOSURE"
      ]
    }
  },
  "allOf": [
    {
      "properties": {
        "nonBypassClauses": {
          "contains": {
            "const": "NO_TRUTH_BYPASS"
          }
        }
      }
    },
    {
      "properties": {
        "nonBypassClauses": {
          "contains": {
            "const": "NO_AUTHORITY_BYPASS"
          }
        }
      }
    },
    {
      "properties": {
        "nonBypassClauses": {
          "contains": {
            "const": "NO_EVIDENCE_BYPASS"
          }
        }
      }
    },
    {
      "properties": {
        "nonBypassClauses": {
          "contains": {
            "const": "NO_FRESHNESS_BYPASS"
          }
        }
      }
    },
    {
      "properties": {
        "nonBypassClauses": {
          "contains": {
            "const": "NO_ADVISORY_TO_COMPLIANCE_SHORTCUT"
          }
        }
      }
    },
    {
      "properties": {
        "nonBypassClauses": {
          "contains": {
            "const": "NO_AGENT_GOVERNANCE_BY_DEFAULT"
          }
        }
      }
    },
    {
      "properties": {
        "nonBypassClauses": {
          "contains": {
            "const": "NO_ROBOT_EXECUTION_AUTHORITY"
          }
        }
      }
    },
    {
      "properties": {
        "nonBypassClauses": {
          "contains": {
            "const": "NO_PACK_CORE_MUTATION"
          }
        }
      }
    },
    {
      "properties": {
        "explicitDeferrals": {
          "contains": {
            "const": "CP12_CYBER_PHYSICAL_MISSION"
          }
        }
      }
    },
    {
      "properties": {
        "explicitDeferrals": {
          "contains": {
            "const": "CP13_LEARNING_EXPERIMENTATION_FARM_MEMORY"
          }
        }
      }
    },
    {
      "properties": {
        "explicitDeferrals": {
          "contains": {
            "const": "CP14_FARM_TO_FARM_INTELLIGENCE"
          }
        }
      }
    },
    {
      "properties": {
        "explicitDeferrals": {
          "contains": {
            "const": "CP15_AGENTIC_SOFTWARE_DELIVERY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "charterState": {
            "const": "ACTIVE"
          }
        },
        "required": [
          "charterState"
        ]
      },
      "then": {
        "required": [
          "activationDecisionRef",
          "authorityDecisionTraceRef",
          "effectiveFrom",
          "activeArtifactSetRef"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "charterState": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "charterState"
        ]
      },
      "then": {
        "required": [
          "supersededByCharterRef"
        ]
      }
    }
  ],
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING"
}
