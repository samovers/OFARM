{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_SustainabilityClaimBasis_schema_v0_1.json",
  "title": "OFARM SustainabilityClaimBasis CP11 schema v0.1 phase 7.3 final boundary and claim-disposition hardening draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "claimBasisId",
    "declaredAt",
    "claimClass",
    "claimScope",
    "timeInterval",
    "metricProfileRefs",
    "evidenceRequirementRefs",
    "evidenceRefs",
    "claimReadiness",
    "basisState",
    "currentStateReliance",
    "noImplicitClaimReadiness"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "claimBasisId": {
      "$ref": "#/$defs/OfarmRef"
    },
    "declaredAt": {
      "$ref": "#/$defs/Timestamp"
    },
    "declaringPartyRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "charterRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "claimClass": {
      "type": "string",
      "enum": [
        "REDUCED_INPUT_USE",
        "SOIL_HEALTH_IMPROVEMENT",
        "WATER_EFFICIENCY",
        "BIODIVERSITY_POSITIVE",
        "LOW_PESTICIDE_RISK",
        "CARBON_OR_EMISSIONS",
        "CHARTER_COMPLIANT",
        "OTHER"
      ]
    },
    "claimStatement": {
      "type": "string"
    },
    "claimScope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/TargetScope"
      }
    },
    "timeInterval": {
      "$ref": "#/$defs/TimeInterval"
    },
    "metricProfileRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/OfarmRef"
      },
      "uniqueItems": true
    },
    "evidenceRequirementRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/OfarmRef"
      },
      "uniqueItems": true
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/OfarmRef"
      },
      "uniqueItems": true
    },
    "evidenceSufficiencyCaseRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "materializationBasisRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "materializationSnapshotRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "currentStateReliance": {
      "type": "string",
      "enum": [
        "RELIES_ON_CURRENT_STATE",
        "DOES_NOT_RELY_ON_CURRENT_STATE",
        "UNKNOWN_BLOCKING"
      ]
    },
    "currentStateNotUsedReason": {
      "type": "string"
    },
    "methodBasisRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OfarmRef"
      },
      "uniqueItems": true
    },
    "uncertaintyStatement": {
      "type": "string"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approvalGateRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "approvalNotRequiredReason": {
      "type": "string"
    },
    "approvalDecisionRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "authorityDecisionTraceRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "outputDisposition": {
      "type": "string",
      "enum": [
        "ADVISORY_ONLY",
        "CLAIM_BEARING",
        "ATTESTATION_CANDIDATE",
        "FILED_SUBMISSION"
      ]
    },
    "outputQualificationRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "filedOutputRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "noProhibitedUseClassViolation": {
      "type": "boolean"
    },
    "claimReadiness": {
      "type": "string",
      "enum": [
        "NOT_CLAIM_READY",
        "ADVISORY_ONLY",
        "CLAIM_READY",
        "ATTESTATION_READY",
        "FILED",
        "REFUSED",
        "SUPERSEDED"
      ]
    },
    "basisState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED",
        "REVOKED"
      ]
    },
    "noImplicitClaimReadiness": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "OfarmRef": {
      "type": "string",
      "minLength": 1,
      "description": "Reference to an OFARM artifact, party, event, schema, trace, pack, decision, materialisation, or external role-bound identifier."
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "TargetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeClass",
        "scopeRef"
      ],
      "properties": {
        "scopeClass": {
          "type": "string",
          "enum": [
            "FARM",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "OPERATION",
            "OUTPUT",
            "CLAIM",
            "PACK",
            "REGION",
            "ORGANISATION",
            "OTHER"
          ]
        },
        "scopeRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "TimeInterval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intervalClass"
      ],
      "properties": {
        "intervalClass": {
          "type": "string",
          "enum": [
            "EXPLICIT",
            "OPEN_START",
            "OPEN_END",
            "EVENT_BOUNDED",
            "SEASONAL",
            "NOT_APPLICABLE"
          ]
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "eventRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "seasonRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "Subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subjectClass",
        "subjectRef"
      ],
      "properties": {
        "subjectClass": {
          "type": "string",
          "enum": [
            "RECOMMENDATION",
            "PLAN",
            "OUTPUT",
            "CLAIM",
            "EXCEPTION",
            "BREACH",
            "AGENT_RUN",
            "WORLD_MODEL_RUN",
            "QUERY_RESULT",
            "PACK_ACTIVATION",
            "BUDGET",
            "OTHER"
          ]
        },
        "subjectRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "ExternalSchemeRole": {
      "type": "string",
      "enum": [
        "SEMANTIC_ANCHOR",
        "SEMANTIC_PROFILE",
        "EXCHANGE_MAPPING",
        "EVIDENCE_SOURCE",
        "ATTESTATION_WRAPPER",
        "AUTHORITY_SOURCE_BY_EXPLICIT_GRANT",
        "REFERENCE_ONLY"
      ]
    },
    "EvidenceSourceClass": {
      "type": "string",
      "enum": [
        "MEASURED",
        "OBSERVED",
        "SAMPLED",
        "LAB_CONFIRMED",
        "MACHINE_REPORTED",
        "SENSOR_DERIVED",
        "SATELLITE_DERIVED",
        "MODELLED",
        "INFERRED",
        "ESTIMATED",
        "SELF_DECLARED",
        "EXTERNALLY_ATTESTED",
        "CERTIFIED"
      ]
    },
    "EvidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "DISPUTED",
        "STALE",
        "INVALIDATED",
        "PARTIAL",
        "UNKNOWN"
      ]
    },
    "FreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALID_BLOCKING",
        "UNKNOWN_BLOCKING",
        "NOT_APPLICABLE"
      ]
    },
    "UseClass": {
      "type": "string",
      "enum": [
        "ADVISORY_DISPLAY",
        "INFORMATIONAL_DASHBOARD",
        "FARMER_WORKFLOW_HINT",
        "HIGH_CONSEQUENCE_DECISION",
        "CLAIM_BEARING_OUTPUT",
        "ATTESTATION_CANDIDATE",
        "FILED_SUBMISSION",
        "EXECUTION_BOUND_PREPARATION",
        "PARTNER_DISCLOSURE",
        "PUBLIC_DISCLOSURE"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "currentStateReliance": {
            "const": "RELIES_ON_CURRENT_STATE"
          }
        },
        "required": [
          "currentStateReliance"
        ]
      },
      "then": {
        "required": [
          "materializationBasisRef"
        ],
        "not": {
          "required": [
            "currentStateNotUsedReason"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "currentStateReliance": {
            "const": "DOES_NOT_RELY_ON_CURRENT_STATE"
          }
        },
        "required": [
          "currentStateReliance"
        ]
      },
      "then": {
        "required": [
          "currentStateNotUsedReason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "claimReadiness": {
            "enum": [
              "CLAIM_READY",
              "ATTESTATION_READY",
              "FILED"
            ]
          }
        },
        "required": [
          "claimReadiness"
        ]
      },
      "then": {
        "not": {
          "properties": {
            "currentStateReliance": {
              "const": "UNKNOWN_BLOCKING"
            }
          },
          "required": [
            "currentStateReliance"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "claimReadiness": {
            "const": "CLAIM_READY"
          }
        },
        "required": [
          "claimReadiness"
        ]
      },
      "then": {
        "required": [
          "evidenceSufficiencyCaseRef",
          "outputDisposition"
        ],
        "anyOf": [
          {
            "required": [
              "approvalGateRef"
            ]
          },
          {
            "required": [
              "approvalNotRequiredReason"
            ]
          }
        ],
        "properties": {
          "outputDisposition": {
            "const": "CLAIM_BEARING"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "claimReadiness": {
            "const": "ATTESTATION_READY"
          }
        },
        "required": [
          "claimReadiness"
        ]
      },
      "then": {
        "required": [
          "evidenceSufficiencyCaseRef",
          "approvalDecisionRef",
          "authorityDecisionTraceRef",
          "outputQualificationRef",
          "outputDisposition"
        ],
        "anyOf": [
          {
            "properties": {
              "currentStateReliance": {
                "const": "DOES_NOT_RELY_ON_CURRENT_STATE"
              }
            },
            "required": [
              "currentStateReliance",
              "currentStateNotUsedReason"
            ]
          },
          {
            "properties": {
              "currentStateReliance": {
                "const": "RELIES_ON_CURRENT_STATE"
              }
            },
            "required": [
              "currentStateReliance",
              "materializationBasisRef",
              "outputQualificationRef"
            ]
          }
        ],
        "properties": {
          "outputDisposition": {
            "const": "ATTESTATION_CANDIDATE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "claimReadiness": {
            "const": "FILED"
          }
        },
        "required": [
          "claimReadiness"
        ]
      },
      "then": {
        "required": [
          "filedOutputRef",
          "approvalDecisionRef",
          "authorityDecisionTraceRef",
          "outputQualificationRef",
          "noProhibitedUseClassViolation",
          "outputDisposition"
        ],
        "properties": {
          "noProhibitedUseClassViolation": {
            "const": true
          },
          "outputDisposition": {
            "const": "FILED_SUBMISSION"
          }
        },
        "anyOf": [
          {
            "properties": {
              "currentStateReliance": {
                "const": "DOES_NOT_RELY_ON_CURRENT_STATE"
              }
            },
            "required": [
              "currentStateReliance",
              "currentStateNotUsedReason"
            ]
          },
          {
            "properties": {
              "currentStateReliance": {
                "const": "RELIES_ON_CURRENT_STATE"
              }
            },
            "required": [
              "currentStateReliance",
              "materializationBasisRef",
              "outputQualificationRef"
            ]
          }
        ]
      }
    }
  ],
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING"
}
