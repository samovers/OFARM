{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/sustainability_charter/OFARM_CharterBreach_schema_v0_1.json",
  "title": "OFARM CharterBreach CP11 schema v0.1 phase 7.3 final boundary and claim-disposition hardening draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "charterBreachId",
    "detectedAt",
    "detectedByPartyRef",
    "charterRef",
    "breachedRuleRefs",
    "breachClass",
    "breachState",
    "severity",
    "subject",
    "noAutomaticComplianceFact"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cp11-v0.1-draft-phase7-3-final-boundary-and-claim-disposition-hardening"
    },
    "charterBreachId": {
      "$ref": "#/$defs/OfarmRef"
    },
    "detectedAt": {
      "$ref": "#/$defs/Timestamp"
    },
    "detectedByPartyRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "charterRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "breachedRuleRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/OfarmRef"
      }
    },
    "breachClass": {
      "type": "string",
      "enum": [
        "CONSTRAINT_VIOLATION",
        "EVIDENCE_FAILURE",
        "CLAIM_BASIS_FAILURE",
        "UNAUTHORISED_EXCEPTION",
        "UNAUTHORISED_DISCLOSURE",
        "PACK_POLICY_CONFLICT",
        "OTHER"
      ]
    },
    "breachState": {
      "type": "string",
      "enum": [
        "SUSPECTED",
        "CONFIRMED",
        "CONTESTED",
        "RESOLVED",
        "SUPERSEDED",
        "FALSE_POSITIVE",
        "EXCEPTION_COVERED"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "subject": {
      "$ref": "#/$defs/Subject"
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OfarmRef"
      }
    },
    "exceptionRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "reviewDecisionRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "authorityDecisionTraceRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "complianceBridgeCandidateRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "outputQualificationRef": {
      "$ref": "#/$defs/OfarmRef"
    },
    "noAutomaticComplianceFact": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "OfarmRef": {
      "type": "string",
      "minLength": 1,
      "description": "Reference to an OFARM artifact, party, event, schema, trace, pack, decision, materialisation, or external role-bound identifier."
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "TargetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeClass",
        "scopeRef"
      ],
      "properties": {
        "scopeClass": {
          "type": "string",
          "enum": [
            "FARM",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "OPERATION",
            "OUTPUT",
            "CLAIM",
            "PACK",
            "REGION",
            "ORGANISATION",
            "OTHER"
          ]
        },
        "scopeRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "TimeInterval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intervalClass"
      ],
      "properties": {
        "intervalClass": {
          "type": "string",
          "enum": [
            "EXPLICIT",
            "OPEN_START",
            "OPEN_END",
            "EVENT_BOUNDED",
            "SEASONAL",
            "NOT_APPLICABLE"
          ]
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "eventRef": {
          "$ref": "#/$defs/OfarmRef"
        },
        "seasonRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "Subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subjectClass",
        "subjectRef"
      ],
      "properties": {
        "subjectClass": {
          "type": "string",
          "enum": [
            "RECOMMENDATION",
            "PLAN",
            "OUTPUT",
            "CLAIM",
            "EXCEPTION",
            "BREACH",
            "AGENT_RUN",
            "WORLD_MODEL_RUN",
            "QUERY_RESULT",
            "PACK_ACTIVATION",
            "BUDGET",
            "OTHER"
          ]
        },
        "subjectRef": {
          "$ref": "#/$defs/OfarmRef"
        }
      }
    },
    "ExternalSchemeRole": {
      "type": "string",
      "enum": [
        "SEMANTIC_ANCHOR",
        "SEMANTIC_PROFILE",
        "EXCHANGE_MAPPING",
        "EVIDENCE_SOURCE",
        "ATTESTATION_WRAPPER",
        "AUTHORITY_SOURCE_BY_EXPLICIT_GRANT",
        "REFERENCE_ONLY"
      ]
    },
    "EvidenceSourceClass": {
      "type": "string",
      "enum": [
        "MEASURED",
        "OBSERVED",
        "SAMPLED",
        "LAB_CONFIRMED",
        "MACHINE_REPORTED",
        "SENSOR_DERIVED",
        "SATELLITE_DERIVED",
        "MODELLED",
        "INFERRED",
        "ESTIMATED",
        "SELF_DECLARED",
        "EXTERNALLY_ATTESTED",
        "CERTIFIED"
      ]
    },
    "EvidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "DISPUTED",
        "STALE",
        "INVALIDATED",
        "PARTIAL",
        "UNKNOWN"
      ]
    },
    "FreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALID_BLOCKING",
        "UNKNOWN_BLOCKING",
        "NOT_APPLICABLE"
      ]
    },
    "UseClass": {
      "type": "string",
      "enum": [
        "ADVISORY_DISPLAY",
        "INFORMATIONAL_DASHBOARD",
        "FARMER_WORKFLOW_HINT",
        "HIGH_CONSEQUENCE_DECISION",
        "CLAIM_BEARING_OUTPUT",
        "ATTESTATION_CANDIDATE",
        "FILED_SUBMISSION",
        "EXECUTION_BOUND_PREPARATION",
        "PARTNER_DISCLOSURE",
        "PUBLIC_DISCLOSURE"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "breachState": {
            "enum": [
              "CONFIRMED",
              "RESOLVED"
            ]
          }
        },
        "required": [
          "breachState"
        ]
      },
      "then": {
        "anyOf": [
          {
            "required": [
              "reviewDecisionRef"
            ]
          },
          {
            "required": [
              "authorityDecisionTraceRef"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "breachState": {
            "const": "EXCEPTION_COVERED"
          }
        },
        "required": [
          "breachState"
        ]
      },
      "then": {
        "required": [
          "exceptionRef"
        ]
      }
    }
  ],
  "x-ofarm-status": "draft-phase7-3-final-boundary-and-claim-disposition-hardening-non-default",
  "x-ofarm-cp": "CP11",
  "x-ofarm-currentness": "DRAFT_NON_DEFAULT_CP11_PHASE7_3_FINAL_BOUNDARY_AND_CLAIM_DISPOSITION_HARDENING"
}
