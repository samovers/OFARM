{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/ExperimentRollbackTrigger/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM ExperimentRollbackTrigger schema v0.1 draft/non-default",
  "description": "Condition under which an experiment, trial, or learning workflow should stop, pause, roll back, downgrade, or require review.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "ExperimentRollbackTrigger"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP13 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "experimentProtocolRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "triggerType": {
      "type": "string",
      "enum": [
        "CHARTER_RISK",
        "REGRET_BUDGET_EXCEEDED",
        "SAFETY_INCIDENT",
        "MISSION_NEAR_MISS",
        "YIELD_LOSS_THRESHOLD",
        "QUALITY_LOSS_THRESHOLD",
        "DATA_QUALITY_FAILURE",
        "AUTHORITY_FAILURE",
        "OTHER"
      ],
      "description": ""
    },
    "triggerCondition": {
      "type": "string",
      "minLength": 1
    },
    "triggerState": {
      "type": "string",
      "enum": [
        "DECLARED",
        "TRIGGERED",
        "RESOLVED",
        "SUPERSEDED"
      ],
      "description": ""
    },
    "triggerAction": {
      "type": "string",
      "enum": [
        "STOP",
        "PAUSE",
        "REQUIRE_REVIEW",
        "ROLLBACK",
        "DOWNGRADE_OUTPUT",
        "REQUEST_EVIDENCE",
        "INVALIDATE_MEMORY_CANDIDATE"
      ],
      "description": ""
    },
    "cp11RiskRegretBudgetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "OFARM artifact references"
    },
    "cp12IncidentRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "OFARM artifact references"
    },
    "doesNotAuthorizeRollbackOperation": {
      "type": "boolean",
      "const": true,
      "description": "guardrail"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "experimentProtocolRef",
    "triggerType",
    "triggerCondition",
    "triggerState",
    "triggerAction",
    "doesNotAuthorizeRollbackOperation"
  ],
  "$comment": "CP13 Phase 7 final amendment candidate schema. Draft/non-default; not current/default until separately promoted."
}
