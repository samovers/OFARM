{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/RandomizationPlan/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM RandomizationPlan schema v0.1 draft/non-default",
  "description": "Declares randomization or non-randomized assignment posture for trial design.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "RandomizationPlan"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP13 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "randomizationMethod": {
      "type": "string",
      "enum": [
        "NONE",
        "SIMPLE_RANDOM",
        "BLOCK_RANDOM",
        "STRATIFIED_RANDOM",
        "SYSTEMATIC_ALTERNATION",
        "OPERATIONAL_CONSTRAINT_ASSIGNMENT",
        "UNKNOWN"
      ],
      "description": ""
    },
    "randomizationSeed": {
      "type": "string"
    },
    "assignmentRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Assignment rule refs"
    },
    "nonRandomizedJustification": {
      "type": "string"
    },
    "randomizationIntegrityState": {
      "type": "string",
      "enum": [
        "DECLARED",
        "VERIFIED",
        "PARTIAL",
        "NOT_APPLICABLE",
        "INSUFFICIENT",
        "DISPUTED"
      ],
      "description": ""
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "randomizationMethod",
    "randomizationIntegrityState"
  ],
  "$comment": "CP13 Phase 7 final amendment candidate schema. Draft/non-default; not current/default until separately promoted."
}
