{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/LearningHypothesis/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM LearningHypothesis schema v0.1 draft/non-default",
  "description": "Represents a testable learning proposition. It is not fact, farm memory, current state, or compliance truth.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "LearningHypothesis"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP13 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "hypothesisStatement": {
      "type": "string",
      "minLength": 1
    },
    "hypothesisState": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "APPROVED_FOR_EVALUATION",
        "UNDER_TEST",
        "SUPPORTED",
        "NOT_SUPPORTED",
        "INCONCLUSIVE",
        "REJECTED",
        "SUPERSEDED",
        "INVALIDATED"
      ],
      "description": ""
    },
    "hypothesisClass": {
      "type": "string",
      "enum": [
        "AGRONOMIC_RESPONSE",
        "MISSION_PERFORMANCE",
        "INPUT_RESPONSE",
        "SOIL_WATER_BIODIVERSITY",
        "RISK_PATTERN",
        "ECONOMIC_PATTERN",
        "LOCAL_MEMORY_CANDIDATE",
        "OTHER"
      ],
      "description": ""
    },
    "basisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Evidence, observation, scenario, expert, or historical basis refs"
    },
    "proposedByAgentRunTraceRef": {
      "type": "string",
      "minLength": 1,
      "description": "Optional agent run trace"
    },
    "noTruthByExistence": {
      "type": "boolean",
      "const": true,
      "description": "guardrail"
    },
    "noFarmMemoryByExistence": {
      "type": "boolean",
      "const": true,
      "description": "guardrail"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "hypothesisStatement",
    "hypothesisState",
    "hypothesisClass",
    "noTruthByExistence",
    "noFarmMemoryByExistence"
  ],
  "$comment": "CP13 Phase 7 final amendment candidate schema. Draft/non-default; not current/default until separately promoted."
}
