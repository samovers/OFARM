{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/LearningPromotionDecision/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM LearningPromotionDecision schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 LearningPromotionDecision contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "LearningPromotionDecision"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "decisionState": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "APPROVED",
        "REJECTED",
        "REQUIRES_MORE_EVIDENCE",
        "SUPERSEDED",
        "INVALIDATED"
      ]
    },
    "promotionDisposition": {
      "type": "string",
      "enum": [
        "PROMOTE_TO_FARM_MEMORY",
        "PROMOTE_TO_FARM_MEMORY_CANDIDATE",
        "PROMOTE_TO_ADVISORY_RECOMMENDATION",
        "PROMOTE_TO_REVIEW_PACKAGE",
        "SUPERSEDE_PRIOR_MEMORY",
        "DO_NOT_PROMOTE",
        "REFUSE",
        "REQUIRE_MORE_EVIDENCE"
      ]
    },
    "learningEvaluationTraceRef": {
      "type": "string",
      "minLength": 1
    },
    "farmMemoryEntryRef": {
      "type": "string",
      "minLength": 1
    },
    "farmMemoryCandidateRef": {
      "type": "string",
      "minLength": 1
    },
    "supersededFarmMemoryEntryRef": {
      "type": "string",
      "minLength": 1
    },
    "rejectedCandidateFarmMemoryEntryRef": {
      "type": "string",
      "minLength": 1
    },
    "outputQualificationRef": {
      "type": "string",
      "minLength": 1
    },
    "reviewDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "reviewPackageRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "decisionRationale": {
      "type": "string",
      "minLength": 1
    },
    "noCurrentStateMutation": {
      "type": "boolean",
      "const": true
    },
    "noComplianceFactByDecision": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "decisionState",
    "promotionDisposition",
    "learningEvaluationTraceRef",
    "decisionRationale",
    "noCurrentStateMutation",
    "noComplianceFactByDecision"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "promotionDisposition": {
            "const": "PROMOTE_TO_FARM_MEMORY"
          }
        },
        "required": [
          "promotionDisposition"
        ]
      },
      "then": {
        "required": [
          "farmMemoryEntryRef",
          "reviewDecisionRef",
          "authorityDecisionTraceRef",
          "effectiveFrom",
          "expiresAt"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "promotionDisposition": {
            "const": "PROMOTE_TO_FARM_MEMORY_CANDIDATE"
          }
        },
        "required": [
          "promotionDisposition"
        ]
      },
      "then": {
        "anyOf": [
          {
            "required": [
              "farmMemoryEntryRef"
            ]
          },
          {
            "required": [
              "farmMemoryCandidateRef"
            ]
          }
        ],
        "required": [
          "reviewDecisionRef"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "promotionDisposition": {
            "const": "PROMOTE_TO_ADVISORY_RECOMMENDATION"
          }
        },
        "required": [
          "promotionDisposition"
        ]
      },
      "then": {
        "required": [
          "outputQualificationRef"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "promotionDisposition": {
            "const": "PROMOTE_TO_REVIEW_PACKAGE"
          }
        },
        "required": [
          "promotionDisposition"
        ]
      },
      "then": {
        "anyOf": [
          {
            "required": [
              "reviewDecisionRef"
            ]
          },
          {
            "required": [
              "reviewPackageRef"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "promotionDisposition": {
            "const": "SUPERSEDE_PRIOR_MEMORY"
          }
        },
        "required": [
          "promotionDisposition"
        ]
      },
      "then": {
        "required": [
          "supersededFarmMemoryEntryRef",
          "farmMemoryEntryRef",
          "reviewDecisionRef",
          "authorityDecisionTraceRef",
          "effectiveFrom"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "promotionDisposition": {
            "enum": [
              "DO_NOT_PROMOTE",
              "REFUSE",
              "REQUIRE_MORE_EVIDENCE"
            ]
          }
        },
        "required": [
          "promotionDisposition"
        ]
      },
      "then": {
        "not": {
          "required": [
            "farmMemoryEntryRef"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "promotionDisposition": {
            "const": "PROMOTE_TO_FARM_MEMORY"
          }
        },
        "required": [
          "promotionDisposition"
        ]
      },
      "then": {
        "properties": {
          "decisionState": {
            "const": "APPROVED"
          }
        },
        "required": [
          "farmMemoryEntryRef",
          "reviewDecisionRef",
          "authorityDecisionTraceRef",
          "effectiveFrom",
          "expiresAt"
        ]
      }
    }
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
