{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/BlockingFactor/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM BlockingFactor schema v0.1 draft/non-default",
  "description": "Represents a factor used to block, stratify, or qualify a trial design or causal evaluation.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "BlockingFactor"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP13 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "factorType": {
      "type": "string",
      "enum": [
        "SOIL_TYPE",
        "SLOPE",
        "IRRIGATION_ZONE",
        "VARIETY",
        "FIELD_HISTORY",
        "MACHINE_PASS",
        "WEATHER_WINDOW",
        "PEST_PRESSURE",
        "OTHER"
      ],
      "description": ""
    },
    "factorRef": {
      "type": "string",
      "minLength": 1,
      "description": "Factor measurement/context reference"
    },
    "blockingRationale": {
      "type": "string",
      "minLength": 1
    },
    "measurementQualityState": {
      "type": "string",
      "enum": [
        "MEASURED",
        "MODELLED",
        "INFERRED",
        "UNKNOWN",
        "DISPUTED",
        "STALE"
      ],
      "description": ""
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "factorType",
    "factorRef",
    "blockingRationale",
    "measurementQualityState"
  ],
  "$comment": "CP13 Phase 7 final amendment candidate schema. Draft/non-default; not current/default until separately promoted."
}
