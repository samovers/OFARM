{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/LearningOutputQualification/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM LearningOutputQualification schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 LearningOutputQualification contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "LearningOutputQualification"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "outputRef": {
      "type": "string",
      "minLength": 1
    },
    "outputDisposition": {
      "type": "string",
      "enum": [
        "ADVISORY_ONLY",
        "RECOMMENDATION_SUPPORT",
        "FARM_MEMORY_RETRIEVAL",
        "SEASONAL_SUMMARY",
        "REVIEW_PACKAGE",
        "REFUSED"
      ]
    },
    "advisoryOnly": {
      "type": "boolean"
    },
    "allowedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "EXPLORATORY_ADVISORY",
          "RECOMMENDATION_SUPPORT",
          "FARMER_DISPLAY",
          "REVIEW_PACKAGE",
          "FARM_MEMORY_CANDIDATE_REVIEW",
          "SEASONAL_SUMMARY_REVIEW"
        ]
      },
      "uniqueItems": true
    },
    "blockedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "CANONICAL_TRUTH",
          "CURRENT_STATE",
          "COMPLIANCE_FACT",
          "AUTOMATIC_EXECUTION",
          "MISSION_DISPATCH",
          "CLAIM_BEARING_OUTPUT",
          "MODEL_TRAINING",
          "MODEL_DEPLOYMENT",
          "CROSS_FARM_SHARING",
          "FEDERATED_LEARNING",
          "PUBLIC_DISCLOSURE",
          "UNQUALIFIED_CLAIM"
        ]
      },
      "uniqueItems": true
    },
    "learningEvaluationTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "LearningEvaluationTrace refs"
    },
    "farmMemoryRetrievalQualificationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "FarmMemoryRetrievalQualification refs"
    },
    "claimSupportRequiresCP11": {
      "type": "boolean",
      "const": true
    },
    "deploymentRequiresCP15": {
      "type": "boolean",
      "const": true
    },
    "crossFarmUseRequiresCP14": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "outputRef",
    "outputDisposition",
    "advisoryOnly",
    "allowedUseClasses",
    "blockedUseClasses",
    "claimSupportRequiresCP11",
    "deploymentRequiresCP15",
    "crossFarmUseRequiresCP14"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "advisoryOnly": {
            "const": true
          }
        },
        "required": [
          "advisoryOnly"
        ]
      },
      "then": {
        "properties": {
          "blockedUseClasses": {
            "allOf": [
              {
                "contains": {
                  "const": "CANONICAL_TRUTH"
                }
              },
              {
                "contains": {
                  "const": "CURRENT_STATE"
                }
              },
              {
                "contains": {
                  "const": "COMPLIANCE_FACT"
                }
              },
              {
                "contains": {
                  "const": "AUTOMATIC_EXECUTION"
                }
              },
              {
                "contains": {
                  "const": "MISSION_DISPATCH"
                }
              },
              {
                "contains": {
                  "const": "CLAIM_BEARING_OUTPUT"
                }
              },
              {
                "contains": {
                  "const": "MODEL_DEPLOYMENT"
                }
              },
              {
                "contains": {
                  "const": "CROSS_FARM_SHARING"
                }
              }
            ]
          }
        }
      }
    }
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
