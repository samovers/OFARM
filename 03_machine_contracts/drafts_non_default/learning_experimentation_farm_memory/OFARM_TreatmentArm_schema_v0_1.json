{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/TreatmentArm/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM TreatmentArm schema v0.1 draft/non-default",
  "description": "Represents a planned treatment, intervention, mission, input, timing, rate, or management difference under comparison.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "TreatmentArm"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP13 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "armLabel": {
      "type": "string",
      "minLength": 1
    },
    "armType": {
      "type": "string",
      "enum": [
        "INPUT_RATE",
        "TIMING_CHANGE",
        "OPERATION_CHANGE",
        "MISSION_STRATEGY",
        "VARIETY",
        "IRRIGATION",
        "FERTILITY",
        "CROP_PROTECTION",
        "CONTROL_LIKE",
        "OTHER"
      ],
      "description": ""
    },
    "interventionIntentRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Intervention intent refs"
    },
    "missionPlanRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "CP12 mission plan refs"
    },
    "cp11CharterTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "CP11 charter traces"
    },
    "doesNotAuthorizeOperation": {
      "type": "boolean",
      "const": true,
      "description": "guardrail"
    },
    "doesNotAuthorizeMission": {
      "type": "boolean",
      "const": true,
      "description": "guardrail"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "armLabel",
    "armType",
    "doesNotAuthorizeOperation",
    "doesNotAuthorizeMission"
  ],
  "$comment": "CP13 Phase 7 final amendment candidate schema. Draft/non-default; not current/default until separately promoted."
}
