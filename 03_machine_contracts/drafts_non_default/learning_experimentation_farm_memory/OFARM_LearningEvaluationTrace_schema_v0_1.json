{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/LearningEvaluationTrace/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM LearningEvaluationTrace schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 LearningEvaluationTrace contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "LearningEvaluationTrace"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1
    },
    "evidenceBundleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "LearningEvidenceBundle refs",
      "minItems": 1
    },
    "evaluationCompleteness": {
      "type": "string",
      "enum": [
        "COMPLETE",
        "PARTIAL",
        "INSUFFICIENT_SCOPE",
        "INSUFFICIENT_EVIDENCE",
        "INSUFFICIENT_DESIGN",
        "AUTHORITY_BLOCKED",
        "CHARTER_BLOCKED",
        "MISSION_BLOCKED"
      ]
    },
    "overallDisposition": {
      "type": "string",
      "enum": [
        "ALLOW_ADVISORY",
        "PROMOTION_CANDIDATE",
        "REQUIRE_REVIEW",
        "REQUIRE_MORE_EVIDENCE",
        "REFUSE",
        "BLOCKED"
      ]
    },
    "checkResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "checkClass": {
            "type": "string",
            "enum": [
              "DESIGN",
              "EVIDENCE",
              "MISSINGNESS",
              "CP11_CHARTER",
              "CP12_EVIDENCE",
              "CAUSAL_IDENTIFICATION",
              "UNCERTAINTY",
              "AUTHORITY",
              "SCOPE",
              "DATA_SOVEREIGNTY",
              "OUTPUT_QUALIFICATION",
              "OTHER"
            ]
          },
          "result": {
            "type": "string",
            "enum": [
              "PASS",
              "FAIL",
              "BLOCKED",
              "INSUFFICIENT_BASIS",
              "REQUIRE_REVIEW",
              "REQUIRE_HUMAN_APPROVAL",
              "NOT_APPLICABLE"
            ]
          },
          "blocking": {
            "type": "boolean"
          },
          "basisRef": {
            "type": "string",
            "minLength": 1
          },
          "limitations": {
            "type": "string"
          }
        },
        "required": [
          "checkClass",
          "result",
          "blocking"
        ]
      },
      "minItems": 1
    },
    "noTruthMutation": {
      "type": "boolean",
      "const": true
    },
    "noFarmMemoryPromotionByTrace": {
      "type": "boolean",
      "const": true
    },
    "noComplianceFactByTrace": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "evidenceBundleRefs",
    "evaluationCompleteness",
    "overallDisposition",
    "checkResults",
    "noTruthMutation",
    "noFarmMemoryPromotionByTrace",
    "noComplianceFactByTrace"
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted.",
  "allOf": [
    {
      "if": {
        "properties": {
          "overallDisposition": {
            "const": "PROMOTION_CANDIDATE"
          }
        },
        "required": [
          "overallDisposition"
        ]
      },
      "then": {
        "properties": {
          "evaluationCompleteness": {
            "const": "COMPLETE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "overallDisposition": {
            "const": "PROMOTION_CANDIDATE"
          }
        },
        "required": [
          "overallDisposition"
        ]
      },
      "then": {
        "properties": {
          "checkResults": {
            "allOf": [
              {
                "contains": {
                  "type": "object",
                  "properties": {
                    "checkClass": {
                      "const": "DESIGN"
                    }
                  },
                  "required": [
                    "checkClass"
                  ]
                },
                "minContains": 1
              },
              {
                "contains": {
                  "type": "object",
                  "properties": {
                    "checkClass": {
                      "const": "EVIDENCE"
                    }
                  },
                  "required": [
                    "checkClass"
                  ]
                },
                "minContains": 1
              },
              {
                "contains": {
                  "type": "object",
                  "properties": {
                    "checkClass": {
                      "const": "MISSINGNESS"
                    }
                  },
                  "required": [
                    "checkClass"
                  ]
                },
                "minContains": 1
              },
              {
                "contains": {
                  "type": "object",
                  "properties": {
                    "checkClass": {
                      "const": "CAUSAL_IDENTIFICATION"
                    }
                  },
                  "required": [
                    "checkClass"
                  ]
                },
                "minContains": 1
              },
              {
                "contains": {
                  "type": "object",
                  "properties": {
                    "checkClass": {
                      "const": "UNCERTAINTY"
                    }
                  },
                  "required": [
                    "checkClass"
                  ]
                },
                "minContains": 1
              },
              {
                "contains": {
                  "type": "object",
                  "properties": {
                    "checkClass": {
                      "const": "AUTHORITY"
                    }
                  },
                  "required": [
                    "checkClass"
                  ]
                },
                "minContains": 1
              },
              {
                "contains": {
                  "type": "object",
                  "properties": {
                    "checkClass": {
                      "const": "SCOPE"
                    }
                  },
                  "required": [
                    "checkClass"
                  ]
                },
                "minContains": 1
              },
              {
                "contains": {
                  "type": "object",
                  "properties": {
                    "checkClass": {
                      "const": "OUTPUT_QUALIFICATION"
                    }
                  },
                  "required": [
                    "checkClass"
                  ]
                },
                "minContains": 1
              }
            ]
          }
        }
      }
    }
  ]
}
