{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/SeasonalLearningSummary/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM SeasonalLearningSummary schema v0.1 draft/non-default",
  "description": "Season-bounded summary linking hypotheses, operations, missions, outcomes, memories, limitations, and learning decisions.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "SeasonalLearningSummary"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP13 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "seasonRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "learningScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "OFARM artifact references",
      "minItems": 1
    },
    "hypothesisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "OFARM artifact references"
    },
    "experimentProtocolRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "OFARM artifact references"
    },
    "outcomeObservationSetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "OFARM artifact references"
    },
    "causalEstimateRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "OFARM artifact references"
    },
    "farmMemoryEntryRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "OFARM artifact references"
    },
    "missionEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "CP12 mission evidence refs"
    },
    "summaryDisposition": {
      "type": "string",
      "enum": [
        "ADVISORY_SUMMARY",
        "REVIEW_PACKAGE",
        "FARM_MEMORY_SUPPORT",
        "CLAIM_SUPPORT_CANDIDATE",
        "INSUFFICIENT_BASIS"
      ],
      "description": ""
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "noBlanketTruthUpdate": {
      "type": "boolean",
      "const": true,
      "description": "guardrail"
    },
    "noCurrentStateMutation": {
      "type": "boolean",
      "const": true,
      "description": "guardrail"
    },
    "sustainabilityClaimBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "learningOutputQualificationRef": {
      "type": "string",
      "minLength": 1
    },
    "reviewDecisionRef": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "seasonRef",
    "learningScopeRefs",
    "summaryDisposition",
    "noBlanketTruthUpdate",
    "noCurrentStateMutation"
  ],
  "$comment": "CP13 Phase 7 final amendment candidate schema. Draft/non-default; not current/default until separately promoted.",
  "allOf": [
    {
      "if": {
        "properties": {
          "summaryDisposition": {
            "const": "CLAIM_SUPPORT_CANDIDATE"
          }
        },
        "required": [
          "summaryDisposition"
        ]
      },
      "then": {
        "required": [
          "sustainabilityClaimBasisRefs",
          "learningOutputQualificationRef",
          "reviewDecisionRef"
        ]
      }
    }
  ]
}
