{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/OutcomeObservationSet/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM OutcomeObservationSet schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 OutcomeObservationSet contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "OutcomeObservationSet"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1
    },
    "outcomeMeasureSpecRef": {
      "type": "string",
      "minLength": 1
    },
    "experimentalUnitRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "ExperimentalUnit refs",
      "minItems": 1
    },
    "observationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Observation/evidence refs",
      "minItems": 1
    },
    "missingnessState": {
      "type": "string",
      "enum": [
        "NONE",
        "MINOR",
        "MATERIAL",
        "BLOCKING",
        "UNKNOWN"
      ]
    },
    "dataQualityState": {
      "type": "string",
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW",
        "UNKNOWN"
      ]
    },
    "evidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "PARTIAL",
        "INSUFFICIENT",
        "STALE",
        "INVALIDATED",
        "UNKNOWN"
      ]
    },
    "missingnessResolutionRef": {
      "type": "string",
      "minLength": 1
    },
    "reviewDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "noCausalConclusionByItself": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "outcomeMeasureSpecRef",
    "experimentalUnitRefs",
    "observationRefs",
    "missingnessState",
    "dataQualityState",
    "evidenceQualityState",
    "noCausalConclusionByItself"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "missingnessState": {
            "enum": [
              "MATERIAL",
              "UNKNOWN"
            ]
          },
          "evidenceQualityState": {
            "const": "SUFFICIENT"
          }
        },
        "required": [
          "missingnessState",
          "evidenceQualityState"
        ]
      },
      "then": {
        "anyOf": [
          {
            "required": [
              "missingnessResolutionRef"
            ]
          },
          {
            "required": [
              "reviewDecisionRef"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "missingnessState": {
            "const": "BLOCKING"
          }
        },
        "required": [
          "missingnessState"
        ]
      },
      "then": {
        "properties": {
          "evidenceQualityState": {
            "enum": [
              "INSUFFICIENT",
              "UNKNOWN"
            ]
          }
        }
      }
    }
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
