{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/ExperimentProtocol/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM ExperimentProtocol schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 ExperimentProtocol contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "ExperimentProtocol"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "protocolState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "PAUSED",
        "COMPLETED",
        "ABORTED",
        "SUPERSEDED"
      ]
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1
    },
    "hypothesisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "LearningHypothesis refs",
      "minItems": 1
    },
    "trialDesignRef": {
      "type": "string",
      "minLength": 1
    },
    "completionEvidenceBundleRef": {
      "type": "string",
      "minLength": 1
    },
    "learningEvaluationTraceRef": {
      "type": "string",
      "minLength": 1
    },
    "closureReviewDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "pauseReason": {
      "type": "string",
      "minLength": 1
    },
    "resumeAuthorityRequirement": {
      "type": "string",
      "minLength": 1
    },
    "doesNotAuthorizeOperation": {
      "type": "boolean",
      "const": true
    },
    "doesNotAuthorizeMission": {
      "type": "boolean",
      "const": true
    },
    "approvalDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1
    },
    "riskBudgetRef": {
      "type": "string",
      "minLength": 1
    },
    "regretBudgetRef": {
      "type": "string",
      "minLength": 1
    },
    "charterSensitive": {
      "type": "boolean"
    },
    "charterEvaluationTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "protocolState",
    "learningScopeRef",
    "hypothesisRefs",
    "trialDesignRef",
    "doesNotAuthorizeOperation",
    "doesNotAuthorizeMission"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "protocolState": {
            "const": "COMPLETED"
          }
        },
        "required": [
          "protocolState"
        ]
      },
      "then": {
        "required": [
          "completionEvidenceBundleRef",
          "completedAt"
        ],
        "anyOf": [
          {
            "required": [
              "learningEvaluationTraceRef"
            ]
          },
          {
            "required": [
              "closureReviewDecisionRef"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "protocolState": {
            "const": "PAUSED"
          }
        },
        "required": [
          "protocolState"
        ]
      },
      "then": {
        "required": [
          "pauseReason",
          "resumeAuthorityRequirement"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "protocolState": {
            "const": "ACTIVE"
          }
        },
        "required": [
          "protocolState"
        ]
      },
      "then": {
        "required": [
          "approvalDecisionRef",
          "authorityDecisionTraceRef"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "protocolState": {
            "const": "ACTIVE"
          },
          "charterSensitive": {
            "const": true
          }
        },
        "required": [
          "protocolState",
          "charterSensitive"
        ]
      },
      "then": {
        "required": [
          "charterEvaluationTraceRefs"
        ],
        "properties": {
          "charterEvaluationTraceRefs": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
