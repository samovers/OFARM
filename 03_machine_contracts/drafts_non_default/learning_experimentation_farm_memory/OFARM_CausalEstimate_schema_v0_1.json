{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/CausalEstimate/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM CausalEstimate schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 CausalEstimate contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "CausalEstimate"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1
    },
    "hypothesisRef": {
      "type": "string",
      "minLength": 1
    },
    "learningEvaluationTraceRef": {
      "type": "string",
      "minLength": 1
    },
    "evidenceBundleRef": {
      "type": "string",
      "minLength": 1
    },
    "trialDesignRef": {
      "type": "string",
      "minLength": 1
    },
    "reviewDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "effectDescription": {
      "type": "string",
      "minLength": 1
    },
    "effectDirection": {
      "type": "string",
      "enum": [
        "POSITIVE",
        "NEGATIVE",
        "NEUTRAL",
        "MIXED",
        "UNKNOWN"
      ]
    },
    "effectSize": {
      "type": "number"
    },
    "effectUnit": {
      "type": "string",
      "minLength": 1
    },
    "estimateMethod": {
      "type": "string",
      "enum": [
        "RANDOMIZED_TRIAL",
        "QUASI_EXPERIMENTAL",
        "OBSERVATIONAL_MATCHED",
        "MODELLED_COUNTERFACTUAL",
        "EXPLORATORY_ASSOCIATION",
        "EXPERT_INTERPRETATION",
        "INSUFFICIENT_FOR_ESTIMATE"
      ]
    },
    "confidenceClass": {
      "type": "string",
      "enum": [
        "HIGH",
        "MODERATE",
        "LOW",
        "EXPLORATORY_ONLY",
        "INSUFFICIENT"
      ]
    },
    "uncertaintyStatement": {
      "type": "string",
      "minLength": 1
    },
    "externalValidityBoundary": {
      "type": "string",
      "minLength": 1
    },
    "causalIdentificationAssumptionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Causal identification assumption refs"
    },
    "biasRiskClass": {
      "type": "string",
      "enum": [
        "LOW",
        "MODERATE",
        "HIGH",
        "UNKNOWN"
      ]
    },
    "missingnessImpactClass": {
      "type": "string",
      "enum": [
        "NONE",
        "MINOR",
        "MATERIAL",
        "BLOCKING",
        "UNKNOWN"
      ]
    },
    "noCausalTruthByEstimate": {
      "type": "boolean",
      "const": true
    },
    "noComplianceFactByEstimate": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "hypothesisRef",
    "learningEvaluationTraceRef",
    "effectDescription",
    "effectDirection",
    "effectUnit",
    "estimateMethod",
    "confidenceClass",
    "uncertaintyStatement",
    "externalValidityBoundary",
    "noCausalTruthByEstimate",
    "noComplianceFactByEstimate"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "estimateMethod": {
            "const": "INSUFFICIENT_FOR_ESTIMATE"
          }
        },
        "required": [
          "estimateMethod"
        ]
      },
      "then": {
        "properties": {
          "confidenceClass": {
            "const": "INSUFFICIENT"
          },
          "effectDirection": {
            "const": "UNKNOWN"
          }
        },
        "not": {
          "required": [
            "effectSize"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "confidenceClass": {
            "const": "HIGH"
          }
        },
        "required": [
          "confidenceClass"
        ]
      },
      "then": {
        "required": [
          "evidenceBundleRef",
          "trialDesignRef",
          "uncertaintyStatement",
          "externalValidityBoundary",
          "learningEvaluationTraceRef"
        ],
        "properties": {
          "estimateMethod": {
            "not": {
              "const": "INSUFFICIENT_FOR_ESTIMATE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "confidenceClass": {
            "const": "HIGH"
          }
        },
        "required": [
          "confidenceClass"
        ]
      },
      "then": {
        "properties": {
          "estimateMethod": {
            "not": {
              "enum": [
                "EXPLORATORY_ASSOCIATION",
                "EXPERT_INTERPRETATION",
                "INSUFFICIENT_FOR_ESTIMATE"
              ]
            }
          },
          "biasRiskClass": {
            "not": {
              "enum": [
                "HIGH",
                "UNKNOWN"
              ]
            }
          },
          "missingnessImpactClass": {
            "not": {
              "enum": [
                "BLOCKING",
                "UNKNOWN"
              ]
            }
          }
        },
        "required": [
          "trialDesignRef",
          "reviewDecisionRef",
          "biasRiskClass",
          "missingnessImpactClass"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "confidenceClass": {
            "const": "MODERATE"
          }
        },
        "required": [
          "confidenceClass"
        ]
      },
      "then": {
        "properties": {
          "estimateMethod": {
            "not": {
              "const": "INSUFFICIENT_FOR_ESTIMATE"
            }
          }
        }
      }
    }
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
