{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/ExperimentalUnit/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM ExperimentalUnit schema v0.1 draft/non-default",
  "description": "Defines the unit of comparison or assignment in a learning design.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "ExperimentalUnit"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP13 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "unitType": {
      "type": "string",
      "enum": [
        "FIELD",
        "FIELD_STRIP",
        "PLOT",
        "ZONE",
        "CROP_CYCLE_SEGMENT",
        "MISSION_SEGMENT",
        "LOT",
        "EQUIPMENT_RUN",
        "OTHER"
      ],
      "description": ""
    },
    "unitScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Field/plot/zone/mission segment refs",
      "minItems": 1
    },
    "geometryRef": {
      "type": "string",
      "minLength": 1,
      "description": "Optional geometry basis"
    },
    "assignmentStatus": {
      "type": "string",
      "enum": [
        "UNASSIGNED",
        "ASSIGNED_TO_TREATMENT",
        "ASSIGNED_TO_CONTROL",
        "EXCLUDED",
        "INVALIDATED"
      ],
      "description": ""
    },
    "exclusionReason": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "unitType",
    "unitScopeRefs",
    "assignmentStatus"
  ],
  "$comment": "CP13 Phase 7 final amendment candidate schema. Draft/non-default; not current/default until separately promoted."
}
