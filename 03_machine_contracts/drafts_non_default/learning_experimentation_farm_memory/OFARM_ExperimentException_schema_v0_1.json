{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/ExperimentException/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM ExperimentException schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 ExperimentException contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "ExperimentException"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "exceptionState": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "APPROVED",
        "ACTIVE",
        "DENIED",
        "EXPIRED",
        "SUPERSEDED"
      ]
    },
    "experimentProtocolRef": {
      "type": "string",
      "minLength": 1
    },
    "exceptionReason": {
      "type": "string",
      "minLength": 1
    },
    "approvalDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "disclosureRequired": {
      "type": "boolean"
    },
    "doesNotDeleteUnderlyingRule": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "exceptionState",
    "experimentProtocolRef",
    "exceptionReason",
    "doesNotDeleteUnderlyingRule"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "exceptionState": {
            "enum": [
              "APPROVED",
              "ACTIVE"
            ]
          }
        },
        "required": [
          "exceptionState"
        ]
      },
      "then": {
        "required": [
          "approvalDecisionRef",
          "authorityDecisionTraceRef",
          "validFrom",
          "validUntil",
          "disclosureRequired"
        ]
      }
    }
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
