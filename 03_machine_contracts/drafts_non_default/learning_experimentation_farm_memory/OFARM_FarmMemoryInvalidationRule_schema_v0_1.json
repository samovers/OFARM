{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/FarmMemoryInvalidationRule/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM FarmMemoryInvalidationRule schema v0.1 draft/non-default",
  "description": "Rule that expires, downgrades, reviews, invalidates, or supersedes farm memory when context or evidence changes.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "FarmMemoryInvalidationRule"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP13 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "farmMemoryEntryRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "OFARM artifact references"
    },
    "triggerClass": {
      "type": "string",
      "enum": [
        "TIME_EXPIRY",
        "NEW_CONTRADICTORY_EVIDENCE",
        "SCOPE_CHANGE",
        "CROP_VARIETY_CHANGE",
        "SOIL_CONTEXT_CHANGE",
        "MACHINE_CONTEXT_CHANGE",
        "CHARTER_RULE_CHANGE",
        "MISSION_SAFETY_INCIDENT",
        "MODEL_INVALIDATION",
        "OTHER"
      ],
      "description": ""
    },
    "triggerCondition": {
      "type": "string",
      "minLength": 1
    },
    "consequence": {
      "type": "string",
      "enum": [
        "EXPIRE",
        "DOWNGRADE_TO_ADVISORY",
        "REQUIRE_REVIEW",
        "INVALIDATE",
        "SUPERSEDE",
        "BLOCK_HIGH_CONSEQUENCE_USE"
      ],
      "description": ""
    },
    "reviewRequired": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "triggerClass",
    "triggerCondition",
    "consequence",
    "reviewRequired"
  ],
  "$comment": "CP13 Phase 7 final amendment candidate schema. Draft/non-default; not current/default until separately promoted."
}
