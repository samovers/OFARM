{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/FarmMemoryEntry/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM FarmMemoryEntry schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 FarmMemoryEntry contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "FarmMemoryEntry"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "memoryStatus": {
      "type": "string",
      "enum": [
        "CANDIDATE",
        "ACTIVE_ADVISORY",
        "ACTIVE_REVIEW_REQUIRED",
        "INVALIDATED",
        "SUPERSEDED"
      ]
    },
    "sourceKind": {
      "type": "string",
      "enum": [
        "LEARNING_PROMOTION",
        "AGENT_MEMORY",
        "MANUAL_NOTE",
        "IMPORT"
      ]
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1
    },
    "memoryStatement": {
      "type": "string",
      "minLength": 1
    },
    "learningPromotionDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "evidenceBundleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "LearningEvidenceBundle refs",
      "minItems": 1
    },
    "validityHorizon": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "validFrom": {
          "type": "string",
          "format": "date-time"
        },
        "validUntil": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "validFrom",
        "validUntil"
      ]
    },
    "retrievalQualificationRef": {
      "type": "string",
      "minLength": 1
    },
    "invalidationRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "FarmMemoryInvalidationRule refs"
    },
    "notAgentMemory": {
      "type": "boolean",
      "const": true
    },
    "notHiddenCurrentState": {
      "type": "boolean",
      "const": true
    },
    "noComplianceFactByMemory": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "memoryStatus",
    "sourceKind",
    "learningScopeRef",
    "memoryStatement",
    "learningPromotionDecisionRef",
    "evidenceBundleRefs",
    "validityHorizon",
    "retrievalQualificationRef",
    "notAgentMemory",
    "notHiddenCurrentState",
    "noComplianceFactByMemory"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "sourceKind": {
            "const": "AGENT_MEMORY"
          }
        },
        "required": [
          "sourceKind"
        ]
      },
      "then": false
    },
    {
      "if": {
        "properties": {
          "memoryStatus": {
            "enum": [
              "ACTIVE_ADVISORY",
              "ACTIVE_REVIEW_REQUIRED"
            ]
          }
        },
        "required": [
          "memoryStatus"
        ]
      },
      "then": {
        "properties": {
          "sourceKind": {
            "const": "LEARNING_PROMOTION"
          }
        },
        "required": [
          "learningPromotionDecisionRef",
          "retrievalQualificationRef"
        ]
      }
    }
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
