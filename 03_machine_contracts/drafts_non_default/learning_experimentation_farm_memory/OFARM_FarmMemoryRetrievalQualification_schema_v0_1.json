{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/FarmMemoryRetrievalQualification/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM FarmMemoryRetrievalQualification schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 FarmMemoryRetrievalQualification contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "FarmMemoryRetrievalQualification"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "farmMemoryEntryRef": {
      "type": "string",
      "minLength": 1
    },
    "retrievalUseClass": {
      "type": "string",
      "enum": [
        "ADVISORY_RECOMMENDATION_SUPPORT",
        "REVIEW_REQUIRED",
        "SEASONAL_SUMMARY",
        "FARMER_DISPLAY"
      ]
    },
    "requiresReviewForHighConsequenceUse": {
      "type": "boolean"
    },
    "highConsequenceUse": {
      "type": "boolean"
    },
    "reviewRequired": {
      "type": "boolean"
    },
    "blockedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "CURRENT_STATE",
          "COMPLIANCE_FACT",
          "AUTOMATIC_EXECUTION",
          "MISSION_DISPATCH",
          "UNQUALIFIED_CLAIM",
          "CROSS_FARM_SHARING",
          "MODEL_DEPLOYMENT",
          "CLAIM_BEARING_OUTPUT"
        ]
      },
      "uniqueItems": true,
      "minItems": 1,
      "allOf": [
        {
          "contains": {
            "const": "CURRENT_STATE"
          },
          "minContains": 1
        },
        {
          "contains": {
            "const": "COMPLIANCE_FACT"
          },
          "minContains": 1
        },
        {
          "contains": {
            "const": "AUTOMATIC_EXECUTION"
          },
          "minContains": 1
        },
        {
          "contains": {
            "const": "CLAIM_BEARING_OUTPUT"
          },
          "minContains": 1
        },
        {
          "contains": {
            "const": "MODEL_DEPLOYMENT"
          },
          "minContains": 1
        },
        {
          "contains": {
            "const": "CROSS_FARM_SHARING"
          },
          "minContains": 1
        },
        {
          "contains": {
            "const": "MISSION_DISPATCH"
          },
          "minContains": 1
        }
      ]
    },
    "qualificationLimitations": {
      "type": "string",
      "minLength": 1
    },
    "notCurrentState": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "farmMemoryEntryRef",
    "retrievalUseClass",
    "blockedUseClasses",
    "notCurrentState"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "highConsequenceUse": {
            "const": true
          }
        },
        "required": [
          "highConsequenceUse"
        ]
      },
      "then": {
        "properties": {
          "reviewRequired": {
            "const": true
          }
        },
        "required": [
          "reviewRequired"
        ]
      }
    }
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
