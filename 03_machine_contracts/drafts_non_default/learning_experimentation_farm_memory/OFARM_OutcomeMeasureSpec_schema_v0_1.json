{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/OutcomeMeasureSpec/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM OutcomeMeasureSpec schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 OutcomeMeasureSpec contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "OutcomeMeasureSpec"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1
    },
    "measureName": {
      "type": "string",
      "minLength": 1
    },
    "measureRole": {
      "type": "string",
      "enum": [
        "PRIMARY",
        "SECONDARY",
        "SAFETY",
        "EXPLORATORY"
      ]
    },
    "preRegistered": {
      "type": "boolean"
    },
    "minimumEvidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "PARTIAL"
      ]
    },
    "claimEligibility": {
      "type": "string",
      "enum": [
        "NOT_CLAIM_ELIGIBLE",
        "CLAIM_ELIGIBLE_IF_EVIDENCE_SUFFICIENT"
      ]
    },
    "outcomeHackingGuardrail": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "measureName",
    "measureRole",
    "preRegistered",
    "minimumEvidenceQualityState",
    "claimEligibility",
    "outcomeHackingGuardrail"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "claimEligibility": {
            "const": "CLAIM_ELIGIBLE_IF_EVIDENCE_SUFFICIENT"
          }
        },
        "required": [
          "claimEligibility"
        ]
      },
      "then": {
        "properties": {
          "minimumEvidenceQualityState": {
            "const": "SUFFICIENT"
          }
        }
      }
    }
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
