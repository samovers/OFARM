{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/LearningEvidenceBundle/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM LearningEvidenceBundle schema v0.1 draft/non-default",
  "description": "Evidence bundle used to support a learning evaluation, causal estimate, seasonal summary, or farm-memory promotion decision. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "LearningEvidenceBundle"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP13 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "outcomeObservationSetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "OFARM artifact references",
      "minItems": 1
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Other evidence refs"
    },
    "evidenceSufficiencyState": {
      "type": "string",
      "enum": [
        "SUFFICIENT_FOR_ADVISORY",
        "SUFFICIENT_FOR_FARM_MEMORY_CANDIDATE",
        "SUFFICIENT_FOR_CLAIM_SUPPORT_CANDIDATE",
        "INSUFFICIENT",
        "DISPUTED",
        "STALE",
        "UNKNOWN"
      ],
      "description": ""
    },
    "missingnessSummary": {
      "type": "string",
      "enum": [
        "NONE",
        "MINOR",
        "MATERIAL",
        "SEVERE",
        "UNKNOWN"
      ],
      "description": ""
    },
    "biasRiskState": {
      "type": "string",
      "enum": [
        "LOW",
        "MODERATE",
        "HIGH",
        "UNKNOWN",
        "DISPUTED"
      ],
      "description": ""
    },
    "currentStateReliance": {
      "type": "string",
      "enum": [
        "RELIES_ON_CURRENT_STATE",
        "DOES_NOT_RELY_ON_CURRENT_STATE",
        "UNKNOWN_BLOCKING"
      ],
      "description": ""
    },
    "materializationBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Current-state materialisation basis refs"
    },
    "cp11EvidenceRequirementRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "CP11 evidence requirement refs"
    },
    "cp12EvidenceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "evidenceClass": {
            "type": "string",
            "enum": [
              "MISSION_EXECUTION_RECEIPT",
              "MISSION_VERIFICATION",
              "MISSION_TELEMETRY",
              "MISSION_INCIDENT",
              "MISSION_ABORT",
              "MISSION_SAFETY_EVENT"
            ]
          },
          "verificationRef": {
            "type": "string",
            "minLength": 1
          },
          "intendedStrength": {
            "type": "string",
            "enum": [
              "BACKGROUND",
              "WEAK",
              "MODERATE",
              "STRONG"
            ]
          },
          "traceDisposition": {
            "type": "string",
            "enum": [
              "PASS",
              "ALLOW",
              "ALLOW_WITH_QUALIFICATION",
              "REQUIRE_REVIEW",
              "REFUSE",
              "BLOCKED",
              "FAILED",
              "UNKNOWN"
            ]
          }
        },
        "required": [
          "ref",
          "evidenceClass",
          "intendedStrength"
        ]
      },
      "uniqueItems": true,
      "description": "Typed CP12 mission evidence items used for learning"
    },
    "noTruthPromotionByBundle": {
      "type": "boolean",
      "const": true,
      "description": "guardrail"
    },
    "freshnessQualificationRef": {
      "type": "string",
      "minLength": 1,
      "description": "Freshness/qualification basis when current state is used"
    },
    "cp11TraceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "resultDisposition": {
            "type": "string",
            "enum": [
              "ALLOW",
              "ALLOW_WITH_QUALIFICATION",
              "PASS",
              "REQUIRE_REVIEW",
              "REQUIRE_HUMAN_APPROVAL",
              "REFUSE",
              "BLOCKED",
              "INSUFFICIENT_BASIS"
            ]
          },
          "intendedStrength": {
            "type": "string",
            "enum": [
              "BACKGROUND",
              "WEAK",
              "MODERATE",
              "SUFFICIENT"
            ]
          },
          "charterSensitive": {
            "type": "boolean"
          }
        },
        "required": [
          "ref",
          "resultDisposition",
          "intendedStrength"
        ]
      },
      "uniqueItems": true,
      "description": "Typed CP11 charter trace items used for learning"
    },
    "reviewDecisionRef": {
      "type": "string",
      "minLength": 1
    },
    "currentStateFreshnessState": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALID_BLOCKING",
        "NOT_APPLICABLE",
        "UNKNOWN_BLOCKING"
      ]
    },
    "currentStateQualificationBasisRef": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "outcomeObservationSetRefs",
    "evidenceSufficiencyState",
    "missingnessSummary",
    "biasRiskState",
    "currentStateReliance",
    "noTruthPromotionByBundle"
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted.",
  "allOf": [
    {
      "if": {
        "properties": {
          "currentStateReliance": {
            "const": "UNKNOWN_BLOCKING"
          }
        },
        "required": [
          "currentStateReliance"
        ]
      },
      "then": {
        "properties": {
          "evidenceSufficiencyState": {
            "not": {
              "enum": [
                "SUFFICIENT_FOR_ADVISORY",
                "SUFFICIENT_FOR_FARM_MEMORY_CANDIDATE",
                "SUFFICIENT_FOR_CLAIM_SUPPORT_CANDIDATE"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "currentStateReliance": {
            "const": "RELIES_ON_CURRENT_STATE"
          }
        },
        "required": [
          "currentStateReliance"
        ]
      },
      "then": {
        "required": [
          "materializationBasisRefs",
          "freshnessQualificationRef"
        ],
        "properties": {
          "materializationBasisRefs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "missingnessSummary": {
            "enum": [
              "SEVERE",
              "UNKNOWN"
            ]
          },
          "evidenceSufficiencyState": {
            "enum": [
              "SUFFICIENT_FOR_FARM_MEMORY_CANDIDATE",
              "SUFFICIENT_FOR_CLAIM_SUPPORT_CANDIDATE"
            ]
          }
        },
        "required": [
          "missingnessSummary",
          "evidenceSufficiencyState"
        ]
      },
      "then": {
        "required": [
          "reviewDecisionRef"
        ],
        "properties": {
          "reviewDecisionRef": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "biasRiskState": {
            "enum": [
              "HIGH",
              "UNKNOWN",
              "DISPUTED"
            ]
          },
          "evidenceSufficiencyState": {
            "enum": [
              "SUFFICIENT_FOR_FARM_MEMORY_CANDIDATE",
              "SUFFICIENT_FOR_CLAIM_SUPPORT_CANDIDATE"
            ]
          }
        },
        "required": [
          "biasRiskState",
          "evidenceSufficiencyState"
        ]
      },
      "then": {
        "required": [
          "reviewDecisionRef"
        ],
        "properties": {
          "reviewDecisionRef": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
