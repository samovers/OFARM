{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/LearningScope/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM LearningScope schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 LearningScope contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "LearningScope"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED",
        "INVALIDATED",
        "ARCHIVED"
      ]
    },
    "farmScopeRef": {
      "type": "string",
      "minLength": 1
    },
    "spatialScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Field/zone/crop-cycle spatial scope refs",
      "minItems": 1
    },
    "temporalScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "validFrom": {
          "type": "string",
          "format": "date-time"
        },
        "validUntil": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "validFrom",
        "validUntil"
      ]
    },
    "targetTwinDefault": {
      "type": "string",
      "enum": [
        "ADVISORY",
        "MIXED_BY_RULE"
      ]
    },
    "complianceBridgePolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1
    },
    "reuseBoundary": {
      "type": "string",
      "enum": [
        "FARM_LOCAL",
        "FARM_GROUP_INTERNAL",
        "PROFILE_LOCAL_ONLY",
        "REVIEW_REQUIRED_FOR_REUSE"
      ]
    },
    "cp14RequiredForCrossFarmUse": {
      "type": "boolean",
      "const": true
    },
    "doesNotCreateCurrentState": {
      "type": "boolean",
      "const": true
    },
    "doesNotCreateComplianceFact": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeState",
    "farmScopeRef",
    "spatialScopeRefs",
    "temporalScope",
    "targetTwinDefault",
    "reuseBoundary",
    "cp14RequiredForCrossFarmUse",
    "doesNotCreateCurrentState",
    "doesNotCreateComplianceFact"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "targetTwinDefault": {
            "const": "MIXED_BY_RULE"
          }
        },
        "required": [
          "targetTwinDefault"
        ]
      },
      "then": {
        "required": [
          "complianceBridgePolicyRef",
          "authorityDecisionTraceRef"
        ]
      }
    }
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
