{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/TrialDesign/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM TrialDesign schema v0.1 draft/non-default remediated",
  "description": "Draft/non-default CP13 TrialDesign contract. Not current/default law. CP13 Phase 7.2 hardened; draft/non-default.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "TrialDesign"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1
    },
    "experimentalUnitRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "ExperimentalUnit refs",
      "minItems": 1
    },
    "treatmentArmRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "TreatmentArm refs",
      "minItems": 1
    },
    "controlConditionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "ControlCondition refs",
      "minItems": 1
    },
    "outcomeMeasureSpecRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "OutcomeMeasureSpec refs",
      "minItems": 1
    },
    "randomizationPlanRef": {
      "type": "string",
      "minLength": 1
    },
    "treatmentUnitRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Units assigned to treatment"
    },
    "controlUnitRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Units assigned to control"
    },
    "randomizationAssignments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "unitRef": {
            "type": "string",
            "minLength": 1
          },
          "armRef": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "unitRef",
          "armRef"
        ]
      }
    },
    "preRegistered": {
      "type": "boolean"
    },
    "doesNotAuthorizeOperation": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "experimentalUnitRefs",
    "treatmentArmRefs",
    "controlConditionRefs",
    "outcomeMeasureSpecRefs",
    "preRegistered",
    "doesNotAuthorizeOperation"
  ],
  "$comment": "CP13 Phase 7.2 temporal causal evidence chain hardening schema. Draft/non-default; not current/default until separately promoted."
}
