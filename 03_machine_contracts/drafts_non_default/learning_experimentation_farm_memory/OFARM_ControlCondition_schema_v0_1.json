{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/learning_experimentation_farm_memory/ControlCondition/v0.1-phase7-2-temporal-causal-evidence-chain-hardening",
  "title": "OFARM ControlCondition schema v0.1 draft/non-default",
  "description": "Defines baseline, standard-practice, untreated, historical, matched, counterfactual, or modelled comparison basis.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp13-v0.1-draft-phase7-2-temporal-causal-evidence-chain-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "ControlCondition"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP13 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority grants / decisions / policy refs",
      "minItems": 1
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV / trace / source references"
    },
    "learningScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "controlType": {
      "type": "string",
      "enum": [
        "UNTREATED",
        "STANDARD_PRACTICE",
        "HISTORICAL_MATCHED",
        "SPATIAL_MATCHED",
        "MODELLED_COUNTERFACTUAL",
        "PREVIOUS_SEASON",
        "OTHER"
      ],
      "description": ""
    },
    "comparisonBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Basis refs",
      "minItems": 1
    },
    "comparabilityAssessment": {
      "type": "string",
      "enum": [
        "STRONG",
        "MODERATE",
        "WEAK",
        "INSUFFICIENT",
        "UNKNOWN"
      ],
      "description": ""
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "authorityBasisRefs",
    "learningScopeRef",
    "controlType",
    "comparisonBasisRefs",
    "comparabilityAssessment"
  ],
  "$comment": "CP13 Phase 7 final amendment candidate schema. Draft/non-default; not current/default until separately promoted."
}
