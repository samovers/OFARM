{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_FarmIntelligenceShareGrant_schema_v0_1.json",
  "title": "OFARM FarmIntelligenceShareGrant schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Specialised sharing grant for a concrete farm-intelligence sharing act or governed class of acts. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "FarmIntelligenceShareGrant"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "grantState": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "APPROVED",
        "ACTIVE",
        "SUSPENDED",
        "REVOKED",
        "EXPIRED",
        "DENIED"
      ],
      "description": ""
    },
    "grantorFarmScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": ""
    },
    "recipientPartyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Recipients",
      "minItems": 1
    },
    "sharePolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "boundaryRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "intelligenceClassRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Shared intelligence classes",
      "minItems": 1
    },
    "allowedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Allowed recipient use classes",
      "minItems": 1
    },
    "prohibitedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Prohibited use classes"
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "recipientUseConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Recipient use constraints",
      "minItems": 1
    },
    "derivativeUsePolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "trainingUsePolicyBindingRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "revocable": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "grantDoesNotConferAuthority": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "grantDoesNotCreateTruth": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "approvalDecisionRef": {
      "type": "string"
    },
    "revocationDecisionRef": {
      "type": "string"
    },
    "revocationPropagationTraceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "grantState",
    "grantorFarmScopeRef",
    "recipientPartyRefs",
    "sharePolicyRef",
    "boundaryRef",
    "intelligenceClassRefs",
    "allowedUseClasses",
    "validFrom",
    "validUntil",
    "authorityDecisionTraceRef",
    "recipientUseConstraintRefs",
    "revocable",
    "grantDoesNotConferAuthority",
    "grantDoesNotCreateTruth"
  ]
}
