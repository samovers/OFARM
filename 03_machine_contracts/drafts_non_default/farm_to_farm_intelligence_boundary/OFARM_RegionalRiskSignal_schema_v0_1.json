{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_RegionalRiskSignal_schema_v0_1.json",
  "title": "OFARM RegionalRiskSignal schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Represents a regional risk signal that may support alerts or advisory regional intelligence. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "RegionalRiskSignal"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "signalState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED",
        "WITHDRAWN",
        "EXPIRED",
        "QUARANTINED"
      ],
      "description": ""
    },
    "riskClass": {
      "type": "string",
      "enum": [
        "PEST",
        "DISEASE",
        "WEATHER",
        "WATER",
        "SOIL",
        "SUSTAINABILITY",
        "MISSION_SAFETY",
        "MARKET_CONTEXT",
        "OTHER"
      ],
      "description": ""
    },
    "regionalScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Region refs",
      "minItems": 1
    },
    "sourceContributionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Source contribution refs",
      "minItems": 1
    },
    "confidenceClass": {
      "type": "string",
      "enum": [
        "LOW",
        "MODERATE",
        "HIGH",
        "UNKNOWN"
      ],
      "description": ""
    },
    "evidenceQualityState": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "PARTIAL",
        "INSUFFICIENT",
        "DISPUTED",
        "STALE",
        "UNKNOWN"
      ],
      "description": ""
    },
    "applicabilityLimitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Limitation refs or statements"
    },
    "doesNotCreateOccurrenceTruth": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotCreateFarmTruth": {
      "type": "boolean",
      "const": true,
      "description": ""
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "signalState",
    "riskClass",
    "regionalScopeRefs",
    "sourceContributionRefs",
    "confidenceClass",
    "evidenceQualityState",
    "doesNotCreateOccurrenceTruth",
    "doesNotCreateFarmTruth"
  ]
}
