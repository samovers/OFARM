{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_LearningArtifactSharePackage_schema_v0_1.json",
  "title": "OFARM LearningArtifactSharePackage schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Special package for CP13 local learning artifacts crossing farm boundaries under CP14 governance. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "LearningArtifactSharePackage"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "packageState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "READY_FOR_REVIEW",
        "APPROVED_FOR_SHARE",
        "SHARED",
        "REVOKED",
        "WITHDRAWN",
        "ARCHIVED"
      ],
      "description": ""
    },
    "cp13LearningArtifactRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "CP13 artifacts prepared for sharing",
      "minItems": 1
    },
    "farmMemoryEntryRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Farm memory refs if used"
    },
    "shareGrantRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "recipientUseConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Recipient use constraints",
      "minItems": 1
    },
    "derivativeUsePolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "trainingUsePolicyBindingRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "crossFarmApplicabilityAssessmentRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "doesNotExportLocalFarmMemoryByDefault": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotCreateRecipientFarmMemory": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotCreateModelDeploymentAuthority": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "farmMemoryDerivativeSharingExplicitlyPermitted": {
      "type": "boolean"
    },
    "recipientFarmMemoryCreationBlocked": {
      "type": "boolean"
    },
    "outputQualificationRef": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "packageState",
    "cp13LearningArtifactRefs",
    "shareGrantRef",
    "recipientUseConstraintRefs",
    "doesNotExportLocalFarmMemoryByDefault",
    "doesNotCreateRecipientFarmMemory",
    "doesNotCreateModelDeploymentAuthority"
  ]
}
