{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_DeidentificationClaim_schema_v0_1.json",
  "title": "OFARM DeidentificationClaim schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Claims deidentification of a data/intelligence package with residual risk and method basis. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "DeidentificationClaim"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "claimState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "CLAIMED",
        "REVIEWED",
        "REJECTED",
        "WITHDRAWN",
        "EXPIRED"
      ],
      "description": ""
    },
    "subjectPackageRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "methodClass": {
      "type": "string",
      "enum": [
        "REDACTION",
        "PSEUDONYMISATION",
        "GENERALISATION",
        "SUPPRESSION",
        "NOISE_ADDITION",
        "AGGREGATION_PLUS_REDACTION",
        "OTHER"
      ],
      "description": ""
    },
    "residualRiskClass": {
      "type": "string",
      "enum": [
        "LOW",
        "MODERATE",
        "HIGH",
        "UNKNOWN"
      ],
      "description": ""
    },
    "reidentificationRiskAssessmentRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "claimBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Claim basis refs",
      "minItems": 1
    },
    "doesNotAssertIrreversibleAnonymisation": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "requiresOutputQualification": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "reviewDecisionRef": {
      "type": "string"
    },
    "outputQualificationRef": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "claimState",
    "subjectPackageRef",
    "methodClass",
    "residualRiskClass",
    "claimBasisRefs",
    "doesNotAssertIrreversibleAnonymisation",
    "requiresOutputQualification"
  ]
}
