{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_TrainingUseReceipt_schema_v0_1.json",
  "title": "OFARM TrainingUseReceipt schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Records use or non-use of shared intelligence for training purposes under a binding policy. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "TrainingUseReceipt"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "receiptState": {
      "type": "string",
      "enum": [
        "DECLARED",
        "CONFIRMED",
        "CONTESTED",
        "REVOKED",
        "INVALIDATED"
      ],
      "description": ""
    },
    "trainingUsePolicyBindingRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "contributionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Contributions used or not used",
      "minItems": 1
    },
    "recipientPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": ""
    },
    "modelTrainingRunRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "trainingPurposeClass": {
      "type": "string",
      "minLength": 1,
      "description": ""
    },
    "usedForTraining": {
      "type": "boolean"
    },
    "policyCompliant": {
      "type": "boolean"
    },
    "doesNotAuthorizeDeployment": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "grantCoverageRef": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "receiptState",
    "trainingUsePolicyBindingRef",
    "contributionRefs",
    "recipientPartyRef",
    "trainingPurposeClass",
    "usedForTraining",
    "policyCompliant",
    "doesNotAuthorizeDeployment"
  ]
}
