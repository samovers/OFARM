{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_RegionalAlert_schema_v0_1.json",
  "title": "OFARM RegionalAlert schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Represents regional advisory alert output derived from multiple signals/contributions. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "RegionalAlert"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "alertState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "PUBLISHED",
        "CORRECTED",
        "WITHDRAWN",
        "EXPIRED",
        "ARCHIVED"
      ],
      "description": ""
    },
    "alertClass": {
      "type": "string",
      "enum": [
        "PEST_RISK",
        "DISEASE_RISK",
        "WEATHER_RISK",
        "WATER_STRESS",
        "BIOSECURITY",
        "SUSTAINABILITY_RISK",
        "MISSION_SAFETY_PATTERN",
        "OTHER"
      ],
      "description": ""
    },
    "regionalScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Region/spatial cohort refs",
      "minItems": 1
    },
    "temporalScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "validFrom": {
          "type": "string",
          "format": "date-time"
        },
        "validUntil": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "validFrom",
        "validUntil"
      ]
    },
    "riskSignalRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "RegionalRiskSignal refs",
      "minItems": 1
    },
    "contributionPackageRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Contribution package refs"
    },
    "applicabilityAssessmentRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "outputQualificationRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "advisoryDefault": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotCreateFarmLevelTruth": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotCreateComplianceFact": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "publicationAuthorityTraceRef": {
      "type": "string"
    },
    "correctionPolicyRef": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "alertState",
    "alertClass",
    "regionalScopeRefs",
    "temporalScope",
    "riskSignalRefs",
    "advisoryDefault",
    "doesNotCreateFarmLevelTruth",
    "doesNotCreateComplianceFact"
  ]
}
