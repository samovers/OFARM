{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_PoisoningOrAnomalyReview_schema_v0_1.json",
  "title": "OFARM PoisoningOrAnomalyReview schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Reviews suspicious contributions, alerts, benchmark deltas, or federated updates for poisoning/anomaly risk. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "PoisoningOrAnomalyReview"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "reviewState": {
      "type": "string",
      "enum": [
        "OPEN",
        "COMPLETE",
        "ESCALATED",
        "DISPUTED",
        "SUPERSEDED"
      ],
      "description": ""
    },
    "targetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Targets under review",
      "minItems": 1
    },
    "anomalyClass": {
      "type": "string",
      "enum": [
        "DATA_OUTLIER",
        "SOURCE_PATTERN",
        "TEMPORAL_PATTERN",
        "SPATIAL_PATTERN",
        "MODEL_UPDATE_ANOMALY",
        "POISONING_SUSPECTED",
        "OTHER"
      ],
      "description": ""
    },
    "severityClass": {
      "type": "string",
      "enum": [
        "LOW",
        "MODERATE",
        "HIGH",
        "CRITICAL",
        "UNKNOWN"
      ],
      "description": ""
    },
    "reviewDisposition": {
      "type": "string",
      "enum": [
        "NO_ISSUE",
        "QUALIFY",
        "BLOCK_USE",
        "QUARANTINE",
        "WITHDRAW",
        "REQUIRE_HUMAN_REVIEW",
        "UNKNOWN"
      ],
      "description": ""
    },
    "blockedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Blocked uses"
    },
    "reviewDecisionRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "reviewDoesNotDeleteEvidence": {
      "type": "boolean",
      "const": true,
      "description": ""
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "reviewState",
    "targetRefs",
    "anomalyClass",
    "severityClass",
    "reviewDisposition",
    "reviewDoesNotDeleteEvidence"
  ]
}
