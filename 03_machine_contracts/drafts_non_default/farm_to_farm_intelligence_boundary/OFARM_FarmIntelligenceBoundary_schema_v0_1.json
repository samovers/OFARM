{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_FarmIntelligenceBoundary_schema_v0_1.json",
  "title": "OFARM FarmIntelligenceBoundary schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Declares the governed boundary for outgoing, incoming, transformed, or received cross-farm intelligence. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "FarmIntelligenceBoundary"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "boundaryState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUSPENDED",
        "SUPERSEDED",
        "REVOKED",
        "ARCHIVED"
      ],
      "description": ""
    },
    "boundaryDirection": {
      "type": "string",
      "enum": [
        "OUTBOUND",
        "INBOUND",
        "BIDIRECTIONAL",
        "TRANSFORMATION_ONLY"
      ],
      "description": ""
    },
    "sourceFarmScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": "Originating farm scope, if outbound or bidirectional"
    },
    "recipientScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Recipient/cohort/platform scopes"
    },
    "dataSovereigntyBoundaryRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Applicable data sovereignty boundaries",
      "minItems": 1
    },
    "sharingPolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "FarmIntelligenceSharePolicy refs"
    },
    "defaultTwinPosture": {
      "type": "string",
      "enum": [
        "ADVISORY_ONLY",
        "ADVISORY_UNLESS_BRIDGED_BY_REVIEW"
      ],
      "description": ""
    },
    "noFarmTruthCreation": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "noAuthorityCreation": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "noComplianceFactCreation": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "noModelDeploymentAuthority": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "cp15RequiredForDeployment": {
      "type": "boolean",
      "const": true,
      "description": ""
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "boundaryState",
    "boundaryDirection",
    "dataSovereigntyBoundaryRefs",
    "defaultTwinPosture",
    "noFarmTruthCreation",
    "noAuthorityCreation",
    "noComplianceFactCreation",
    "noModelDeploymentAuthority",
    "cp15RequiredForDeployment"
  ]
}
