{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_TrainingUsePolicyBinding_schema_v0_1.json",
  "title": "OFARM TrainingUsePolicyBinding schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Binds shared intelligence to training/model-improvement use restrictions without granting deployment authority. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "TrainingUsePolicyBinding"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "bindingState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUSPENDED",
        "REVOKED",
        "EXPIRED"
      ],
      "description": ""
    },
    "trainingUseAllowed": {
      "type": "boolean"
    },
    "allowedTrainingPurposeClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Allowed training purposes"
    },
    "prohibitedTrainingPurposeClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Prohibited training purposes"
    },
    "targetModelFamilyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Model families, if known"
    },
    "shareGrantRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "recipientPartyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Recipients"
    },
    "trainingUseReceiptRequired": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotAuthorizeModelDeployment": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotAuthorizeFineTuningByDefault": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "cp15RequiredForDeployment": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "retentionPolicyRef": {
      "type": "string"
    },
    "revocationPolicyRef": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "bindingState",
    "trainingUseAllowed",
    "trainingUseReceiptRequired",
    "doesNotAuthorizeModelDeployment",
    "doesNotAuthorizeFineTuningByDefault",
    "cp15RequiredForDeployment"
  ]
}
