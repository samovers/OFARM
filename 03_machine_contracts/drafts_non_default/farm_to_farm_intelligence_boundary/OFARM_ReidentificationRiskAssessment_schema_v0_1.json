{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_ReidentificationRiskAssessment_schema_v0_1.json",
  "title": "OFARM ReidentificationRiskAssessment schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Assesses re-identification risk for deidentified, anonymised, or aggregate intelligence. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "ReidentificationRiskAssessment"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "assessmentState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "COMPLETE",
        "STALE",
        "INVALIDATED",
        "DISPUTED"
      ],
      "description": ""
    },
    "subjectPackageRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "riskClass": {
      "type": "string",
      "enum": [
        "VERY_LOW",
        "LOW",
        "MODERATE",
        "HIGH",
        "UNKNOWN_BLOCKING"
      ],
      "description": ""
    },
    "attackerModelClass": {
      "type": "string",
      "enum": [
        "CASUAL_OBSERVER",
        "COMMERCIAL_ACTOR",
        "INSIDER",
        "DATA_BROKER",
        "STATE_OR_LEGAL_PROCESS",
        "UNKNOWN"
      ],
      "description": ""
    },
    "quasiIdentifierRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Quasi-identifier refs"
    },
    "mitigationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Mitigation refs"
    },
    "reviewDecisionRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "highRiskBlocksPublicDisclosure": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "partnerDisclosureRequiresReview": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "assessmentState",
    "subjectPackageRef",
    "riskClass",
    "attackerModelClass",
    "highRiskBlocksPublicDisclosure"
  ]
}
