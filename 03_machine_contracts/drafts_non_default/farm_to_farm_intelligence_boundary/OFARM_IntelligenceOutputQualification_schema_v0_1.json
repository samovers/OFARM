{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_IntelligenceOutputQualification_schema_v0_1.json",
  "title": "OFARM IntelligenceOutputQualification schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Qualifies cross-farm intelligence outputs with permitted/prohibited uses, source posture, advisory status, and disclosure limits. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "IntelligenceOutputQualification"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "qualificationState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED",
        "INVALIDATED"
      ],
      "description": ""
    },
    "outputDisposition": {
      "type": "string",
      "enum": [
        "ADVISORY_ONLY",
        "REGIONAL_ALERT_ADVISORY",
        "BENCHMARK_ADVISORY",
        "SHARE_PACKAGE",
        "FEDERATED_RECEIPT",
        "MODEL_IMPROVEMENT_ADVISORY",
        "WITHDRAWAL_OR_CORRECTION"
      ],
      "description": ""
    },
    "allowedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Allowed uses",
      "minItems": 1
    },
    "blockedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Blocked uses",
      "minItems": 1
    },
    "sourcePosture": {
      "type": "string",
      "enum": [
        "SINGLE_FARM",
        "AGGREGATED",
        "DEIDENTIFIED",
        "ANONYMISED_CLAIMED",
        "RECEIVED_INTELLIGENCE",
        "MIXED"
      ],
      "description": ""
    },
    "advisoryDefault": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotCreateFarmTruth": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotCreateComplianceFact": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotAuthorizeMission": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotAuthorizeModelDeployment": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "sharingGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Sharing grants"
    },
    "recipientUseConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Recipient constraints"
    },
    "reidentificationRiskAssessmentRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "requiredDisplayLimitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Display limitation refs"
    },
    "publicAuthorityBasisRef": {
      "type": "string"
    },
    "dataSovereigntyBoundaryRef": {
      "type": "string"
    },
    "disclosureClass": {
      "type": "string"
    },
    "localApplicabilityRequiredBeforeAction": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "qualificationState",
    "outputDisposition",
    "allowedUseClasses",
    "blockedUseClasses",
    "sourcePosture",
    "advisoryDefault",
    "doesNotCreateFarmTruth",
    "doesNotCreateComplianceFact",
    "doesNotAuthorizeMission",
    "doesNotAuthorizeModelDeployment"
  ]
}
