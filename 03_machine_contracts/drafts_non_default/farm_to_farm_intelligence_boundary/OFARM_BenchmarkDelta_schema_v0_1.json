{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_BenchmarkDelta_schema_v0_1.json",
  "title": "OFARM BenchmarkDelta schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Represents a benchmark delta between a farm/cohort and a governed comparison group without creating compliance fact. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "BenchmarkDelta"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "benchmarkState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "READY_FOR_REVIEW",
        "PUBLISHED_ADVISORY",
        "WITHDRAWN",
        "ARCHIVED"
      ],
      "description": ""
    },
    "metricProfileRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "subjectScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "cohortDefinitionRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "aggregationFloorRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "deidentificationClaimRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "deltaValue": {
      "type": "number"
    },
    "deltaUnitRef": {
      "type": "string",
      "minLength": 1,
      "description": ""
    },
    "confidenceClass": {
      "type": "string",
      "enum": [
        "LOW",
        "MODERATE",
        "HIGH",
        "UNKNOWN"
      ],
      "description": ""
    },
    "outputQualificationRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "doesNotCreateComplianceFact": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotCreateFarmRankingByDefault": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "reidentificationRiskAssessmentRef": {
      "type": "string"
    },
    "publicDisclosureIntended": {
      "type": "boolean"
    },
    "partnerDisclosureIntended": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "benchmarkState",
    "metricProfileRef",
    "subjectScopeRef",
    "cohortDefinitionRef",
    "aggregationFloorRef",
    "deltaValue",
    "deltaUnitRef",
    "confidenceClass",
    "doesNotCreateComplianceFact",
    "doesNotCreateFarmRankingByDefault"
  ]
}
