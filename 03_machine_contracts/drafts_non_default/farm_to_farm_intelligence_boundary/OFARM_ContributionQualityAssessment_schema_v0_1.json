{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_ContributionQualityAssessment_schema_v0_1.json",
  "title": "OFARM ContributionQualityAssessment schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Assesses quality, completeness, freshness, anomaly, poisoning, and usability posture of a contribution. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "ContributionQualityAssessment"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "assessmentState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "COMPLETE",
        "STALE",
        "INVALIDATED",
        "DISPUTED"
      ],
      "description": ""
    },
    "targetContributionRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "completenessClass": {
      "type": "string",
      "enum": [
        "COMPLETE",
        "PARTIAL",
        "INSUFFICIENT",
        "UNKNOWN"
      ],
      "description": ""
    },
    "freshnessClass": {
      "type": "string",
      "enum": [
        "FRESH",
        "STALE_INFORMATIONAL_ALLOWED",
        "STALE_BLOCKING",
        "INVALIDATED",
        "UNKNOWN"
      ],
      "description": ""
    },
    "anomalyClass": {
      "type": "string",
      "enum": [
        "NONE_DETECTED",
        "LOW",
        "MODERATE",
        "HIGH",
        "UNKNOWN"
      ],
      "description": ""
    },
    "poisoningReviewRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "usableForClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Allowed use classes after assessment"
    },
    "blockedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Blocked use classes"
    },
    "assessmentDoesNotCreateTruth": {
      "type": "boolean",
      "const": true,
      "description": ""
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "assessmentState",
    "targetContributionRef",
    "completenessClass",
    "freshnessClass",
    "anomalyClass",
    "assessmentDoesNotCreateTruth"
  ]
}
