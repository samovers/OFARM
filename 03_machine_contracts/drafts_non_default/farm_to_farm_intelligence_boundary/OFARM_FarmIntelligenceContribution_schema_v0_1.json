{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_FarmIntelligenceContribution_schema_v0_1.json",
  "title": "OFARM FarmIntelligenceContribution schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Represents one farm-scoped contribution prepared for cross-farm intelligence use. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "FarmIntelligenceContribution"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "contributionState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "PACKAGED",
        "SHARED",
        "RECEIVED",
        "WITHDRAWN",
        "REVOKED",
        "QUARANTINED",
        "ARCHIVED"
      ],
      "description": ""
    },
    "contributionClass": {
      "type": "string",
      "enum": [
        "OBSERVATION_SUMMARY",
        "CP11_SUSTAINABILITY_SIGNAL",
        "CP12_MISSION_SIGNAL",
        "CP12_INCIDENT_SIGNAL",
        "CP13_LEARNING_ARTIFACT",
        "FARM_MEMORY_DERIVATIVE",
        "BENCHMARK_INPUT",
        "REGIONAL_ALERT_INPUT",
        "FEDERATED_UPDATE_INPUT",
        "OTHER"
      ],
      "description": ""
    },
    "sourceFarmScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": ""
    },
    "shareGrantRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "contributionPackageRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "qualityAssessmentRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "outputQualificationRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "deidentificationClaimRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "anonymisationClaimRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "doesNotCreateRecipientTruth": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotCreateComplianceFact": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotAuthorizeModelDeployment": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "cp11QualificationRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "cp12QualificationRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "containsSustainabilityClaim": {
      "type": "boolean"
    },
    "containsMissionOrIncidentSignal": {
      "type": "boolean"
    },
    "farmMemoryDerivative": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "contributionState",
    "contributionClass",
    "sourceFarmScopeRef",
    "shareGrantRef",
    "doesNotCreateRecipientTruth",
    "doesNotCreateComplianceFact",
    "doesNotAuthorizeModelDeployment"
  ]
}
