{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_IntelligenceContributionPackage_schema_v0_1.json",
  "title": "OFARM IntelligenceContributionPackage schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Packages one or more contributions with provenance, grant, aggregation, redaction, and output-qualification posture. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "IntelligenceContributionPackage"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "packageState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "READY_FOR_REVIEW",
        "APPROVED_FOR_SHARE",
        "SHARED",
        "RECEIVED",
        "QUARANTINED",
        "WITHDRAWN",
        "ARCHIVED"
      ],
      "description": ""
    },
    "contributionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Contribution refs",
      "minItems": 1
    },
    "shareGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Share grant refs",
      "minItems": 1
    },
    "sourceScopeClass": {
      "type": "string",
      "enum": [
        "SINGLE_FARM",
        "MULTI_FARM_COHORT",
        "REGIONAL_AGGREGATE",
        "UNKNOWN_BLOCKING"
      ],
      "description": ""
    },
    "aggregationFloorRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "deidentificationClaimRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Deidentification claim refs"
    },
    "anonymisationClaimRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Anonymisation claim refs"
    },
    "recipientUseConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Recipient use constraints",
      "minItems": 1
    },
    "outputQualificationRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "redactionPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "packageDoesNotCreateTruth": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "reidentificationRiskAssessmentRef": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "packageState",
    "contributionRefs",
    "shareGrantRefs",
    "sourceScopeClass",
    "recipientUseConstraintRefs",
    "outputQualificationRef",
    "packageDoesNotCreateTruth"
  ]
}
