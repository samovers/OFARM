{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_FarmIntelligenceSharePolicy_schema_v0_1.json",
  "title": "OFARM FarmIntelligenceSharePolicy schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Defines what farm intelligence may be shared, with whom, for what purpose, and under which restrictions. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "FarmIntelligenceSharePolicy"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "policyState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUSPENDED",
        "SUPERSEDED",
        "REVOKED",
        "ARCHIVED"
      ],
      "description": ""
    },
    "permittedIntelligenceClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Permitted intelligence class identifiers",
      "minItems": 1
    },
    "allowedRecipientClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Allowed recipient class identifiers",
      "minItems": 1
    },
    "allowedPurposeClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Allowed purpose classes",
      "minItems": 1
    },
    "prohibitedPurposeClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Prohibited purpose classes"
    },
    "minimumAggregationFloorRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "requiredRecipientUseConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Recipient use constraints",
      "minItems": 1
    },
    "requiredDerivativeUsePolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "requiredTrainingUsePolicyBindingRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "retentionPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "revocationPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "policyDoesNotConferAuthority": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "policyBlocksFarmTruthCreation": {
      "type": "boolean"
    },
    "policyBlocksModelDeployment": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "policyState",
    "permittedIntelligenceClasses",
    "allowedRecipientClasses",
    "allowedPurposeClasses",
    "requiredRecipientUseConstraintRefs",
    "policyDoesNotConferAuthority"
  ]
}
