{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_RevocationPropagationTrace_schema_v0_1.json",
  "title": "OFARM RevocationPropagationTrace schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Records propagation of a sharing, derivative-use, or training-use revocation to recipients and derivatives. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "RevocationPropagationTrace"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "revocationState": {
      "type": "string",
      "enum": [
        "REQUESTED",
        "IN_PROGRESS",
        "PARTIAL",
        "COMPLETE",
        "FAILED",
        "DISPUTED"
      ],
      "description": ""
    },
    "revocationDecisionRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "affectedGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Affected grants",
      "minItems": 1
    },
    "affectedRecipientRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Affected recipients",
      "minItems": 1
    },
    "affectedPackageRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Affected packages"
    },
    "propagationStartedAt": {
      "type": "string",
      "format": "date-time"
    },
    "propagationCompletedAt": {
      "type": "string",
      "format": "date-time"
    },
    "unresolvedRecipientRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Recipients not yet confirmed"
    },
    "derivativeRecallPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "revocationDoesNotEraseHistory": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "affectedOutputRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "affectedTrainingUseReceiptRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "affectedContributionRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "failureReasonRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "revocationState",
    "revocationDecisionRef",
    "affectedGrantRefs",
    "affectedRecipientRefs",
    "propagationStartedAt",
    "revocationDoesNotEraseHistory"
  ]
}
