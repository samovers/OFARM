{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_RegionalAlertWithdrawal_schema_v0_1.json",
  "title": "OFARM RegionalAlertWithdrawal schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Records withdrawal of a regional alert without deleting history. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "RegionalAlertWithdrawal"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "withdrawalState": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "APPROVED",
        "PUBLISHED",
        "DISPUTED"
      ],
      "description": ""
    },
    "targetAlertRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "withdrawalReasonClass": {
      "type": "string",
      "enum": [
        "FALSE_POSITIVE",
        "POISONING_RISK",
        "SOURCE_REVOCATION",
        "EXPIRED_SCOPE",
        "LEGAL_OR_POLICY",
        "OTHER"
      ],
      "description": ""
    },
    "authorityDecisionTraceRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "revocationPropagationTraceRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "notificationRequired": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "withdrawalDoesNotEraseHistory": {
      "type": "boolean",
      "const": true,
      "description": ""
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "withdrawalState",
    "targetAlertRef",
    "withdrawalReasonClass",
    "authorityDecisionTraceRef",
    "notificationRequired",
    "withdrawalDoesNotEraseHistory"
  ]
}
