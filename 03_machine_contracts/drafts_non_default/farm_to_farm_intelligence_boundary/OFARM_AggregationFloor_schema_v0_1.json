{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_AggregationFloor_schema_v0_1.json",
  "title": "OFARM AggregationFloor schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Declares minimum cohort and suppression requirements for aggregate cross-farm intelligence. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "AggregationFloor"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "floorState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED",
        "INVALIDATED"
      ],
      "description": ""
    },
    "minimumSourceFarmCount": {
      "type": "integer",
      "minimum": 2
    },
    "minimumDistinctOperatorCount": {
      "type": "integer",
      "minimum": 1
    },
    "minimumSpatialSeparationClass": {
      "type": "string",
      "enum": [
        "NONE",
        "FIELD_LEVEL",
        "FARM_LEVEL",
        "LOCALITY_LEVEL",
        "REGIONAL_LEVEL"
      ],
      "description": ""
    },
    "minimumTemporalWindowClass": {
      "type": "string",
      "enum": [
        "NONE",
        "DAY",
        "WEEK",
        "SEASON",
        "YEAR"
      ],
      "description": ""
    },
    "suppressionRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Suppression rule refs"
    },
    "smallCellSuppressionRequired": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "aggregationDoesNotEqualAnonymisation": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "policyClass": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "floorState",
    "minimumSourceFarmCount",
    "minimumDistinctOperatorCount",
    "minimumSpatialSeparationClass",
    "minimumTemporalWindowClass",
    "smallCellSuppressionRequired",
    "aggregationDoesNotEqualAnonymisation"
  ]
}
