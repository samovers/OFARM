{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_FederatedAggregationReceipt_schema_v0_1.json",
  "title": "OFARM FederatedAggregationReceipt schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Receipt from a federated aggregator indicating aggregation processing without model deployment authority. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "FederatedAggregationReceipt"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "receiptState": {
      "type": "string",
      "enum": [
        "RECEIVED",
        "ACCEPTED",
        "REJECTED",
        "QUARANTINED",
        "WITHDRAWN",
        "REVOKED"
      ],
      "description": ""
    },
    "aggregatorPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": ""
    },
    "federatedContributionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Federated contribution refs",
      "minItems": 1
    },
    "aggregationFloorRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "privacyAuditRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Privacy/security audit refs"
    },
    "modelImprovementSignalRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Produced model-improvement signals"
    },
    "doesNotDeployModel": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotAuthorizeModelUpdate": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "trainingUseReceiptRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "poisoningOrAnomalyReviewRef": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "receiptState",
    "aggregatorPartyRef",
    "federatedContributionRefs",
    "doesNotDeployModel",
    "doesNotAuthorizeModelUpdate"
  ]
}
