{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_FederatedLearningContribution_schema_v0_1.json",
  "title": "OFARM FederatedLearningContribution schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Represents a bounded federated-learning contribution without deployment authority. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "FederatedLearningContribution"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "contributionState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "READY_FOR_REVIEW",
        "SUBMITTED",
        "ACCEPTED_BY_AGGREGATOR",
        "REJECTED",
        "WITHDRAWN",
        "REVOKED",
        "QUARANTINED"
      ],
      "description": ""
    },
    "sourceFarmScopeRef": {
      "type": "string",
      "minLength": 1,
      "description": ""
    },
    "shareGrantRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "trainingUsePolicyBindingRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "targetModelFamilyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "privacyMechanismClass": {
      "type": "string",
      "enum": [
        "NONE_DECLARED",
        "SECURE_AGGREGATION",
        "DIFFERENTIAL_PRIVACY",
        "LOCAL_ONLY_FEATURES",
        "OTHER"
      ],
      "description": ""
    },
    "contributionPayloadDigest": {
      "type": "string",
      "minLength": 1,
      "description": ""
    },
    "qualityAssessmentRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "poisoningOrAnomalyReviewRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "doesNotAuthorizeModelDeployment": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "cp15RequiredForDeployment": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "privacyReviewApprovalRef": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "contributionState",
    "sourceFarmScopeRef",
    "shareGrantRef",
    "trainingUsePolicyBindingRef",
    "targetModelFamilyRef",
    "privacyMechanismClass",
    "contributionPayloadDigest",
    "doesNotAuthorizeModelDeployment",
    "cp15RequiredForDeployment"
  ]
}
