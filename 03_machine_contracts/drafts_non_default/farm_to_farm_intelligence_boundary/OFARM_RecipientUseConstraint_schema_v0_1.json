{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_RecipientUseConstraint_schema_v0_1.json",
  "title": "OFARM RecipientUseConstraint schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Declares permitted, prohibited, retention, redisclosure, derivative-use, and training-use limits for a recipient. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "RecipientUseConstraint"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "constraintState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED",
        "REVOKED",
        "EXPIRED"
      ],
      "description": ""
    },
    "recipientClass": {
      "type": "string",
      "minLength": 1,
      "description": ""
    },
    "allowedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Allowed uses",
      "minItems": 1
    },
    "prohibitedUseClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Prohibited uses",
      "minItems": 1
    },
    "redisclosurePosture": {
      "type": "string",
      "enum": [
        "PROHIBITED",
        "GRANT_REQUIRED",
        "AGGREGATED_ONLY",
        "PUBLIC_AUTHORITY_ONLY",
        "ALLOWED_WITH_CONSTRAINTS"
      ],
      "description": ""
    },
    "retentionLimitRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "derivativeUsePolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "trainingUsePolicyBindingRef": {
      "type": "string",
      "minLength": 1,
      "description": "OFARM artifact reference"
    },
    "revocationPropagationRequired": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "useConstraintDoesNotConferAuthority": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "blockedUseClasses": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "blocksRecipientFarmMemoryCreation": {
      "type": "boolean"
    },
    "blocksFarmTruthCreation": {
      "type": "boolean"
    },
    "blocksModelDeployment": {
      "type": "boolean"
    },
    "blocksMissionAuthority": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "constraintState",
    "recipientClass",
    "allowedUseClasses",
    "prohibitedUseClasses",
    "redisclosurePosture",
    "revocationPropagationRequired",
    "useConstraintDoesNotConferAuthority"
  ]
}
