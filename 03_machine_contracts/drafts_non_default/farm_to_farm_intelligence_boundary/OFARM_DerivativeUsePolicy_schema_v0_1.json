{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/drafts/non-default/farm_to_farm_intelligence_boundary/OFARM_DerivativeUsePolicy_schema_v0_1.json",
  "title": "OFARM DerivativeUsePolicy schema v0.1 draft/non-default \u2014 CP14 Phase 7.2 cross-record policy/disclosure/federated-use hardening draft/non-default",
  "description": "Controls whether and how recipients may derive new intelligence, outputs, products, or model signals from shared intelligence. CP14 Phase 7.2 keeps this schema draft/non-default and adds cross-record policy, disclosure, regional-alert, federated-use, revocation, and output-authority hardening via conformance runner where JSON Schema cannot express cross-record constraints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "cp14-v0.1-draft-phase7-2-cross-record-policy-disclosure-federated-use-hardening"
    },
    "artifactType": {
      "type": "string",
      "const": "DerivativeUsePolicy"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable CP14 artifact id"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByPartyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Responsible party, farm, platform, or agent sponsor"
    },
    "authorityBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Authority, policy, grant, or review basis refs"
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "PROV, trace, or source references"
    },
    "policyState": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUSPENDED",
        "SUPERSEDED",
        "REVOKED"
      ],
      "description": ""
    },
    "permittedDerivativeClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Permitted derivative classes"
    },
    "prohibitedDerivativeClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Prohibited derivative classes",
      "minItems": 1
    },
    "approvalRequiredForDerivativeClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "OFARM artifact reference"
      },
      "uniqueItems": true,
      "description": "Derivative classes requiring approval"
    },
    "recipientDisclosureRequired": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "derivativeOutputQualificationRequired": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "doesNotAuthorizeModelDeployment": {
      "type": "boolean",
      "const": true,
      "description": ""
    },
    "cp15RequiredForDeployment": {
      "type": "boolean",
      "const": true,
      "description": ""
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "createdByPartyRef",
    "policyState",
    "prohibitedDerivativeClasses",
    "recipientDisclosureRequired",
    "derivativeOutputQualificationRequired",
    "doesNotAuthorizeModelDeployment",
    "cp15RequiredForDeployment"
  ]
}
