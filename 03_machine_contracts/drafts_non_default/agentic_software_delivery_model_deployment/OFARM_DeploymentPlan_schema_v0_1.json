{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/deployment-plan/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Defines deployment scope, target environments, blast radius, canary, and rollback posture.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "DeploymentPlan"
    },
    "blastRadiusApprovalRef": {
      "minLength": 1,
      "type": "string"
    },
    "blastRadiusClass": {
      "enum": [
        "LOCAL_SANDBOX",
        "LIMITED_CANARY",
        "SINGLE_FARM",
        "MULTI_FARM",
        "GLOBAL",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "canaryPlanRef": {
      "minLength": 1,
      "type": "string"
    },
    "cpGateRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentCandidateRef": {
      "minLength": 1,
      "type": "string"
    },
    "noApplicableCPGatesBasis": {
      "minLength": 1,
      "type": "string"
    },
    "planReviewDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "planState": {
      "enum": [
        "DRAFT",
        "APPROVED_CANDIDATE",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "rollbackPlanRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "stagedRolloutPlanRef": {
      "minLength": 1,
      "type": "string"
    },
    "targetEnvironmentRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "planState",
    "deploymentCandidateRef",
    "targetEnvironmentRefs",
    "blastRadiusClass",
    "rollbackPlanRef",
    "canaryPlanRef",
    "cpGateRefs"
  ],
  "title": "OFARM DeploymentPlan schema v0.1 draft/non-default remediated",
  "type": "object"
}