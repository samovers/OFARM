{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/conformance-test-plan/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Defines conformance tests required for delivery or deployment candidate.",
  "properties": {
    "approvalDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "ConformanceTestPlan"
    },
    "conformanceScope": {
      "enum": [
        "SCHEMA",
        "RUNTIME_SURFACE",
        "AUTHORITY",
        "SECURITY",
        "CP11",
        "CP12",
        "CP13",
        "CP14",
        "CP15",
        "FULL_RELEASE_CANDIDATE"
      ],
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "planState": {
      "enum": [
        "DRAFT",
        "APPROVED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "requiredFixtureRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "targetArtifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "planState",
    "targetArtifactRefs",
    "conformanceScope",
    "requiredFixtureRefs",
    "approvalDecisionRef"
  ],
  "title": "OFARM ConformanceTestPlan schema v0.1 draft/non-default remediated",
  "type": "object"
}