{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/rollback-event/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records rollback execution as evidence, not proof of restored correctness by itself.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "RollbackEvent"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentIncidentRef": {
      "minLength": 1,
      "type": "string"
    },
    "occurredAt": {
      "format": "date-time",
      "type": "string"
    },
    "rollbackDisposition": {
      "enum": [
        "SUCCESS",
        "FAILED",
        "PARTIAL",
        "REQUIRE_REVIEW"
      ],
      "type": "string"
    },
    "rollbackPlanRef": {
      "minLength": 1,
      "type": "string"
    },
    "rollbackState": {
      "enum": [
        "TRIGGERED",
        "IN_PROGRESS",
        "COMPLETED",
        "FAILED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "triggerRef": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "rollbackState",
    "rollbackPlanRef",
    "triggerRef",
    "rollbackDisposition",
    "occurredAt",
    "deploymentIncidentRef"
  ],
  "title": "OFARM RollbackEvent schema v0.1 draft/non-default remediated",
  "type": "object"
}