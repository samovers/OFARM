{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/generated-adapter-artifact/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Represents generated integration/adapter software while preserving CP12 mission authority boundaries.",
  "properties": {
    "adapterKind": {
      "enum": [
        "IMPORT_ADAPTER",
        "EXPORT_ADAPTER",
        "ROBOT_VENDOR_ADAPTER",
        "SENSOR_ADAPTER",
        "DATA_SPACE_ADAPTER",
        "REGISTRY_ADAPTER"
      ],
      "type": "string"
    },
    "adapterStatus": {
      "enum": [
        "DRAFT",
        "GENERATED",
        "UNDER_REVIEW",
        "APPROVED_CANDIDATE",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "GeneratedAdapterArtifact"
    },
    "conformanceRunRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "cp12GateTraceRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "cp14GateTraceRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateDeploymentAuthority": {
      "const": true
    },
    "doesNotCreateMissionAuthority": {
      "const": true
    },
    "doesNotCreateRuntimeAuthority": {
      "const": true
    },
    "doesNotPromoteCurrentDefault": {
      "const": true
    },
    "lossMapDisposition": {
      "enum": [
        "ACCEPTABLE",
        "REQUIRE_REVIEW",
        "INSUFFICIENT",
        "BLOCK"
      ],
      "type": "string"
    },
    "lossMapRef": {
      "minLength": 1,
      "type": "string"
    },
    "mappingCoverageStatementRef": {
      "minLength": 1,
      "type": "string"
    },
    "mappingCoverageSufficient": {
      "type": "boolean"
    },
    "mappingCurrentnessReviewRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "securityScanResultRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "semanticMappingCandidateRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "sourceSystemRef": {
      "minLength": 1,
      "type": "string"
    },
    "targetSurfaceRef": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "adapterKind",
    "sourceSystemRef",
    "targetSurfaceRef",
    "semanticMappingCandidateRefs",
    "mappingCoverageStatementRef",
    "lossMapRef",
    "adapterStatus",
    "doesNotCreateDeploymentAuthority",
    "doesNotCreateRuntimeAuthority",
    "doesNotPromoteCurrentDefault",
    "doesNotCreateMissionAuthority"
  ],
  "title": "OFARM GeneratedAdapterArtifact schema v0.1 draft/non-default remediated",
  "type": "object"
}