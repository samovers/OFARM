{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/deployment-telemetry-envelope/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Captures deployment telemetry without turning telemetry into deployment success.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "DeploymentTelemetryEnvelope"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentRef": {
      "minLength": 1,
      "type": "string"
    },
    "doesNotCreateDeploymentSuccess": {
      "const": true
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "telemetryDisposition": {
      "enum": [
        "NORMAL",
        "WARNING",
        "INCIDENT_CANDIDATE",
        "INSUFFICIENT_BASIS",
        "INVALIDATED"
      ],
      "type": "string"
    },
    "telemetrySourceRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "telemetryState": {
      "enum": [
        "CAPTURED",
        "QUALIFIED",
        "DISPUTED",
        "INVALIDATED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "telemetryWindowEnd": {
      "format": "date-time",
      "type": "string"
    },
    "telemetryWindowStart": {
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "telemetryState",
    "deploymentRef",
    "telemetryWindowStart",
    "telemetryWindowEnd",
    "telemetrySourceRefs",
    "telemetryDisposition",
    "doesNotCreateDeploymentSuccess"
  ],
  "title": "OFARM DeploymentTelemetryEnvelope schema v0.1 draft/non-default remediated",
  "type": "object"
}