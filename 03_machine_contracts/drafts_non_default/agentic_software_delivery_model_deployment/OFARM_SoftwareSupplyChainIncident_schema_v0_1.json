{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/software-supply-chain-incident/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records software supply-chain incidents for generated or deployable artifacts.",
  "properties": {
    "affectedArtifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "SoftwareSupplyChainIncident"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "detectedAt": {
      "format": "date-time",
      "type": "string"
    },
    "incidentClass": {
      "enum": [
        "DEPENDENCY_COMPROMISE",
        "SIGNATURE_FAILURE",
        "PROVENANCE_GAP",
        "MALICIOUS_CODE",
        "LICENSE_RISK",
        "BUILD_ENVIRONMENT_COMPROMISE",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "incidentState": {
      "enum": [
        "SUSPECTED",
        "CONFIRMED",
        "MITIGATED",
        "RESOLVED",
        "FALSE_POSITIVE",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "reviewDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "severityClass": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL",
        "UNKNOWN"
      ],
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "incidentState",
    "affectedArtifactRefs",
    "incidentClass",
    "severityClass",
    "detectedAt",
    "reviewDecisionRef"
  ],
  "title": "OFARM SoftwareSupplyChainIncident schema v0.1 draft/non-default remediated",
  "type": "object"
}