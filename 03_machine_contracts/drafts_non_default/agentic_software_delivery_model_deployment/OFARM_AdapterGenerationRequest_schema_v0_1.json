{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/adapter-generation-request/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Requests generation of an adapter under explicit authority and mapping constraints.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "AdapterGenerationRequest"
    },
    "authorityDecisionTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "requestState": {
      "enum": [
        "DRAFT",
        "SUBMITTED",
        "APPROVED_FOR_GENERATION",
        "REJECTED",
        "CANCELLED"
      ],
      "type": "string"
    },
    "requestedByPartyRef": {
      "minLength": 1,
      "type": "string"
    },
    "requiredMappingRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "sourceSystemRef": {
      "minLength": 1,
      "type": "string"
    },
    "targetSurfaceRef": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "requestState",
    "requestedByPartyRef",
    "sourceSystemRef",
    "targetSurfaceRef",
    "authorityDecisionTraceRef",
    "requiredMappingRefs"
  ],
  "title": "OFARM AdapterGenerationRequest schema v0.1 draft/non-default remediated",
  "type": "object"
}