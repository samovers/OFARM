{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/deployment-authorization/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Authorises a deployment plan for a bounded scope/time.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "DeploymentAuthorization"
    },
    "authorityDecisionTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "authorizationScopeRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "authorizationState": {
      "enum": [
        "REQUESTED",
        "APPROVED",
        "ACTIVE",
        "DENIED",
        "EXPIRED",
        "REVOKED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "authorizedByPartyRef": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentPlanRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "validFrom": {
      "format": "date-time",
      "type": "string"
    },
    "validUntil": {
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "authorizationState",
    "deploymentPlanRef",
    "authorityDecisionTraceRef",
    "authorizedByPartyRef",
    "validFrom",
    "validUntil",
    "authorizationScopeRefs"
  ],
  "title": "OFARM DeploymentAuthorization schema v0.1 draft/non-default remediated",
  "type": "object"
}