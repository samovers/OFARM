{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/generated-prompt-or-policy-artifact/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Represents generated prompt or policy artifacts subject to review before use.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactKind": {
      "enum": [
        "PROMPT",
        "SYSTEM_INSTRUCTION",
        "POLICY_RULE",
        "ROUTING_POLICY",
        "TOOL_POLICY"
      ],
      "type": "string"
    },
    "artifactStatus": {
      "enum": [
        "DRAFT",
        "GENERATED",
        "UNDER_REVIEW",
        "APPROVED_CANDIDATE",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "artifactType": {
      "const": "GeneratedPromptOrPolicyArtifact"
    },
    "authorityDecisionTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "changeType": {
      "enum": [
        "CREATE",
        "UPDATE",
        "DEPRECATE",
        "REPLACE"
      ],
      "type": "string"
    },
    "conformanceRunRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateDeploymentAuthority": {
      "const": true
    },
    "doesNotCreateRuntimeAuthority": {
      "const": true
    },
    "doesNotPromoteCurrentDefault": {
      "const": true
    },
    "reviewRequired": {
      "type": "boolean"
    },
    "riskReviewRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "securityScanResultRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "targetUseClass": {
      "enum": [
        "ADVISORY",
        "STATE_AFFECTING",
        "HIGH_CONSEQUENCE",
        "DEPLOYMENT_RELATED",
        "MISSION_RELATED"
      ],
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "artifactKind",
    "targetUseClass",
    "changeType",
    "reviewRequired",
    "artifactStatus",
    "doesNotCreateDeploymentAuthority",
    "doesNotCreateRuntimeAuthority",
    "doesNotPromoteCurrentDefault"
  ],
  "title": "OFARM GeneratedPromptOrPolicyArtifact schema v0.1 draft/non-default remediated",
  "type": "object"
}