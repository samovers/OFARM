{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/static-analysis-result/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records static-analysis outcome for generated/deployable artifacts.",
  "properties": {
    "analysisState": {
      "enum": [
        "COMPLETE",
        "FAILED",
        "REQUIRES_REVIEW",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "artifactType": {
      "const": "StaticAnalysisResult"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "disposition": {
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "REQUIRE_REVIEW",
        "BLOCK",
        "TOOL_FAILED"
      ],
      "type": "string"
    },
    "findingRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "securityFindingWaiverRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "severityMax": {
      "enum": [
        "NONE",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "toolRef": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "analysisState",
    "artifactRefs",
    "toolRef",
    "severityMax",
    "findingRefs",
    "disposition"
  ],
  "title": "OFARM StaticAnalysisResult schema v0.1 draft/non-default remediated",
  "type": "object"
}