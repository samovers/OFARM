{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/s-b-o-m-reference/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "References an SBOM for generated or deployable artifacts.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "artifactType": {
      "const": "SBOMReference"
    },
    "coveredArtifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "generatedAt": {
      "format": "date-time",
      "type": "string"
    },
    "licenseSummaryRef": {
      "minLength": 1,
      "type": "string"
    },
    "sbomDigest": {
      "minLength": 1,
      "type": "string"
    },
    "sbomFormat": {
      "enum": [
        "SPDX",
        "CYCLONEDX",
        "OTHER_DECLARED"
      ],
      "type": "string"
    },
    "sbomStatus": {
      "enum": [
        "GENERATED",
        "VALIDATED",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "sbomStatus",
    "artifactRefs",
    "sbomDigest",
    "sbomFormat",
    "generatedAt",
    "licenseSummaryRef"
  ],
  "title": "OFARM SBOMReference schema v0.1 draft/non-default remediated",
  "type": "object"
}