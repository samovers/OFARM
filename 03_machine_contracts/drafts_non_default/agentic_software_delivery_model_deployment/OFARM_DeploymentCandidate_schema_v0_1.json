{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/deployment-candidate/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Collects evidence for a deployable candidate without granting deployment authority.",
  "properties": {
    "approvedEvidenceSummaryRef": {
      "minLength": 1,
      "type": "string"
    },
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "artifactType": {
      "const": "DeploymentCandidate"
    },
    "authorityDecisionTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "buildProvenanceRef": {
      "minLength": 1,
      "type": "string"
    },
    "candidateState": {
      "enum": [
        "DRAFT",
        "ASSEMBLED",
        "UNDER_REVIEW",
        "BLOCKED",
        "APPROVED_CANDIDATE",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "conformanceRunRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "dependencyRiskAssessmentRef": {
      "minLength": 1,
      "type": "string"
    },
    "doesNotCreateDeploymentAuthority": {
      "const": true
    },
    "doesNotCreateRuntimeAuthority": {
      "const": true
    },
    "doesNotPromoteCurrentDefault": {
      "const": true
    },
    "reviewDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "sbomRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "securityFindingWaiverRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "securityScanResultRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "softwareSupplyChainIncidentRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "staticAnalysisResultRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "targetRuntimeSurfaceRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "candidateState",
    "artifactRefs",
    "buildProvenanceRef",
    "sbomRef",
    "dependencyRiskAssessmentRef",
    "staticAnalysisResultRefs",
    "securityScanResultRefs",
    "conformanceRunRefs",
    "targetRuntimeSurfaceRefs",
    "doesNotCreateDeploymentAuthority",
    "doesNotCreateRuntimeAuthority",
    "doesNotPromoteCurrentDefault"
  ],
  "title": "OFARM DeploymentCandidate schema v0.1 draft/non-default remediated",
  "type": "object"
}