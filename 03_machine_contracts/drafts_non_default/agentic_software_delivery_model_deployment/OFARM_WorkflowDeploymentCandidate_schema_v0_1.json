{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/workflow-deployment-candidate/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Represents workflow deployment candidate without runtime authority.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "WorkflowDeploymentCandidate"
    },
    "candidateState": {
      "enum": [
        "DRAFT",
        "UNDER_REVIEW",
        "APPROVED_CANDIDATE",
        "BLOCKED",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "conformanceRunRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateRuntimeAuthority": {
      "const": true
    },
    "generatedWorkflowArtifactRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "securityScanRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "targetRuntimeSurfaceRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "candidateState",
    "generatedWorkflowArtifactRef",
    "targetRuntimeSurfaceRefs",
    "conformanceRunRefs",
    "securityScanRefs",
    "doesNotCreateRuntimeAuthority"
  ],
  "title": "OFARM WorkflowDeploymentCandidate schema v0.1 draft/non-default remediated",
  "type": "object"
}