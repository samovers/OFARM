{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/canary-plan/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Defines canary scope, success criteria, abort criteria, and authority.",
  "properties": {
    "abortCriteriaRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "CanaryPlan"
    },
    "authorityDecisionTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "canaryScopeRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "canaryState": {
      "enum": [
        "DRAFT",
        "APPROVED",
        "ACTIVE",
        "COMPLETED",
        "ABORTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentPlanRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "successCriteriaRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "canaryState",
    "deploymentPlanRef",
    "canaryScopeRefs",
    "successCriteriaRefs",
    "abortCriteriaRefs",
    "authorityDecisionTraceRef"
  ],
  "title": "OFARM CanaryPlan schema v0.1 draft/non-default remediated",
  "type": "object"
}