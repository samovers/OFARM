{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/generated-software-artifact/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "artifactStatus": {
            "const": "APPROVED_CANDIDATE"
          }
        },
        "required": [
          "artifactStatus"
        ]
      },
      "then": {
        "properties": {
          "conformanceRunRefs": {
            "minItems": 1
          },
          "securityScanResultRefs": {
            "minItems": 1
          }
        },
        "required": [
          "reviewDecisionRef",
          "authorityDecisionTraceRef",
          "conformanceRunRefs",
          "securityScanResultRefs"
        ]
      }
    }
  ],
  "description": "Represents software generated by a human or agent without granting deployment authority.",
  "properties": {
    "artifactDigest": {
      "minLength": 1,
      "type": "string"
    },
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactKind": {
      "enum": [
        "LIBRARY",
        "SERVICE",
        "SCRIPT",
        "POLICY_CODE",
        "VALIDATOR",
        "UI_SURFACE",
        "RUNTIME_COMPONENT"
      ],
      "type": "string"
    },
    "artifactStatus": {
      "enum": [
        "DRAFT",
        "GENERATED",
        "UNDER_REVIEW",
        "APPROVED_CANDIDATE",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "artifactType": {
      "const": "GeneratedSoftwareArtifact"
    },
    "authorityDecisionTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "conformanceRunRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateDeploymentAuthority": {
      "const": true
    },
    "doesNotCreateRuntimeAuthority": {
      "const": true
    },
    "doesNotPromoteCurrentDefault": {
      "const": true
    },
    "generatedByAgentRunTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "intendedSurfaceRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "provenanceRef": {
      "minLength": 1,
      "type": "string"
    },
    "reviewDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "securityScanResultRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "sourcePromptOrSpecRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "artifactKind",
    "generatedByAgentRunTraceRef",
    "sourcePromptOrSpecRefs",
    "artifactDigest",
    "intendedSurfaceRefs",
    "provenanceRef",
    "artifactStatus",
    "doesNotCreateDeploymentAuthority",
    "doesNotCreateRuntimeAuthority",
    "doesNotPromoteCurrentDefault"
  ],
  "title": "OFARM GeneratedSoftwareArtifact schema v0.1 draft/non-default remediated",
  "type": "object"
}