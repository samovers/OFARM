{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/semantic-mapping-candidate/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Represents a candidate mapping that cannot mutate OFARM core meaning.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "SemanticMappingCandidate"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateCoreMeaning": {
      "const": true
    },
    "lossMapDisposition": {
      "enum": [
        "ACCEPTABLE",
        "REQUIRE_REVIEW",
        "INSUFFICIENT",
        "BLOCK"
      ],
      "type": "string"
    },
    "lossMapRef": {
      "minLength": 1,
      "type": "string"
    },
    "mappingConfidenceClass": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "INSUFFICIENT"
      ],
      "type": "string"
    },
    "mappingCoverageStatementRef": {
      "minLength": 1,
      "type": "string"
    },
    "mappingCoverageSufficient": {
      "type": "boolean"
    },
    "mappingStatus": {
      "enum": [
        "DRAFT",
        "UNDER_REVIEW",
        "APPROVED_CANDIDATE",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "sourceConceptRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "targetConceptRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "sourceConceptRefs",
    "targetConceptRefs",
    "mappingConfidenceClass",
    "mappingStatus",
    "lossMapRef",
    "mappingCoverageStatementRef",
    "doesNotCreateCoreMeaning"
  ],
  "title": "OFARM SemanticMappingCandidate schema v0.1 draft/non-default remediated",
  "type": "object"
}