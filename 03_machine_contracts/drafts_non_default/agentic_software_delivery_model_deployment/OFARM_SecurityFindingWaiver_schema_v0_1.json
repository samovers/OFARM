{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/security-finding-waiver/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records governed waiver of a security finding.",
  "properties": {
    "approvalDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "SecurityFindingWaiver"
    },
    "authorityDecisionTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "expiresAt": {
      "format": "date-time",
      "type": "string"
    },
    "findingRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "justification": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "severityCovered": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "specialAuthorityRef": {
      "minLength": 1,
      "type": "string"
    },
    "waiverState": {
      "enum": [
        "REQUESTED",
        "APPROVED",
        "DENIED",
        "EXPIRED",
        "SUPERSEDED"
      ],
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "waiverState",
    "findingRefs",
    "approvalDecisionRef",
    "authorityDecisionTraceRef",
    "expiresAt",
    "justification"
  ],
  "title": "OFARM SecurityFindingWaiver schema v0.1 draft/non-default remediated",
  "type": "object"
}