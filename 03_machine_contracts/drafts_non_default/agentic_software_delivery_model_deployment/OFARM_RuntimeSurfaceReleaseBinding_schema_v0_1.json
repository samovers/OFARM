{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/runtime-surface-release-binding/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Binds a release bundle to a runtime surface without current/default promotion.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "RuntimeSurfaceReleaseBinding"
    },
    "bindingReviewDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "bindingState": {
      "enum": [
        "DRAFT",
        "BOUND_CANDIDATE",
        "ACTIVE_NON_DEFAULT",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "capabilityManifestRef": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentAuthorizationRef": {
      "minLength": 1,
      "type": "string"
    },
    "deploymentIncidentRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "doesNotPromoteCurrentDefault": {
      "const": true
    },
    "releaseBundleRef": {
      "minLength": 1,
      "type": "string"
    },
    "releaseDigestRef": {
      "minLength": 1,
      "type": "string"
    },
    "runtimeSurfaceRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "softwareSupplyChainIncidentRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "bindingState",
    "runtimeSurfaceRef",
    "releaseBundleRef",
    "capabilityManifestRef",
    "deploymentAuthorizationRef",
    "doesNotPromoteCurrentDefault"
  ],
  "title": "OFARM RuntimeSurfaceReleaseBinding schema v0.1 draft/non-default remediated",
  "type": "object"
}