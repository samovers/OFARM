{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/deployment-incident/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records runtime deployment incidents and rollback linkage.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "DeploymentIncident"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentRef": {
      "minLength": 1,
      "type": "string"
    },
    "detectedAt": {
      "format": "date-time",
      "type": "string"
    },
    "incidentClass": {
      "enum": [
        "OUTAGE",
        "SECURITY",
        "DATA_QUALITY",
        "AUTHORITY_BYPASS",
        "MISSION_RISK",
        "MODEL_RISK",
        "ROLLBACK_FAILURE",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "incidentState": {
      "enum": [
        "SUSPECTED",
        "CONFIRMED",
        "MITIGATED",
        "RESOLVED",
        "FALSE_POSITIVE",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "rollbackEventRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "severityClass": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL",
        "UNKNOWN"
      ],
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "incidentState",
    "deploymentRef",
    "incidentClass",
    "severityClass",
    "detectedAt",
    "rollbackEventRefs"
  ],
  "title": "OFARM DeploymentIncident schema v0.1 draft/non-default remediated",
  "type": "object"
}