{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/deployment-output-qualification/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Qualifies deployment outputs so reports cannot become authority/readiness facts.",
  "properties": {
    "advisoryOnly": {
      "type": "boolean"
    },
    "allowedUseClasses": {
      "items": {
        "enum": [
          "ADVISORY_REVIEW",
          "DEPLOYMENT_REPORTING",
          "DEPLOYMENT_CANDIDATE_EVIDENCE",
          "INCIDENT_REVIEW"
        ],
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "DeploymentOutputQualification"
    },
    "blockedUseClasses": {
      "items": {
        "enum": [
          "DEPLOYMENT_AUTHORITY",
          "RUNTIME_AUTHORITY",
          "CURRENT_DEFAULT_PROMOTION",
          "MISSION_AUTHORITY",
          "COMPLIANCE_FACT",
          "PRODUCTION_READINESS",
          "MODEL_DEPLOYMENT_AUTHORITY",
          "AUTOMATIC_EXECUTION"
        ],
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentRef": {
      "minLength": 1,
      "type": "string"
    },
    "evidenceRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "outputDisposition": {
      "enum": [
        "ADVISORY_ONLY",
        "DEPLOYMENT_REPORT",
        "DEPLOYMENT_CANDIDATE_EVIDENCE",
        "PRODUCTION_READINESS_CANDIDATE",
        "INCIDENT_REPORT"
      ],
      "type": "string"
    },
    "qualificationState": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "reviewBasisRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "qualificationState",
    "deploymentRef",
    "outputDisposition",
    "allowedUseClasses",
    "blockedUseClasses",
    "evidenceRefs",
    "advisoryOnly"
  ],
  "title": "OFARM DeploymentOutputQualification schema v0.1 draft/non-default remediated",
  "type": "object"
}