{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/canary-result/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records canary result without production-readiness authority.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "CanaryResult"
    },
    "canaryPlanRef": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateProductionReadiness": {
      "const": true
    },
    "incidentTelemetryRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "incidentTelemetryReviewRef": {
      "type": "string"
    },
    "observedAt": {
      "format": "date-time",
      "type": "string"
    },
    "resultDisposition": {
      "enum": [
        "PASS",
        "FAIL",
        "REQUIRE_REVIEW",
        "INCONCLUSIVE"
      ],
      "type": "string"
    },
    "resultState": {
      "enum": [
        "RUNNING",
        "PASSED",
        "FAILED",
        "INCONCLUSIVE",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "telemetryRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "resultState",
    "canaryPlanRef",
    "telemetryRefs",
    "resultDisposition",
    "observedAt",
    "doesNotCreateProductionReadiness"
  ],
  "title": "OFARM CanaryResult schema v0.1 draft/non-default remediated",
  "type": "object"
}