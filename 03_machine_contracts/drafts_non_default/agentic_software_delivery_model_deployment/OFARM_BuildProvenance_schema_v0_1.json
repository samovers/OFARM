{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/build-provenance/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records build provenance without deployment authority.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "BuildProvenance"
    },
    "buildDigest": {
      "minLength": 1,
      "type": "string"
    },
    "buildEnvironmentRef": {
      "minLength": 1,
      "type": "string"
    },
    "buildStatus": {
      "enum": [
        "STARTED",
        "SUCCEEDED",
        "FAILED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "builderAgentOrServiceRef": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateDeploymentAuthority": {
      "const": true
    },
    "reproducibilityClass": {
      "enum": [
        "REPRODUCIBLE",
        "PARTIALLY_REPRODUCIBLE",
        "NOT_REPRODUCIBLE",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "sourceArtifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "sourceDigestRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "buildStatus",
    "sourceArtifactRefs",
    "builderAgentOrServiceRef",
    "buildDigest",
    "buildEnvironmentRef",
    "reproducibilityClass",
    "doesNotCreateDeploymentAuthority"
  ],
  "title": "OFARM BuildProvenance schema v0.1 draft/non-default remediated",
  "type": "object"
}