{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/runtime-deployment-receipt/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records runtime deployment receipt without production readiness.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "RuntimeDeploymentReceipt"
    },
    "authorizationValidFrom": {
      "format": "date-time",
      "type": "string"
    },
    "authorizationValidUntil": {
      "format": "date-time",
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deployedAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentAuthorizationRef": {
      "minLength": 1,
      "type": "string"
    },
    "doesNotCreateProductionReadiness": {
      "const": true
    },
    "receiptState": {
      "enum": [
        "RECEIVED",
        "CONFIRMED_BY_RUNTIME",
        "DISPUTED",
        "INVALIDATED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "releaseBundleRef": {
      "minLength": 1,
      "type": "string"
    },
    "releaseDigestRef": {
      "minLength": 1,
      "type": "string"
    },
    "runtimeEnvironmentRef": {
      "minLength": 1,
      "type": "string"
    },
    "runtimeSurfaceBindingRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "receiptState",
    "deploymentAuthorizationRef",
    "releaseBundleRef",
    "runtimeSurfaceBindingRef",
    "deployedAt",
    "runtimeEnvironmentRef",
    "doesNotCreateProductionReadiness"
  ],
  "title": "OFARM RuntimeDeploymentReceipt schema v0.1 draft/non-default remediated",
  "type": "object"
}