{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/conformance-run-receipt/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records conformance run result without deployment authority.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "ConformanceRunReceipt"
    },
    "completedAt": {
      "format": "date-time",
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateDeploymentAuthority": {
      "const": true
    },
    "resultDigest": {
      "minLength": 1,
      "type": "string"
    },
    "reviewDecisionRef": {
      "type": "string"
    },
    "runDisposition": {
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL",
        "INCONCLUSIVE"
      ],
      "type": "string"
    },
    "runState": {
      "enum": [
        "STARTED",
        "PASSED",
        "FAILED",
        "INCONCLUSIVE",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "runnerRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "targetArtifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "testPlanRef": {
      "minLength": 1,
      "type": "string"
    },
    "warningDisposition": {
      "enum": [
        "ACCEPTED",
        "REQUIRE_REVIEW",
        "BLOCKING",
        "NOT_APPLICABLE"
      ],
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "runState",
    "testPlanRef",
    "targetArtifactRefs",
    "runnerRef",
    "runDisposition",
    "resultDigest",
    "completedAt",
    "doesNotCreateDeploymentAuthority"
  ],
  "title": "OFARM ConformanceRunReceipt schema v0.1 draft/non-default remediated",
  "type": "object"
}