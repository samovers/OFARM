{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/deployment-promotion-decision/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records a governed promotion decision for a deployment candidate.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "DeploymentPromotionDecision"
    },
    "authorityDecisionTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "canaryNotApplicableBasis": {
      "type": "string"
    },
    "canaryResultRef": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "decisionState": {
      "enum": [
        "PROPOSED",
        "APPROVED",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "deploymentAuthorizationRef": {
      "minLength": 1,
      "type": "string"
    },
    "deploymentCandidateRef": {
      "minLength": 1,
      "type": "string"
    },
    "deploymentIncidentRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "doesNotPromoteCurrentDefault": {
      "const": true
    },
    "promotionDisposition": {
      "enum": [
        "PROMOTE_TO_CANARY",
        "PROMOTE_TO_RELEASE_BUNDLE",
        "PROMOTE_TO_RUNTIME",
        "REJECT",
        "REQUIRE_REMEDIATION"
      ],
      "type": "string"
    },
    "releaseBundleRef": {
      "minLength": 1,
      "type": "string"
    },
    "reviewDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "rollbackPlanRef": {
      "minLength": 1,
      "type": "string"
    },
    "runtimeSurfaceReleaseBindingRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "softwareSupplyChainIncidentRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "decisionState",
    "deploymentCandidateRef",
    "deploymentAuthorizationRef",
    "promotionDisposition",
    "reviewDecisionRef",
    "authorityDecisionTraceRef",
    "doesNotPromoteCurrentDefault"
  ],
  "title": "OFARM DeploymentPromotionDecision schema v0.1 draft/non-default remediated",
  "type": "object"
}