{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/rollback-plan/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Defines rollback triggers, methods, test evidence, and readiness.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "RollbackPlan"
    },
    "authorityDecisionTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentPlanRef": {
      "minLength": 1,
      "type": "string"
    },
    "lastTestedAt": {
      "format": "date-time",
      "type": "string"
    },
    "rollbackMethodRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "rollbackReadinessFreshnessState": {
      "enum": [
        "FRESH",
        "STALE",
        "UNKNOWN",
        "INVALIDATED"
      ],
      "type": "string"
    },
    "rollbackReadinessState": {
      "enum": [
        "DRAFT",
        "READY",
        "NOT_READY",
        "EXPIRED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "rollbackTestResultRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "rollbackTriggerRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "rollbackReadinessState",
    "deploymentPlanRef",
    "rollbackTriggerRefs",
    "rollbackMethodRefs",
    "lastTestedAt",
    "authorityDecisionTraceRef"
  ],
  "title": "OFARM RollbackPlan schema v0.1 draft/non-default remediated",
  "type": "object"
}