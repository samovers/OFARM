{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/generated-patch-artifact/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Represents a generated patch proposal without promotion or deployment authority.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "GeneratedPatchArtifact"
    },
    "buildProvenanceRef": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "diffDigest": {
      "minLength": 1,
      "type": "string"
    },
    "doesNotCreateDeploymentAuthority": {
      "const": true
    },
    "doesNotCreateRuntimeAuthority": {
      "const": true
    },
    "doesNotPromoteCurrentDefault": {
      "const": true
    },
    "generatedByAgentRunTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "patchKind": {
      "enum": [
        "SOURCE_PATCH",
        "SCHEMA_PATCH",
        "CONFIG_PATCH",
        "POLICY_PATCH",
        "DOCUMENTATION_PATCH"
      ],
      "type": "string"
    },
    "patchStatus": {
      "enum": [
        "DRAFT",
        "GENERATED",
        "UNDER_REVIEW",
        "APPROVED_CANDIDATE",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "targetArtifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "patchKind",
    "targetArtifactRefs",
    "diffDigest",
    "generatedByAgentRunTraceRef",
    "buildProvenanceRef",
    "patchStatus",
    "doesNotCreateDeploymentAuthority",
    "doesNotCreateRuntimeAuthority",
    "doesNotPromoteCurrentDefault"
  ],
  "title": "OFARM GeneratedPatchArtifact schema v0.1 draft/non-default remediated",
  "type": "object"
}