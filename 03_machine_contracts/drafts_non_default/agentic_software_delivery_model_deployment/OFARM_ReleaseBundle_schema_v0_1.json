{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/release-bundle/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Packages signed artifacts and evidence for release.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "artifactType": {
      "const": "ReleaseBundle"
    },
    "bundleState": {
      "enum": [
        "DRAFT",
        "ASSEMBLED",
        "SIGNED",
        "RELEASE_CANDIDATE",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "conformanceRunRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "deploymentCandidateRef": {
      "minLength": 1,
      "type": "string"
    },
    "releaseArtifactDigestRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "releaseDigest": {
      "minLength": 1,
      "type": "string"
    },
    "sbomRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "signatureCoverageClasses": {
      "items": {
        "enum": [
          "RELEASE_DIGEST",
          "ARTIFACT_REFS",
          "SBOM",
          "DEPLOYMENT_CANDIDATE",
          "RUNTIME_SURFACE",
          "AUTHORIZATION"
        ],
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "signatureRef": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "bundleState",
    "artifactRefs",
    "deploymentCandidateRef",
    "releaseDigest",
    "signatureRef",
    "sbomRef",
    "conformanceRunRefs"
  ],
  "title": "OFARM ReleaseBundle schema v0.1 draft/non-default remediated",
  "type": "object"
}