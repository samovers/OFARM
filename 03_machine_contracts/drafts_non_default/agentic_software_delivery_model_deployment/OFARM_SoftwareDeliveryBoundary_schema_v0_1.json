{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/software-delivery-boundary/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Declares the CP15 software-delivery boundary and non-bypass posture.",
  "properties": {
    "applicableGateRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "SoftwareDeliveryBoundary"
    },
    "boundaryState": {
      "enum": [
        "DRAFT",
        "ACTIVE_CANDIDATE",
        "ACCEPTED_NON_DEFAULT",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateDeploymentAuthority": {
      "const": true
    },
    "doesNotCreateRuntimeAuthority": {
      "const": true
    },
    "doesNotPromoteCurrentDefault": {
      "const": true
    },
    "explicitDeferrals": {
      "items": {
        "enum": [
          "FULL_CI_CD_IMPLEMENTATION",
          "CLOUD_VENDOR_TOPOLOGY",
          "GENERIC_MLOPS_PLATFORM",
          "OFARM_SOCIAL_CONSTITUTION",
          "OFARM_EXCHANGE_CONSTITUTION",
          "LEGAL_SECURITY_CERTIFICATION_ADVICE",
          "AUTOMATIC_CURRENT_DEFAULT_PROMOTION"
        ],
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "nonBypassClauses": {
      "items": {
        "enum": [
          "NO_DEPLOYMENT_AUTHORITY_BY_BUILD",
          "NO_RUNTIME_AUTHORITY_BY_TOOL_SUCCESS",
          "NO_CURRENT_DEFAULT_PROMOTION_BY_SCHEMA",
          "NO_MISSION_AUTHORITY_BY_ADAPTER",
          "NO_COMPLIANCE_FACT_BY_TELEMETRY",
          "NO_PRODUCTION_READINESS_BY_CANARY",
          "NO_MODEL_DEPLOYMENT_BY_MODEL_IMPROVEMENT_SIGNAL"
        ],
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "scopeRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "boundaryState",
    "scopeRefs",
    "nonBypassClauses",
    "explicitDeferrals",
    "applicableGateRefs",
    "doesNotCreateDeploymentAuthority",
    "doesNotCreateRuntimeAuthority",
    "doesNotPromoteCurrentDefault"
  ],
  "title": "OFARM SoftwareDeliveryBoundary schema v0.1 draft/non-default remediated",
  "type": "object"
}