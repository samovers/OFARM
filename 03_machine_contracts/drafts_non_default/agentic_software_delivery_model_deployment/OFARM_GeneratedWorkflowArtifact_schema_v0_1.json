{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/generated-workflow-artifact/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "workflowStatus": {
            "const": "APPROVED_CANDIDATE"
          }
        },
        "required": [
          "workflowStatus"
        ]
      },
      "then": {
        "properties": {
          "conformanceRunRefs": {
            "minItems": 1
          },
          "securityScanResultRefs": {
            "minItems": 1
          }
        },
        "required": [
          "reviewDecisionRef",
          "authorityDecisionTraceRef",
          "conformanceRunRefs",
          "securityScanResultRefs"
        ]
      }
    }
  ],
  "description": "Represents generated workflow logic without authorising execution or deployment.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "GeneratedWorkflowArtifact"
    },
    "authorityDecisionTraceRef": {
      "minLength": 1,
      "type": "string"
    },
    "conformanceRunRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateDeploymentAuthority": {
      "const": true
    },
    "doesNotCreateRuntimeAuthority": {
      "const": true
    },
    "doesNotPromoteCurrentDefault": {
      "const": true
    },
    "policyGateRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "reviewDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "securityScanResultRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "stepRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "triggerRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "workflowKind": {
      "enum": [
        "AGENT_WORKFLOW",
        "APPROVAL_WORKFLOW",
        "CONFORMANCE_WORKFLOW",
        "DEPLOYMENT_WORKFLOW",
        "ROLLBACK_WORKFLOW"
      ],
      "type": "string"
    },
    "workflowStatus": {
      "enum": [
        "DRAFT",
        "GENERATED",
        "UNDER_REVIEW",
        "APPROVED_CANDIDATE",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "workflowKind",
    "stepRefs",
    "triggerRefs",
    "policyGateRefs",
    "workflowStatus",
    "doesNotCreateDeploymentAuthority",
    "doesNotCreateRuntimeAuthority",
    "doesNotPromoteCurrentDefault"
  ],
  "title": "OFARM GeneratedWorkflowArtifact schema v0.1 draft/non-default remediated",
  "type": "object"
}