{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/model-evaluation-evidence/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Records model-evaluation evidence for candidate deployment.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "ModelEvaluationEvidence"
    },
    "biasRiskClass": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "evaluationDatasetRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "evaluationDisposition": {
      "enum": [
        "SUFFICIENT_FOR_CANDIDATE",
        "REQUIRE_REVIEW",
        "INSUFFICIENT",
        "BLOCK"
      ],
      "type": "string"
    },
    "evidenceState": {
      "enum": [
        "DRAFT",
        "COMPLETE",
        "INSUFFICIENT",
        "DISPUTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "limitationRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "metricRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "modelArtifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "reviewDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "evidenceState",
    "modelArtifactRefs",
    "evaluationDatasetRefs",
    "metricRefs",
    "biasRiskClass",
    "evaluationDisposition"
  ],
  "title": "OFARM ModelEvaluationEvidence schema v0.1 draft/non-default remediated",
  "type": "object"
}