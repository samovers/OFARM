{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/dependency-risk-assessment/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Assesses dependency, vulnerability, and license risk from SBOM evidence.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "DependencyRiskAssessment"
    },
    "assessmentState": {
      "enum": [
        "DRAFT",
        "COMPLETE",
        "REQUIRES_REVIEW",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "authorityDecisionTraceRef": {
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "disposition": {
      "enum": [
        "ALLOW",
        "ALLOW_WITH_REVIEW",
        "BLOCK",
        "INSUFFICIENT_BASIS"
      ],
      "type": "string"
    },
    "licenseRiskRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "reviewDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "riskClass": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "sbomRef": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "securityFindingWaiverRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "vulnerabilityScanRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "assessmentState",
    "sbomRef",
    "riskClass",
    "vulnerabilityScanRefs",
    "licenseRiskRefs",
    "disposition"
  ],
  "title": "OFARM DependencyRiskAssessment schema v0.1 draft/non-default remediated",
  "type": "object"
}