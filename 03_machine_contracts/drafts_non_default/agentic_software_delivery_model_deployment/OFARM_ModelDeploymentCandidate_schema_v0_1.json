{
  "$id": "https://ofarm.dev/schema/drafts/non-default/agentic-software-delivery-model-deployment/model-deployment-candidate/v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Represents a model deployment candidate without deployment authority.",
  "properties": {
    "artifactId": {
      "minLength": 1,
      "type": "string"
    },
    "artifactType": {
      "const": "ModelDeploymentCandidate"
    },
    "cp13LearningOutputQualificationRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "cp13LearningOutputRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "cp14ModelImprovementSignalRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "cp14TrainingUseReceiptQualificationRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "doesNotCreateModelDeploymentAuthority": {
      "const": true
    },
    "externalLearningEvidenceBasisRef": {
      "type": "string"
    },
    "modelArtifactRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "modelCandidateState": {
      "enum": [
        "DRAFT",
        "UNDER_REVIEW",
        "APPROVED_CANDIDATE",
        "BLOCKED",
        "REJECTED",
        "SUPERSEDED"
      ],
      "type": "string"
    },
    "modelEvaluationEvidenceRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "modelReviewDecisionRef": {
      "minLength": 1,
      "type": "string"
    },
    "poisoningOrAnomalyReviewRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "schemaVersion": {
      "const": "cp15-v0.1-draft-phase7-2-cross-record-release-chain-artifact-evidence-hardening"
    },
    "trainingUsePolicyComplianceRef": {
      "minLength": 1,
      "type": "string"
    },
    "trainingUseReceiptRefs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "artifactType",
    "artifactId",
    "createdAt",
    "modelCandidateState",
    "modelArtifactRefs",
    "modelEvaluationEvidenceRefs",
    "trainingUseReceiptRefs",
    "cp13LearningOutputRefs",
    "cp14ModelImprovementSignalRefs",
    "doesNotCreateModelDeploymentAuthority"
  ],
  "title": "OFARM ModelDeploymentCandidate schema v0.1 draft/non-default remediated",
  "type": "object"
}