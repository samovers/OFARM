{
  "schemaVersion": "ofarm.agentAuthorityActionClassPostureMap.v0.1",
  "status": "MACHINE_CONTRACT",
  "promotionPhase": "AAI-CP3",
  "purpose": "Declares the default software-agent posture for authority action classes after sponsor-bound actorship promotion.",
  "coreRule": "Agent identity, model identity, tool identity, session identity, prompt approval, API key possession, or public-operation success does not confer authority. Every software-agent action must resolve sponsor-bound authority, scope, revocation posture, and the action-class posture before execution or output qualification.",
  "defaultPosture": "deny_or_require_review",
  "postures": [
    {
      "authorityActionClass": "public_read_preflight_or_explain",
      "agentPosture": "allowed_with_preflight_and_qualification",
      "requirements": [
        "sponsor_ref",
        "executing_agent_instance",
        "actorship_binding",
        "authority_snapshot_ref",
        "revocation_check",
        "result_qualification_ref"
      ]
    },
    {
      "authorityActionClass": "state_affecting_write_or_promotion",
      "agentPosture": "human_approval_required",
      "requirements": [
        "sponsor_ref",
        "executing_agent_instance",
        "authority_snapshot_ref",
        "revocation_check",
        "explicit_human_approval_ref",
        "authorization_decision_trace"
      ]
    },
    {
      "authorityActionClass": "pack_activation_or_policy_change",
      "agentPosture": "human_only",
      "requirements": [
        "explicit_accountable_party_action",
        "authority_grant",
        "authorization_decision_trace"
      ]
    },
    {
      "authorityActionClass": "attestation_certification_or_filing",
      "agentPosture": "human_only",
      "requirements": [
        "accountable_party_signature_or_equivalent_authorized_action",
        "evidence_basis",
        "authorization_decision_trace"
      ]
    },
    {
      "authorityActionClass": "sharing_or_disclosure",
      "agentPosture": "approval_required_and_revocation_rechecked",
      "requirements": [
        "sponsor_ref",
        "share_policy_ref",
        "permission_snapshot_ref",
        "revocation_check",
        "redaction_profile_ref",
        "authorization_decision_trace"
      ]
    }
  ],
  "explicitNonPromotions": [
    "AgentRunEnvelope",
    "AgentRunTrace",
    "AgentHandoffEnvelope",
    "AgentToolManifest",
    "WorldModelRun",
    "WorldModelState",
    "EvidenceNeed",
    "ObservationRequest"
  ]
}
