{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/localartifact/v0.1",
  "title": "OFARM LocalArtifact v0.1",
  "$comment": "Minimal machine contract derived from the harmonized Alignment Register v0.13 and the Local Knowledge and Planning Closure RFC v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "localArtifactId",
    "artifactKind",
    "holderPartyRef",
    "createdAt",
    "targetScope",
    "storagePosture",
    "title"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.localartifact.v0.1"
    },
    "localArtifactId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "artifactKind": {
      "enum": [
        "NOTEBOOK_PAGE",
        "PHOTO",
        "SKETCH_MAP",
        "WHITEBOARD_CAPTURE",
        "HAND_MARKED_PLAN",
        "AUDIO_NOTE",
        "OTHER"
      ]
    },
    "holderPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "createdByAgentRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "storagePosture": {
      "enum": [
        "LOCAL_ONLY",
        "LOCAL_WITH_HASH_ONLY",
        "LOCAL_WITH_REDACTED_EXTRACT",
        "SHARED_COPY"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "checksum": {
      "type": "string"
    },
    "provenanceNote": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
