{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/roleassignment/v0.1",
  "title": "OFARM RoleAssignment v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a77.6-7.8 plus Authority Source Record Closure RFC v0.1 \u00a74.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "roleAssignmentId",
    "partyRef",
    "roleType",
    "anchorScopes",
    "validFrom"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.roleassignment.v0.1"
    },
    "roleAssignmentId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "partyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "roleType": {
      "type": "string",
      "minLength": 1
    },
    "anchorScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
