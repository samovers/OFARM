{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/lotlineagechange/v0.1",
  "title": "OFARM LotLineageChange v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a77.22, Identity and Lifecycle RFC v0.1 \u00a76, and the Lot Traceability and Claim Basis RFC v0.1. It records the governed continuity decision at a lot red-flag boundary without reopening the identity model.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "lineageChangeId",
    "evaluatedAt",
    "changeType",
    "continuityOutcome",
    "materialContinuityClass"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.lotlineagechange.v0.1"
    },
    "lineageChangeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "changeType": {
      "enum": [
        "CREATE",
        "SPLIT",
        "MERGE",
        "COMMINGLE",
        "TRANSFORM",
        "CLAIM_BASIS_RESET",
        "SHIPMENT_REFERENCE_ATTACH",
        "METADATA_CORRECTION"
      ]
    },
    "continuityOutcome": {
      "enum": [
        "SAME_LOT_CONTINUES",
        "NEW_LOT_REQUIRED",
        "LOT_REVISION_ONLY"
      ]
    },
    "materialContinuityClass": {
      "enum": [
        "ONE_TO_ONE",
        "ONE_TO_MANY",
        "MANY_TO_ONE",
        "MANY_TO_MANY",
        "REFERENCE_ONLY"
      ]
    },
    "subjectLotRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "predecessorLotRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "successorLotRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "lineageEdges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceLotRef",
          "targetLotRef",
          "relationOnTarget"
        ],
        "properties": {
          "sourceLotRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "targetLotRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "relationOnTarget": {
            "enum": [
              "splitFrom",
              "mergedFrom",
              "derivedFrom",
              "succeeds",
              "revises"
            ]
          }
        }
      }
    },
    "preChangeClaimBasisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "postChangeClaimBasisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "eventRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "decisionRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "shipmentReferenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "rationale": {
      "type": "string"
    }
  }
}
