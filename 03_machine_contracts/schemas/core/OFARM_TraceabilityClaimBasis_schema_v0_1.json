{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/traceabilityclaimbasis/v0.1",
  "title": "OFARM TraceabilityClaimBasis v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a77.22, Identity and Lifecycle RFC v0.1 \u00a76, and the Lot Traceability and Claim Basis RFC v0.1. It declares the traceability/claim model relevant to lot continuity when stronger and weaker chain-of-custody semantics must remain query-visible.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "claimBasisId",
    "basisLabel",
    "traceabilityModel",
    "physicalContinuityClass",
    "lotIdentityPreservationPolicy",
    "governingArtifactRefs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.traceabilityclaimbasis.v0.1"
    },
    "claimBasisId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "basisLabel": {
      "type": "string"
    },
    "traceabilityModel": {
      "enum": [
        "IDENTITY_PRESERVED",
        "SEGREGATED",
        "MASS_BALANCE",
        "BOOK_AND_CLAIM",
        "DECLARED_OTHER"
      ]
    },
    "physicalContinuityClass": {
      "enum": [
        "ONE_TO_ONE_PHYSICAL",
        "SEGREGATED_MULTI_SOURCE",
        "COMMINGLED_ACCOUNTED",
        "NO_PHYSICAL_CONTINUITY_ASSERTED"
      ]
    },
    "lotIdentityPreservationPolicy": {
      "enum": [
        "SAME_LOT_ONLY_IF_ONE_TO_ONE",
        "SAME_LOT_ALLOWED_IF_SEGREGATED",
        "NEW_LOT_REQUIRED_ON_COMMINGLE",
        "NEVER_USE_FOR_SAME_LOT_CONTINUITY",
        "PROFILE_DEFINED"
      ]
    },
    "governingArtifactRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "applicableClaimRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "evidencePolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
