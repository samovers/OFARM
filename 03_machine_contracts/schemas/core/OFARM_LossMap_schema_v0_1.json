{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ofarm.lossmap.v0.1",
  "title": "OFARM LossMap v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "lossMapId",
    "mappingCoverageStatementRef",
    "overallLossPosture",
    "lossItems"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.lossmap.v0.1"
    },
    "lossMapId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "mappingCoverageStatementRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "overallLossPosture": {
      "enum": [
        "MINIMAL",
        "MANAGED",
        "MATERIAL",
        "HIGH_RISK"
      ]
    },
    "lossItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "externalConstructRef",
          "lossClass",
          "impactLevel",
          "downstreamRisk",
          "requiresGovernanceOnHighConsequenceUse"
        ],
        "properties": {
          "externalConstructRef": {
            "type": "string"
          },
          "ofarmTargetRef": {
            "type": "string"
          },
          "lossClass": {
            "enum": [
              "DROPPED",
              "APPROXIMATED",
              "COLLAPSED",
              "ASSUMED",
              "UNREPRESENTABLE",
              "SPLIT"
            ]
          },
          "impactLevel": {
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "downstreamRisk": {
            "type": "string"
          },
          "requiresGovernanceOnHighConsequenceUse": {
            "type": "boolean"
          },
          "mitigation": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Loss disclosure contract for import/export mappings."
}
