{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ofarm.mappingcoveragestatement.v0.1",
  "title": "OFARM MappingCoverageStatement v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "statementId",
    "mappingModuleRef",
    "direction",
    "externalStandardRef",
    "coveredConstructs",
    "promotionPosture",
    "roundTripExpectation",
    "lossMapRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.mappingcoveragestatement.v0.1"
    },
    "statementId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "mappingModuleRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "direction": {
      "enum": [
        "IMPORT",
        "EXPORT",
        "BIDIRECTIONAL"
      ]
    },
    "externalStandardRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "runtimeSurfaceContractRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "coveredConstructs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "externalConstructRef",
          "ofarmTargetRef"
        ],
        "properties": {
          "externalConstructRef": {
            "type": "string"
          },
          "ofarmTargetRef": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "droppedConstructs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "externalConstructRef",
          "reasonCode"
        ],
        "properties": {
          "externalConstructRef": {
            "type": "string"
          },
          "reasonCode": {
            "enum": [
              "OUT_OF_SCOPE",
              "SOURCE_OPTIONAL_NOT_IMPLEMENTED",
              "NO_OFARM_TARGET",
              "VENDOR_VARIANT_UNSUPPORTED",
              "REQUIRES_GOVERNANCE"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "approximatedConstructs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "externalConstructRef",
          "ofarmTargetRef",
          "approximationClass"
        ],
        "properties": {
          "externalConstructRef": {
            "type": "string"
          },
          "ofarmTargetRef": {
            "type": "string"
          },
          "approximationClass": {
            "enum": [
              "NARROWING",
              "WIDENING",
              "COLLAPSE",
              "SPLIT",
              "DEFAULT_INFERENCE"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "requiredOfarmConceptsWithoutSource": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "promotionPosture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultCommitClasses",
        "autoPromotionAllowed"
      ],
      "properties": {
        "defaultCommitClasses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "note",
              "observation assertion",
              "hypothesis assertion",
              "structure assertion",
              "operation claim",
              "evidence record",
              "compliance assertion",
              "governance decision",
              "advisory output"
            ]
          }
        },
        "autoPromotionAllowed": {
          "type": "boolean"
        },
        "requiresReviewForAcceptedConsequences": {
          "type": "boolean"
        }
      }
    },
    "roundTripExpectation": {
      "enum": [
        "NOT_APPLICABLE",
        "BEST_EFFORT",
        "LOSS_AWARE",
        "REQUIRED_FOR_DECLARED_SUBSET"
      ]
    },
    "lossMapRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Mapping coverage contract for interoperability surfaces."
}
