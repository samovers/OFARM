{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/localmemoryrule/v0.1",
  "title": "OFARM LocalMemoryRule v0.1",
  "$comment": "Minimal machine contract derived from the harmonized Alignment Register v0.13 and the Local Knowledge and Planning Closure RFC v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "localMemoryRuleId",
    "authoredAt",
    "authorPartyRef",
    "targetScope",
    "ruleStatement",
    "ruleState",
    "validFrom"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.localmemoryrule.v0.1"
    },
    "localMemoryRuleId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "authoredAt": {
      "type": "string",
      "format": "date-time"
    },
    "authorPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "ruleStatement": {
      "type": "string",
      "minLength": 1
    },
    "appliesWhen": {
      "type": "string"
    },
    "recommendedAction": {
      "type": "string"
    },
    "supportingNarrativeObservationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "localArtifactRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "ruleState": {
      "enum": [
        "ACTIVE",
        "RETIRED",
        "DRAFT"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
