{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/temporalfieldconformancematrix/v0.1",
  "title": "OFARM TemporalFieldConformanceMatrix v0.1",
  "$comment": "Companion contract describing required temporal semantics by carrier class. It prevents timestamp collapse but does not replace baseline temporal law.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "temporalFieldConformanceMatrixId",
    "issuedAt",
    "status",
    "rules"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.temporalfieldconformancematrix.v0.1"
    },
    "temporalFieldConformanceMatrixId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "ACTIVE_COMPANION",
        "DRAFT_COMPANION",
        "SUPERSEDED"
      ]
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "recordClass",
          "requiredTemporalFields",
          "forbiddenSubstitutions",
          "delayedSyncRule"
        ],
        "properties": {
          "recordClass": {
            "type": "string"
          },
          "requiredTemporalFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "optionalTemporalFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbiddenSubstitutions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "delayedSyncRule": {
            "type": "string"
          },
          "highConsequenceUseRule": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
