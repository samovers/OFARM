{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ofarm.semanticsubstratebundle.v0.1",
  "title": "OFARM SemanticSubstrateBundle v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleId",
    "status",
    "ofarmVersion",
    "publishedAt",
    "alignmentRegisterVersionRef",
    "semanticAnchors",
    "validationBackbones"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.semanticsubstratebundle.v0.1"
    },
    "bundleId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "supersedesBundleId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ofarmVersion": {
      "type": "string"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "alignmentRegisterVersionRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "semanticAnchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "anchorRef",
          "role",
          "versionPin"
        ],
        "properties": {
          "anchorRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "role": {
            "enum": [
              "SPACE_GEOMETRY",
              "TEMPORAL_SEMANTICS",
              "QUANTITY_UNIT_SEMANTICS",
              "OBSERVATION_SEMANTICS",
              "PROVENANCE_SEMANTICS",
              "AGRICULTURAL_ALIGNMENT",
              "VOCABULARY_BRIDGE",
              "CODE_BINDING"
            ]
          },
          "versionPin": {
            "type": "string"
          },
          "profileRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "mandatory": {
            "type": "boolean"
          }
        }
      }
    },
    "validationBackbones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "standardRef",
          "usage",
          "versionPin"
        ],
        "properties": {
          "standardRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "usage": {
            "enum": [
              "SEMANTIC_PROFILE_VALIDATION",
              "RDF_GRAPH_SHAPE_VALIDATION"
            ]
          },
          "versionPin": {
            "type": "string"
          }
        }
      }
    },
    "exchangeBindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "standardRef",
          "usage",
          "versionPin"
        ],
        "properties": {
          "standardRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "usage": {
            "enum": [
              "UNIT_CODE_SERIALIZATION",
              "PAYLOAD_CODE_BINDING",
              "IDENTIFIER_BINDING"
            ]
          },
          "versionPin": {
            "type": "string"
          },
          "requiredSurfaceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Machine contract for version-pinned substrate dependencies used by semantic profiles and conformance claims."
}
