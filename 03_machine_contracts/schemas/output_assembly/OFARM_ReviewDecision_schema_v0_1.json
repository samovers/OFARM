{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/reviewdecision/v0.1",
  "title": "OFARM ReviewDecision v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a710.1-10.2 plus Source Truth Record Closure RFC v0.1 \u00a74.2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reviewDecisionId",
    "reviewedArtifactFamily",
    "reviewedArtifactRef",
    "reviewAction",
    "anchorScopes",
    "decidedByPartyRef",
    "decidedAt",
    "decisionOutcomeState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.reviewdecision.v0.1"
    },
    "reviewDecisionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "reviewedArtifactFamily": {
      "enum": [
        "ASSERTION_RECORD",
        "ACCEPTED_EVENT_CONSEQUENCE",
        "DOCUMENT_ASSEMBLY",
        "DOSSIER_ASSEMBLY",
        "SUBMISSION_ASSEMBLY",
        "EVIDENCE_SUFFICIENCY_CASE"
      ]
    },
    "reviewedArtifactRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "reviewAction": {
      "enum": [
        "REVIEW_ACCEPT",
        "REVIEW_REJECT_OR_CONTEST",
        "REVIEW_SUPERSEDE",
        "REVIEW_REQUEST"
      ]
    },
    "anchorScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "decidedByPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "decidedAt": {
      "type": "string",
      "format": "date-time"
    },
    "decisionOutcomeState": {
      "enum": [
        "ACCEPTED",
        "REJECTED",
        "CONTESTED",
        "SUPERSEDED",
        "REVIEW_REQUESTED"
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "resultingAcceptedConsequenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "supersedesReviewDecisionRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "notes": {
      "type": "string"
    }
  }
}
