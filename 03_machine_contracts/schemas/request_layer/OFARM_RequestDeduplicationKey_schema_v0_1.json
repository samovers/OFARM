{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestdeduplicationkey-v0-1",
  "title": "OFARM RequestDeduplicationKey v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestDeduplicationKeyId",
    "targetScopeHash",
    "gapType",
    "reasonHash",
    "timeBucket",
    "sourceRefs",
    "dedupeKey"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestdeduplicationkey.v0.1"
    },
    "requestDeduplicationKeyId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "targetScopeHash": {
      "type": "string",
      "minLength": 1
    },
    "gapType": {
      "type": "string",
      "minLength": 1
    },
    "reasonHash": {
      "type": "string",
      "minLength": 1
    },
    "timeBucket": {
      "type": "string",
      "minLength": 1
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "dedupeKey": {
      "type": "string",
      "minLength": 1
    }
  },
  "description": "Stable key to collapse duplicate requests."
}
