{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/observationrequest-v0-1",
  "title": "OFARM ObservationRequest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "observationRequestId",
    "createdAt",
    "evidenceNeedRef",
    "requestedObservationType",
    "captureInstructions",
    "acceptableModalities",
    "minimumSufficientPayload",
    "targetScopeRef",
    "dueWindow",
    "burdenEstimateRef",
    "privacyNote",
    "safetyNote",
    "batchGroupId",
    "alternativeSubmissionPaths",
    "completionCriteriaRef",
    "requestStatus",
    "resultRef",
    "disputeRouteRef",
    "requestDisplayEnvelopeRef",
    "noiseControlEnvelopeRef",
    "notEvidence",
    "notObligation",
    "notBlockerByItself",
    "resultQualificationRef",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.observationrequest.v0.1"
    },
    "observationRequestId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "evidenceNeedRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestedObservationType": {
      "type": "string",
      "minLength": 1
    },
    "captureInstructions": {
      "type": "string",
      "minLength": 1
    },
    "acceptableModalities": {
      "type": "array",
      "items": {
        "enum": [
          "PHOTO",
          "NOTE",
          "VOICE_NOTE",
          "SENSOR_READING",
          "CONTRACTOR_UPLOAD",
          "DOCUMENT",
          "HUMAN_REVIEW",
          "OTHER"
        ]
      },
      "minItems": 1
    },
    "minimumSufficientPayload": {
      "type": "object"
    },
    "targetScopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "dueWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startsAt",
        "endsAt"
      ],
      "properties": {
        "startsAt": {
          "type": "string",
          "format": "date-time"
        },
        "endsAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "burdenEstimateRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "privacyNote": {
      "type": "string"
    },
    "safetyNote": {
      "type": "string"
    },
    "batchGroupId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "alternativeSubmissionPaths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "completionCriteriaRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestStatus": {
      "enum": [
        "CREATED",
        "DISPLAYED",
        "DEFERRED",
        "IN_PROGRESS",
        "SUBMITTED_PENDING_REVIEW",
        "SATISFIED",
        "DECLINED",
        "EXPIRED",
        "CANCELLED",
        "SUPERSEDED"
      ]
    },
    "resultRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "disputeRouteRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestDisplayEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "noiseControlEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "notEvidence": {
      "const": true
    },
    "notObligation": {
      "const": true
    },
    "notBlockerByItself": {
      "const": true
    },
    "resultQualificationRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "runtimeConformanceClaimed": {
      "const": false
    }
  },
  "description": "Bounded request to capture or provide observation. It is not evidence, obligation, or blocker by itself."
}
