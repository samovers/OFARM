{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestrelevancewindow-v0-1",
  "title": "OFARM RequestRelevanceWindow v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestRelevanceWindowId",
    "startsAt",
    "endsAt",
    "staleAfter",
    "relevanceBasis",
    "afterWindowDisposition"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestrelevancewindow.v0.1"
    },
    "requestRelevanceWindowId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "startsAt": {
      "type": "string",
      "format": "date-time"
    },
    "endsAt": {
      "type": "string",
      "format": "date-time"
    },
    "staleAfter": {
      "type": "string",
      "format": "date-time"
    },
    "relevanceBasis": {
      "type": "string",
      "minLength": 1
    },
    "afterWindowDisposition": {
      "enum": [
        "HIDE",
        "DEPRIORITIZE",
        "REVIEW",
        "EXPIRE",
        "QUALIFY_ONLY"
      ]
    }
  },
  "description": "Time window where a request remains relevant."
}
