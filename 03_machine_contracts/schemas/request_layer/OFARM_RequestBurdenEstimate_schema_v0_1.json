{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestburdenestimate-v0-1",
  "title": "OFARM RequestBurdenEstimate v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestBurdenEstimateId",
    "userTimeEstimateMinutes",
    "requiredEquipment",
    "connectivityRequirement",
    "cognitiveBurden",
    "safetyRisk",
    "privacySensitivity",
    "farmerBurdenScore",
    "burdenJustification"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestburdenestimate.v0.1"
    },
    "requestBurdenEstimateId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "userTimeEstimateMinutes": {
      "type": "number",
      "minimum": 0
    },
    "requiredEquipment": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "connectivityRequirement": {
      "enum": [
        "NONE",
        "LOW_BANDWIDTH",
        "BROADBAND",
        "OFFLINE_ALLOWED"
      ]
    },
    "cognitiveBurden": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "safetyRisk": {
      "enum": [
        "NONE",
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "privacySensitivity": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "farmerBurdenScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "burdenJustification": {
      "type": "string",
      "minLength": 1
    }
  },
  "description": "Estimated farmer burden for a request."
}
