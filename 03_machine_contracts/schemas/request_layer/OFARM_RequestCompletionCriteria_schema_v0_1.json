{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestcompletioncriteria-v0-1",
  "title": "OFARM RequestCompletionCriteria v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestCompletionCriteriaId",
    "criteriaType",
    "minimumPayload",
    "requiredQualityChecks",
    "acceptedAlternativeRefs",
    "completionDoesNotPromoteEvidence"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestcompletioncriteria.v0.1"
    },
    "requestCompletionCriteriaId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "criteriaType": {
      "enum": [
        "EVIDENCE_CAPTURED",
        "HUMAN_REVIEWED",
        "EXTERNAL_VERIFICATION",
        "DECLINED_WITH_REASON",
        "OTHER"
      ]
    },
    "minimumPayload": {
      "type": "object"
    },
    "requiredQualityChecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptedAlternativeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "completionDoesNotPromoteEvidence": {
      "const": true
    }
  },
  "description": "Completion criteria. Completion does not promote evidence by itself."
}
