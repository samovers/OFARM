{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/evidenceneed-v0-1",
  "title": "OFARM EvidenceNeed v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evidenceNeedId",
    "createdAt",
    "createdByRef",
    "createdByKind",
    "relatedScopeRefs",
    "gapType",
    "whyNeeded",
    "consequenceIfMissing",
    "blockingBasisRef",
    "blockingStatus",
    "priorityClassificationRef",
    "burdenEstimateRef",
    "relevanceWindowRef",
    "freshnessRequirement",
    "requestedFromRole",
    "completionCriteriaRef",
    "evidenceOptionRefs",
    "dedupeKeyRef",
    "requestDisplayEnvelopeRef",
    "lifecycleStateRef",
    "status",
    "expiresAt",
    "notEvidence",
    "notObligation",
    "notBlockerByItself",
    "resultQualificationRef",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.evidenceneed.v0.1"
    },
    "evidenceNeedId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "createdByKind": {
      "enum": [
        "HUMAN",
        "AGENT_RUN",
        "WORLD_MODEL_RUN",
        "PREFLIGHT",
        "GOVERNANCE_GATE",
        "OTHER"
      ]
    },
    "relatedScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "gapType": {
      "enum": [
        "MISSING_OBSERVATION",
        "STALE_BASIS",
        "PERMISSION_LIMIT",
        "EVIDENCE_QUALITY",
        "DISPUTE",
        "APPROVAL_MISSING",
        "TRACE_MISSING",
        "OTHER"
      ]
    },
    "whyNeeded": {
      "type": "string",
      "minLength": 1
    },
    "consequenceIfMissing": {
      "type": "string",
      "minLength": 1
    },
    "blockingBasisRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "blockingStatus": {
      "enum": [
        "NON_BLOCKING",
        "BLOCKING_BY_EXTERNAL_RULE",
        "ADVISORY_ONLY"
      ]
    },
    "priorityClassificationRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "burdenEstimateRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "relevanceWindowRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "freshnessRequirement": {
      "type": "string",
      "minLength": 1
    },
    "requestedFromRole": {
      "type": "string",
      "minLength": 1
    },
    "completionCriteriaRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "evidenceOptionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "dedupeKeyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestDisplayEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "lifecycleStateRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "OPEN",
        "DISPLAYED",
        "DEFERRED",
        "SATISFIED_PENDING_REVIEW",
        "SATISFIED",
        "DECLINED",
        "EXPIRED",
        "CANCELLED",
        "SUPERSEDED"
      ]
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "notEvidence": {
      "const": true
    },
    "notObligation": {
      "const": true
    },
    "notBlockerByItself": {
      "const": true
    },
    "resultQualificationRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "runtimeConformanceClaimed": {
      "const": false
    }
  },
  "description": "Missing-information need. It is not evidence, obligation, or blocker by itself."
}
