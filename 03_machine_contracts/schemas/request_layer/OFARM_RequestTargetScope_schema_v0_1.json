{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requesttargetscope-v0-1",
  "title": "OFARM RequestTargetScope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestTargetScopeId",
    "scopeKind",
    "targetRefs",
    "permissionBasisRef",
    "sharingConstraintRefs",
    "displayName"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requesttargetscope.v0.1"
    },
    "requestTargetScopeId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "scopeKind": {
      "enum": [
        "FARM",
        "FIELD",
        "LOT",
        "TASK",
        "PERSON",
        "ROLE",
        "ASSET",
        "EVENT",
        "OTHER"
      ]
    },
    "targetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "permissionBasisRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sharingConstraintRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    }
  },
  "description": "Scope and permissions for a request target."
}
