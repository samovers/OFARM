{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestsatisfactiontrace-v0-1",
  "title": "OFARM RequestSatisfactionTrace v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestSatisfactionTraceId",
    "requestRef",
    "evidenceNeedRef",
    "observationRequestRefs",
    "submittedPayloadRefs",
    "qualityCheckRefs",
    "actorRef",
    "satisfiedAt",
    "satisfactionOutcome",
    "reviewRequired",
    "acceptedEvidenceRefs",
    "promotionDecisionRef",
    "doesNotCreateEvidence"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestsatisfactiontrace.v0.1"
    },
    "requestSatisfactionTraceId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "evidenceNeedRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "observationRequestRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "submittedPayloadRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "qualityCheckRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "actorRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "satisfiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "satisfactionOutcome": {
      "enum": [
        "SATISFIED_PENDING_REVIEW",
        "SATISFIED",
        "DECLINED",
        "INSUFFICIENT",
        "DISPUTED"
      ]
    },
    "reviewRequired": {
      "type": "boolean"
    },
    "acceptedEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "promotionDecisionRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "doesNotCreateEvidence": {
      "const": true
    }
  },
  "description": "Trace of request satisfaction. The trace does not create evidence by itself."
}
