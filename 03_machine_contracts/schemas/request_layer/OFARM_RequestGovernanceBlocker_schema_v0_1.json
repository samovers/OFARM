{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestgovernanceblocker-v0-1",
  "title": "OFARM RequestGovernanceBlocker v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestGovernanceBlockerId",
    "requestRef",
    "blockerType",
    "blockerReason",
    "blockingBasisRef",
    "disposition",
    "notEvidence"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestgovernanceblocker.v0.1"
    },
    "requestGovernanceBlockerId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "blockerType": {
      "enum": [
        "MISSING_EXTERNAL_RULE",
        "MISSING_PERMISSION",
        "MISSING_COMPLETION_CRITERIA",
        "EXCESSIVE_BURDEN",
        "DUPLICATE_REQUEST",
        "STALE_REQUEST",
        "DISPUTED_REQUEST",
        "OTHER"
      ]
    },
    "blockerReason": {
      "type": "string",
      "minLength": 1
    },
    "blockingBasisRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "disposition": {
      "enum": [
        "BLOCK_DISPLAY",
        "REQUIRE_REVIEW",
        "DEFER",
        "QUALIFY_RESULT",
        "CANCEL_REQUEST"
      ]
    },
    "notEvidence": {
      "const": true
    }
  },
  "description": "Governance blocker for request display or use; not evidence."
}
