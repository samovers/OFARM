{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestpriorityclassification-v0-1",
  "title": "OFARM RequestPriorityClassification v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestPriorityClassificationId",
    "priority",
    "priorityBasis",
    "interruptiveAllowed",
    "escalationAllowed",
    "timingSensitivity",
    "externalGateRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestpriorityclassification.v0.1"
    },
    "requestPriorityClassificationId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "priority": {
      "enum": [
        "LOW",
        "NORMAL",
        "HIGH",
        "URGENT"
      ]
    },
    "priorityBasis": {
      "type": "string",
      "minLength": 1
    },
    "interruptiveAllowed": {
      "type": "boolean"
    },
    "escalationAllowed": {
      "type": "boolean"
    },
    "timingSensitivity": {
      "enum": [
        "NONE",
        "TIME_WINDOWED",
        "URGENT"
      ]
    },
    "externalGateRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    }
  },
  "description": "Priority and interruption posture."
}
