{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestblockingbasis-v0-1",
  "title": "OFARM RequestBlockingBasis v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestBlockingBasisId",
    "basisType",
    "externalRuleRef",
    "gateRef",
    "explanation",
    "blockApplies",
    "requestAloneIsNotBasis"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestblockingbasis.v0.1"
    },
    "requestBlockingBasisId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "basisType": {
      "enum": [
        "GOVERNANCE_GATE",
        "REGULATORY_RULE",
        "PACK_REQUIREMENT",
        "OUTPUT_POLICY",
        "SHARING_POLICY",
        "HUMAN_DECISION",
        "NONE"
      ]
    },
    "externalRuleRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "gateRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "explanation": {
      "type": "string",
      "minLength": 1
    },
    "blockApplies": {
      "type": "boolean"
    },
    "requestAloneIsNotBasis": {
      "const": true
    }
  },
  "description": "External basis that can make a missing request consequential."
}
