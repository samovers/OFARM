{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestdisplayenvelope-v0-1",
  "title": "OFARM RequestDisplayEnvelope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestDisplayEnvelopeId",
    "displayMode",
    "plainLanguageSummary",
    "whyThisMatters",
    "whatItBlocks",
    "whatItDoesNotBlock",
    "actionLabel",
    "declineOrDeferAllowed",
    "qualificationChips",
    "burdenEstimateRef",
    "relevanceWindowRef",
    "visibilityPolicyRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestdisplayenvelope.v0.1"
    },
    "requestDisplayEnvelopeId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "displayMode": {
      "enum": [
        "DAILY_BRIEF",
        "TASK_CARD",
        "PREFLIGHT_PANEL",
        "INTERRUPTIVE_ALERT",
        "DETAIL_VIEW",
        "HIDDEN"
      ]
    },
    "plainLanguageSummary": {
      "type": "string",
      "minLength": 1
    },
    "whyThisMatters": {
      "type": "string",
      "minLength": 1
    },
    "whatItBlocks": {
      "type": "string",
      "minLength": 1
    },
    "whatItDoesNotBlock": {
      "type": "string",
      "minLength": 1
    },
    "actionLabel": {
      "type": "string",
      "minLength": 1
    },
    "declineOrDeferAllowed": {
      "type": "boolean"
    },
    "qualificationChips": {
      "type": "array",
      "items": {
        "enum": [
          "ADVISORY_ONLY",
          "MISSING_EVIDENCE",
          "STALE_DATA",
          "PERMISSION_LIMITED",
          "APPROVAL_NEEDED",
          "DISPUTED",
          "NOT_BLOCKER",
          "LOW_CONFIDENCE",
          "REVIEW_REQUIRED"
        ]
      },
      "minItems": 1
    },
    "burdenEstimateRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "relevanceWindowRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "visibilityPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    }
  },
  "description": "Farmer-facing display envelope for request context and limitations."
}
