{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/evidenceoption-v0-1",
  "title": "OFARM EvidenceOption v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evidenceOptionId",
    "evidenceNeedRef",
    "optionLabel",
    "acceptedEvidenceKinds",
    "burdenEstimateRef",
    "sufficiencyCaveat",
    "promotionPathRef",
    "notEvidence"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.evidenceoption.v0.1"
    },
    "evidenceOptionId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "evidenceNeedRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "optionLabel": {
      "type": "string",
      "minLength": 1
    },
    "acceptedEvidenceKinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "burdenEstimateRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sufficiencyCaveat": {
      "type": "string"
    },
    "promotionPathRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "notEvidence": {
      "const": true
    }
  },
  "description": "Candidate route to satisfy a need; not evidence by itself."
}
