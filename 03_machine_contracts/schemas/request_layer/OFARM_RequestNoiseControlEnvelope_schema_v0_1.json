{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestnoisecontrolenvelope-v0-1",
  "title": "OFARM RequestNoiseControlEnvelope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestNoiseControlEnvelopeId",
    "dedupeKeyRef",
    "batchGroupId",
    "suppressionReason",
    "displayCadence",
    "interruptiveAllowed",
    "maxPromptsPerWindow",
    "relatedRequestRefs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestnoisecontrolenvelope.v0.1"
    },
    "requestNoiseControlEnvelopeId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "dedupeKeyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "batchGroupId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "suppressionReason": {
      "type": [
        "string",
        "null"
      ]
    },
    "displayCadence": {
      "enum": [
        "IMMEDIATE",
        "DAILY_BRIEF",
        "WEEKLY_SUMMARY",
        "ON_DEMAND",
        "HIDDEN"
      ]
    },
    "interruptiveAllowed": {
      "type": "boolean"
    },
    "maxPromptsPerWindow": {
      "type": "integer",
      "minimum": 0
    },
    "relatedRequestRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    }
  },
  "description": "Deduplication, batching, and interruption control for requests."
}
