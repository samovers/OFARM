{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/requestlifecyclestate-v0-1",
  "title": "OFARM RequestLifecycleState v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestLifecycleStateId",
    "requestRef",
    "status",
    "stateChangedAt",
    "stateReason",
    "terminal",
    "acceptedEvidenceRef",
    "promotionDecisionRef",
    "notEvidence"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.requestlifecyclestate.v0.1"
    },
    "requestLifecycleStateId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "CREATED",
        "DISPLAYED",
        "DEFERRED",
        "IN_PROGRESS",
        "SATISFIED_PENDING_REVIEW",
        "SATISFIED",
        "DECLINED",
        "EXPIRED",
        "CANCELLED",
        "SUPERSEDED"
      ]
    },
    "stateChangedAt": {
      "type": "string",
      "format": "date-time"
    },
    "stateReason": {
      "type": "string"
    },
    "terminal": {
      "type": "boolean"
    },
    "acceptedEvidenceRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "promotionDecisionRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "notEvidence": {
      "const": true
    }
  },
  "description": "Lifecycle state for request artifacts."
}
