{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/referenceresolutionreport/v0.1",
  "title": "OFARM ReferenceResolutionReport v0.1",
  "$comment": "Report generated by package-local semantic reference-resolution checks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportId",
    "manifestRef",
    "generatedAt",
    "runner",
    "scope",
    "overallStatus",
    "summary",
    "findings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.referenceresolutionreport.v0.1"
    },
    "reportId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "manifestRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "runner": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "overallStatus": {
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "REVIEW_REQUIRED",
        "FAIL_CLOSED",
        "FAIL"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filesChecked",
        "refsChecked",
        "resolvedPackageLocalCount",
        "unresolvedPackageLocalCount",
        "externalDeclaredCount",
        "externalVerifiedCount",
        "warningCount",
        "errorCount"
      ],
      "properties": {
        "filesChecked": {
          "type": "integer",
          "minimum": 0
        },
        "refsChecked": {
          "type": "integer",
          "minimum": 0
        },
        "resolvedPackageLocalCount": {
          "type": "integer",
          "minimum": 0
        },
        "unresolvedPackageLocalCount": {
          "type": "integer",
          "minimum": 0
        },
        "externalDeclaredCount": {
          "type": "integer",
          "minimum": 0
        },
        "externalVerifiedCount": {
          "type": "integer",
          "minimum": 0
        },
        "warningCount": {
          "type": "integer",
          "minimum": 0
        },
        "errorCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "findingId",
        "sourceArtifact",
        "refPath",
        "refValue",
        "resolutionStatus",
        "severity",
        "consequenceClass"
      ],
      "properties": {
        "schemaVersion": {
          "const": "ofarm.referenceresolutionfinding.v0.1"
        },
        "findingId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "sourceArtifact": {
          "type": "string",
          "minLength": 1
        },
        "sourceObjectId": {
          "type": "string"
        },
        "sourceObjectClass": {
          "type": "string"
        },
        "refPath": {
          "type": "string",
          "minLength": 1
        },
        "refField": {
          "type": "string"
        },
        "refValue": {
          "type": "string",
          "minLength": 1
        },
        "expectedTargetClass": {
          "type": "string"
        },
        "targetArtifact": {
          "type": "string"
        },
        "targetObjectId": {
          "type": "string"
        },
        "targetObjectClass": {
          "type": "string"
        },
        "resolutionStatus": {
          "enum": [
            "RESOLVED_PACKAGE_LOCAL",
            "RESOLVED_EXTERNAL_DECLARED",
            "RESOLVED_EXTERNAL_VERIFIED",
            "UNRESOLVED_PACKAGE_LOCAL",
            "TYPE_MISMATCH",
            "ID_ALIAS_USED",
            "DEPRECATED_ID_USED",
            "EXTERNAL_UNVERIFIED",
            "STALE_REFERENCE",
            "REQUIRES_REVIEW",
            "FAIL_CLOSED"
          ]
        },
        "severity": {
          "enum": [
            "INFO",
            "WARNING",
            "ERROR",
            "REVIEW_REQUIRED",
            "FAIL_CLOSED"
          ]
        },
        "consequenceClass": {
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "UNKNOWN"
          ]
        },
        "verifiedByRef": {
          "type": "string"
        },
        "aliasOfRef": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
