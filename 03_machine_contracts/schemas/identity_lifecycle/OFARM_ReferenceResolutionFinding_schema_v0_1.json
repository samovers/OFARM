{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/referenceresolutionfinding/v0.1",
  "title": "OFARM ReferenceResolutionFinding v0.1",
  "$comment": "Semantic conformance carrier for package-local and externally anchored reference-resolution outcomes. It does not make external references OFARM law.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "findingId",
    "sourceArtifact",
    "refPath",
    "refValue",
    "resolutionStatus",
    "severity",
    "consequenceClass"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.referenceresolutionfinding.v0.1"
    },
    "findingId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceArtifact": {
      "type": "string",
      "minLength": 1
    },
    "sourceObjectId": {
      "type": "string"
    },
    "sourceObjectClass": {
      "type": "string"
    },
    "refPath": {
      "type": "string",
      "minLength": 1
    },
    "refField": {
      "type": "string"
    },
    "refValue": {
      "type": "string",
      "minLength": 1
    },
    "expectedTargetClass": {
      "type": "string"
    },
    "targetArtifact": {
      "type": "string"
    },
    "targetObjectId": {
      "type": "string"
    },
    "targetObjectClass": {
      "type": "string"
    },
    "resolutionStatus": {
      "enum": [
        "RESOLVED_PACKAGE_LOCAL",
        "RESOLVED_EXTERNAL_DECLARED",
        "RESOLVED_EXTERNAL_VERIFIED",
        "UNRESOLVED_PACKAGE_LOCAL",
        "TYPE_MISMATCH",
        "ID_ALIAS_USED",
        "DEPRECATED_ID_USED",
        "EXTERNAL_UNVERIFIED",
        "STALE_REFERENCE",
        "REQUIRES_REVIEW",
        "FAIL_CLOSED"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "WARNING",
        "ERROR",
        "REVIEW_REQUIRED",
        "FAIL_CLOSED"
      ]
    },
    "consequenceClass": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "UNKNOWN"
      ]
    },
    "verifiedByRef": {
      "type": "string"
    },
    "aliasOfRef": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
