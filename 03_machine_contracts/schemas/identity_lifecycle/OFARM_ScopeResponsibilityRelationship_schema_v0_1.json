{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/scoperesponsibilityrelationship/v0.1",
  "title": "OFARM ScopeResponsibilityRelationship v0.1",
  "$comment": "Durable relationship-basis contract promoted by OFARM Durable Relationship Semantics RFC v0.1. This object declares persistent responsibility/control/stewardship context for a scope and does not by itself grant authority, delegation, sharing, or compliance truth.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "scopeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    }
  },
  "required": [
    "schemaVersion",
    "scopeResponsibilityRelationshipId",
    "relationshipKind",
    "partyRef",
    "targetScope",
    "validFrom",
    "relationshipState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.scoperesponsibilityrelationship.v0.1"
    },
    "scopeResponsibilityRelationshipId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "relationshipKind": {
      "enum": [
        "TENANCY_LEASE",
        "BENEFICIAL_OWNERSHIP",
        "OPERATIONAL_STEWARDSHIP",
        "ADVISOR_OF_RECORD",
        "POOLED_RESPONSIBILITY",
        "EMERGENCY_OPERATOR_DESIGNATION"
      ]
    },
    "partyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetScope": {
      "$ref": "#/$defs/scopeRef"
    },
    "counterpartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "responsibilityClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "relationshipState": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUSPENDED",
        "TERMINATED",
        "EXPIRED"
      ]
    },
    "exclusiveOrSharedPosture": {
      "enum": [
        "EXCLUSIVE",
        "SHARED",
        "INFORMATIONAL_ONLY"
      ]
    },
    "leaseBasisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "ownershipBasisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "economicInterestPosture": {
      "enum": [
        "PRIMARY_BENEFICIAL_OWNER",
        "PARTIAL_BENEFICIAL_OWNER",
        "INFORMATIONAL_ONLY"
      ]
    },
    "stewardshipClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "careDutySummary": {
      "type": "string"
    },
    "advisorDomain": {
      "type": "string",
      "minLength": 1
    },
    "advisorRecordBasisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "retainingPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "poolGroupRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "responsibilitySharePosture": {
      "enum": [
        "LEAD",
        "SHARED",
        "ROTATING",
        "INFORMATIONAL_ONLY"
      ]
    },
    "coordinationPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "temporaryDesignationReason": {
      "type": "string"
    },
    "coversSubmissionAuthorityInformationalOnly": {
      "type": "boolean"
    },
    "externalBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
