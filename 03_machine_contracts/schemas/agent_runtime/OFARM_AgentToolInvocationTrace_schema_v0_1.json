{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agenttoolinvocationtrace-v0-1",
  "title": "OFARM AgentToolInvocationTrace v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "toolInvocationTraceId",
    "runRef",
    "invokedAt",
    "toolOrOperationRef",
    "requestedActionClass",
    "targetTwin",
    "targetScopeRefs",
    "sideEffectClass",
    "authorizationPosture",
    "toolResultState",
    "governanceOutcome",
    "toolSuccessIsNotGovernanceSuccess"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenttoolinvocationtrace.v0.1"
    },
    "toolInvocationTraceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "runRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "invokedAt": {
      "type": "string",
      "format": "date-time"
    },
    "toolOrOperationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestedActionClass": {
      "type": "string",
      "pattern": "^[A-Z0-9_:-]+$"
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "NONE"
      ]
    },
    "targetScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "inputBundleRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "inputSummary": {
      "type": "string"
    },
    "authorizationDecisionTraceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "preflightResultRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "approvalCheckpointRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "sideEffectClass": {
      "enum": [
        "READ_ONLY",
        "LOCAL_DRAFT_ONLY",
        "STATE_AFFECTING",
        "EXTERNAL_CALL",
        "SHARING_OR_DISCLOSURE",
        "PUBLICATION_OR_EXPORT",
        "ATTESTATION_OR_FILING",
        "UNKNOWN"
      ]
    },
    "authorizationPosture": {
      "enum": [
        "AUTHORIZED",
        "AUTHORIZED_WITH_APPROVAL",
        "DENIED",
        "REQUIRE_REVIEW",
        "NOT_EVALUATED"
      ]
    },
    "toolResultState": {
      "enum": [
        "NOT_CALLED",
        "CALL_SUCCEEDED",
        "CALL_FAILED",
        "CALL_BLOCKED",
        "CALL_PARTIALLY_SUCCEEDED"
      ]
    },
    "governanceOutcome": {
      "enum": [
        "PASS",
        "FAIL",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL",
        "BLOCKED_NOT_ATTEMPTED"
      ]
    },
    "outputDispositionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "blockedActionTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "runtimeProblemReasonCodeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "resultQualificationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "toolSuccessIsNotGovernanceSuccess": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Trace for an agent-invoked tool or public operation. Tool success is explicitly separate from governance outcome."
}
