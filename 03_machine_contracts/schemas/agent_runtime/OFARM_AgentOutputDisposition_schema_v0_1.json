{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentoutputdisposition-v0-1",
  "title": "OFARM AgentOutputDisposition v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "outputDispositionId",
    "runRef",
    "dispositionKind",
    "targetTwin",
    "outputPosture",
    "artifactRefs",
    "promotionPath",
    "generatedByAgentProvenanceOnly",
    "acceptedFarmFactCreated"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentoutputdisposition.v0.1"
    },
    "outputDispositionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "runRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "toolInvocationTraceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "dispositionKind": {
      "enum": [
        "DRAFT_ASSERTION",
        "DRAFT_OBSERVATION",
        "EVIDENCE_CANDIDATE",
        "ADVISORY_SUMMARY",
        "REVIEW_REQUEST",
        "PREFLIGHT_RESULT",
        "BLOCKED_ACTION_TRACE",
        "NO_OUTPUT"
      ]
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "NONE"
      ]
    },
    "outputPosture": {
      "enum": [
        "DRAFT_ONLY",
        "CANDIDATE_ONLY",
        "ADVISORY_ONLY",
        "REVIEW_REQUIRED",
        "HUMAN_APPROVAL_REQUIRED",
        "BLOCKED",
        "NO_OUTPUT"
      ]
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "draftRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "reviewRequestRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "promotionPath": {
      "enum": [
        "NONE",
        "NORMAL_REVIEW_PROMOTION_REQUIRED",
        "BRIDGE_CANDIDATE_REQUIRED",
        "HUMAN_APPROVAL_REQUIRED",
        "BLOCKED"
      ]
    },
    "requiresReview": {
      "type": "boolean"
    },
    "requiresHumanApproval": {
      "type": "boolean"
    },
    "freshnessPosture": {
      "enum": [
        "FRESH",
        "STALE",
        "INVALIDATED",
        "NOT_EVALUATED",
        "NOT_APPLICABLE"
      ]
    },
    "evidencePosture": {
      "enum": [
        "SUFFICIENT",
        "INSUFFICIENT",
        "MISSING",
        "REVIEW_REQUIRED",
        "NOT_APPLICABLE"
      ]
    },
    "handoffAllowed": {
      "type": "boolean"
    },
    "permissionLimited": {
      "type": "boolean"
    },
    "generatedByAgentProvenanceOnly": {
      "const": true
    },
    "acceptedFarmFactCreated": {
      "type": "boolean"
    },
    "resultQualificationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Disposition of material produced during an agent run. Generated-by-agent status is provenance only."
}
