{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agenthandoffenvelope-v0-1",
  "title": "OFARM AgentHandoffEnvelope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "handoffEnvelopeId",
    "fromRunRef",
    "toRunRef",
    "createdAt",
    "fromAgentInstanceRef",
    "toAgentInstanceRef",
    "sponsorRef",
    "handoffReason",
    "taskScopeHash",
    "authoritySnapshotRefBefore",
    "delegatedRights",
    "nonDelegatedRights",
    "includedContextRefs",
    "requiredRevalidationChecks",
    "recipientAcceptanceStatus",
    "authorityTransferred",
    "receivingAgentMustReauthorize",
    "traceparent",
    "tracestate",
    "expiresAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenthandoffenvelope.v0.1"
    },
    "handoffEnvelopeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "fromRunRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "toRunRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "fromAgentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "toAgentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "receivingAgentProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sponsorRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "handoffReason": {
      "enum": [
        "TASK_CONTINUATION",
        "SPECIALIST_AGENT",
        "HUMAN_REQUESTED",
        "SCOPE_TRANSFER",
        "REVIEW_ESCALATION",
        "OTHER"
      ]
    },
    "taskScopeHash": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "authoritySnapshotRefBefore": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "delegatedRights": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nonDelegatedRights": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "approvalRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "packRefsTransferred": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "assumptionsTransferred": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptionsNotTransferred": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "includedContextRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "includedArtifactRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "redactedOrExcludedRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "permissionLimitedMarkers": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "staleBasisMarkers": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "unresolvedConflictRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "blockedActionTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "requiredHumanDecisionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "requiredRevalidationChecks": {
      "type": "array",
      "items": {
        "enum": [
          "SPONSOR_RECHECK",
          "AUTHORITY_RECHECK",
          "REVOCATION_RECHECK",
          "ACTION_CLASS_POSTURE_RECHECK",
          "FRESHNESS_RECHECK",
          "EVIDENCE_RECHECK",
          "SHARING_RECHECK",
          "PACK_PROFILE_RECHECK",
          "RESULT_QUALIFICATION_RECHECK"
        ]
      },
      "minItems": 1
    },
    "recipientAcceptanceStatus": {
      "enum": [
        "PENDING",
        "ACCEPTED_WITH_REVALIDATION",
        "REJECTED",
        "EXPIRED"
      ]
    },
    "recipientAcceptanceEvidence": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "authorityTransferred": {
      "const": false
    },
    "receivingAgentMustReauthorize": {
      "const": true
    },
    "receivingAgentPreflightRequired": {
      "type": "boolean"
    },
    "traceparent": {
      "type": "string"
    },
    "tracestate": {
      "type": "string"
    },
    "traceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Handoff envelope for task context transfer. Authority does not silently transfer through handoff."
}
