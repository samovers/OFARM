{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentruninputbundle-v0-1",
  "title": "OFARM AgentRunInputBundle v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "inputBundleId",
    "createdAt",
    "bundlePurpose",
    "inputRefs",
    "basisPosture",
    "qualificationRefs",
    "notTruthByItself"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentruninputbundle.v0.1"
    },
    "inputBundleId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "bundlePurpose": {
      "enum": [
        "USER_REQUEST",
        "PREFLIGHT_BASIS",
        "EVIDENCE_CAPTURE",
        "HANDOFF_CONTEXT",
        "CURRENT_STATE_READ",
        "QUERY_RESULT_BUNDLE",
        "ADVISORY_CONTEXT",
        "MIXED"
      ]
    },
    "inputRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ref",
          "refType"
        ],
        "properties": {
          "ref": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "refType": {
            "enum": [
              "ASSERTION_RECORD",
              "QUERY_SPECIFICATION",
              "QUERY_RESULT",
              "CURRENT_STATE_MATERIALIZATION",
              "CONTEXT_SNAPSHOT",
              "EVIDENCE_RECORD",
              "PUBLIC_READ_MODEL",
              "HANDOFF_CONTEXT",
              "USER_PROMPT",
              "LOCAL_DRAFT",
              "AGENT_MEMORY_SCRATCH",
              "OTHER"
            ]
          },
          "qualificationRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    },
    "querySpecificationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "queryPlanIRRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "contextSnapshotRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "materializationResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "packActivationSetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "qualificationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "freshnessSnapshotRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "permissionLimitRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "basisPosture": {
      "enum": [
        "GOVERNED_BASIS",
        "PERMISSION_LIMITED",
        "STALE_OR_INVALID",
        "ADVISORY_ONLY",
        "CANDIDATE_ONLY",
        "MIXED"
      ]
    },
    "notTruthByItself": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Input bundle for a governed agent run. It can carry basis and context but is not canonical truth by itself."
}
