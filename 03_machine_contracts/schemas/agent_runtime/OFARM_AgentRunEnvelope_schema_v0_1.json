{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentrunenvelope-v0-1",
  "title": "OFARM AgentRunEnvelope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runEnvelopeId",
    "runId",
    "createdAt",
    "runPurpose",
    "executingAgentInstanceRef",
    "softwareAgentProfileRef",
    "agentSponsorRef",
    "agentActorshipBindingRef",
    "authorityEnvelopeRefs",
    "objective",
    "targetTwin",
    "targetScopeRefs",
    "requestedActionClasses",
    "allowedActionClasses",
    "forbiddenActionClasses",
    "allowedToolOrOperationRefs",
    "allowedWriteSurfaces",
    "allowedOutputDispositions",
    "inputBundleRefs",
    "approvalCheckpointRefs",
    "freshnessRequirementRefs",
    "stopConditionRefs",
    "traceRequired",
    "blockedActionTraceRequired",
    "resultQualificationRequired",
    "handoffAllowed",
    "handoffRequiresReauthorization",
    "expiresAt",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentrunenvelope.v0.1"
    },
    "runEnvelopeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "runId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "traceparent": {
      "type": "string"
    },
    "tracestate": {
      "type": "string"
    },
    "runPurpose": {
      "enum": [
        "PREFLIGHT",
        "EVIDENCE_CAPTURE",
        "COMPLIANCE_REVIEW_DRAFT",
        "ADVISORY_SUMMARY",
        "SHARING_PREPARATION",
        "OUTPUT_PREPARATION",
        "SCOUTING_TO_PLANNING",
        "OTHER"
      ]
    },
    "executingAgentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "softwareAgentProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentSponsorRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentActorshipBindingRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "initiatingSurfaceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "objective": {
      "type": "string"
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "NONE"
      ]
    },
    "targetScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "scopeInheritanceMode": {
      "enum": [
        "NO_INHERITANCE",
        "EXPLICIT_SCOPE_ONLY",
        "MIXED_SCOPE_REQUIRES_REVIEW"
      ]
    },
    "requestedActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      },
      "minItems": 1
    },
    "allowedActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "forbiddenActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "authorityEnvelopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "permittedQuerySpecificationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "permittedQueryClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "allowedToolOrOperationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "allowedWriteSurfaces": {
      "type": "array",
      "items": {
        "enum": [
          "NONE",
          "LOCAL_DRAFT",
          "DRAFT_ASSERTION",
          "EVIDENCE_CANDIDATE",
          "OBSERVATION_CANDIDATE",
          "REVIEW_REQUEST",
          "PUBLIC_READ_ONLY",
          "PREFLIGHT_ONLY"
        ]
      },
      "minItems": 1
    },
    "allowedOutputDispositions": {
      "type": "array",
      "items": {
        "enum": [
          "NONE",
          "ADVISORY_SUMMARY",
          "DRAFT_ARTIFACT",
          "EVIDENCE_CANDIDATE",
          "REVIEW_REQUEST",
          "PREFLIGHT_RESULT",
          "QUALIFIED_PUBLIC_READ",
          "BLOCKED_TRACE_ONLY"
        ]
      },
      "minItems": 1
    },
    "preflightRequired": {
      "type": "boolean"
    },
    "humanApprovalRequired": {
      "type": "boolean"
    },
    "approvalCheckpointRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "inputBundleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "contextSnapshotRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "materializationResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "packActivationSetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "freshnessRequirementRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "sharingAndDataSovereigntyLimits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "externalCallPolicy": {
      "enum": [
        "NO_EXTERNAL_CALLS",
        "ALLOWLIST_ONLY",
        "REQUIRE_PREFLIGHT_AND_TRACE",
        "PROHIBITED_FOR_RUN",
        "NOT_APPLICABLE"
      ]
    },
    "farmDataLearningPolicy": {
      "enum": [
        "NO_TRAINING_OR_MEMORY",
        "LOCAL_SCRATCH_ONLY",
        "GOVERNED_LOCAL_MEMORY_ONLY",
        "PROHIBITED"
      ]
    },
    "stopConditionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "traceRequired": {
      "const": true
    },
    "blockedActionTraceRequired": {
      "const": true
    },
    "resultQualificationRequired": {
      "const": true
    },
    "handoffAllowed": {
      "type": "boolean"
    },
    "handoffRequiresReauthorization": {
      "const": true
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "runtimeConformanceClaimed": {
      "enum": [
        "NOT_CLAIMED",
        "STUB_TEST_ONLY",
        "RUNTIME_VALIDATED_PROFILE"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Bounded envelope for a state-affecting, high-consequence, or multi-step software-agent run."
}
