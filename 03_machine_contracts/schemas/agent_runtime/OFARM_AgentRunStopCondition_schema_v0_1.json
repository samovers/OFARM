{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentrunstopcondition-v0-1",
  "title": "OFARM AgentRunStopCondition v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "stopConditionId",
    "conditionType",
    "severity",
    "triggerBasis",
    "requiredResponse",
    "stopsRun"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentrunstopcondition.v0.1"
    },
    "stopConditionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "conditionType": {
      "enum": [
        "AUTHORITY_DENIED",
        "HUMAN_APPROVAL_REQUIRED",
        "FRESHNESS_FAILED",
        "EVIDENCE_INSUFFICIENT",
        "SHARING_DENIED",
        "PACK_OR_PROFILE_BLOCKED",
        "TOOL_SIDE_EFFECT_NOT_ALLOWED",
        "TIMEOUT",
        "SCOPE_BOUNDARY",
        "USER_CANCELLED",
        "POLICY_VIOLATION"
      ]
    },
    "severity": {
      "enum": [
        "INFO",
        "WARNING",
        "BLOCKING"
      ]
    },
    "triggerBasis": {
      "type": "string"
    },
    "requiredResponse": {
      "enum": [
        "STOP_RUN",
        "BLOCK_ACTION",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL",
        "REFUSE_OUTPUT",
        "CONTINUE_WITH_QUALIFICATION"
      ]
    },
    "reasonCodeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "stopsRun": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Stop condition for agent run governance."
}
