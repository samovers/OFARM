{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentrunapprovalcheckpoint-v0-1",
  "title": "OFARM AgentRunApprovalCheckpoint v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "approvalCheckpointId",
    "checkpointType",
    "approvalState",
    "requiredForActionClasses",
    "targetScope",
    "approvalRequired",
    "finalActionPermitted"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentrunapprovalcheckpoint.v0.1"
    },
    "approvalCheckpointId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "checkpointType": {
      "enum": [
        "HUMAN_APPROVAL",
        "HUMAN_REVIEW",
        "SPONSOR_CONFIRMATION",
        "OUTPUT_APPROVAL",
        "PACK_ACTIVATION_APPROVAL",
        "SHARING_APPROVAL",
        "FILING_APPROVAL"
      ]
    },
    "approvalState": {
      "enum": [
        "NOT_REQUIRED",
        "REQUIRED_NOT_OBTAINED",
        "OBTAINED",
        "EXPIRED",
        "REVOKED",
        "DENIED"
      ]
    },
    "requiredForActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      },
      "minItems": 1
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT",
            "MIXED"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "targetTime": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "approverPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "decisionTraceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "approvalRequired": {
      "type": "boolean"
    },
    "finalActionPermitted": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Approval checkpoint for human-governed or sponsor-confirmed agent run actions."
}
