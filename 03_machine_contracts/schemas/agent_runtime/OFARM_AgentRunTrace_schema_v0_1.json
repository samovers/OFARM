{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentruntrace-v0-1",
  "title": "OFARM AgentRunTrace v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentRunTraceId",
    "runRef",
    "runEnvelopeRef",
    "traceId",
    "startedAt",
    "completedAt",
    "agentSponsorRef",
    "executingAgentInstanceRef",
    "softwareAgentProfileRef",
    "agentActorshipBindingRef",
    "objective",
    "targetTwin",
    "targetScopeRefs",
    "authoritySnapshotRef",
    "inputBundleRefs",
    "assumptionRecords",
    "toolInvocationTraceRefs",
    "outputDispositionRefs",
    "blockedActionTraceRefs",
    "approvalCheckpointRefs",
    "freshnessRequirementRefs",
    "revocationEvents",
    "finalRunOutcome",
    "governanceOutcome",
    "executionOutcome",
    "traceRetrievalRef",
    "resultQualificationRefs",
    "retentionClass",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentruntrace.v0.1"
    },
    "agentRunTraceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "runRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "runEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "parentRunRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "traceparent": {
      "type": "string"
    },
    "tracestate": {
      "type": "string"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "agentSponsorRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "executingAgentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "softwareAgentProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentActorshipBindingRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "modelToolProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "objective": {
      "type": "string"
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "NONE"
      ]
    },
    "targetScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "authoritySnapshotRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "authorityEnvelopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "inputBundleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "querySpecificationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "queryPlanIRRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "contextSnapshotRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "materializationResultRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "packActivationSetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "evidenceBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "assumptionRecords": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assumptionId",
          "statement",
          "source",
          "disposition"
        ],
        "properties": {
          "assumptionId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "statement": {
            "type": "string"
          },
          "source": {
            "enum": [
              "USER_PROVIDED",
              "MODEL_INFERRED",
              "LOCAL_CONTEXT",
              "WORLD_MODEL",
              "HANDOFF",
              "OTHER"
            ]
          },
          "basisRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:/#-]+$"
            }
          },
          "disposition": {
            "enum": [
              "EXPLICITLY_QUALIFIED",
              "REQUIRES_REVIEW",
              "NOT_USED_FOR_GOVERNANCE",
              "BLOCKED"
            ]
          }
        }
      }
    },
    "uncertaintyStatements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "toolInvocationTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "outputDispositionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "blockedActionTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "approvalCheckpointRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "freshnessRequirementRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "handoffEnvelopeRefsEmitted": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "handoffEnvelopeRefsReceived": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "revocationEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "revocationEventId",
          "checkedAt",
          "outcome"
        ],
        "properties": {
          "revocationEventId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "checkedAt": {
            "type": "string",
            "format": "date-time"
          },
          "outcome": {
            "enum": [
              "NO_ACTIVE_REVOCATION",
              "ACTIVE_REVOCATION_FOUND",
              "NOT_EVALUATED"
            ]
          },
          "basisRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:/#-]+$"
            }
          }
        }
      }
    },
    "policyChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "checkId",
          "checkKind",
          "outcome"
        ],
        "properties": {
          "checkId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "checkKind": {
            "enum": [
              "RUN_ENVELOPE_PRESENT",
              "AUTHORITY_SNAPSHOT_PRESENT",
              "ACTION_CLASS_ALLOWED",
              "REVOCATION_RECHECK",
              "HUMAN_APPROVAL",
              "FRESHNESS",
              "EVIDENCE",
              "SHARING",
              "PACK_OR_PROFILE",
              "TOOL_SIDE_EFFECT",
              "NO_SILENT_HANDOFF_AUTHORITY",
              "RESULT_QUALIFICATION_LINKED",
              "TRACE_RETRIEVABLE"
            ]
          },
          "outcome": {
            "enum": [
              "PASS",
              "FAIL",
              "WARNING",
              "REQUIRE_REVIEW",
              "REDACTED",
              "NOT_APPLICABLE"
            ]
          },
          "reason": {
            "type": "string"
          },
          "basisRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:/#-]+$"
            }
          }
        }
      }
    },
    "finalRunOutcome": {
      "enum": [
        "COMPLETED_ALLOWED",
        "COMPLETED_WITH_QUALIFICATION",
        "BLOCKED",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL",
        "FAILED",
        "CANCELLED"
      ]
    },
    "governanceOutcome": {
      "enum": [
        "PASS",
        "FAIL",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL",
        "BLOCKED"
      ]
    },
    "executionOutcome": {
      "enum": [
        "SUCCEEDED",
        "PARTIAL",
        "FAILED",
        "NOT_EXECUTED_BLOCKED"
      ]
    },
    "traceRetrievalRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "runtimeProblemReasonCodeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "resultQualificationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "retentionClass": {
      "enum": [
        "STANDARD_AUDIT",
        "HIGH_CONSEQUENCE_AUDIT",
        "SHORT_LIVED_NON_GOVERNING",
        "REDACTED_AUDIT"
      ]
    },
    "runtimeConformanceClaimed": {
      "enum": [
        "NOT_CLAIMED",
        "STUB_TEST_ONLY",
        "RUNTIME_VALIDATED_PROFILE"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Trace for a governed software-agent run. It records reads, assumptions, tool calls, policy checks, blocked actions, outputs, revocation, and result qualifications."
}
