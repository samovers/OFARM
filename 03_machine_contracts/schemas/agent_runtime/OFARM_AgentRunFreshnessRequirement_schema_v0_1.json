{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentrunfreshnessrequirement-v0-1",
  "title": "OFARM AgentRunFreshnessRequirement v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "freshnessRequirementId",
    "targetUse",
    "targetRefs",
    "requiredFreshnessPosture",
    "evaluatedAt",
    "evaluationResult",
    "onFailure"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentrunfreshnessrequirement.v0.1"
    },
    "freshnessRequirementId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "targetUse": {
      "enum": [
        "QUERY_RESULT_USE",
        "CURRENT_STATE_USE",
        "PUBLIC_READ_MODEL_USE",
        "TOOL_CALL",
        "HANDOFF_ACCEPTANCE",
        "OUTPUT_PREPARATION",
        "SHARING_OR_DISCLOSURE",
        "FILING_OR_ATTESTATION"
      ]
    },
    "targetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "requiredFreshnessPosture": {
      "enum": [
        "FRESH",
        "FRESH_OR_REVIEWED",
        "STALE_ALLOWED_WITH_QUALIFICATION",
        "NOT_APPLICABLE"
      ]
    },
    "freshnessPolicyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "evaluationResult": {
      "enum": [
        "PASS",
        "FAIL_STALE",
        "FAIL_NOT_COMPUTED",
        "FAIL_INVALIDATED",
        "REQUIRE_REVIEW",
        "NOT_EVALUATED"
      ]
    },
    "onFailure": {
      "enum": [
        "BLOCK_ACTION",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL",
        "ALLOW_WITH_QUALIFICATION",
        "REFUSE_OUTPUT"
      ]
    },
    "resultQualificationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Freshness rule used by an AgentRunEnvelope or AgentRunTrace."
}
