{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentblockedactiontrace-v0-1",
  "title": "OFARM AgentBlockedActionTrace v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "blockedActionTraceId",
    "runRef",
    "attemptedAt",
    "attemptedActionClass",
    "attemptedOperationRef",
    "targetTwin",
    "targetScopeRefs",
    "blockingReasonCodes",
    "requiredResponse",
    "acceptedFarmFactCreated",
    "blockedBeforeSideEffect",
    "resultQualificationRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentblockedactiontrace.v0.1"
    },
    "blockedActionTraceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "runRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "toolInvocationTraceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "attemptedAt": {
      "type": "string",
      "format": "date-time"
    },
    "attemptedActionClass": {
      "type": "string",
      "pattern": "^[A-Z0-9_:-]+$"
    },
    "attemptedOperationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "NONE"
      ]
    },
    "targetScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "blockingReasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      },
      "minItems": 1
    },
    "violatedEnvelopeConstraint": {
      "type": "string"
    },
    "violatedAuthorityConstraint": {
      "type": "string"
    },
    "violatedFreshnessConstraint": {
      "type": "string"
    },
    "violatedSharingConstraint": {
      "type": "string"
    },
    "violatedPackOrEvidenceConstraint": {
      "type": "string"
    },
    "requiredResponse": {
      "enum": [
        "DENY",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL",
        "REFUSE_OUTPUT",
        "RETRY_AFTER_PREFLIGHT",
        "RETRY_AFTER_FRESHNESS_UPDATE"
      ]
    },
    "draftMaterialRetained": {
      "type": "boolean"
    },
    "acceptedFarmFactCreated": {
      "const": false
    },
    "blockedBeforeSideEffect": {
      "type": "boolean"
    },
    "resultQualificationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "traceRetrievalRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Trace emitted when a software-agent action is blocked before or after attempting an operation."
}
