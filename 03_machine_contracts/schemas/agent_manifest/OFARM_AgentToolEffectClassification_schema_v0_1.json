{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-tool-effect-classification/v0.1",
  "title": "OFARM AgentToolEffectClassification v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "effectClassificationId",
    "effectClass",
    "stateAffecting",
    "externalDisclosurePossible",
    "complianceConsequencePossible",
    "manifestDoesNotGrantAuthority"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenttooleffectclassification.v0.1"
    },
    "effectClassificationId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "effectClass": {
      "enum": [
        "READ_ONLY",
        "QUALIFIED_READ",
        "DRAFT_CREATE",
        "EVIDENCE_CANDIDATE_CREATE",
        "ADVISORY_CREATE",
        "BRIDGE_CANDIDATE_CREATE",
        "REVIEW_REQUEST_CREATE",
        "OUTPUT_PREVIEW_CREATE",
        "EXTERNAL_DISCLOSURE_PREPARE",
        "STATE_AFFECTING_GOVERNED_OPERATION",
        "PROHIBITED_FOR_AGENT_USE"
      ]
    },
    "stateAffecting": {
      "type": "boolean"
    },
    "externalDisclosurePossible": {
      "type": "boolean"
    },
    "complianceConsequencePossible": {
      "type": "boolean"
    },
    "allowedOutputDispositions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockedIfMisdeclared": {
      "type": "boolean"
    },
    "manifestDoesNotGrantAuthority": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  }
}
