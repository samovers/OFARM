{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-tool-semantic-precondition/v0.1",
  "title": "OFARM AgentToolSemanticPrecondition v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "semanticPreconditionId",
    "preconditionType",
    "requiredBasisRefs",
    "onFailure",
    "preconditionCanBeSatisfiedByManifestOnly"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenttoolsemanticprecondition.v0.1"
    },
    "semanticPreconditionId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "preconditionType": {
      "enum": [
        "AUTHORITY_PRESENT",
        "AUTHORITY_NOT_REVOKED",
        "PREFLIGHT_PASS",
        "HUMAN_APPROVAL_PRESENT",
        "EVIDENCE_SUFFICIENCY_PRESENT",
        "FRESHNESS_PRESENT",
        "PACK_CONTEXT_PRESENT",
        "SHARING_ALLOWED",
        "REDACTION_POLICY_PRESENT",
        "OUTPUT_DISPOSITION_ALLOWED",
        "TRACE_RETENTION_PRESENT",
        "RESULT_QUALIFICATION_PRESENT",
        "TWIN_BOUNDARY_ALLOWED"
      ]
    },
    "requiredBasisRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "onFailure": {
      "enum": [
        "DENY",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL",
        "DEGRADE_TO_ADVISORY",
        "REFUSE_OUTPUT",
        "STOP_RUN"
      ]
    },
    "preconditionCanBeSatisfiedByManifestOnly": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
