{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-tool-approval-requirement/v0.1",
  "title": "OFARM AgentToolApprovalRequirement v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "approvalRequirementId",
    "approvalClass",
    "preflightRequired",
    "humanApprovalRequired",
    "approvalCanBeImpliedByManifest",
    "approvalReasonCodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenttoolapprovalrequirement.v0.1"
    },
    "approvalRequirementId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "approvalClass": {
      "enum": [
        "NO_APPROVAL_READ_ONLY",
        "PREFLIGHT_REQUIRED",
        "HUMAN_APPROVAL_REQUIRED",
        "HUMAN_GOVERNED_ONLY",
        "NOT_AGENT_CALLABLE"
      ]
    },
    "preflightRequired": {
      "type": "boolean"
    },
    "humanApprovalRequired": {
      "type": "boolean"
    },
    "humanGovernedOnly": {
      "type": "boolean"
    },
    "approvalCanBeImpliedByManifest": {
      "const": false
    },
    "approvalReasonCodes": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowedApproverRoleRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
