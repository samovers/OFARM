{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-external-call-policy/v0.1",
  "title": "OFARM AgentExternalCallPolicy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "externalCallPolicyId",
    "egressPolicy",
    "allowedDomains",
    "prohibitedDomains",
    "requiresSharePolicyCheck",
    "requiresRedactionCheck",
    "externalCallCanBeHiddenByManifest"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentexternalcallpolicy.v0.1"
    },
    "externalCallPolicyId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "egressPolicy": {
      "enum": [
        "NO_EXTERNAL_CALLS",
        "ALLOWLIST_ONLY",
        "GOVERNED_RUNTIME_PROXY",
        "PROHIBITED"
      ]
    },
    "allowedDomains": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibitedDomains": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiresSharePolicyCheck": {
      "type": "boolean"
    },
    "requiresRedactionCheck": {
      "type": "boolean"
    },
    "disclosureRiskClass": {
      "enum": [
        "NONE",
        "LOW",
        "MEDIUM",
        "HIGH",
        "PROHIBITED"
      ]
    },
    "externalCallCanBeHiddenByManifest": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
