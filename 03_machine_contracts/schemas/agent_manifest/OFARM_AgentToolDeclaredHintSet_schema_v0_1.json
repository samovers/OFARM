{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-tool-declared-hint-set/v0.1",
  "title": "OFARM AgentToolDeclaredHintSet v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "declaredHintSetId",
    "hintsAreUntrusted",
    "mustBeVerifiedAgainstEffectPolicy",
    "readOnlyHint",
    "externalNetworkHint",
    "destructiveHint"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenttooldeclaredhintset.v0.1"
    },
    "declaredHintSetId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "hintsAreUntrusted": {
      "const": true
    },
    "mustBeVerifiedAgainstEffectPolicy": {
      "const": true
    },
    "readOnlyHint": {
      "type": "boolean"
    },
    "idempotentHint": {
      "type": "boolean"
    },
    "safeHint": {
      "type": "boolean"
    },
    "externalNetworkHint": {
      "type": "boolean"
    },
    "destructiveHint": {
      "type": "boolean"
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
