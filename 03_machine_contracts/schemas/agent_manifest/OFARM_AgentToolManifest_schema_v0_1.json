{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-tool-manifest/v0.1",
  "title": "OFARM AgentToolManifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentToolManifestId",
    "manifestPurpose",
    "manifestVersion",
    "publisherRef",
    "issuedAt",
    "expiresAt",
    "signatureRef",
    "sourceUri",
    "deploymentOrTenantRef",
    "capabilityManifestRef",
    "agentSupportSectionRef",
    "toolDescriptorRefs",
    "defaultExternalCallPolicyRef",
    "defaultDataLearningPolicyRef",
    "defaultTraceRetentionPolicyRef",
    "defaultRedactionPolicyRef",
    "readinessClaimRefs",
    "manifestDoesNotGrantAuthority",
    "toolHintsAreNonAuthoritative",
    "manifestIsNotGovernanceSuccess",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenttoolmanifest.v0.1"
    },
    "agentToolManifestId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "manifestPurpose": {
      "enum": [
        "AGENT_TOOL_DISCOVERY",
        "AGENT_RUNTIME_SELF_DESCRIPTION",
        "IMPLEMENTER_REVIEW",
        "CONFORMANCE_FIXTURE"
      ]
    },
    "manifestVersion": {
      "type": "string",
      "minLength": 1
    },
    "publisherRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "signatureRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sourceUri": {
      "type": "string",
      "minLength": 1
    },
    "manifestDigest": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Fa-f0-9]{32,128}$|^[A-Za-z0-9._:/#-]+$"
    },
    "deploymentOrTenantRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "capabilityManifestRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentSupportSectionRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "toolDescriptorRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "defaultExternalCallPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "defaultDataLearningPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "defaultTraceRetentionPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "defaultRedactionPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "claimEvidencePackRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "readinessClaimRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "manifestDoesNotGrantAuthority": {
      "const": true
    },
    "toolHintsAreNonAuthoritative": {
      "const": true
    },
    "manifestIsNotGovernanceSuccess": {
      "const": true
    },
    "runtimeConformanceClaimed": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
