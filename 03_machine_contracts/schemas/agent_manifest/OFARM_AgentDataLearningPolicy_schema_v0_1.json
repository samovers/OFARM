{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-data-learning-policy/v0.1",
  "title": "OFARM AgentDataLearningPolicy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "dataLearningPolicyId",
    "learningUsePolicy",
    "farmDataMayBeUsedForTraining",
    "memoryUsePolicy",
    "requiresExplicitOptIn",
    "revocationRecheckRequired"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentdatalearningpolicy.v0.1"
    },
    "dataLearningPolicyId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "learningUsePolicy": {
      "enum": [
        "NO_TRAINING_OR_MODEL_LEARNING",
        "EPHEMERAL_SESSION_ONLY",
        "TENANT_LOCAL_MEMORY_WITH_POLICY",
        "EXPLICIT_OPT_IN_ONLY",
        "PROHIBITED"
      ]
    },
    "farmDataMayBeUsedForTraining": {
      "type": "boolean"
    },
    "memoryUsePolicy": {
      "enum": [
        "NO_MEMORY",
        "SESSION_SCRATCH_ONLY",
        "GOVERNED_LOCAL_MEMORY",
        "EXPLICITLY_APPROVED_MEMORY_ONLY"
      ]
    },
    "requiresExplicitOptIn": {
      "type": "boolean"
    },
    "revocationRecheckRequired": {
      "type": "boolean"
    },
    "dataLearningDoesNotCreateTruth": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  }
}
