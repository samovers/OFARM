{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-support-section/v0.1",
  "title": "OFARM AgentSupportSection v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentSupportSectionId",
    "agentSupportStatus",
    "supportedAgentClasses",
    "supportedAutonomyLevels",
    "maxAutonomyByActionClass",
    "supportedRunEnvelopeVersions",
    "supportedRunTraceVersions",
    "supportedHandoffEnvelopeVersions",
    "agentToolManifestRefs",
    "manifestDoesNotGrantAuthority",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentsupportsection.v0.1"
    },
    "agentSupportSectionId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentSupportStatus": {
      "enum": [
        "NOT_SUPPORTED",
        "DECLARED_ONLY",
        "STATIC_VALIDATED",
        "IMPLEMENTATION_PRESENT_NOT_TESTED",
        "RUNTIME_TESTED"
      ]
    },
    "supportedAgentClasses": {
      "type": "array",
      "minItems": 0,
      "items": {
        "enum": [
          "READ_ASSISTANT",
          "EVIDENCE_STEWARD",
          "COMPLIANCE_STEWARD",
          "ADVISORY_AGRONOMY",
          "CONTRACTOR_COORDINATION",
          "LOT_STORAGE",
          "SHARING_SOVEREIGNTY",
          "DISPUTE_RECONSTRUCTION",
          "LOCAL_MEMORY",
          "WORLD_MODEL_SCENARIO"
        ]
      }
    },
    "supportedAutonomyLevels": {
      "type": "array",
      "minItems": 0,
      "items": {
        "enum": [
          "READ_ONLY",
          "DRAFT_ONLY",
          "PREFLIGHT_ONLY",
          "HUMAN_APPROVAL_REQUIRED",
          "POLICY_BOUNDED_EXECUTION",
          "HUMAN_GOVERNED_ONLY",
          "NOT_AGENT_CALLABLE"
        ]
      }
    },
    "maxAutonomyByActionClass": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "authorityActionClass",
          "maxAutonomyLevel"
        ],
        "properties": {
          "authorityActionClass": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "maxAutonomyLevel": {
            "enum": [
              "READ_ONLY",
              "DRAFT_ONLY",
              "PREFLIGHT_ONLY",
              "HUMAN_APPROVAL_REQUIRED",
              "POLICY_BOUNDED_EXECUTION",
              "HUMAN_GOVERNED_ONLY",
              "NOT_AGENT_CALLABLE"
            ]
          }
        }
      }
    },
    "supportedTargetTwins": {
      "type": "array",
      "minItems": 0,
      "items": {
        "enum": [
          "COMPLIANCE",
          "ADVISORY",
          "BOTH_READ_ONLY"
        ]
      }
    },
    "supportedRunEnvelopeVersions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedRunTraceVersions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedHandoffEnvelopeVersions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "agentToolManifestRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "readinessClaimRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "manifestDoesNotGrantAuthority": {
      "const": true
    },
    "runtimeConformanceClaimed": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
