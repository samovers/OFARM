{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agentic-capability-manifest-overlay/v0.1",
  "title": "OFARM AgenticCapabilityManifestOverlay v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agenticCapabilityManifestOverlayId",
    "baseCapabilityManifestRef",
    "agentSupportSectionRef",
    "agentToolManifestRefs",
    "readinessClaimRefs",
    "overlayDoesNotGrantAuthority",
    "worldModelSupportPromoted",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenticcapabilitymanifestoverlay.v0.1"
    },
    "agenticCapabilityManifestOverlayId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "baseCapabilityManifestRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentSupportSectionRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentToolManifestRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "readinessClaimRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "overlayDoesNotGrantAuthority": {
      "const": true
    },
    "worldModelSupportPromoted": {
      "const": false
    },
    "runtimeConformanceClaimed": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
