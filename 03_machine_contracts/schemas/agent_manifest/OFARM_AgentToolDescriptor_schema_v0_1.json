{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-tool-descriptor/v0.1",
  "title": "OFARM AgentToolDescriptor v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentToolDescriptorId",
    "toolId",
    "toolName",
    "toolVersion",
    "publisherRef",
    "sourceUri",
    "inputSchemaRef",
    "inputSchemaHash",
    "outputSchemaRef",
    "outputSchemaHash",
    "effectClass",
    "targetTwins",
    "stateTargetRefs",
    "dataClassesIn",
    "dataClassesOut",
    "authModes",
    "requiredScopes",
    "authorityActionClass",
    "approvalRequirementRef",
    "semanticPreconditionRefs",
    "declaredHintSetRef",
    "externalCallPolicyRef",
    "traceRetentionPolicyRef",
    "redactionPolicyRef",
    "dataLearningPolicyRef",
    "knownLimitations",
    "prohibitedUses",
    "readinessClaimRefs",
    "descriptorDoesNotGrantAuthority",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenttooldescriptor.v0.1"
    },
    "agentToolDescriptorId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "toolId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "toolName": {
      "type": "string",
      "minLength": 1
    },
    "toolVersion": {
      "type": "string",
      "minLength": 1
    },
    "publisherRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sourceUri": {
      "type": "string",
      "minLength": 1
    },
    "inputSchemaRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "inputSchemaHash": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Fa-f0-9]{32,128}$|^[A-Za-z0-9._:/#-]+$"
    },
    "outputSchemaRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "outputSchemaHash": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Fa-f0-9]{32,128}$|^[A-Za-z0-9._:/#-]+$"
    },
    "effectClassificationRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "effectClass": {
      "enum": [
        "READ_ONLY",
        "QUALIFIED_READ",
        "DRAFT_CREATE",
        "EVIDENCE_CANDIDATE_CREATE",
        "ADVISORY_CREATE",
        "BRIDGE_CANDIDATE_CREATE",
        "REVIEW_REQUEST_CREATE",
        "OUTPUT_PREVIEW_CREATE",
        "EXTERNAL_DISCLOSURE_PREPARE",
        "STATE_AFFECTING_GOVERNED_OPERATION",
        "PROHIBITED_FOR_AGENT_USE"
      ]
    },
    "targetTwins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "COMPLIANCE",
          "ADVISORY",
          "BOTH_READ_ONLY",
          "NONE"
        ]
      }
    },
    "stateTargetRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "dataClassesIn": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dataClassesOut": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authModes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "NONE",
          "USER_SESSION",
          "SERVICE_ACCOUNT",
          "OAUTH",
          "API_KEY",
          "MUTUAL_TLS",
          "SIGNED_REQUEST",
          "PLATFORM_INTERNAL"
        ]
      }
    },
    "requiredScopes": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authorityActionClass": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "approvalRequirementRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "semanticPreconditionRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "declaredHintSetRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "externalCallPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "traceRetentionPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "redactionPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "dataLearningPolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "allowedOutputDispositions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "knownLimitations": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibitedUses": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "claimEvidencePackRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "readinessClaimRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "descriptorDoesNotGrantAuthority": {
      "const": true
    },
    "runtimeConformanceClaimed": {
      "const": false
    },
    "notes": {
      "type": "string"
    }
  }
}
