{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/redaction-and-permission-limited-result-policy/v0.1",
  "title": "OFARM RedactionAndPermissionLimitedResultPolicy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "redactionPolicyId",
    "permissionLimitedResultsMustBeQualified",
    "redactedFieldsMustNotLeakToSummary",
    "sharePolicyRecheckRequired",
    "onPermissionLimit"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.redactionandpermissionlimitedresultpolicy.v0.1"
    },
    "redactionPolicyId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "permissionLimitedResultsMustBeQualified": {
      "const": true
    },
    "redactedFieldsMustNotLeakToSummary": {
      "const": true
    },
    "sharePolicyRecheckRequired": {
      "type": "boolean"
    },
    "onPermissionLimit": {
      "enum": [
        "QUALIFY_RESULT",
        "REDACT_AND_QUALIFY",
        "REFUSE_OUTPUT",
        "REQUIRE_REVIEW"
      ]
    },
    "resultQualificationRequirementRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
