{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-trace-retention-policy/v0.1",
  "title": "OFARM AgentTraceRetentionPolicy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "traceRetentionPolicyId",
    "minimumRetentionClass",
    "requiredTraceEvents",
    "blockedActionTraceRequired",
    "tracePromisesAreRuntimeVerifiable"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agenttraceretentionpolicy.v0.1"
    },
    "traceRetentionPolicyId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "minimumRetentionClass": {
      "enum": [
        "EPHEMERAL_DEBUG_ONLY",
        "GOVERNED_RUN_MINIMUM",
        "HIGH_CONSEQUENCE_AUDIT",
        "REGULATORY_RECONSTRUCTION"
      ]
    },
    "requiredTraceEvents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "TOOL_INVOCATION",
          "POLICY_CHECK",
          "AUTHORITY_CHECK",
          "APPROVAL_CHECK",
          "FRESHNESS_CHECK",
          "EVIDENCE_CHECK",
          "SHARING_CHECK",
          "EXTERNAL_CALL",
          "REDACTION_CHECK",
          "BLOCKED_ACTION",
          "OUTPUT_DISPOSITION",
          "RESULT_QUALIFICATION",
          "RUN_STOP"
        ]
      }
    },
    "blockedActionTraceRequired": {
      "const": true
    },
    "tracePromisesAreRuntimeVerifiable": {
      "const": true
    },
    "retentionBasisRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
