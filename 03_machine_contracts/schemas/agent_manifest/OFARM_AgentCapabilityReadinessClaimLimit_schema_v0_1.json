{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-capability-readiness-claim-limit/v0.1",
  "title": "OFARM AgentCapabilityReadinessClaimLimit v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "readinessClaimId",
    "claimSubjectRef",
    "claimStatus",
    "evidenceRefs",
    "expiresAt",
    "publicClaimAllowed",
    "runtimeEvidenceRequired",
    "staticValidationIsNotRuntimeEvidence"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentcapabilityreadinessclaimlimit.v0.1"
    },
    "readinessClaimId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "claimSubjectRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "claimStatus": {
      "enum": [
        "DECLARED_ONLY",
        "STATIC_SCHEMA_VALIDATED",
        "STATIC_EXAMPLE_VALIDATED",
        "IMPLEMENTATION_PRESENT_NOT_TESTED",
        "RUNTIME_EXECUTED",
        "RUNTIME_PASSED",
        "TWO_AGENT_COMPATIBILITY_PASSED",
        "EXTERNAL_CONFORMANCE_REVIEWED",
        "PROHIBITED_CLAIM"
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "publicClaimAllowed": {
      "type": "boolean"
    },
    "runtimeEvidenceRequired": {
      "type": "boolean"
    },
    "staticValidationIsNotRuntimeEvidence": {
      "const": true
    },
    "blockedClaimsBeforeRuntimeEvidence": {
      "type": "array",
      "minItems": 0,
      "items": {
        "enum": [
          "RUNTIME_READY",
          "TWO_AGENT_COMPATIBLE",
          "WORLD_MODEL_READY",
          "AUTONOMOUS_COMPLIANCE_SUPPORT",
          "PRODUCTION_READY",
          "EXTERNAL_STANDARD_READY",
          "LEGAL_ADVICE",
          "LIVE_REGISTRY_INTEGRATED"
        ]
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
