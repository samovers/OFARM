{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/evidencesufficiencycase/v0.1",
  "title": "OFARM EvidenceSufficiencyCase v0.1",
  "$comment": "Minimal machine contract derived from Platform RC2.1 \u00a7\u00a73.6, 4.4-4.7, 10.5 and Constitution RC2.1 \u00a7\u00a710.10, 10.12-10.16, 11.4.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sufficiencyCaseId",
    "generatedAt",
    "caseClass",
    "targetTwin",
    "anchorScopes",
    "subject",
    "governingPolicyRefs",
    "claims",
    "arguments",
    "evidenceBundles",
    "outcome"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.evidencesufficiencycase.v0.1"
    },
    "sufficiencyCaseId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "caseClass": {
      "enum": [
        "COMPLIANCE_ASSERTION",
        "DOCUMENT_ATTESTATION",
        "SUBMISSION_ASSEMBLY"
      ]
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "anchorScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subjectType",
        "subjectRef"
      ],
      "properties": {
        "subjectType": {
          "enum": [
            "ASSERTION_RECORD",
            "DOCUMENT_ASSEMBLY",
            "DOSSIER_ASSEMBLY",
            "SUBMISSION_ASSEMBLY"
          ]
        },
        "subjectRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "governingPolicyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "materializationBasisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "materializationSnapshotRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claimId",
          "claimType",
          "claimRef",
          "statement"
        ],
        "properties": {
          "claimId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "claimType": {
            "enum": [
              "COMPLIANCE_CLAIM",
              "OUTPUT_INTEGRITY_CLAIM",
              "SUBMISSION_COMPLETENESS_CLAIM"
            ]
          },
          "claimRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "arguments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "argumentId",
          "supportsClaimIds",
          "policyRef",
          "ruleRef",
          "conclusion"
        ],
        "properties": {
          "argumentId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "supportsClaimIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "policyRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "ruleRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "conclusion": {
            "enum": [
              "SUPPORTED",
              "UNSUPPORTED",
              "REVIEW_REQUIRED"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "evidenceBundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bundleId",
          "supportsArgumentIds",
          "bundleStatus",
          "rawSourceRefs",
          "normalizedInterpretationRefs",
          "provenanceRefs",
          "chainOfCustodyStatus"
        ],
        "properties": {
          "bundleId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "bundleRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "supportsArgumentIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "bundleStatus": {
            "enum": [
              "COMPLETE",
              "PARTIAL",
              "MISSING_REQUIRED_SUPPORT"
            ]
          },
          "rawSourceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "normalizedInterpretationRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "provenanceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "chainOfCustodyStatus": {
            "enum": [
              "PRESERVED",
              "PARTIAL",
              "NOT_REQUIRED",
              "UNKNOWN"
            ]
          }
        }
      }
    },
    "reviewDecisionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "attestationPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attestationRequired",
        "attestationActionFamily",
        "portableEnvelopeMode"
      ],
      "properties": {
        "attestationRequired": {
          "type": "boolean"
        },
        "attestationActionFamily": {
          "enum": [
            "NONE",
            "OUTPUT_APPROVE_DOCUMENT_ASSEMBLY",
            "OUTPUT_ATTEST_DOCUMENT_ASSEMBLY",
            "OUTPUT_FILE_SUBMISSION_ASSEMBLY"
          ]
        },
        "portableEnvelopeMode": {
          "enum": [
            "NONE",
            "JWS",
            "VC_JWS"
          ]
        },
        "signatoryAuthorityRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "rationale",
        "attestationAllowed"
      ],
      "properties": {
        "decision": {
          "enum": [
            "ALLOW",
            "REQUIRE_REVIEW",
            "REFUSE"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "insufficiencyReasonCodes": {
          "type": "array",
          "items": {
            "enum": [
              "MISSING_REQUIRED_EVIDENCE",
              "MISSING_NORMALIZED_INTERPRETATION",
              "MISSING_PROVENANCE_LINK",
              "CHAIN_OF_CUSTODY_PARTIAL",
              "CHAIN_OF_CUSTODY_UNKNOWN",
              "BASIS_NOT_RETAINED",
              "CONFLICTING_EVIDENCE",
              "ATTESTATION_AUTHORITY_MISSING"
            ]
          }
        },
        "blockingGapRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "attestationAllowed": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "caseClass": {
            "const": "COMPLIANCE_ASSERTION"
          }
        }
      },
      "then": {
        "properties": {
          "subject": {
            "properties": {
              "subjectType": {
                "const": "ASSERTION_RECORD"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "caseClass": {
            "const": "DOCUMENT_ATTESTATION"
          }
        }
      },
      "then": {
        "required": [
          "materializationBasisRef",
          "materializationSnapshotRef",
          "attestationPlan"
        ],
        "properties": {
          "subject": {
            "properties": {
              "subjectType": {
                "enum": [
                  "DOCUMENT_ASSEMBLY",
                  "DOSSIER_ASSEMBLY"
                ]
              }
            }
          },
          "attestationPlan": {
            "properties": {
              "attestationActionFamily": {
                "enum": [
                  "OUTPUT_APPROVE_DOCUMENT_ASSEMBLY",
                  "OUTPUT_ATTEST_DOCUMENT_ASSEMBLY"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "caseClass": {
            "const": "SUBMISSION_ASSEMBLY"
          }
        }
      },
      "then": {
        "required": [
          "materializationBasisRef",
          "materializationSnapshotRef",
          "attestationPlan"
        ],
        "properties": {
          "subject": {
            "properties": {
              "subjectType": {
                "const": "SUBMISSION_ASSEMBLY"
              }
            }
          },
          "attestationPlan": {
            "properties": {
              "attestationActionFamily": {
                "const": "OUTPUT_FILE_SUBMISSION_ASSEMBLY"
              }
            }
          }
        }
      }
    }
  ]
}
