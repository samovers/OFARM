{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-authorization-decision-trace/v0.1",
  "title": "OFARM AgentAuthorizationDecisionTrace v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentAuthorizationDecisionTraceId",
    "evaluatedAt",
    "agentSponsorRef",
    "executingAgentInstanceRef",
    "softwareAgentProfileRef",
    "requestedActionClass",
    "targetScope",
    "twinContext",
    "authoritySnapshotRef",
    "agentActorshipBindingRef",
    "agentAuthorityEnvelopeRef",
    "agentRevocationStateRef",
    "authorizationDecisionResultRef",
    "decisionOutcome",
    "finalActionPermitted",
    "humanApprovalRequired",
    "policyChecks",
    "blockedActionTraceRefs",
    "resultQualificationRefs",
    "noSilentDelegationApplied"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentauthorizationdecisiontrace.v0.1"
    },
    "agentAuthorizationDecisionTraceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "traceparent": {
      "type": "string"
    },
    "tracestate": {
      "type": "string"
    },
    "agentSponsorRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "executingAgentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "softwareAgentProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestedActionClass": {
      "type": "string",
      "pattern": "^[A-Z0-9_:-]+$"
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef",
        "targetTime"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "targetTime": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "twinContext": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "NONE"
      ]
    },
    "authoritySnapshotRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentActorshipBindingRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentAuthorityEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentRevocationStateRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "authorizationDecisionResultRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "approvalRefsRequired": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "approvalRefsObtained": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "decisionOutcome": {
      "enum": [
        "ALLOW",
        "DENY",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL"
      ]
    },
    "finalActionPermitted": {
      "type": "boolean"
    },
    "humanApprovalRequired": {
      "type": "boolean"
    },
    "policyChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "checkId",
          "checkKind",
          "outcome"
        ],
        "properties": {
          "checkId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "checkKind": {
            "enum": [
              "SPONSOR_PRESENT",
              "AUTHORITY_SNAPSHOT_PRESENT",
              "ACTION_CLASS_POSTURE",
              "REVOCATION_RECHECK",
              "HUMAN_APPROVAL",
              "TWIN_CONTEXT",
              "TARGET_SCOPE",
              "NO_SILENT_DELEGATION",
              "RESULT_QUALIFICATION_LINKED"
            ]
          },
          "outcome": {
            "enum": [
              "PASS",
              "FAIL",
              "REQUIRE_REVIEW"
            ]
          },
          "reason": {
            "type": "string"
          },
          "basisRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:/#-]+$"
            }
          }
        }
      }
    },
    "blockedActionTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "resultQualificationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "noSilentDelegationApplied": {
      "const": true
    },
    "reasonSummary": {
      "type": "string"
    }
  },
  "$comment": "Trace of the software-agent authority decision; complements existing AuthorizationDecisionTrace for agent-specific actorship context."
}
