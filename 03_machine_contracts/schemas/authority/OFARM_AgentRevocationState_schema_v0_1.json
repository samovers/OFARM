{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-revocation-state/v0.1",
  "title": "OFARM AgentRevocationState v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentRevocationStateId",
    "evaluatedAt",
    "executingAgentInstanceRef",
    "agentSponsorRef",
    "authorityEnvelopeRef",
    "revocationResult",
    "revocationRefs",
    "recheckRequiredBeforeAction",
    "authorityUsable"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentrevocationstate.v0.1"
    },
    "agentRevocationStateId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "executingAgentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentSponsorRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "authorityEnvelopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "revocationResult": {
      "enum": [
        "NONE_APPLICABLE",
        "NO_ACTIVE_REVOCATION",
        "ACTIVE_REVOCATION_FOUND",
        "EXPIRED_AUTHORITY",
        "UNKNOWN_REQUIRES_REVIEW"
      ]
    },
    "revocationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "revokedAuthorityRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "recheckRequiredBeforeAction": {
      "const": true
    },
    "authorityUsable": {
      "type": "boolean"
    },
    "reason": {
      "type": "string"
    },
    "nextRequiredDisposition": {
      "enum": [
        "ALLOW",
        "DENY",
        "REQUIRE_REVIEW",
        "REQUIRE_HUMAN_APPROVAL"
      ]
    }
  },
  "$comment": "Captures revocation posture for an agent authority check."
}
