{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/datasovereigntyboundary/v0.1",
  "title": "OFARM DataSovereigntyBoundary v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a77.16 and the Governance Object Closure RFC v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "dataSovereigntyBoundaryId",
    "boundaryScope",
    "owningPartyRef",
    "effectiveFrom",
    "defaultTruthControl",
    "crossFarmSharingDefault",
    "regionalIntelligenceDefaultTwin",
    "boundaryState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.datasovereigntyboundary.v0.1"
    },
    "dataSovereigntyBoundaryId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "boundaryScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "owningPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date-time"
    },
    "effectiveUntil": {
      "type": "string",
      "format": "date-time"
    },
    "defaultTruthControl": {
      "enum": [
        "FARM_SIDE_AUTHORITY",
        "EXTERNAL_RULE_OVERRIDE_REQUIRED"
      ]
    },
    "crossFarmSharingDefault": {
      "enum": [
        "EXPLICIT_GRANT_REQUIRED",
        "LAW_OR_CONTRACT_EXCEPTION"
      ]
    },
    "regionalIntelligenceDefaultTwin": {
      "enum": [
        "ADVISORY",
        "GOVERNED_EXCEPTION"
      ]
    },
    "strongerRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "boundaryState": {
      "enum": [
        "ACTIVE",
        "RETIRED",
        "DRAFT"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
