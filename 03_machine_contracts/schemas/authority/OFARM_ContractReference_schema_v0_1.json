{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/contractreference/v0.1",
  "title": "OFARM ContractReference v0.1",
  "$comment": "Exchange-boundary reference contract promoted by OFARM Exchange Boundary Starter Contracts RFC v0.1. This object links OFARM parties/scopes/outputs to an external contract or equivalent commercial commitment. It does not create authority, delivery acceptance, settlement, or payment truth.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "scopeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    }
  },
  "required": [
    "schemaVersion",
    "contractReferenceId",
    "externalSystemRef",
    "contractType",
    "contractIdentifier",
    "validFrom",
    "referencePosture"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.contractreference.v0.1"
    },
    "contractReferenceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "externalSystemRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "contractType": {
      "type": "string",
      "minLength": 1
    },
    "contractIdentifier": {
      "type": "string",
      "minLength": 1
    },
    "contractVersionOrDate": {
      "type": "string",
      "minLength": 1
    },
    "linkedPartyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "linkedScopes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scopeRef"
      }
    },
    "linkedOutputRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "referencePosture": {
      "enum": [
        "REFERENCE_ONLY",
        "EVIDENCE_LINKED",
        "ACCESS_CONTEXT_ONLY"
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "anyOf": [
    {
      "required": [
        "linkedPartyRefs"
      ]
    },
    {
      "required": [
        "linkedScopes"
      ]
    },
    {
      "required": [
        "linkedOutputRefs"
      ]
    }
  ]
}
