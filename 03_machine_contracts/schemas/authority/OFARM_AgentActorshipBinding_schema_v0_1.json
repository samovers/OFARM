{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-actorship-binding/v0.1",
  "title": "OFARM AgentActorshipBinding v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentActorshipBindingId",
    "boundAt",
    "agentSponsorRef",
    "softwareAgentProfileRef",
    "agentInstanceRef",
    "agentModelToolProfileRef",
    "actorshipBasis",
    "authoritySnapshotRef",
    "permittedAuthorityActionClasses",
    "humanGovernedDefaultActionClasses",
    "prohibitedActionClasses",
    "bindingState",
    "noSilentDelegation",
    "notAuthorityGrant"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentactorshipbinding.v0.1"
    },
    "agentActorshipBindingId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "boundAt": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "agentSponsorRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "softwareAgentProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentModelToolProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "actorshipBasis": {
      "enum": [
        "SPONSOR_BOUND",
        "EXPLICIT_AUTHORITY_GRANT",
        "EXPLICIT_DELEGATION_GRANT",
        "HUMAN_APPROVED_RUN",
        "NO_AUTHORITY_AVAILABLE"
      ]
    },
    "authoritySnapshotRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "permittedAuthorityActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "humanGovernedDefaultActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "prohibitedActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "bindingState": {
      "enum": [
        "ACTIVE",
        "SUSPENDED",
        "REVOKED",
        "EXPIRED",
        "DRAFT"
      ]
    },
    "noSilentDelegation": {
      "const": true
    },
    "notAuthorityGrant": {
      "const": true
    }
  },
  "$comment": "Binding of sponsor, profile, instance, model/tool basis, and authority snapshot. This binding is not an AuthorityGrant."
}
