{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/software-agent-profile/v0.1",
  "title": "OFARM SoftwareAgentProfile v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "softwareAgentProfileId",
    "displayName",
    "agentKind",
    "purpose",
    "ownerProductRef",
    "sponsorRequired",
    "defaultHumanGovernedPosture",
    "permittedOperationClasses",
    "prohibitedActionClasses",
    "profileState",
    "notAuthorityGrant"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.softwareagentprofile.v0.1"
    },
    "softwareAgentProfileId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "displayName": {
      "type": "string"
    },
    "agentKind": {
      "enum": [
        "ASSISTANT_AGENT",
        "WORKFLOW_AGENT",
        "SCOUTING_AGENT",
        "COMPLIANCE_STEWARD_AGENT",
        "DATA_IMPORT_AGENT",
        "SHARING_AGENT",
        "OTHER"
      ]
    },
    "purpose": {
      "type": "string"
    },
    "ownerProductRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "modelToolProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "publicOperationDescriptorRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "sponsorRequired": {
      "const": true
    },
    "defaultHumanGovernedPosture": {
      "enum": [
        "REVIEW_ACCEPTANCE",
        "PACK_ACTIVATION",
        "OUTPUT_APPROVAL",
        "ATTESTATION",
        "FILING_SUBMISSION",
        "HIGH_CONSEQUENCE_PROMOTION",
        "AUTHORITY_OR_SHARING_EXPANSION"
      ]
    },
    "permittedOperationClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "prohibitedActionClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_:-]+$"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supportPolicyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "profileState": {
      "enum": [
        "ACTIVE",
        "SUSPENDED",
        "REVOKED",
        "EXPIRED",
        "DRAFT"
      ]
    },
    "notAuthorityGrant": {
      "const": true
    }
  },
  "$comment": "A software-agent profile describes a governed agent type; it is not an AuthorityGrant."
}
