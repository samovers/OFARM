{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-instance/v0.1",
  "title": "OFARM AgentInstance v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentInstanceId",
    "softwareAgentProfileRef",
    "deploymentRef",
    "instantiatedAt",
    "runtimeEnvironment",
    "instanceState",
    "sponsorRequired",
    "authorityBoundAtRuntime"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentinstance.v0.1"
    },
    "agentInstanceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "softwareAgentProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "deploymentRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "tenantRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sessionRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "instantiatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "runtimeEnvironment": {
      "enum": [
        "PRODUCTION",
        "STAGING",
        "SANDBOX",
        "TEST",
        "LOCAL"
      ]
    },
    "instanceState": {
      "enum": [
        "ACTIVE",
        "SUSPENDED",
        "REVOKED",
        "EXPIRED",
        "TEST_ONLY"
      ]
    },
    "currentModelToolProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "configuredPublicOperationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "allowedTwinContexts": {
      "type": "array",
      "items": {
        "enum": [
          "COMPLIANCE",
          "ADVISORY",
          "BOTH"
        ]
      }
    },
    "sponsorRequired": {
      "const": true
    },
    "authorityBoundAtRuntime": {
      "const": true
    },
    "traceRetentionPolicyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    }
  },
  "$comment": "A deployed instance is not authority by itself; authority is evaluated at runtime."
}
