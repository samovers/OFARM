{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-sponsor-ref/v0.1",
  "title": "OFARM AgentSponsorRef v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentSponsorRefId",
    "sponsorPartyRef",
    "sponsorRole",
    "accountabilityScope",
    "validFrom",
    "sponsorState",
    "revocationCheckRequired"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentsponsorref.v0.1"
    },
    "agentSponsorRefId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sponsorPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sponsorRole": {
      "enum": [
        "FARM_OPERATOR",
        "BENEFICIAL_OWNER",
        "SERVICE_PROVIDER",
        "CERTIFIER",
        "PLATFORM_OPERATOR",
        "DATA_CONTROLLER",
        "OTHER"
      ]
    },
    "accountabilityScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        }
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validTo": {
      "type": "string",
      "format": "date-time"
    },
    "sponsorState": {
      "enum": [
        "ACTIVE",
        "SUSPENDED",
        "REVOKED",
        "EXPIRED"
      ]
    },
    "delegatedByAuthorityGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "dataSovereigntyBoundaryRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "revocationCheckRequired": {
      "const": true
    }
  },
  "$comment": "Identifies the accountable sponsor/controller for a software-agent action."
}
