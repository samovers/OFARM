{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/crossplatformgrantreceipt/v0.1",
  "title": "OFARM CrossPlatformGrantReceipt v0.1",
  "$comment": "Exchange-boundary receipt contract promoted by OFARM Exchange Boundary Starter Contracts RFC v0.1. This object records that an OFARM grant was externalised or consumed by a sister platform. It never becomes independent authority and must remain revocation-sensitive to the underlying source grant.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "scopeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    }
  },
  "required": [
    "schemaVersion",
    "crossPlatformGrantReceiptId",
    "sourceGrantFamily",
    "sourceGrantRef",
    "externalPlatformRef",
    "issuedAt",
    "deliveryMode",
    "revocationCheckPosture",
    "receiptState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.crossplatformgrantreceipt.v0.1"
    },
    "crossPlatformGrantReceiptId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceGrantFamily": {
      "enum": [
        "AUTHORITY_GRANT",
        "DELEGATION_GRANT",
        "SHARING_GRANT"
      ]
    },
    "sourceGrantRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "externalPlatformRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "linkedScopes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scopeRef"
      }
    },
    "linkedArtifactRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "externalCredentialOrTokenRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "deliveryMode": {
      "enum": [
        "VIEW_LINK",
        "EXPORT_RECEIPT",
        "API_TOKEN",
        "WEBHOOK_BINDING",
        "OUT_OF_BAND"
      ]
    },
    "revocationCheckPosture": {
      "enum": [
        "MUST_RECHECK_SOURCE_GRANT",
        "RECHECK_ON_USE",
        "EXPIRES_WITH_SOURCE"
      ]
    },
    "receiptState": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "STALE",
        "REVOKED",
        "EXPIRED"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
