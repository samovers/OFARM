{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-authority-envelope/v0.1",
  "title": "OFARM AgentAuthorityEnvelope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentAuthorityEnvelopeId",
    "evaluatedAt",
    "executingAgentInstanceRef",
    "softwareAgentProfileRef",
    "agentSponsorRef",
    "requestedActionClass",
    "actionStage",
    "targetScope",
    "twinContext",
    "authoritySnapshotRef",
    "actorshipBasis",
    "authorizationDecisionResultRef",
    "authorizationDecisionTraceRef",
    "revocationStateRef",
    "finalActionPermitted",
    "humanApprovalRequired",
    "nonDelegationDefault"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentauthorityenvelope.v0.1"
    },
    "agentAuthorityEnvelopeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "executingAgentInstanceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "softwareAgentProfileRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentSponsorRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "agentActorshipBindingRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "requestedActionClass": {
      "type": "string",
      "pattern": "^[A-Z0-9_:-]+$"
    },
    "actionStage": {
      "enum": [
        "DRAFT_PREPARATION",
        "PREFLIGHT_ONLY",
        "PROMOTION",
        "PUBLICATION",
        "ATTESTATION",
        "QUERY_READ",
        "CURRENT_STATE_USE",
        "CONTEXT_ACTIVATION",
        "SHARING",
        "FILING_SUBMISSION"
      ]
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef",
        "targetTime"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "targetTime": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "twinContext": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY",
        "BOTH",
        "NONE"
      ]
    },
    "authoritySnapshotRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "actorshipBasis": {
      "enum": [
        "SPONSOR_BOUND",
        "EXPLICIT_AUTHORITY_GRANT",
        "EXPLICIT_DELEGATION_GRANT",
        "HUMAN_APPROVED_RUN",
        "NO_AUTHORITY_AVAILABLE"
      ]
    },
    "authorityGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "delegationGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "sharingGrantRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "authorizationDecisionResultRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "authorizationDecisionTraceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "revocationStateRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "approvalRefsRequired": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "approvalRefsObtained": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "finalActionPermitted": {
      "type": "boolean"
    },
    "humanApprovalRequired": {
      "type": "boolean"
    },
    "nonDelegationDefault": {
      "const": true
    },
    "resultQualificationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    }
  },
  "$comment": "Evaluated authority envelope for a specific software-agent action."
}
