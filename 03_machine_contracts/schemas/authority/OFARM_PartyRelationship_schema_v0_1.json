{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/partyrelationship/v0.1",
  "title": "OFARM PartyRelationship v0.1",
  "$comment": "Durable relationship-basis contract promoted by OFARM Durable Relationship Semantics RFC v0.1. Relationship artifacts are context/basis only and do not by themselves grant authority, delegation, sharing, or compliance truth.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "scopeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    }
  },
  "required": [
    "schemaVersion",
    "partyRelationshipId",
    "relationshipKind",
    "partyARef",
    "partyBRef",
    "relationshipDirectionality",
    "validFrom",
    "relationshipState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.partyrelationship.v0.1"
    },
    "partyRelationshipId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "relationshipKind": {
      "enum": [
        "COOPERATIVE_MEMBERSHIP",
        "COOPERATIVE_ADMIN",
        "EMPLOYMENT",
        "CONTRACTED_SERVICE",
        "ADVISOR_RETAINED_BY",
        "POOLED_RESPONSIBILITY_PARTICIPANT"
      ]
    },
    "partyARef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "partyBRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "relationshipDirectionality": {
      "enum": [
        "PARTY_A_TO_PARTY_B",
        "PARTY_B_TO_PARTY_A",
        "MUTUAL",
        "UNDIRECTED"
      ]
    },
    "anchorScopes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scopeRef"
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "relationshipState": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUSPENDED",
        "TERMINATED",
        "EXPIRED"
      ]
    },
    "membershipClass": {
      "type": "string",
      "minLength": 1
    },
    "memberSince": {
      "type": "string",
      "format": "date-time"
    },
    "brandingParticipationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "adminRoleType": {
      "type": "string",
      "minLength": 1
    },
    "appointingBasisRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "employerPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "workScopes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scopeRef"
      }
    },
    "supervisorPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "serviceType": {
      "type": "string",
      "minLength": 1
    },
    "customerPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "serviceScopeRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scopeRef"
      }
    },
    "serviceContractRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "poolGroupRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "externalBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
