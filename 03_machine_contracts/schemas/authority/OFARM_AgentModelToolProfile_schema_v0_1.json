{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agent-model-tool-profile/v0.1",
  "title": "OFARM AgentModelToolProfile v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentModelToolProfileId",
    "modelRefs",
    "toolRefs",
    "capabilityManifestRefs",
    "riskClasses",
    "untrustedDescriptorHandling",
    "profileState",
    "manifestDoesNotGrantAuthority"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agentmodeltoolprofile.v0.1"
    },
    "agentModelToolProfileId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "modelRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "toolRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "capabilityManifestRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "publicOperationDescriptorRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "toolManifestRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "riskClasses": {
      "type": "array",
      "items": {
        "enum": [
          "LOW",
          "MEDIUM",
          "HIGH",
          "HIGH_CONSEQUENCE",
          "STATE_AFFECTING",
          "EXTERNAL_CALL",
          "DATA_EXPORT"
        ]
      }
    },
    "knownLimitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "untrustedDescriptorHandling": {
      "enum": [
        "VALIDATE_BEFORE_USE",
        "REQUIRE_TRUSTED_SERVER",
        "REQUIRE_HUMAN_CONFIRMATION",
        "PROHIBIT_SENSITIVE_USE"
      ]
    },
    "profileState": {
      "enum": [
        "ACTIVE",
        "SUSPENDED",
        "REVOKED",
        "EXPIRED",
        "DRAFT"
      ]
    },
    "lastVerifiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "manifestDoesNotGrantAuthority": {
      "const": true
    }
  },
  "$comment": "Describes model/tool basis; it does not grant authority or prove safety."
}
