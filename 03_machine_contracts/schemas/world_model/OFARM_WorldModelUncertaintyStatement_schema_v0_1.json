{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-uncertainty-statement-v0-1",
  "title": "OFARM WorldModelUncertaintyStatement v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelUncertaintyStatementId",
    "uncertaintySummary",
    "uncertaintyMethod",
    "variableUncertainty",
    "limitations",
    "advisoryOnly"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodeluncertaintystatement.v0.1"
    },
    "worldModelUncertaintyStatementId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "uncertaintySummary": {
      "type": "string",
      "minLength": 1
    },
    "uncertaintyMethod": {
      "enum": [
        "QUALITATIVE",
        "QUANTITATIVE_INTERVAL",
        "MODEL_REPORTED",
        "EXPERT_JUDGMENT",
        "MIXED",
        "UNKNOWN"
      ]
    },
    "variableUncertainty": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "variable",
          "uncertaintyKind",
          "level",
          "note"
        ],
        "properties": {
          "variable": {
            "type": "string",
            "minLength": 1
          },
          "uncertaintyKind": {
            "enum": [
              "CONFIDENCE",
              "INTERVAL",
              "SOURCE_LIMITATION",
              "MODEL_LIMITATION",
              "FRESHNESS_LIMITATION",
              "OTHER"
            ]
          },
          "level": {
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "UNKNOWN"
            ]
          },
          "interval": {
            "type": "string"
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "advisoryOnly": {
      "const": true
    }
  },
  "description": "Machine-readable uncertainty and limitations for world-model runs and states."
}
