{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-state-v0-1",
  "title": "OFARM WorldModelState v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelStateId",
    "parentWorldModelRunRef",
    "twinRef",
    "scenarioRef",
    "stateKind",
    "stateTimestamp",
    "horizonStart",
    "horizonEnd",
    "variables",
    "units",
    "uncertaintyByVariable",
    "provenanceSplit",
    "validityWindowRef",
    "invalidationStatus",
    "invalidationReason",
    "reconciliationStatus",
    "advisoryOnly",
    "bridgeStatus",
    "currentStateMaterializationRef",
    "noCurrentStateMutation"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelstate.v0.1"
    },
    "worldModelStateId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "parentWorldModelRunRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "twinRef": {
      "const": "ADVISORY"
    },
    "scenarioRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "stateKind": {
      "enum": [
        "SIMULATED",
        "PREDICTED",
        "COUNTERFACTUAL",
        "SENSITIVITY",
        "RISK_STATE",
        "OTHER"
      ]
    },
    "stateTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "horizonStart": {
      "type": "string",
      "format": "date-time"
    },
    "horizonEnd": {
      "type": "string",
      "format": "date-time"
    },
    "variables": {
      "type": "object",
      "minProperties": 1
    },
    "units": {
      "type": "object"
    },
    "uncertaintyByVariable": {
      "type": "object",
      "minProperties": 1
    },
    "provenanceSplit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observedInputs",
        "modelAssumptions",
        "modelDerivedOutputs"
      ],
      "properties": {
        "observedInputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        },
        "modelAssumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        },
        "modelDerivedOutputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        }
      }
    },
    "validityWindowRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "invalidationStatus": {
      "enum": [
        "VALID_WITHIN_WINDOW",
        "INVALIDATED",
        "EXPIRED",
        "REVIEW_REQUIRED",
        "UNKNOWN"
      ]
    },
    "invalidationReason": {
      "type": "string"
    },
    "reconciliationStatus": {
      "enum": [
        "NOT_RECONCILED",
        "MATCHED",
        "PARTIAL_MATCH",
        "DIVERGED",
        "INVALIDATED",
        "REVIEW_REQUIRED"
      ]
    },
    "advisoryOnly": {
      "const": true
    },
    "bridgeStatus": {
      "enum": [
        "NONE",
        "CANDIDATE",
        "ACCEPTED",
        "REJECTED"
      ]
    },
    "currentStateMaterializationRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "noCurrentStateMutation": {
      "const": true
    }
  },
  "description": "Advisory world-model state. State-like shape is not current state and must remain horizon-bound and uncertainty-qualified."
}
