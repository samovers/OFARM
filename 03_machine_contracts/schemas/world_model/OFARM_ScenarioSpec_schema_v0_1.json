{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/scenario-spec-v0-1",
  "title": "OFARM ScenarioSpec v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scenarioSpecId",
    "scenarioName",
    "scenarioType",
    "targetScopeRefs",
    "twinRef",
    "objective",
    "inputBasisRef",
    "assumptionSetRef",
    "simulationHorizon",
    "outputDispositionRef",
    "advisoryOnly"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.scenariospec.v0.1"
    },
    "scenarioSpecId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "scenarioName": {
      "type": "string",
      "minLength": 1
    },
    "scenarioType": {
      "enum": [
        "WHAT_IF",
        "RISK_FORECAST",
        "OPERATIONAL_PLAN",
        "COMPARATIVE_SCENARIO",
        "SENSITIVITY_ANALYSIS",
        "OTHER"
      ]
    },
    "targetScopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "twinRef": {
      "const": "ADVISORY"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "inputBasisRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "assumptionSetRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "simulationHorizon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startsAt",
        "endsAt"
      ],
      "properties": {
        "startsAt": {
          "type": "string",
          "format": "date-time"
        },
        "endsAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "outputDispositionRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "advisoryOnly": {
      "const": true
    }
  },
  "description": "Scenario specification for advisory world-model execution."
}
