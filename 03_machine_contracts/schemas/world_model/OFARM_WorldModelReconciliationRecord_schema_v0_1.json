{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-reconciliation-record-v0-1",
  "title": "OFARM WorldModelReconciliationRecord v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelReconciliationRecordId",
    "worldModelRunRef",
    "observedOutcomeRefs",
    "reconciliationStatus",
    "differences",
    "invalidationStatus",
    "governanceOutcome",
    "noSilentPromotion"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelreconciliationrecord.v0.1"
    },
    "worldModelReconciliationRecordId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "worldModelRunRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "observedOutcomeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "reconciliationStatus": {
      "enum": [
        "NOT_RECONCILED",
        "MATCHED",
        "PARTIAL_MATCH",
        "DIVERGED",
        "INVALIDATED",
        "REVIEW_REQUIRED"
      ]
    },
    "differences": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "invalidationStatus": {
      "enum": [
        "NOT_INVALIDATED",
        "INVALIDATED",
        "REVIEW_REQUIRED",
        "UNKNOWN"
      ]
    },
    "governanceOutcome": {
      "enum": [
        "ADVISORY_RETAINED",
        "QUALIFIED",
        "REVIEW_REQUIRED",
        "BLOCKED",
        "BRIDGE_CANDIDATE_CREATED",
        "NO_GOVERNED_USE"
      ]
    },
    "noSilentPromotion": {
      "const": true
    }
  },
  "description": "Reconciles advisory world-model output with later observed outcomes without silently promoting model state into truth."
}
