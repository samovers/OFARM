{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-assumption-set-v0-1",
  "title": "OFARM WorldModelAssumptionSet v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelAssumptionSetId",
    "scenarioRef",
    "createdAt",
    "assumptions",
    "uncertaintyStatementRefs",
    "advisoryOnly",
    "notEvidence",
    "notCurrentState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelassumptionset.v0.1"
    },
    "worldModelAssumptionSetId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "scenarioRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByAgentRunRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assumptionId",
          "statement",
          "assumptionType",
          "confidence",
          "invalidatable"
        ],
        "properties": {
          "assumptionId": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "assumptionType": {
            "enum": [
              "WEATHER",
              "SOIL",
              "PEST_DISEASE",
              "MARKET",
              "OPERATIONAL",
              "MODEL_PARAMETER",
              "OTHER"
            ]
          },
          "sourceRef": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "confidence": {
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "UNKNOWN"
            ]
          },
          "invalidatable": {
            "type": "boolean"
          },
          "invalidationRuleRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9._:/#-]+$"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "uncertaintyStatementRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "advisoryOnly": {
      "const": true
    },
    "notEvidence": {
      "const": true
    },
    "notCurrentState": {
      "const": true
    }
  },
  "description": "Assumptions for an advisory world-model run. Assumptions are not evidence and not current state."
}
