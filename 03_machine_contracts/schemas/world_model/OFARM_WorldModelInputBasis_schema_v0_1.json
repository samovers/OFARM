{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-input-basis-v0-1",
  "title": "OFARM WorldModelInputBasis v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelInputBasisId",
    "observationBasisRefs",
    "assumptionSetRef",
    "sourceFidelityEnvelopeRefs",
    "freshnessSnapshotRef",
    "currentStateMaterializationRefs",
    "usedCurrentStateAsInputOnly",
    "notTruthByItself"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelinputbasis.v0.1"
    },
    "worldModelInputBasisId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "observationBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "assumptionSetRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sourceFidelityEnvelopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "freshnessSnapshotRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "currentStateMaterializationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "usedCurrentStateAsInputOnly": {
      "const": true
    },
    "notTruthByItself": {
      "const": true
    }
  },
  "description": "Input basis for advisory world-model runs; current-state materialization may be input but is not mutated by this artifact."
}
