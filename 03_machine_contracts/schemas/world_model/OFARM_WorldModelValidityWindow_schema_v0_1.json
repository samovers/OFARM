{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-validity-window-v0-1",
  "title": "OFARM WorldModelValidityWindow v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelValidityWindowId",
    "startsAt",
    "endsAt",
    "validityBasis",
    "invalidationRuleRefs",
    "requiresRevalidationOnStateChange"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelvaliditywindow.v0.1"
    },
    "worldModelValidityWindowId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "startsAt": {
      "type": "string",
      "format": "date-time"
    },
    "endsAt": {
      "type": "string",
      "format": "date-time"
    },
    "validityBasis": {
      "type": "string",
      "minLength": 1
    },
    "invalidationRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "requiresRevalidationOnStateChange": {
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "description": "Validity window for advisory world-model outputs. Validity is bounded and can be invalidated by later observations or governance changes."
}
