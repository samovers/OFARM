{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-invalidation-rule-v0-1",
  "title": "OFARM WorldModelInvalidationRule v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelInvalidationRuleId",
    "triggerType",
    "triggerDescription",
    "requiredDisposition",
    "revalidationRequired"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelinvalidationrule.v0.1"
    },
    "worldModelInvalidationRuleId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "triggerType": {
      "enum": [
        "NEW_OBSERVATION",
        "FRESHNESS_EXPIRED",
        "MODEL_VERSION_CHANGED",
        "ASSUMPTION_REJECTED",
        "AUTHORITY_OR_SHARING_CHANGED",
        "PACK_CONTEXT_CHANGED",
        "MANUAL_REVIEW",
        "OTHER"
      ]
    },
    "triggerDescription": {
      "type": "string",
      "minLength": 1
    },
    "invalidatesRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "requiredDisposition": {
      "enum": [
        "MARK_INVALID",
        "REVIEW_REQUIRED",
        "RERUN_REQUIRED",
        "QUALIFY_RESULT",
        "BLOCK_HARDER_USE"
      ]
    },
    "revalidationRequired": {
      "const": true
    }
  },
  "description": "Rule describing how a later observation, authority change, model update, or other trigger invalidates an advisory world-model result."
}
