{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-governance-blocker-v0-1",
  "title": "OFARM WorldModelGovernanceBlocker v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelGovernanceBlockerId",
    "blockerType",
    "reason",
    "blockedUse",
    "requiredNextGate",
    "resultQualificationRef",
    "traceRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelgovernanceblocker.v0.1"
    },
    "worldModelGovernanceBlockerId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "blockerType": {
      "enum": [
        "ADVISORY_ONLY",
        "EVIDENCE_INSUFFICIENT",
        "FRESHNESS_STALE",
        "AUTHORITY_MISSING",
        "SHARING_RESTRICTED",
        "INVALIDATED",
        "NO_ACCEPTED_BRIDGE",
        "PACK_CONTEXT_BLOCKER",
        "OTHER"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "blockedUse": {
      "enum": [
        "CURRENT_STATE_MATERIALIZATION",
        "COMPLIANCE_PROMOTION",
        "OFFICIAL_OUTPUT",
        "SHARING",
        "PUBLIC_SURFACE",
        "AUTONOMOUS_ACTION",
        "OTHER"
      ]
    },
    "requiredNextGate": {
      "type": "string",
      "minLength": 1
    },
    "resultQualificationRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "traceRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    }
  },
  "description": "Traceable blocker explaining why advisory world-model material cannot be used for a harder governance purpose."
}
