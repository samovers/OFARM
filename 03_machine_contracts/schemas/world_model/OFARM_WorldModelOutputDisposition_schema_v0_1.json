{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-output-disposition-v0-1",
  "title": "OFARM WorldModelOutputDisposition v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelOutputDispositionId",
    "disposition",
    "permittedUseNotes",
    "prohibitedUseNotes",
    "requiresBridgeForComplianceUse",
    "advisoryOnly"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodeloutputdisposition.v0.1"
    },
    "worldModelOutputDispositionId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "disposition": {
      "enum": [
        "HYPOTHESIS",
        "RISK_FLAG",
        "SCENARIO_RESULT",
        "DRAFT_PLAN",
        "EVIDENCE_NEED_CANDIDATE",
        "OBSERVATION_REQUEST_CANDIDATE",
        "BRIDGE_CANDIDATE",
        "NO_GOVERNED_USE"
      ]
    },
    "permittedUseNotes": {
      "type": "string",
      "minLength": 1
    },
    "prohibitedUseNotes": {
      "type": "string",
      "minLength": 1
    },
    "requiresBridgeForComplianceUse": {
      "const": true
    },
    "advisoryOnly": {
      "const": true
    }
  },
  "description": "Disposition for world-model outputs; harder compliance use requires an explicit bridge and existing governance gates."
}
