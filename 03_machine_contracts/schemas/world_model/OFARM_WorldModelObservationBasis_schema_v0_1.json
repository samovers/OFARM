{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-observation-basis-v0-1",
  "title": "OFARM WorldModelObservationBasis v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelObservationBasisId",
    "observationRefs",
    "evidenceRefs",
    "observedAt",
    "freshnessStatus",
    "provenanceSplit",
    "observationLimitations",
    "notEvidenceByItself"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelobservationbasis.v0.1"
    },
    "worldModelObservationBasisId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "observationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "observedAt": {
      "type": "string",
      "format": "date-time"
    },
    "freshnessStatus": {
      "enum": [
        "FRESH",
        "STALE",
        "UNKNOWN",
        "MIXED"
      ]
    },
    "provenanceSplit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observedInputs",
        "modelAssumptions",
        "modelDerivedOutputs"
      ],
      "properties": {
        "observedInputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        },
        "modelAssumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        },
        "modelDerivedOutputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        }
      }
    },
    "observationLimitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "notEvidenceByItself": {
      "const": true
    }
  },
  "description": "Observed basis used as input to an advisory world-model run. It preserves provenance split and does not itself create new evidence."
}
