{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/world-model-run-v0-1",
  "title": "OFARM WorldModelRun v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "worldModelRunId",
    "twinRef",
    "scenarioRef",
    "scenarioType",
    "modelRef",
    "modelVersion",
    "modelCardRef",
    "calibrationPackRef",
    "inputBasisRef",
    "assumptionSetRef",
    "parameterOverrides",
    "runTimestamp",
    "simulationHorizon",
    "validityWindowRef",
    "uncertaintyStatementRef",
    "invalidationRuleRefs",
    "reconciliationPlanRef",
    "outputDispositionRefs",
    "governanceBlockerRefs",
    "advisoryOnly",
    "currentStateBridgeRef",
    "publicSurfacePolicyRef",
    "resultQualificationRef",
    "noCurrentStateMutation",
    "runtimeConformanceClaimed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.worldmodelrun.v0.1"
    },
    "worldModelRunId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "twinRef": {
      "const": "ADVISORY"
    },
    "scenarioRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "scenarioType": {
      "enum": [
        "WHAT_IF",
        "RISK_FORECAST",
        "OPERATIONAL_PLAN",
        "COMPARATIVE_SCENARIO",
        "SENSITIVITY_ANALYSIS",
        "OTHER"
      ]
    },
    "modelRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "modelVersion": {
      "type": "string",
      "minLength": 1
    },
    "modelCardRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "calibrationPackRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "inputBasisRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "assumptionSetRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "parameterOverrides": {
      "type": "object"
    },
    "runTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "simulationHorizon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startsAt",
        "endsAt"
      ],
      "properties": {
        "startsAt": {
          "type": "string",
          "format": "date-time"
        },
        "endsAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "validityWindowRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "uncertaintyStatementRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "invalidationRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "reconciliationPlanRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "outputDispositionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      },
      "minItems": 1
    },
    "governanceBlockerRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "advisoryOnly": {
      "const": true
    },
    "currentStateBridgeRef": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "publicSurfacePolicyRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "resultQualificationRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "noCurrentStateMutation": {
      "const": true
    },
    "runtimeConformanceClaimed": {
      "const": false
    }
  },
  "description": "Governed advisory world-model execution. It cannot mutate current state and cannot claim runtime readiness by schema conformance alone."
}
