{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/scenario-result-set-v0-1",
  "title": "OFARM ScenarioResultSet v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scenarioResultSetId",
    "scenarioSpecRef",
    "worldModelRunRef",
    "resultItems",
    "uncertaintyStatementRef",
    "outputDispositionRef",
    "resultQualificationRef",
    "advisoryOnly"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.scenarioresultset.v0.1"
    },
    "scenarioResultSetId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "scenarioSpecRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "worldModelRunRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "resultItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "resultItemId",
          "summary",
          "basisRef"
        ],
        "properties": {
          "resultItemId": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "basisRef": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "score": {
            "type": "number"
          }
        }
      }
    },
    "uncertaintyStatementRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "outputDispositionRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "resultQualificationRef": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "advisoryOnly": {
      "const": true
    }
  },
  "description": "Result set from an advisory scenario; results remain advisory unless separately bridged and accepted."
}
