{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/packmergepolicy/v0.1",
  "title": "OFARM PackMergePolicy v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a76.14, the Pack Merge Semantics RFC v0.1, and the Governance Object Closure RFC v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packMergePolicyId",
    "declaredAt",
    "declaringPartyRef",
    "appliesToPackRefs",
    "surfaceFamily",
    "mergeMode",
    "targetScope",
    "policyState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.packmergepolicy.v0.1"
    },
    "packMergePolicyId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "declaredAt": {
      "type": "string",
      "format": "date-time"
    },
    "declaringPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "appliesToPackRefs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "surfaceFamily": {
      "enum": [
        "VOCABULARY_BINDINGS",
        "EVIDENCE_POLICY",
        "ARCHETYPE_DEFINITION",
        "TEMPLATE_CONSTRAINT",
        "VALIDATION_RULE",
        "DECISION_RULE",
        "EVENT_SUBTYPE_DEFINITION",
        "VIEW_SHAPING",
        "DOCUMENT_ASSEMBLY_SHAPING"
      ]
    },
    "mergeMode": {
      "enum": [
        "ADDITIVE_UNION",
        "CONSTRAINT_INTERSECTION",
        "STRONGEST_REQUIREMENT",
        "ORDERED_COMPOSITION",
        "IDENTICAL_ONLY",
        "HARD_FAIL"
      ]
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "compatibilityDeclarationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "policyState": {
      "enum": [
        "ACTIVE",
        "RETIRED",
        "DRAFT"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
