{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/packexclusionrule/v0.1",
  "title": "OFARM PackExclusionRule v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a76.16, the pack safety policy, and the Governance Object Closure RFC v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packExclusionRuleId",
    "declaredAt",
    "declaringPartyRef",
    "excludedPackRefs",
    "targetScope",
    "reason",
    "exclusionState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.packexclusionrule.v0.1"
    },
    "packExclusionRuleId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "declaredAt": {
      "type": "string",
      "format": "date-time"
    },
    "declaringPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "excludedPackRefs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "exclusionState": {
      "enum": [
        "ACTIVE",
        "RETIRED",
        "DRAFT"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
