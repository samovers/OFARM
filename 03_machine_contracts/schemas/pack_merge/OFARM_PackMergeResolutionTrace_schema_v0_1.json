{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/packmergeresolutiontrace/v0.1",
  "title": "OFARM PackMergeResolutionTrace v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a76.15, Pack Merge Semantics RFC v0.1 \u00a77, and Platform RC2.1 \u00a713.9.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "traceId",
    "generatedAt",
    "comparedPackRefs",
    "packActivationSetRef",
    "surfaceFamily",
    "appliedMergeMode",
    "precedenceRelationship",
    "outcome"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.packmergeresolutiontrace.v0.1"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "comparedPackRefs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "packActivationSetRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "surfaceFamily": {
      "enum": [
        "VOCABULARY_BINDINGS",
        "EVIDENCE_POLICY",
        "ARCHETYPE_DEFINITION",
        "TEMPLATE_CONSTRAINT",
        "VALIDATION_RULE",
        "DECISION_RULE",
        "EVENT_SUBTYPE_DEFINITION",
        "VIEW_SHAPING",
        "DOCUMENT_ASSEMBLY_SHAPING"
      ]
    },
    "appliedMergeMode": {
      "enum": [
        "ADDITIVE_UNION",
        "CONSTRAINT_INTERSECTION",
        "STRONGEST_REQUIREMENT",
        "ORDERED_COMPOSITION",
        "IDENTICAL_ONLY",
        "HARD_FAIL"
      ]
    },
    "precedenceRelationship": {
      "type": "string"
    },
    "outcome": {
      "enum": [
        "MERGED",
        "HARD_FAIL",
        "GOVERNANCE_REQUIRED"
      ]
    },
    "reason": {
      "type": "string"
    },
    "packMergePolicyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "compatibilityDeclarationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    }
  }
}
