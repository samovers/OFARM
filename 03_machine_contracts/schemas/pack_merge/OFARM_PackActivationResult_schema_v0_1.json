{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/packactivationresult/v0.1",
  "title": "OFARM PackActivationResult v0.1",
  "$comment": "Minimal boundary result envelope for pack activation derived from Platform RC2.1 \u00a713.6-13.11. It stabilizes outcome, compatibility class, trace links, and failure reporting for this seam.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "resultId",
    "requestId",
    "evaluatedAt",
    "packActivationSetRef",
    "outcome",
    "compatibilityClass",
    "resolvedActivePackRefs",
    "resolvedActiveProfileRefs",
    "mergeResolutionTraceRefs",
    "problems"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.packactivationresult.v0.1"
    },
    "resultId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "packActivationSetRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "outcome": {
      "enum": [
        "ALLOW_ACTIVATION",
        "DENY_ACTIVATION",
        "GOVERNANCE_REQUIRED"
      ]
    },
    "compatibilityClass": {
      "enum": [
        "COMPATIBLE",
        "COMPATIBLE_WITH_DECLARED_MERGE",
        "COMPATIBLE_BY_SCOPE_SEPARATION",
        "EXCLUSIVE",
        "GOVERNANCE_REQUIRED"
      ]
    },
    "resolvedActivePackRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "resolvedActiveProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "mergeResolutionTraceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "activationStateRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "reasonSummary": {
      "type": "string"
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "problemId",
          "severity",
          "reasonCode",
          "title",
          "detail"
        ],
        "properties": {
          "schemaVersion": {
            "const": "ofarm.runtimeproblem.v0.1"
          },
          "problemId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "severity": {
            "enum": [
              "INFO",
              "WARNING",
              "ERROR"
            ]
          },
          "reasonCode": {
            "type": "string",
            "pattern": "^[A-Z0-9_:-]+$"
          },
          "title": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "pointerRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relatedRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "suggestedRemediation": {
            "type": "string"
          }
        }
      }
    },
    "compatibilityDeclarationRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "mergePolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "exclusionRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "ALLOW_ACTIVATION"
          }
        }
      },
      "then": {
        "properties": {
          "compatibilityClass": {
            "enum": [
              "COMPATIBLE",
              "COMPATIBLE_WITH_DECLARED_MERGE",
              "COMPATIBLE_BY_SCOPE_SEPARATION"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "DENY_ACTIVATION"
          }
        }
      },
      "then": {
        "properties": {
          "compatibilityClass": {
            "const": "EXCLUSIVE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "GOVERNANCE_REQUIRED"
          }
        }
      },
      "then": {
        "properties": {
          "compatibilityClass": {
            "const": "GOVERNANCE_REQUIRED"
          }
        }
      }
    }
  ]
}
