{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/packcompatibilitydeclaration/v0.1",
  "title": "OFARM PackCompatibilityDeclaration v0.1",
  "$comment": "Minimal machine contract derived from Constitution RC2.1 \u00a76.12, the pack safety policy, and the Governance Object Closure RFC v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packCompatibilityDeclarationId",
    "declaredAt",
    "declaringPartyRef",
    "evaluatedPackRefs",
    "targetScope",
    "compatibilityClass",
    "declarationState"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.packcompatibilitydeclaration.v0.1"
    },
    "packCompatibilityDeclarationId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "declaredAt": {
      "type": "string",
      "format": "date-time"
    },
    "declaringPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "evaluatedPackRefs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "targetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "compatibilityClass": {
      "enum": [
        "COMPATIBLE",
        "COMPATIBLE_WITH_DECLARED_MERGE",
        "COMPATIBLE_BY_SCOPE_SEPARATION",
        "EXCLUSIVE",
        "GOVERNANCE_REQUIRED"
      ]
    },
    "mergePolicyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "exclusionRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "declarationState": {
      "enum": [
        "ACTIVE",
        "RETIRED",
        "DRAFT"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
