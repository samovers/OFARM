{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/activeartifactset/v0.1",
  "title": "OFARM ActiveArtifactSet v0.1",
  "$comment": "Minimal machine contract for the active artifact/package state already referenced by Capability Manifest RFC v0.1 \u00a76 and Platform RC2.1 \u00a713.4-13.5. It grounds manifest claims in a concrete runtime artifact state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "activeArtifactSetId",
    "generatedAt",
    "deploymentScope",
    "artifactRegistryRef",
    "activePackRefs",
    "activeProfileRefs",
    "activeArtifactRefs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.activeartifactset.v0.1"
    },
    "activeArtifactSetId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "deploymentScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "artifactRegistryRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "activePackRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "activeProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "activeScopedExtensionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "activeArtifactRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "sourcePackActivationSetRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
