{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/semanticpathaliasresolutiontrace/v0.1",
  "title": "OFARM SemanticPathAliasResolutionTrace v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "traceId",
    "sourceQuerySpecificationId",
    "aliasCatalogRef",
    "resolvedAt",
    "overallOutcome",
    "aliasResolutions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.semanticpathaliasresolutiontrace.v0.1"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceQuerySpecificationId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "aliasCatalogRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "contextSnapshotRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "resolutionUseClass": {
      "enum": [
        "HIGH_CONSEQUENCE",
        "NORMAL",
        "EXPLORATORY"
      ]
    },
    "resolvedAt": {
      "type": "string",
      "format": "date-time"
    },
    "overallOutcome": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "aliasResolutions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/aliasResolution"
      }
    }
  },
  "$defs": {
    "warningCode": {
      "enum": [
        "DEPRECATED_ALIAS_VERSION",
        "CANONICAL_SUCCESSOR_APPLIED",
        "HIGH_CONSEQUENCE_PIN_REQUIRED",
        "QUERY_PATH_MISMATCH",
        "AMBIGUOUS_ALIAS",
        "ALIAS_NOT_FOUND"
      ]
    },
    "aliasResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queryAlias",
        "rootVar",
        "queryPathRef",
        "outcome"
      ],
      "properties": {
        "queryAlias": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
        },
        "rootVar": {
          "type": "string",
          "pattern": "^[a-z][A-Za-z0-9_]*$"
        },
        "queryPathRef": {
          "type": "string",
          "pattern": "^/"
        },
        "requestedAliasVersionRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "outcome": {
          "enum": [
            "RESOLVED",
            "RESOLVED_WITH_DEPRECATION",
            "AMBIGUOUS_FAIL",
            "VERSION_PIN_REQUIRED_FAIL",
            "PATH_MISMATCH_FAIL",
            "MISSING_ALIAS_FAIL"
          ]
        },
        "matchedCatalogAliasVersionRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "canonicalAliasVersionRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "resolvedToType": {
          "enum": [
            "SEMANTIC_ANCHOR",
            "GOVERNED_CONTENT_NODE"
          ]
        },
        "resolvedRef": {
          "type": "string"
        },
        "semanticEquivalenceGroupRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warningCode"
          }
        },
        "ambiguityCandidateAliasVersionRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "failureDetail": {
          "type": "string"
        }
      }
    }
  }
}
