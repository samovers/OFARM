{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/queryexecutionresult/v0.1",
  "title": "OFARM QueryExecutionResult v0.1",
  "$comment": "Minimal boundary result envelope for query execution derived from Platform RC2.1 §§7.10-7.11 and 15.3.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "resultId",
    "requestId",
    "evaluatedAt",
    "outcome",
    "querySpecificationRef",
    "queryPlanRef",
    "aliasResolutionTraceRefs",
    "resultShape",
    "resultRef",
    "projectionTraceBackReady",
    "problems",
    "reasonSummary"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.queryexecutionresult.v0.1"
    },
    "resultId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "outcome": {
      "enum": [
        "SUCCESS",
        "REQUIRE_REVIEW",
        "REFUSED"
      ]
    },
    "querySpecificationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "queryPlanRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "aliasResolutionTraceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "authorizationDecisionTraceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "materializationResultRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "resultShape": {
      "enum": [
        "ROW_SET",
        "VIEW_MODEL",
        "COMPILED_OUTPUT_INPUT"
      ]
    },
    "resultRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "outputMetadataRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "projectionTraceBackReady": {
      "type": "boolean"
    },
    "executorRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "reasonSummary": {
      "type": "string"
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "problemId",
          "severity",
          "reasonCode",
          "title",
          "detail"
        ],
        "properties": {
          "schemaVersion": {
            "const": "ofarm.runtimeproblem.v0.1"
          },
          "problemId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "severity": {
            "enum": [
              "INFO",
              "WARNING",
              "ERROR"
            ]
          },
          "reasonCode": {
            "type": "string",
            "pattern": "^[A-Z0-9_:-]+$"
          },
          "title": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "pointerRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relatedRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "suggestedRemediation": {
            "type": "string"
          }
        }
      }
    },
    "reconstructionPolicyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "reconstructionTraceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    }
  }
}
