{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/queryexecutionrequest/v0.1",
  "title": "OFARM QueryExecutionRequest v0.1",
  "$comment": "Minimal boundary request envelope for query entry/execution derived from QuerySpecification RFC v0.1 and Platform RC2.1 §§7 and 15.3.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "requestedAt",
    "requestedByPartyRef",
    "querySpecificationRef",
    "queryPlanRef",
    "targetTwin",
    "anchorScopes",
    "evaluationTimePolicy",
    "contextSnapshotRef",
    "aliasResolutionTraceRefs",
    "requiredFreshness",
    "highConsequenceUse",
    "resultProfile"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.queryexecutionrequest.v0.1"
    },
    "requestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "requestedByPartyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requestedByAgentRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "querySpecificationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "queryPlanRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "targetTwin": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "anchorScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "evaluationTimePolicy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyType"
          ],
          "properties": {
            "policyType": {
              "const": "NOW"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyType",
            "asOfTime"
          ],
          "properties": {
            "policyType": {
              "const": "AS_OF"
            },
            "asOfTime": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyType",
            "windowStart",
            "windowEnd"
          ],
          "properties": {
            "policyType": {
              "const": "WINDOW"
            },
            "windowStart": {
              "type": "string",
              "format": "date-time"
            },
            "windowEnd": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      ]
    },
    "contextSnapshotRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "aliasResolutionTraceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "requiredFreshness": {
      "enum": [
        "REQUIRE_FRESH",
        "ALLOW_STALE_EXPLORATORY",
        "NO_CURRENT_STATE_DEPENDENCY"
      ]
    },
    "highConsequenceUse": {
      "type": "boolean"
    },
    "usePurpose": {
      "type": "string"
    },
    "resultProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "enum": [
            "VIEW_MODULE",
            "ROW_SET",
            "COMPILED_OUTPUT_INPUT"
          ]
        },
        "viewModuleRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "reconstructionPolicyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "resultProfile": {
            "properties": {
              "mode": {
                "const": "VIEW_MODULE"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "resultProfile": {
            "required": [
              "mode",
              "viewModuleRef"
            ]
          }
        }
      }
    }
  ]
}
