{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/semanticpathaliascatalog/v0.1",
  "title": "OFARM SemanticPathAliasCatalog v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "catalogId",
    "governancePolicy",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.semanticpathaliascatalog.v0.1"
    },
    "catalogId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "catalogName": {
      "type": "string"
    },
    "artifactSetRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "contextScopeRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "governancePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requireAliasVersionPinningForHighConsequence",
        "ambiguityHandling",
        "deprecatedResolutionPolicy"
      ],
      "properties": {
        "requireAliasVersionPinningForHighConsequence": {
          "type": "boolean"
        },
        "ambiguityHandling": {
          "enum": [
            "FAIL_HARD"
          ]
        },
        "deprecatedResolutionPolicy": {
          "enum": [
            "ALLOW_EXPLICIT_TRACE_ONLY",
            "DISALLOW"
          ]
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/aliasEntry"
      }
    }
  },
  "$defs": {
    "artifactRefArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "aliasEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aliasName",
        "aliasVersionRef",
        "status",
        "rootConceptRef",
        "pathRef",
        "resolvesToType",
        "resolvedRef",
        "semanticEquivalenceGroupRef",
        "governingArtifactRefs"
      ],
      "properties": {
        "aliasName": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
        },
        "aliasVersionRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "status": {
          "enum": [
            "ACTIVE",
            "DEPRECATED",
            "RETIRED"
          ]
        },
        "rootConceptRef": {
          "type": "string"
        },
        "pathRef": {
          "type": "string",
          "pattern": "^/"
        },
        "resolvesToType": {
          "enum": [
            "SEMANTIC_ANCHOR",
            "GOVERNED_CONTENT_NODE"
          ]
        },
        "resolvedRef": {
          "type": "string"
        },
        "expectedType": {
          "type": "string"
        },
        "semanticEquivalenceGroupRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "governingArtifactRefs": {
          "$ref": "#/$defs/artifactRefArray"
        },
        "supersededByAliasVersionRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "deprecationReason": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
