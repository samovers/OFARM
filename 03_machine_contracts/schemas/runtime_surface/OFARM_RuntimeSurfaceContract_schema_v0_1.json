{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ofarm.runtimesurfacecontract.v0.1",
  "title": "OFARM RuntimeSurfaceContract v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractId",
    "status",
    "surfaceKind",
    "direction",
    "protocolFamily",
    "targetStandardRef",
    "semanticPreservationPosture"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.runtimesurfacecontract.v0.1"
    },
    "contractId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "surfaceKind": {
      "enum": [
        "API",
        "EVENT",
        "QUERY_FACADE",
        "DISCOVERY"
      ]
    },
    "direction": {
      "enum": [
        "IMPORT",
        "EXPORT",
        "BIDIRECTIONAL"
      ]
    },
    "protocolFamily": {
      "enum": [
        "HTTP",
        "MESSAGE_BUS",
        "FILE_EXCHANGE",
        "WEBHOOK",
        "OTHER"
      ]
    },
    "targetStandardRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "semanticPreservationPosture": {
      "enum": [
        "PROJECTION_ONLY",
        "LOSS_AWARE",
        "STRUCTURE_PRESERVING"
      ]
    },
    "mappingModuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "serviceDescriptionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "discoveryRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Runtime-surface contract for APIs, events, query facades, and discovery documents."
}
