{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ofarm.conformanceclaimset.v0.1",
  "title": "OFARM ConformanceClaimSet v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "claimSetId",
    "subjectRef",
    "generatedAt",
    "activeArtifactSetRef",
    "claims"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.conformanceclaimset.v0.1"
    },
    "claimSetId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "subjectRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "activeArtifactSetRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claimId",
          "claimFamily",
          "targetRef",
          "status"
        ],
        "properties": {
          "claimId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "claimFamily": {
            "enum": [
              "SEMANTIC_SUBSTRATE",
              "PROFILE",
              "MAPPING",
              "RUNTIME_SURFACE"
            ]
          },
          "targetRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "status": {
            "enum": [
              "DECLARED",
              "PARTIAL",
              "VERIFIED",
              "FAILED"
            ]
          },
          "conformanceClassRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "testSuiteRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "profileRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$comment": "Conformance claim contract for deployment-facing substrate/profile/mapping/runtime-surface claims."
}
