{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/referenceresolutionmanifest/v0.1",
  "title": "OFARM ReferenceResolutionManifest v0.1",
  "$comment": "Declares the scope and policy for semantic reference resolution. Schema validity remains separate from semantic conformance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "referenceResolutionManifestId",
    "issuedAt",
    "scope",
    "packageRootRef",
    "conformanceLevels",
    "targetArtifacts",
    "localResolutionPolicy",
    "externalReferencePolicy",
    "highConsequencePolicy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.referenceresolutionmanifest.v0.1"
    },
    "referenceResolutionManifestId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "packageRootRef": {
      "type": "string",
      "minLength": 1
    },
    "conformanceLevels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "SCHEMA_VALID",
          "PACKAGE_LOCAL_REFERENCES_RESOLVED",
          "EXTERNAL_REFERENCES_DECLARED",
          "EXTERNAL_REFERENCES_VERIFIED",
          "RUNTIME_POLICY_GATES_PASSED",
          "HIGH_CONSEQUENCE_OUTPUT_ELIGIBLE"
        ]
      }
    },
    "targetArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifactGlob",
          "requiredResolution"
        ],
        "properties": {
          "artifactGlob": {
            "type": "string"
          },
          "requiredResolution": {
            "enum": [
              "SCHEMA_ONLY",
              "PACKAGE_LOCAL",
              "EXTERNAL_DECLARED",
              "EXTERNAL_VERIFIED",
              "POLICY_GATE"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "localResolutionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageLocalPrefixes",
        "unresolvedPackageLocalBehavior"
      ],
      "properties": {
        "packageLocalPrefixes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unresolvedPackageLocalBehavior": {
          "enum": [
            "FAIL_CONFORMANCE",
            "REQUIRE_REVIEW",
            "WARN_ONLY"
          ]
        },
        "typeMismatchBehavior": {
          "enum": [
            "FAIL_CONFORMANCE",
            "REQUIRE_REVIEW",
            "WARN_ONLY"
          ]
        }
      }
    },
    "externalReferencePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declaredExternalBehavior",
        "verifiedExternalBehavior",
        "unverifiedHighConsequenceBehavior"
      ],
      "properties": {
        "declaredExternalBehavior": {
          "enum": [
            "ALLOW_AS_INFORMATIONAL",
            "REQUIRE_REVIEW",
            "FAIL_CONFORMANCE"
          ]
        },
        "verifiedExternalBehavior": {
          "enum": [
            "ALLOW_WITH_TRACE",
            "REQUIRE_REVIEW",
            "FAIL_CONFORMANCE"
          ]
        },
        "unverifiedHighConsequenceBehavior": {
          "enum": [
            "REQUIRE_REVIEW",
            "FAIL_CLOSED"
          ]
        }
      }
    },
    "highConsequencePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiresReferenceResolutionReport",
        "requiresAliasResolutionTrace",
        "requiresCodeBindingStatus",
        "requiresFreshnessCheck"
      ],
      "properties": {
        "requiresReferenceResolutionReport": {
          "type": "boolean"
        },
        "requiresAliasResolutionTrace": {
          "type": "boolean"
        },
        "requiresCodeBindingStatus": {
          "type": "boolean"
        },
        "requiresFreshnessCheck": {
          "type": "boolean"
        },
        "outputIfUnresolved": {
          "enum": [
            "REQUIRE_REVIEW",
            "REFUSE_OUTPUT"
          ]
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
