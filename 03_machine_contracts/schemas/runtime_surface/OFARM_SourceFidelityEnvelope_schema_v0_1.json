{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/sourcefidelityenvelope/v0.1",
  "title": "OFARM SourceFidelityEnvelope v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceFidelityEnvelopeId",
    "sourceSystem",
    "sourceRecordRefs",
    "retrieval",
    "payloadIntegrity",
    "fidelityPosture",
    "promotionEligibility"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.sourcefidelityenvelope.v0.1"
    },
    "sourceFidelityEnvelopeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "sourceSystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "systemRef",
        "systemClass"
      ],
      "properties": {
        "systemRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "systemClass": {
          "enum": [
            "FMIS",
            "MACHINERY",
            "SENSOR",
            "WEATHER",
            "INVENTORY",
            "FINANCE",
            "MANUAL_IMPORT",
            "OTHER"
          ]
        },
        "vendorRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "schemaVersionRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        }
      }
    },
    "sourceRecordRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "retrieval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retrievedAt",
        "receivedAt"
      ],
      "properties": {
        "retrievedAt": {
          "type": "string",
          "format": "date-time"
        },
        "receivedAt": {
          "type": "string",
          "format": "date-time"
        },
        "timezoneAssumption": {
          "type": "string"
        }
      }
    },
    "payloadIntegrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payloadHash",
        "originalPayloadRef"
      ],
      "properties": {
        "payloadHash": {
          "type": "string"
        },
        "hashAlgorithm": {
          "type": "string"
        },
        "originalPayloadRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        },
        "redactionStatus": {
          "enum": [
            "NONE",
            "REDACTED",
            "PARTIAL",
            "UNKNOWN"
          ]
        }
      }
    },
    "fidelityPosture": {
      "enum": [
        "FULL_FIDELITY",
        "MANAGED_LOSS",
        "MATERIAL_LOSS",
        "HIGH_RISK_LOSS",
        "UNKNOWN"
      ]
    },
    "lossMapRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "identityResolutionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "unitAssumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "promotionEligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultPosture",
        "highConsequenceUseAllowed"
      ],
      "properties": {
        "defaultPosture": {
          "enum": [
            "CANDIDATE_ONLY",
            "CLAIM_ONLY",
            "EVIDENCE_ONLY",
            "REVIEW_REQUIRED",
            "PROMOTION_ELIGIBLE_AFTER_REVIEW"
          ]
        },
        "highConsequenceUseAllowed": {
          "type": "boolean"
        },
        "requiredReviewRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "description": "Source-fidelity envelope for imports/adapters. It preserves source context and loss posture without promoting source data to truth."
}
