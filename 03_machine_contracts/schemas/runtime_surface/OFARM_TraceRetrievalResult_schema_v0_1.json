{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/traceretrievalresult/v0.1",
  "title": "OFARM TraceRetrievalResult v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "traceId",
    "traceType",
    "status",
    "requestedBy",
    "retrievedAt",
    "summary",
    "gateOutcomes",
    "problems",
    "redactions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.traceretrievalresult.v0.1"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "traceType": {
      "enum": [
        "AUTHORIZATION",
        "PROMOTION",
        "QUERY",
        "MATERIALIZATION",
        "PUBLICATION",
        "PACK_ACTIVATION",
        "IMPORT",
        "CALCULATION",
        "PREFLIGHT"
      ]
    },
    "status": {
      "enum": [
        "AVAILABLE",
        "PARTIALLY_REDACTED",
        "REDACTED",
        "NOT_FOUND",
        "ACCESS_DENIED"
      ]
    },
    "requestedBy": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "retrievedAt": {
      "type": "string",
      "format": "date-time"
    },
    "scopeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "summary": {
      "type": "string"
    },
    "gateOutcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gateId",
          "gateName",
          "outcome"
        ],
        "properties": {
          "gateId": {
            "type": "string"
          },
          "gateName": {
            "type": "string"
          },
          "outcome": {
            "enum": [
              "PASS",
              "FAIL",
              "WARNING",
              "NOT_APPLICABLE",
              "REDACTED"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "problemRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "materializationBasisRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "relatedRecordRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reasonCode",
          "severity",
          "title"
        ],
        "properties": {
          "reasonCode": {
            "type": "string",
            "pattern": "^[A-Z0-9_:-]+$"
          },
          "severity": {
            "enum": [
              "INFO",
              "WARNING",
              "ERROR"
            ]
          },
          "title": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "suggestedRemediation": {
            "type": "string"
          },
          "relatedTraceTypes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "redactions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "redactionId",
          "reasonCode"
        ],
        "properties": {
          "redactionId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:/#-]+$"
          },
          "reasonCode": {
            "type": "string"
          },
          "safeExplanation": {
            "type": "string"
          }
        }
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "actionId",
          "label",
          "actorClass"
        ],
        "properties": {
          "actionId": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "actorClass": {
            "enum": [
              "USER",
              "HUMAN_REVIEWER",
              "SYSTEM",
              "AI_AGENT",
              "PLATFORM_OPERATOR"
            ]
          },
          "operationRef": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
