{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/runtimeproblemreasoncoderegistry/v0.1",
  "title": "OFARM RuntimeProblemReasonCodeRegistry v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "registryId",
    "status",
    "publishedAt",
    "reasonCodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.runtimeproblemreasoncoderegistry.v0.1"
    },
    "registryId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "family",
          "severity",
          "retryable",
          "humanReviewRequired",
          "redactionSensitive",
          "safeUserMessage",
          "developerMeaning",
          "requiredRemediation",
          "safeUiBehavior"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z0-9_:-]+$"
          },
          "family": {
            "enum": [
              "AUTHORITY",
              "EVIDENCE",
              "IDENTITY",
              "UNIT_CALCULATION",
              "MATERIALIZATION",
              "QUERY",
              "PUBLICATION",
              "PACK_PROFILE",
              "IMPORT_SOURCE_FIDELITY",
              "RETRY_IDEMPOTENCY",
              "PERMISSION_REDACTION",
              "CORRECTION_DISPUTE",
              "OTHER"
            ]
          },
          "severity": {
            "enum": [
              "INFO",
              "WARNING",
              "ERROR"
            ]
          },
          "retryable": {
            "type": "boolean"
          },
          "humanReviewRequired": {
            "type": "boolean"
          },
          "redactionSensitive": {
            "type": "boolean"
          },
          "safeUserMessage": {
            "type": "string"
          },
          "developerMeaning": {
            "type": "string"
          },
          "requiredRemediation": {
            "type": "string"
          },
          "relatedTraceTypes": {
            "type": "array",
            "items": {
              "enum": [
                "AUTHORIZATION",
                "PROMOTION",
                "QUERY",
                "MATERIALIZATION",
                "PUBLICATION",
                "PACK_ACTIVATION",
                "IMPORT",
                "CALCULATION",
                "PREFLIGHT"
              ]
            }
          },
          "safeUiBehavior": {
            "type": "string"
          }
        }
      }
    }
  }
}
