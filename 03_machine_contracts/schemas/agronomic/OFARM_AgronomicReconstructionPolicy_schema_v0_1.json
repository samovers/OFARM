{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agronomicreconstructionpolicy/v0.1",
  "title": "OFARM AgronomicReconstructionPolicy v0.1",
  "$comment": "Accepted by OFARM_Agronomic_Query_and_Output_Reconstruction_RFC_v0_1. This is a query/output guardrail, not a source-of-truth carrier.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "policyId",
    "status",
    "scope",
    "queryBindings",
    "truthAndEvidencePolicy",
    "materializationPolicy",
    "geometryPolicy",
    "lateEvidencePolicy",
    "disputePolicy",
    "outputPolicy",
    "expectedReconstructionChecks"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agronomicreconstructionpolicy.v0.1"
    },
    "policyId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "policyName": {
      "type": "string"
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "DEPRECATED"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truthScope",
        "outputSurface",
        "anchorScopes",
        "effectiveAsOf",
        "knowledgeCut"
      ],
      "properties": {
        "truthScope": {
          "enum": [
            "COMPLIANCE",
            "ADVISORY"
          ]
        },
        "outputSurface": {
          "enum": [
            "QUERY_ONLY",
            "PASSPORT_VIEW",
            "DOCUMENT_ASSEMBLY",
            "SUBMISSION_ASSEMBLY"
          ]
        },
        "anchorScopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "scopeType",
              "scopeRef"
            ],
            "properties": {
              "scopeType": {
                "enum": [
                  "FARM",
                  "SITE",
                  "FIELD",
                  "ZONE",
                  "CROP_CYCLE",
                  "LOT",
                  "FACILITY",
                  "OPERATION",
                  "SUBMISSION",
                  "DEPLOYMENT",
                  "TENANT"
                ]
              },
              "scopeRef": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._:-]+$"
              }
            }
          }
        },
        "effectiveAsOf": {
          "type": "string",
          "format": "date-time"
        },
        "knowledgeCut": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "queryBindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "querySpecificationRefs",
        "queryPlanRefs",
        "semanticPathAliasCatalogRefs"
      ],
      "properties": {
        "querySpecificationRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "queryPlanRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "semanticPathAliasCatalogRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "truthAndEvidencePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotionPolicy",
        "evidenceFloor",
        "truthSourceRule"
      ],
      "properties": {
        "promotionPolicy": {
          "enum": [
            "ACCEPTED_ONLY",
            "ADVISORY_ALLOWED",
            "PROVISIONAL_ALLOWED_WITH_DISCLOSURE",
            "HISTORY_ALL_WITH_STATUS"
          ]
        },
        "evidenceFloor": {
          "enum": [
            "NONE",
            "SOURCE_IDENTIFIED",
            "MEASUREMENT_CONTEXT_COMPLETE",
            "EVIDENCE_SUFFICIENT",
            "ATTESTED"
          ]
        },
        "truthSourceRule": {
          "enum": [
            "ASSERTION_HISTORY_FIRST",
            "ACCEPTED_CONSEQUENCES_ONLY",
            "ADVISORY_HISTORY_WITH_STATUS"
          ]
        },
        "codeProfileRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "requiredAuthorityFamilies": {
          "type": "array",
          "items": {
            "enum": [
              "OBSERVE_REPORT",
              "ASSERT_SUBMIT",
              "OPERATE_INTERVENE",
              "REVIEW",
              "GOVERN_DECIDE",
              "ATTEST_SIGN",
              "CONTEXT_GOVERNANCE",
              "SHARE_REVOKE",
              "RECEIVE_USE"
            ]
          }
        }
      }
    },
    "materializationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshnessPolicy",
        "highConsequenceUse",
        "staleMaterializationBehavior"
      ],
      "properties": {
        "freshnessPolicy": {
          "enum": [
            "REQUIRE_FRESH",
            "ALLOW_STALE_EXPLORATORY",
            "NO_CURRENT_STATE_DEPENDENCY"
          ]
        },
        "highConsequenceUse": {
          "type": "boolean"
        },
        "staleMaterializationBehavior": {
          "enum": [
            "REFUSE",
            "RECOMPUTE",
            "REQUIRE_REVIEW",
            "ALLOW_WITH_DISCLOSURE"
          ]
        }
      }
    },
    "geometryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "geometryUseRule",
        "basisFloor"
      ],
      "properties": {
        "geometryUseRule": {
          "enum": [
            "EXACT_ACCEPTED_ONLY",
            "EVENT_BOUND_EXTENT_ONLY",
            "INCLUDE_DISPUTED_WITH_STATUS",
            "ALLOW_ESTIMATED_WITH_QUALIFIER"
          ]
        },
        "basisFloor": {
          "enum": [
            "NONE",
            "DECLARED",
            "MEASURED",
            "ACCEPTED_EXTENT",
            "ATTESTED"
          ]
        },
        "allowDisputedGeometryInPassport": {
          "type": "boolean"
        },
        "allowDisputedGeometryInDocumentAssembly": {
          "type": "boolean"
        }
      }
    },
    "lateEvidencePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lateEvidenceUse",
        "correctionBehavior",
        "materializationBehavior"
      ],
      "properties": {
        "lateEvidenceUse": {
          "enum": [
            "RECOMPUTE_OR_REFUSE",
            "DISCLOSE_AND_SUPERSEDE",
            "IGNORE_AFTER_FREEZE_UNLESS_SUCCESSOR",
            "HISTORY_RECONSTRUCTION_ONLY"
          ]
        },
        "correctionBehavior": {
          "enum": [
            "NO_EDIT_IN_PLACE",
            "ALLOW_REVIEWED_SUPERSESSION"
          ]
        },
        "materializationBehavior": {
          "enum": [
            "INVALIDATE_AND_RECOMPUTE",
            "KEEP_HISTORICAL_AND_CREATE_SUCCESSOR",
            "REQUIRE_REVIEW"
          ]
        }
      }
    },
    "disputePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disputedRecordUse",
        "passportDisclosure",
        "documentAssemblyDisclosure"
      ],
      "properties": {
        "disputedRecordUse": {
          "enum": [
            "EXCLUDE_FROM_HIGH_CONSEQUENCE",
            "INCLUDE_WITH_STATUS_ONLY",
            "REQUIRE_REVIEW"
          ]
        },
        "passportDisclosure": {
          "enum": [
            "EXCLUDE",
            "DISCLOSE_STATUS_ONLY",
            "PROFILE_PERMITTED_SUMMARY"
          ]
        },
        "documentAssemblyDisclosure": {
          "enum": [
            "INCLUDE_FULL_ANNEX",
            "INCLUDE_STATUS_ONLY",
            "EXCLUDE"
          ]
        }
      }
    },
    "outputPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passportSourceRule",
        "documentAssemblyRule",
        "freezePolicy",
        "requiresTraceBack"
      ],
      "properties": {
        "passportSourceRule": {
          "enum": [
            "ACCEPTED_CONSEQUENCES_ONLY",
            "PROFILE_PERMITTED_PROVISIONAL_WITH_STATUS",
            "ADVISORY_ONLY"
          ]
        },
        "documentAssemblyRule": {
          "enum": [
            "FROZEN_WITH_BASIS_AND_ANNEXES",
            "FROZEN_ACCEPTED_ONLY",
            "LIVE_VIEW_NOT_ALLOWED"
          ]
        },
        "freezePolicy": {
          "enum": [
            "LIVE_RECOMPUTABLE",
            "FROZEN_VERSIONED",
            "NOT_APPLICABLE"
          ]
        },
        "requiresTraceBack": {
          "type": "boolean"
        }
      }
    },
    "expectedReconstructionChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "checkId",
          "checkType",
          "expectedOutcome"
        ],
        "properties": {
          "checkId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "checkType": {
            "enum": [
              "ALIAS_PINNING",
              "FRESHNESS",
              "EVIDENCE_FLOOR",
              "GEOMETRY_BASIS",
              "CODE_BINDING",
              "DISPUTE_HANDLING",
              "LATE_EVIDENCE",
              "OUTPUT_DISCLOSURE",
              "TRACEBACK"
            ]
          },
          "expectedOutcome": {
            "enum": [
              "PASS",
              "PASS_WITH_DISCLOSURE",
              "REQUIRE_REVIEW",
              "REFUSE_USE"
            ]
          },
          "relatedRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scope": {
            "properties": {
              "outputSurface": {
                "const": "PASSPORT_VIEW"
              }
            },
            "required": [
              "outputSurface"
            ]
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "outputPolicy": {
            "properties": {
              "passportSourceRule": {
                "enum": [
                  "ACCEPTED_CONSEQUENCES_ONLY",
                  "PROFILE_PERMITTED_PROVISIONAL_WITH_STATUS"
                ]
              }
            },
            "required": [
              "passportSourceRule"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "properties": {
              "outputSurface": {
                "enum": [
                  "DOCUMENT_ASSEMBLY",
                  "SUBMISSION_ASSEMBLY"
                ]
              }
            },
            "required": [
              "outputSurface"
            ]
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "outputPolicy": {
            "properties": {
              "documentAssemblyRule": {
                "enum": [
                  "FROZEN_WITH_BASIS_AND_ANNEXES",
                  "FROZEN_ACCEPTED_ONLY"
                ]
              }
            },
            "required": [
              "documentAssemblyRule"
            ]
          }
        }
      }
    }
  ]
}
