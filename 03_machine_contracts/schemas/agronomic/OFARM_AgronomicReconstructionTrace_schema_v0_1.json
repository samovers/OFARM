{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/agronomicreconstructiontrace/v0.1",
  "title": "OFARM AgronomicReconstructionTrace v0.1",
  "$comment": "Explanation carrier for query/output reconstruction decisions. It is not canonical truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reconstructionTraceId",
    "policyRef",
    "querySpecificationRef",
    "queryPlanRef",
    "queryExecutionResultRef",
    "traceOutcome",
    "checks",
    "sourceUse",
    "outputDisclosure"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.agronomicreconstructiontrace.v0.1"
    },
    "reconstructionTraceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "policyRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "querySpecificationRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "queryPlanRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "queryExecutionResultRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "truthScope": {
      "enum": [
        "COMPLIANCE",
        "ADVISORY"
      ]
    },
    "anchorScopes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "SUBMISSION",
              "DEPLOYMENT",
              "TENANT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "effectiveAsOf": {
      "type": "string",
      "format": "date-time"
    },
    "knowledgeCut": {
      "type": "string",
      "format": "date-time"
    },
    "traceOutcome": {
      "enum": [
        "PASS",
        "PASS_WITH_DISCLOSURE",
        "REQUIRE_REVIEW",
        "REFUSE_OUTPUT"
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "checkId",
          "checkType",
          "status",
          "summary"
        ],
        "properties": {
          "checkId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "checkType": {
            "enum": [
              "ALIAS_PINNING",
              "FRESHNESS",
              "EVIDENCE_FLOOR",
              "GEOMETRY_BASIS",
              "CODE_BINDING",
              "DISPUTE_HANDLING",
              "LATE_EVIDENCE",
              "OUTPUT_DISCLOSURE",
              "TRACEBACK"
            ]
          },
          "status": {
            "enum": [
              "PASS",
              "PASS_WITH_DISCLOSURE",
              "REQUIRE_REVIEW",
              "FAIL_REFUSED"
            ]
          },
          "summary": {
            "type": "string"
          },
          "relatedRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]+$"
            }
          }
        }
      }
    },
    "sourceUse": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceRef",
          "sourceRole",
          "useStatus"
        ],
        "properties": {
          "sourceRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "sourceRole": {
            "enum": [
              "ASSERTION_HISTORY",
              "ACCEPTED_CONSEQUENCE",
              "MATERIALIZATION",
              "EVIDENCE",
              "ADVISORY_OUTPUT",
              "DISPUTED_RECORD",
              "ANNEX_ONLY"
            ]
          },
          "useStatus": {
            "enum": [
              "USED",
              "EXCLUDED",
              "ANNEXED",
              "REFUSED"
            ]
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "outputDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passportDisclosure",
        "documentAssemblyDisclosure",
        "projectionTraceBackReady"
      ],
      "properties": {
        "passportDisclosure": {
          "enum": [
            "ACCEPTED_ONLY",
            "DISCLOSED_WITH_STATUS",
            "REFUSED",
            "NOT_APPLICABLE"
          ]
        },
        "documentAssemblyDisclosure": {
          "enum": [
            "FROZEN_BASIS_ONLY",
            "FROZEN_WITH_ANNEXES",
            "DRAFT_ONLY",
            "NOT_APPLICABLE"
          ]
        },
        "projectionTraceBackReady": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
