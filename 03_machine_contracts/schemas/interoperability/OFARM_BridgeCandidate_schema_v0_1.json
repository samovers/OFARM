{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/bridgecandidate/v0.1",
  "title": "OFARM BridgeCandidate v0.1",
  "$comment": "Narrow active bridge-handoff contract derived from the Advisory scenario workspace note, Platform RC2.1 twin/bridge law, and BridgeCandidate Closure RFC v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bridgeCandidateId",
    "createdAt",
    "originTwin",
    "bridgePosture",
    "sourceScenarioResultSetRef",
    "proposedNextStepClass",
    "intendedNextTwin",
    "targetScopes",
    "requiresHumanApproval",
    "recheckRequirements",
    "rationale"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.bridgecandidate.v0.1"
    },
    "bridgeCandidateId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "originTwin": {
      "const": "ADVISORY"
    },
    "bridgePosture": {
      "const": "PROPOSAL_ONLY"
    },
    "sourceScenarioResultSetRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceScenarioSpecRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "proposedNextStepClass": {
      "enum": [
        "REQUEST_REVIEW",
        "REQUEST_EVIDENCE",
        "PREPARE_REPORT_ASSEMBLY",
        "PREPARE_DOSSIER_ASSEMBLY",
        "PREPARE_SUBMISSION_ASSEMBLY",
        "PREPARE_OPERATION_PLAN",
        "PREPARE_ASSERTION_DRAFT"
      ]
    },
    "intendedNextTwin": {
      "enum": [
        "ADVISORY",
        "COMPLIANCE"
      ]
    },
    "targetScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scopeType",
          "scopeRef"
        ],
        "properties": {
          "scopeType": {
            "enum": [
              "FARM",
              "SITE",
              "FIELD",
              "ZONE",
              "CROP_CYCLE",
              "LOT",
              "FACILITY",
              "OPERATION",
              "DEPLOYMENT",
              "TENANT"
            ]
          },
          "scopeRef": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        }
      }
    },
    "proposedDraftArtifactRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceMaterializationResultRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "sourceContextSnapshotRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "requiresHumanApproval": {
      "const": true
    },
    "recheckRequirements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "RECHECK_COMPLIANCE_FRESHNESS",
          "RECHECK_AUTHORITY",
          "RECHECK_CONTEXT",
          "RECHECK_EVIDENCE_SUFFICIENCY",
          "COLLECT_ADDITIONAL_EVIDENCE",
          "HUMAN_REVIEW_GATE"
        ]
      }
    },
    "prerequisiteRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "intendedNextTwin": {
            "const": "COMPLIANCE"
          }
        }
      },
      "then": {
        "properties": {
          "recheckRequirements": {
            "contains": {
              "const": "RECHECK_COMPLIANCE_FRESHNESS"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "proposedNextStepClass": {
            "enum": [
              "PREPARE_DOSSIER_ASSEMBLY",
              "PREPARE_SUBMISSION_ASSEMBLY",
              "PREPARE_OPERATION_PLAN",
              "PREPARE_ASSERTION_DRAFT"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "intendedNextTwin": {
            "const": "COMPLIANCE"
          }
        }
      }
    }
  ]
}
