{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofarm.dev/schema/externalcommitmentlink/v0.1",
  "title": "OFARM ExternalCommitmentLink v0.1",
  "$comment": "Boundary/reference contract promoted by OFARM Durable Relationship Semantics RFC v0.1. This object links OFARM parties/scopes/outputs to external contracts, filings, or commitments. It is reference/evidence only and does not create authority or financial truth.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "scopeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeType",
        "scopeRef"
      ],
      "properties": {
        "scopeType": {
          "enum": [
            "FARM",
            "SITE",
            "FIELD",
            "ZONE",
            "CROP_CYCLE",
            "LOT",
            "FACILITY",
            "OPERATION",
            "DEPLOYMENT",
            "TENANT"
          ]
        },
        "scopeRef": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    }
  },
  "required": [
    "schemaVersion",
    "externalCommitmentLinkId",
    "linkKind",
    "externalSystemRef",
    "externalObjectType",
    "externalObjectIdentifier",
    "referencePosture",
    "validFrom"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ofarm.externalcommitmentlink.v0.1"
    },
    "externalCommitmentLinkId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "linkKind": {
      "enum": [
        "BUYER_CONTRACT_LINKAGE",
        "SERVICE_CONTRACT_LINKAGE",
        "LEASE_DOCUMENT_LINKAGE",
        "COOPERATIVE_AGREEMENT_LINKAGE",
        "EXTERNAL_FILING_LINKAGE",
        "EXTERNAL_CLAIM_LINKAGE"
      ]
    },
    "externalSystemRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "externalObjectType": {
      "enum": [
        "CONTRACT",
        "LEASE",
        "AGREEMENT",
        "FILING",
        "CLAIM",
        "OTHER"
      ]
    },
    "externalObjectIdentifier": {
      "type": "string",
      "minLength": 1
    },
    "linkedPartyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "linkedScopes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scopeRef"
      }
    },
    "linkedOutputRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "referencePosture": {
      "enum": [
        "REFERENCE_ONLY",
        "EVIDENCE_LINKED",
        "ACCESS_JUSTIFICATION_ONLY"
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "anyOf": [
    {
      "required": [
        "linkedPartyRefs"
      ]
    },
    {
      "required": [
        "linkedScopes"
      ]
    },
    {
      "required": [
        "linkedOutputRefs"
      ]
    }
  ]
}
